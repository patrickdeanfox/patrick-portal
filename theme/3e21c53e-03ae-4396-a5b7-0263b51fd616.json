    "css": [
      "/* Applied Filters List */",
      ".p-applied-filter-list {",
      "    color: var(--color-text);",
      "}",
      "",
      "/* Cascading Filter Group */",
      ".p-block-cascading-filter-group .input .wrapper,",
      ".p-block-cascading-filter-group .singleselect .toggle,",
      ".p-block-cascading-filter-group .multiselect .toggle,",
      ".p-block-cascading-filter-group .datepicker .wrapper>label {",
      "    background-color: var(--input-bg-color);",
      "    border-color: var(--input-border-color);",
      "    color: var(--input-text-color);",
      "}",
      "",
      ".p-block-cascading-filter-group .singleselect .dropdown-icon,",
      ".p-block-cascading-filter-group .multiselect .dropdown-icon,",
      ".p-block-cascading-filter-group .datepicker .dropdown-icon {",
      "    stroke: var(--input-text-color);",
      "}",
      "",
      ".p-block-cascading-filter-group .singleselect .dropdown-wrapper .option,",
      ".p-block-cascading-filter-group .multiselect .dropdown-wrapper .option {",
      "    background-color: var(--input-bg-color);",
      "    color: var(--input-text-color);",
      "}",
      "",
      ".p-block-cascading-filter-group .singleselect .dropdown-wrapper .option:hover,",
      ".p-block-cascading-filter-group .multiselect .dropdown-wrapper .option:hover {",
      "    background-color: var(--input-highlight-bg-color);",
      "    color: var(--input-highlight-text-color);",
      "}",
      "",
      ".p-block-cascading-filter-group .multiselect .deselect .minus {",
      "    background: white;",
      "}",
      "",
      ".p-block-cascading-filter-group .multiselect .option-checkbox svg {",
      "    fill: white;",
      "}",
      "",
      "/* Clear Filters Button */",
      ".p-block-clear-filters-button .btn {",
      "    background-color: var(--button-primary-bg-color);",
      "    border-color: var(--button-primary-border-color);",
      "    color: var(--button-primary-text-color);",
      "}",
      "",
      ".p-block-clear-filters-button .btn:hover,",
      ".p-block-clear-filters-button .btn:focus {",
      "    background-color: var(--button-primary-hover-color);",
      "}",
      "",
      "/* Data Table */",
      ".p-block-data-table .pagination {",
      "    color: var(--color-text);",
      "}",
      "",
      ".p-block-data-table .table-wrapper {",
      "    color: var(--color-text);",
      "    background-color: var(--body-bg-color);",
      "}",
      "",
      ".p-block-data-table .table-wrapper th {",
      "    background-color: var(--system-gray);",
      "}",
      "",
      ".p-block-data-table .table-wrapper tbody>tr td.p-line-number-cell {",
      "    background-color: var(--color-gray);",
      "}",
      "",
      ".p-block-data-table .table-wrapper tbody>tr td.p-data-cell {",
      "    color: var(--color-text);",
      "    border-right-color: var(--color-white)",
      "}",
      "",
      ".p-block-data-table .table-wrapper tbody>tr.selected td.p-line-number-cell {",
      "    background-color: var(--color-info) !important;",
      "}",
      "",
      "/* DateTime Filter */",
      ".p-datepicker .toggle {",
      "    background-color: var(--input-bg-color);",
      "    border-color: var(--input-border-color);",
      "    color: var(--input-text-color);",
      "}",
      "",
      ".p-datepicker .toggle .dropdown-icon{",
      "    stroke: var(--input-text-color);",
      "}",
      "",
      "/* HTML */",
      ".p-block-html {",
      "    background-color: var(--block-bg-color);",
      "}",
      "",
      "/* Input Filter */",
      ".p-input-filter .wrapper {",
      "    background-color: var(--input-bg-color);",
      "    border-color: var(--input-border-color);",
      "    color: var(--input-text-color);",
      "}",
      "",
      ".p-input-filter .input {",
      "    color: var(--input-text-color);",
      "}",
      "",
      "/* Multi-select Filter */",
      ".multi-select .toggle {",
      "    background-color: var(--input-bg-color);",
      "    border-color: var(--input-border-color);",
      "    color: var(--input-text-color);",
      "}",
      "",
      ".select-filter .toggle .dropdown-icon {",
      "    stroke: var(--input-text-color);",
      "}",
      "",
      ".multi-select .toggle-closed {",
      "    color: var(--input-text-color);",
