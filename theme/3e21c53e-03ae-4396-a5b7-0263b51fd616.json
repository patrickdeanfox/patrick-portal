      "    color: var(--input-text-color);",
      "}",
      "",
      ".multi-select .dropdown-wrapper .option:hover {",
      "    background-color: var(--input-highlight-bg-color);",
      "    color: var(--input-highlight-text-color);",
      "}",
      "",
      "/* Page Navigation */",
      ".p-page-nav .item.active .title {",
      "    color: var(--color-text);",
      "}",
      "",
      "/* Page Rotate */",
      ".p-page-rotate .list-wrapper .list .item .option-checkbox.selected {",
      "    background-color: var(--color-primary);",
      "}",
      "",
      "/* Select Filter */",
      ".select-filter .toggle-wrapper .toggle-opened,",
      ".select-filter .toggle-wrapper .toggle-closed {",
      "    background-color: var(--input-bg-color);",
      "    border-color: var(--input-border-color);",
      "    color: var(--input-text-color);",
      "}",
      "",
      ".select-filter .toggle-wrapper .dropdown-icon {",
      "    stroke: var(--input-text-color);",
      "}",
      "",
      ".select-filter .dropdown-wrapper .option {",
      "    background-color: var(--input-bg-color);",
      "    color: var(--input-text-color);",
      "}",
      "",
      ".select-filter .dropdown-wrapper .option:hover,",
      ".select-filter .dropdown-wrapper .option.selected {",
      "    background-color: var(--input-highlight-bg-color);",
      "    color: var(--input-highlight-text-color);",
      "}",
      "",
