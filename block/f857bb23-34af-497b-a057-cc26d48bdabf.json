{
  "name": "RT · Table Top Customers",
  "type": "html",
  "css": [
    ".wrapper {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,.07));\n  --row-line: rgba(255,255,255,.06);\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.wrapper .rt-topcust {\n  display: flex;\n  flex-direction: column;\n  gap: 14px;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n}\n.wrapper .rt-tc-head {\n  display: flex;\n  align-items: flex-end;\n  justify-content: space-between;\n  gap: 12px;\n  flex-wrap: wrap;\n}\n.wrapper .rt-tc-eyebrow {\n  margin: 0 0 3px;\n  font: 700 11px/1.2 inherit;\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--muted);\n}\n.wrapper .rt-tc-eyebrow::before {\n  content: \"\";\n  display: inline-block;\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  margin-right: 7px;\n  background: var(--accent);\n  vertical-align: middle;\n}\n.wrapper .rt-tc-title {\n  margin: 0;\n  font: 800 20px/1.15 inherit;\n  letter-spacing: -.01em;\n  color: var(--ink);\n}\n.wrapper .rt-tc-sub {\n  margin: 0;\n  font: 600 11px/1.4 inherit;\n  color: var(--muted);\n  font-variant-numeric: tabular-nums;\n  text-align: right;\n}\n.wrapper .rt-tc-wrap {\n  overflow-x: auto;\n  overflow-y: auto;\n  overscroll-behavior-x: contain;\n  max-width: 100%;\n  max-height: 560px;\n  border-radius: 12px;\n  border: 1px solid var(--line);\n  -webkit-overflow-scrolling: touch;\n}\n.wrapper .rt-tc-table {\n  width: 100%;\n  border-collapse: collapse;\n  font: 500 13px/1.4 inherit;\n}\n.wrapper .rt-tc-table thead th {\n  position: sticky;\n  top: 0;\n  z-index: 1;\n  background: var(--surface);\n  border-bottom: 1px solid var(--line);\n  padding: 0;\n  transition: box-shadow .15s ease;\n}\n.wrapper th[aria-sort=\"ascending\"],\n.wrapper th[aria-sort=\"descending\"] {\n  box-shadow: inset 0 -2px 0 0 var(--accent),\n              0 6px 16px -12px color-mix(in srgb, var(--accent) 75%, transparent);\n}\n.wrapper .rt-tc-sort {\n  width: 100%;\n  box-sizing: border-box;\n  min-height: 44px;\n  min-width: 44px;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  background: none;\n  border: 0;\n  cursor: pointer;\n  color: var(--muted);\n  font: 700 11px/1.2 inherit;\n  letter-spacing: .04em;\n  text-transform: uppercase;\n  padding: 11px 12px;\n  transition: color .15s ease;\n}\n.wrapper th.num .rt-tc-sort {\n  justify-content: flex-end;\n}\n.wrapper .rt-tc-sort:hover {\n  color: var(--ink);\n}\n.wrapper .rt-tc-sort:active {\n  color: var(--accent);\n}\n.wrapper .rt-tc-sort:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: -2px;\n  border-radius: 6px;\n}\n.wrapper th[aria-sort=\"ascending\"] .rt-tc-sort,\n.wrapper th[aria-sort=\"descending\"] .rt-tc-sort {\n  color: var(--accent);\n}\n.wrapper .rt-tc-arrow {\n  font-size: 9px;\n  line-height: 1;\n}\n.wrapper tbody td {\n  padding: 10px 12px;\n  border-top: 1px solid var(--row-line);\n  color: var(--ink);\n  white-space: nowrap;\n  transition: background-color .12s ease, box-shadow .12s ease;\n}\n.wrapper td.num {\n  text-align: right;\n  font-variant-numeric: tabular-nums;\n}\n.wrapper tbody tr:hover td {\n  background: var(--surface-raised);\n}\n.wrapper tbody tr:hover td:first-child {\n  box-shadow: inset 3px 0 0 var(--accent-2);\n}\n.wrapper .rt-tc-name {\n  font-weight: 700;\n}\n.wrapper .rt-tc-muted {\n  color: var(--muted);\n}\n.wrapper .rt-tc-tier {\n  display: inline-block;\n  padding: 2px 8px;\n  border-radius: 999px;\n  font: 700 11px/1.4 inherit;\n  border: 1px solid var(--line);\n  color: var(--muted);\n}\n.wrapper .rt-tc-tier[data-tier=\"Platinum\"] {\n  color: var(--accent);\n  border-color: color-mix(in srgb, var(--accent) 40%, transparent);\n  background: color-mix(in srgb, var(--accent) 12%, transparent);\n}\n.wrapper .rt-tc-tier[data-tier=\"Gold\"] {\n  color: #F6C453;\n  border-color: color-mix(in srgb, #F6C453 40%, transparent);\n  background: color-mix(in srgb, #F6C453 12%, transparent);\n}\n.wrapper .rt-tc-tier[data-tier=\"Silver\"] {\n  color: var(--color-gray-700, #C2C2CC);\n  border-color: rgba(255,255,255,.14);\n}\n.wrapper .rt-tc-tier[data-tier=\"Bronze\"] {\n  color: #FF9F45;\n  border-color: color-mix(in srgb, #FF9F45 35%, transparent);\n}\n.wrapper .rt-tc-empty {\n  margin: 8px 4px;\n  font: 600 13px/1.4 inherit;\n  color: var(--muted);\n}\n@container (max-width: 640px) {\n  .wrapper .rt-topcust { padding: 12px; }\n  .wrapper .rt-tc-title { font-size: 18px; }\n  .wrapper .rt-tc-sub { text-align: left; }\n  .wrapper .rt-tc-table { font-size: 12px; }\n  .wrapper tbody td { padding: 8px 10px; }\n  .wrapper .rt-tc-sort { padding: 8px 10px; min-height: 44px; }\n}\n@container (max-width: 420px) {\n  .wrapper .rt-topcust { padding: 10px; }\n  .wrapper .rt-tc-eyebrow { letter-spacing: .08em; }\n  .wrapper tbody td { padding-left: 8px; padding-right: 8px; }\n  .wrapper .rt-tc-sort { padding-left: 8px; padding-right: 8px; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper .rt-tc-table thead th,\n  .wrapper .rt-tc-sort,\n  .wrapper tbody td { transition: none; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": "<div class=\"wrapper\">\n  <section class=\"rt-topcust\" aria-label=\"Top customers by lifetime value\">\n    <header class=\"rt-tc-head\">\n      <div>\n        <p class=\"rt-tc-eyebrow\">Retail · Customers</p>\n        <h2 class=\"rt-tc-title\">Top Customers</h2>\n      </div>\n      <p class=\"rt-tc-sub\" id=\"rt-tc-sub\"></p>\n    </header>\n    <div class=\"rt-tc-wrap\">\n      <table class=\"rt-tc-table\">\n        <thead><tr id=\"rt-tc-headrow\"></tr></thead>\n        <tbody id=\"rt-tc-body\" aria-live=\"polite\"></tbody>\n      </table>\n    </div>\n    <p class=\"rt-tc-empty\" id=\"rt-tc-empty\" hidden>No customers match the current filters.</p>\n  </section>\n\n  <script>\n  (function () {\n      'use strict';\n\n      // ---- Top-level config -------------------------------------------------\n      const DEBUG = false;\n      const TAG = '[RT · Table Top Customers]';\n      const log = (...a) => { if (DEBUG) console.log(TAG, ...a); };\n      log.warn = (...a) => { if (DEBUG) console.warn(TAG, ...a); };\n      log.error = (...a) => { if (DEBUG) console.error(TAG, ...a); };\n\n      const QUERY_INDEX = { CUSTOMERS: 0 };\n\n      // Column-name constants — must match the bound query aliases exactly.\n      const COL = {\n          NAME: 'customer_name',\n          SEGMENT: 'customer_segment',\n          TIER: 'loyalty_tier',\n          STATE: 'state',\n          LTV: 'lifetime_value',\n          ORDERS: 'orders',\n          REVENUE: 'net_revenue',\n          LAST_ORDER: 'last_order_date',\n          CSAT: 'avg_csat',\n          AR: 'open_ar'\n      };\n\n      // Display config (order = column order). numeric -> right align + numeric sort.\n      const COLUMNS = [\n          { key: COL.NAME, label: 'Customer', kind: 'name' },\n          { key: COL.SEGMENT, label: 'Segment', kind: 'text' },\n          { key: COL.TIER, label: 'Tier', kind: 'tier' },\n          { key: COL.STATE, label: 'State', kind: 'text' },\n          { key: COL.LTV, label: 'Lifetime Value', kind: 'currency', numeric: true },\n          { key: COL.ORDERS, label: 'Orders', kind: 'int', numeric: true },\n          { key: COL.REVENUE, label: 'Net Revenue', kind: 'currency', numeric: true },\n          { key: COL.LAST_ORDER, label: 'Last Order', kind: 'date' },\n          { key: COL.CSAT, label: 'Avg CSAT', kind: 'csat', numeric: true },\n          { key: COL.AR, label: 'Open AR', kind: 'currency', numeric: true }\n      ];\n\n      const SEL = {\n          headRow: '#rt-tc-headrow',\n          body: '#rt-tc-body',\n          sub: '#rt-tc-sub',\n          empty: '#rt-tc-empty'\n      };\n\n      const STATE_KEY = '__RT_TOPCUST_STATE__';\n      const DEFAULT_SORT = { key: COL.LTV, dir: 'desc' };\n      const DASH = '—';\n\n      // Persist sort choice + the filter listener handle across script re-runs.\n      const store = (window[STATE_KEY] = window[STATE_KEY] || {\n          sort: { key: DEFAULT_SORT.key, dir: DEFAULT_SORT.dir },\n          handler: null,\n          dsIds: []\n      });\n\n      // ---- Pure helpers -----------------------------------------------------\n      const getQueryData = (index) => {\n          const q = (typeof currentBlock !== 'undefined' && currentBlock.queryResults) ? currentBlock.queryResults[index] : null;\n          if (!q || q.data === undefined || q.data === null) return [];\n          if (q.mappedData) return q.mappedData;\n          const cols = q.columns || [];\n          return q.data.map((row) => {\n              const obj = {};\n              cols.forEach((c, i) => { obj[c] = row[i]; });\n              return obj;\n          });\n      };\n\n      const toNumber = (v) => {\n          if (v === null || v === undefined || v === '') return NaN;\n          const n = typeof v === 'number' ? v : Number(v);\n          return Number.isFinite(n) ? n : NaN;\n      };\n\n      const fmtCurrency = (v) => {\n          const n = toNumber(v);\n          if (!Number.isFinite(n)) return DASH;\n          return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n      };\n\n      const fmtInt = (v) => {\n          const n = toNumber(v);\n          if (!Number.isFinite(n)) return DASH;\n          return n.toLocaleString('en-US');\n      };\n\n      const fmtDate = (v) => {\n          if (v === null || v === undefined || v === '') return DASH;\n          const d = new Date(String(v) + 'T00:00:00');\n          if (isNaN(d.getTime())) return DASH;\n          return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });\n      };\n\n      const fmtCsat = (v) => {\n          const n = toNumber(v);\n          if (!Number.isFinite(n)) return DASH;\n          return n.toFixed(1);\n      };\n\n      const displayValue = (col, value) => {\n          if (col.kind === 'currency') return fmtCurrency(value);\n          if (col.kind === 'int') return fmtInt(value);\n          if (col.kind === 'date') return fmtDate(value);\n          if (col.kind === 'csat') return fmtCsat(value);\n          return (value === null || value === undefined || value === '') ? DASH : String(value);\n      };\n\n      const sortKey = (col, value) => {\n          if (col.numeric) {\n              const n = toNumber(value);\n              return Number.isFinite(n) ? n : -Infinity;\n          }\n          if (col.kind === 'date') {\n              if (value === null || value === undefined || value === '') return -Infinity;\n              const t = new Date(String(value) + 'T00:00:00').getTime();\n              return isNaN(t) ? -Infinity : t;\n          }\n          return (value === null || value === undefined) ? '' : String(value).toLowerCase();\n      };\n\n      const sortRows = (rows, sort) => {\n          const col = COLUMNS.find((c) => c.key === sort.key) || COLUMNS[0];\n          const dir = sort.dir === 'asc' ? 1 : -1;\n          const numericSort = !!(col.numeric || col.kind === 'date');\n          const copy = rows.slice();\n          copy.sort((a, b) => {\n              const va = sortKey(col, a[col.key]);\n              const vb = sortKey(col, b[col.key]);\n              let cmp;\n              if (numericSort) {\n                  cmp = va === vb ? 0 : (va < vb ? -1 : 1);\n              } else {\n                  cmp = String(va).localeCompare(String(vb));\n              }\n              return cmp * dir;\n          });\n          return copy;\n      };\n\n      // ---- Render -----------------------------------------------------------\n      const onSort = (col) => {\n          if (store.sort.key === col.key) {\n              store.sort.dir = store.sort.dir === 'asc' ? 'desc' : 'asc';\n          } else {\n              store.sort.key = col.key;\n              store.sort.dir = col.numeric ? 'desc' : 'asc';\n          }\n          log('sort changed', store.sort);\n          render();\n      };\n\n      const buildHeader = (headRow, sort) => {\n          headRow.innerHTML = '';\n          COLUMNS.forEach((col) => {\n              const th = document.createElement('th');\n              th.setAttribute('scope', 'col');\n              if (col.numeric) th.className = 'num';\n              const isActive = col.key === sort.key;\n              th.setAttribute('aria-sort', isActive ? (sort.dir === 'asc' ? 'ascending' : 'descending') : 'none');\n\n              const btn = document.createElement('button');\n              btn.type = 'button';\n              btn.className = 'rt-tc-sort';\n              btn.setAttribute('aria-label', 'Sort by ' + col.label);\n\n              const labelSpan = document.createElement('span');\n              labelSpan.textContent = col.label;\n\n              const arrow = document.createElement('span');\n              arrow.className = 'rt-tc-arrow';\n              arrow.setAttribute('aria-hidden', 'true');\n              arrow.textContent = isActive ? (sort.dir === 'asc' ? '▲' : '▼') : '';\n\n              btn.appendChild(labelSpan);\n              btn.appendChild(arrow);\n              btn.addEventListener('click', () => onSort(col));\n              th.appendChild(btn);\n              headRow.appendChild(th);\n          });\n      };\n\n      const buildBody = (tbody, rows) => {\n          tbody.innerHTML = '';\n          const frag = document.createDocumentFragment();\n          rows.forEach((row) => {\n              const tr = document.createElement('tr');\n              COLUMNS.forEach((col) => {\n                  const td = document.createElement('td');\n                  if (col.numeric) td.className = 'num';\n                  const text = displayValue(col, row[col.key]);\n                  if (col.kind === 'name') {\n                      td.classList.add('rt-tc-name');\n                      td.textContent = text;\n                  } else if (col.kind === 'tier') {\n                      const raw = row[col.key];\n                      const tierVal = (raw === null || raw === undefined || raw === '') ? '' : String(raw);\n                      const chip = document.createElement('span');\n                      chip.className = 'rt-tc-tier';\n                      if (tierVal) chip.setAttribute('data-tier', tierVal);\n                      chip.textContent = tierVal || DASH;\n                      td.appendChild(chip);\n                  } else {\n                      if (text === DASH) td.classList.add('rt-tc-muted');\n                      td.textContent = text;\n                  }\n                  tr.appendChild(td);\n              });\n              frag.appendChild(tr);\n          });\n          tbody.appendChild(frag);\n      };\n\n      const render = () => {\n          const scope = (typeof currentBlock !== 'undefined' && currentBlock.container) ? currentBlock.container : document;\n          const headRow = scope.querySelector(SEL.headRow);\n          const tbody = scope.querySelector(SEL.body);\n          const sub = scope.querySelector(SEL.sub);\n          const empty = scope.querySelector(SEL.empty);\n          if (!headRow || !tbody) { log.warn('table DOM not found'); return; }\n\n          const rows = getQueryData(QUERY_INDEX.CUSTOMERS);\n          log('rows loaded', rows.length);\n          const sorted = sortRows(rows, store.sort);\n\n          buildHeader(headRow, store.sort);\n          buildBody(tbody, sorted);\n\n          const activeCol = COLUMNS.find((c) => c.key === store.sort.key);\n          if (sub) {\n              const dirText = store.sort.dir === 'desc' ? 'high → low' : 'low → high';\n              sub.textContent = rows.length.toLocaleString('en-US') + ' customers · sorted by ' + (activeCol ? activeCol.label : '') + ' (' + dirText + ')';\n          }\n          if (empty) empty.hidden = rows.length > 0;\n      };\n\n      // ---- Filters (re-render on datasource reload) -------------------------\n      const wireFilters = () => {\n          if (typeof zPortal === 'undefined' || !zPortal.dataSource) return;\n          try {\n              if (store.handler && Array.isArray(store.dsIds)) {\n                  store.dsIds.forEach((id) => {\n                      try { zPortal.dataSource.off('load', id, store.handler); } catch (e) { log.error('off failed', id, e); }\n                  });\n              }\n              const sources = zPortal.dataSource.get() || [];\n              const dsIds = sources.map((d) => d && d.id).filter(Boolean);\n              const handler = () => { try { render(); } catch (e) { log.error('render on load failed', e); } };\n              dsIds.forEach((id) => {\n                  try { zPortal.dataSource.on('load', id, handler); } catch (e) { log.error('on failed', id, e); }\n              });\n              store.handler = handler;\n              store.dsIds = dsIds;\n              log('filters wired', dsIds.length);\n          } catch (e) {\n              log.error('wireFilters failed', e);\n          }\n      };\n\n      // ---- Orchestrator -----------------------------------------------------\n      const init = () => {\n          let onLoaded = null;\n          try {\n              if (typeof currentBlock !== 'undefined' && typeof currentBlock.getOnLoadedCallback === 'function') {\n                  onLoaded = currentBlock.getOnLoadedCallback();\n              }\n          } catch (e) { log.error('getOnLoadedCallback failed', e); }\n          try {\n              render();\n              wireFilters();\n          } catch (e) {\n              log.error('init failed', e);\n          } finally {\n              if (typeof onLoaded === 'function') {\n                  try { onLoaded(); } catch (e) { log.error('onLoaded failed', e); }\n              }\n          }\n      };\n\n      init();\n  })();\n  </script>\n</div>"
  },
