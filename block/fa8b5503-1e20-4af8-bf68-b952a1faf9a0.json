{
  "name": "CRM · Chart Resolution by Department",
  "type": "html",
  "css": [
    ".crm-resdept{--surface:var(--block-bg-color,#15151A);--surface-raised:#1B1B22;--ink:var(--color-text,#F4F4F7);--muted:var(--color-gray-500,#8A8A96);--line:var(--color-gray-200,rgba(255,255,255,.07));--accent:var(--color-primary,#FFD21E);--accent-2:var(--color-secondary,#FF3D8B);height:100%;box-sizing:border-box;min-width:0;max-width:100%;display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:16px 16px 12px;font-family:var(--font-stack-primary,'Inter',system-ui,-apple-system,sans-serif);color:var(--ink);font-variant-numeric:tabular-nums;container-type:inline-size;box-shadow:0 1px 0 rgba(255,255,255,.03) inset,0 6px 18px rgba(0,0,0,.5);transition:border-color .15s ease;}",
    ".crm-resdept:hover{border-color:color-mix(in srgb,var(--accent) 22%,var(--line));}",
    ".crm-resdept .head{display:flex;flex-direction:column;gap:3px;margin-bottom:12px;min-width:0;}",
    ".crm-resdept .head .title{display:flex;align-items:center;gap:8px;margin:0;min-width:0;font-size:14px;font-weight:800;line-height:1.2;letter-spacing:-.005em;color:var(--ink);overflow-wrap:anywhere;}",
    ".crm-resdept .head .title::before{content:\"\";flex:0 0 auto;width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px -1px color-mix(in srgb,var(--accent) 65%,transparent);}",
    ".crm-resdept .head .sub{margin:0;padding-left:16px;min-width:0;font-size:11px;font-weight:600;line-height:1.3;color:var(--muted);overflow-wrap:anywhere;}",
    ".crm-resdept .canvas{flex:1 1 auto;min-height:240px;width:100%;min-width:0;}",
    ".crm-resdept .empty{display:flex;align-items:center;justify-content:center;height:100%;min-height:240px;color:var(--muted);font-size:13px;font-weight:500;text-align:center;padding:0 8px;}",
    "@container (max-width: 420px){.crm-resdept .head{margin-bottom:10px;}}",
    "@container (max-width: 320px){.crm-resdept .head{margin-bottom:8px;gap:2px;}.crm-resdept .head .sub{padding-left:0;}}",
    "@media (prefers-reduced-motion: reduce){.crm-resdept{transition:none;}}"
  ],
  "json_data": {
    "isolated": false,
    "html": [
      "<div class=\"wrapper crm-resdept\">\n  <div class=\"head\">\n    <h3 class=\"title\">Resolution Time by Department</h3>\n    <span class=\"sub\">Avg resolution hours · current filter</span>\n  </div>\n  <div class=\"canvas\" id=\"crm-resdept-canvas\" role=\"img\" aria-label=\"Average ticket resolution hours by agent department\"></div>\n</div>\n<script>(function () {\n    'use strict';\n\n    // ── Top-level config ───────────────────────────────────────────────────\n    const DEBUG = false;\n    const log = (...a) => { if (DEBUG && window.console) console.log('[CRM Resolution by Dept]', ...a); };\n\n    const QUERY_INDEX = { tickets: 0 };\n    const COL_DEPT = 'agent_department';\n    const COL_HOURS = 'resolution_hours';\n\n    const EL_ID = 'crm-resdept-canvas';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const FACT_DS_ID = '53ac2850-7b7d-4cd1-83a3-d0cddbf66c03';\n\n    let inst = null;\n    let obs = null;\n\n    // ── Pure helpers ────────────────────────────────────────────\n    const themeVar = (name, fallback) => {\n        try {\n            const v = getComputedStyle(document.documentElement).getPropertyValue(name);\n            return v && v.trim() ? v.trim() : fallback;\n        } catch (e) { return fallback; }\n    };\n\n    const getQueryData = (index) => {\n        const r = currentBlock.queryResults[index];\n        if (!r || !r.data) return [];\n        if (Array.isArray(r.mappedData)) return r.mappedData;\n        const cols = (r.columns || []).map(c => (typeof c === 'string' ? c : c && c.name));\n        return r.data.map(row => {\n            const o = {};\n            cols.forEach((c, i) => { o[c] = row[i]; });\n            return o;\n        });\n    };\n\n    const toNumber = (v) => {\n        const n = parseFloat(v);\n        return isFinite(n) ? n : NaN;\n    };\n\n    const avgHoursByDept = (rows) => {\n        const sums = {};\n        const counts = {};\n        rows.forEach(row => {\n            const dept = row[COL_DEPT];\n            const hours = toNumber(row[COL_HOURS]);\n            if (dept == null || dept === '' || !isFinite(hours)) return;\n            sums[dept] = (sums[dept] || 0) + hours;\n            counts[dept] = (counts[dept] || 0) + 1;\n        });\n        return Object.keys(sums)\n            .map(dept => ({ name: dept, value: sums[dept] / counts[dept], n: counts[dept] }))\n            .sort((a, b) => a.value - b.value);\n    };\n\n    const buildOption = (data, theme) => ({\n        backgroundColor: 'transparent',\n        grid: { left: 6, right: 56, top: 8, bottom: 4, containLabel: true },\n        tooltip: {\n            trigger: 'axis',\n            axisPointer: { type: 'shadow' },\n            backgroundColor: '#1B1B22',\n            borderColor: 'rgba(255,255,255,.12)',\n            borderWidth: 1,\n            textStyle: { color: theme.ink },\n            valueFormatter: (v) => Number(v).toFixed(1) + ' h'\n        },\n        xAxis: {\n            type: 'value',\n            axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n            axisTick: { show: false },\n            axisLabel: { color: '#C2C2CC', fontSize: 10, formatter: (v) => v + ' h' },\n            splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } }\n        },\n        yAxis: {\n            type: 'category',\n            data: data.map(d => d.name),\n            axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n            axisTick: { show: false },\n            axisLabel: { color: '#C2C2CC', fontSize: 11, fontWeight: 600 }\n        },\n        series: [{\n            type: 'bar',\n            data: data.map(d => d.value),\n            barWidth: '56%',\n            itemStyle: { color: theme.accent, borderRadius: [0, 4, 4, 0] },\n            label: {\n                show: true,\n                position: 'right',\n                color: theme.ink,\n                fontSize: 11,\n                fontWeight: 700,\n                formatter: (p) => Number(p.value).toFixed(1) + ' h'\n            }\n        }]\n    });\n\n    // ── Side-effecting render ──────────────────────────────────────\n    const disposeChart = () => {\n        try { if (obs) obs.disconnect(); } catch (e) {}\n        obs = null;\n        try { if (inst) inst.dispose(); } catch (e) {}\n        inst = null;\n    };\n\n    const render = () => {\n        if (typeof echarts === 'undefined') return;\n        const el = document.getElementById(EL_ID);\n        if (!el) return;\n        const data = avgHoursByDept(getQueryData(QUERY_INDEX.tickets));\n        log('departments', data.length);\n        if (!data.length) {\n            disposeChart();\n            el.innerHTML = '<div class=\"empty\">No tickets match the current filter</div>';\n            return;\n        }\n        disposeChart();\n        el.innerHTML = '';\n        const existing = echarts.getInstanceByDom(el);\n        if (existing) { try { existing.dispose(); } catch (e) {} }\n        inst = echarts.init(el);\n        obs = new ResizeObserver(() => { try { inst.resize(); } catch (e) {} });\n        obs.observe(el);\n        const theme = {\n            ink: themeVar('--color-text', '#F4F4F7'),\n            accent: themeVar('--color-primary', '#FFD21E')\n        };\n        inst.setOption(buildOption(data, theme));\n    };\n\n    // ── Async ECharts load (UMD define guard so it attaches to window) ────────\n    const loadECharts = () => {\n        if (typeof echarts !== 'undefined') return Promise.resolve();\n        const savedDefine = window.define;\n        window.define = undefined;\n        return Promise.resolve(zPortal.resources.load(ECHARTS_URL))\n            .finally(() => { window.define = savedDefine; });\n    };\n\n    // ── Orchestrator ────────────────────────────────────────────\n    const init = () => {\n        const loaded = (typeof currentBlock !== 'undefined' && currentBlock && currentBlock.getOnLoadedCallback)\n            ? currentBlock.getOnLoadedCallback()\n            : () => {};\n        loadECharts()\n            .then(() => { render(); })\n            .catch((e) => { log('echarts load failed', e); })\n            .finally(() => { loaded(); });\n        try {\n            if (typeof zPortal !== 'undefined' && zPortal.dataSource && zPortal.dataSource.on) {\n                zPortal.dataSource.on('load', FACT_DS_ID, () => { if (typeof echarts !== 'undefined') render(); });\n            }\n        } catch (e) { log('filter subscribe failed', e); }\n    };\n\n    init();\n})();</script>"
    ]
  },
