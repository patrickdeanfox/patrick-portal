    "html": [
      "<div class=\"ind-bar\">\n  <div><div class=\"ind-eyebrow\">Industry Showcase · Financial Services</div><h1 class=\"ind-title\">Banking Performance</h1></div>\n  <div class=\"ind-controls\">\n    <label class=\"ind-field\">Region<select id=\"ind-f-region\"><option value=\"\">All regions</option></select></label>\n    <label class=\"ind-field\">Branch<select id=\"ind-f-branch\"><option value=\"\">All branches</option></select></label>\n    <label class=\"ind-field\">Product<select id=\"ind-f-product\"><option value=\"\">All products</option></select></label>\n    <button id=\"ind-clear\" class=\"ind-clear\" type=\"button\">Clear filters</button>\n  </div>\n</div>\n<script>(function(){\n  var DS_ID=\"0b475da2-7aa9-4903-b604-ef21f89dc412\";\n  var COLS=[\"region\",\"branch\",\"product\"];\n  var built=false;\n  function g(id){return document.getElementById(id);}\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function distinct(d,col){var s={};d.forEach(function(x){if(x[col]!=null&&x[col]!=='')s[x[col]]=1;});return Object.keys(s).sort();}\n  function buildOptions(){if(built)return;var d=rows();if(!d.length)return;COLS.forEach(function(col){var sel=g('ind-f-'+col);if(!sel)return;distinct(d,col).forEach(function(v){var o=document.createElement('option');o.value=v;o.textContent=v;sel.appendChild(o);});});built=true;}\n  function setF(col,val){try{zPortal.dataSource.setFilters(col,val?[val]:[]);}catch(e){console.error('setFilters',e);}}\n  function wire(){COLS.forEach(function(col){var sel=g('ind-f-'+col);if(sel)sel.addEventListener('change',function(){setF(col,sel.value);});});var c=g('ind-clear');if(c)c.addEventListener('click',function(){COLS.forEach(function(col){var sel=g('ind-f-'+col);if(sel)sel.value='';setF(col,'');});});}\n  function applyUrl(){try{var p=new URLSearchParams(window.location.search);COLS.forEach(function(col){var v=p.get(col);if(v){var sel=g('ind-f-'+col);if(sel)sel.value=v;setF(col,v);}});}catch(e){}}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{buildOptions();wire();applyUrl();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,buildOptions);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
