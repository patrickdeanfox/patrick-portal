{
  "name": "EXEC · Chart AR Aging",
  "type": "html",
  "css": [
    ".wrapper-exec-arage{--surface:var(--block-bg-color,#15151A);--surface-raised:#1B1B22;--ink:var(--color-text,#F4F4F7);--muted:var(--color-gray-500,#8A8A96);--line:var(--color-gray-200,rgba(255,255,255,.07));--accent:var(--color-primary,#FFD21E);--accent-2:var(--color-secondary,#FF3D8B);height:100%;max-width:100%;min-width:0;box-sizing:border-box;color:var(--ink);font-family:var(--font-stack-primary,'Inter',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif);font-variant-numeric:tabular-nums;container-type:inline-size;}\n.wrapper-exec-arage .chart-card{display:flex;flex-direction:column;height:100%;min-height:300px;min-width:0;max-width:100%;box-sizing:border-box;background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:16px 18px 12px;box-shadow:0 1px 0 rgba(255,255,255,.03) inset,0 6px 18px rgba(0,0,0,.5);transition:border-color .15s ease,box-shadow .15s ease;}\n.wrapper-exec-arage .chart-card:hover{border-color:color-mix(in srgb,var(--accent) 22%,var(--line));}\n.wrapper-exec-arage .card-head{display:flex;flex-direction:column;gap:3px;margin-bottom:10px;min-width:0;}\n.wrapper-exec-arage .card-head h3{display:flex;align-items:center;gap:8px;margin:0;min-width:0;font:800 14px/1.2 var(--font-stack-primary,'Inter',system-ui,sans-serif);letter-spacing:-.01em;color:var(--ink);overflow-wrap:break-word;}\n.wrapper-exec-arage .card-head h3::before{content:\"\";flex:0 0 auto;width:7px;height:7px;border-radius:50%;background:var(--accent);}\n.wrapper-exec-arage .card-head .sub{font:700 11px/1.3 var(--font-stack-primary,'Inter',system-ui,sans-serif);letter-spacing:.12em;text-transform:uppercase;color:var(--muted);overflow-wrap:break-word;}\n.wrapper-exec-arage .canvas{flex:1 1 auto;min-height:240px;width:100%;max-width:100%;min-width:0;}\n.wrapper-exec-arage .empty{flex:1 1 auto;display:flex;align-items:center;justify-content:center;min-height:240px;box-sizing:border-box;padding:0 12px;text-align:center;color:var(--muted);font:600 13px/1.4 var(--font-stack-primary,'Inter',system-ui,sans-serif);}\n.wrapper-exec-arage .empty[hidden]{display:none;}\n@container (max-width:720px){.wrapper-exec-arage .chart-card{padding:14px 16px 10px;}}\n@container (max-width:480px){.wrapper-exec-arage .chart-card{padding:12px 14px 10px;}}\n@container (max-width:420px){.wrapper-exec-arage .chart-card{padding:12px;}.wrapper-exec-arage .card-head h3{font-size:13px;}.wrapper-exec-arage .card-head .sub{letter-spacing:.08em;}}\n@container (max-width:320px){.wrapper-exec-arage .canvas,.wrapper-exec-arage .empty{min-height:220px;}}\n@media (prefers-reduced-motion:reduce){.wrapper-exec-arage .chart-card{transition:none;}}"
  ],
  "json_data": {
    "isolated": false,
    "html": [
      "<div class=\"wrapper wrapper-exec-arage\">\n  <div class=\"chart-card\">\n    <div class=\"card-head\">\n      <h3>Accounts Receivable Aging</h3>\n      <span class=\"sub\">Open balance by aging bucket &middot; USD</span>\n    </div>\n    <div id=\"exec-ar-aging-canvas\" class=\"canvas\" role=\"img\" aria-label=\"Bar chart of accounts receivable amount by aging bucket, current through 90-plus days\"></div>\n    <div id=\"exec-ar-aging-empty\" class=\"empty\" hidden>No accounts receivable data available.</div>\n  </div>\n  <script>(function () {\n    'use strict';\n\n    /* ---- top-level config ---- */\n    const DEBUG = false;\n    const TAG = '[EXEC · Chart AR Aging]';\n    const log = (...a) => { if (DEBUG && window.console) console.log(TAG, ...a); };\n    const warn = (...a) => { if (DEBUG && window.console) console.warn(TAG, ...a); };\n    const fail = (...a) => { if (DEBUG && window.console) console.error(TAG, ...a); };\n\n    const QUERY_INDEX = { aging: 0 };\n    const COL = { bucket: 'aging_bucket', amount: 'ar_amount', status: 'payment_status' };\n    const OPEN_STATUSES = ['Outstanding', 'Overdue'];\n    const DATASOURCE_ID = 'bfddfcdd-4b02-4412-9676-3e999ff7191c';\n    const CHART_EL_ID = 'exec-ar-aging-canvas';\n    const EMPTY_EL_ID = 'exec-ar-aging-empty';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const HANDLER_KEY = '__execArAgingOnLoad';\n\n    const BUCKET_ORDER = ['0 Current', '1-30', '31-60', '61-90', '90+'];\n    const BUCKET_LABEL = { '0 Current': 'Current', '1-30': '1-30', '31-60': '31-60', '61-90': '61-90', '90+': '90+' };\n    const BUCKET_COLOR = { '0 Current': '#36D399', '1-30': '#A8D85B', '31-60': '#F6C453', '61-90': '#FF9F45', '90+': '#FF5A6E' };\n    const FALLBACK_COLOR = '#34B9F3';\n\n    /* ---- formatters (no literal currency sign) ---- */\n    const fmtFull = (v) => Number(v || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n    const fmtCompact = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 }).format(Number(v || 0));\n\n    /* ---- escape untrusted text before HTML injection ---- */\n    const ESC_MAP = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;', \"'\": '&#39;' };\n    const escapeHtml = (s) => String(s == null ? '' : s).replace(/[&<>\"']/g, (ch) => ESC_MAP[ch]);\n\n    /* ---- read theme colors from the wrapper so chart text tracks light/dark ---- */\n    const readThemeColors = (el) => {\n        const root = (el && el.closest) ? (el.closest('.wrapper-exec-arage') || el) : el;\n        const cs = (root && window.getComputedStyle) ? window.getComputedStyle(root) : null;\n        const pick = (name, fallbackValue) => {\n            const v = cs ? String(cs.getPropertyValue(name) || '').trim() : '';\n            return v || fallbackValue;\n        };\n        return {\n            ink: pick('--ink', '#F4F4F7'),\n            muted: pick('--muted', '#8A8A96'),\n            line: pick('--line', 'rgba(255,255,255,.07)')\n        };\n    };\n\n    /* ---- pure data helpers ---- */\n    const getQueryData = (index) => {\n        const cb = (typeof currentBlock !== 'undefined') ? currentBlock : null;\n        const q = cb && cb.queryResults && cb.queryResults[index];\n        if (!q || !q.data) return [];\n        if (Array.isArray(q.mappedData)) return q.mappedData;\n        const cols = (q.columns || []).map((c) => (typeof c === 'string' ? c : (c && c.name)));\n        return (q.data || []).map((row) => {\n            const obj = {};\n            cols.forEach((c, i) => { obj[c] = row[i]; });\n            return obj;\n        });\n    };\n\n    const aggregateByBucket = (rows) => {\n        const totals = {};\n        rows.forEach((r) => {\n            const bucket = r[COL.bucket];\n            if (bucket == null) return;\n            if (OPEN_STATUSES.indexOf(r[COL.status]) === -1) return;\n            totals[bucket] = (totals[bucket] || 0) + (Number(r[COL.amount]) || 0);\n        });\n        const ordered = BUCKET_ORDER.filter((b) => totals[b] !== undefined);\n        const extras = Object.keys(totals).filter((b) => BUCKET_ORDER.indexOf(b) === -1);\n        return ordered.concat(extras).map((b) => ({\n            label: BUCKET_LABEL[b] || b,\n            value: totals[b],\n            color: BUCKET_COLOR[b] || FALLBACK_COLOR\n        }));\n    };\n\n    /* ---- pure chart option ---- */\n    const buildOption = (series, theme) => ({\n        backgroundColor: 'transparent',\n        grid: { left: 6, right: 16, top: 28, bottom: 6, containLabel: true },\n        tooltip: {\n            trigger: 'axis',\n            axisPointer: { type: 'shadow', shadowStyle: { color: 'rgba(255,255,255,.05)' } },\n            backgroundColor: '#1B1B22',\n            borderColor: 'rgba(255,255,255,.10)',\n            borderWidth: 1,\n            textStyle: { color: '#F4F4F7', fontSize: 12 },\n            formatter: (params) => {\n                const p = params[0];\n                return '<div style=\"font-weight:700;margin-bottom:3px\">' + escapeHtml(p.name) + '</div>' + p.marker + fmtFull(p.value);\n            }\n        },\n        xAxis: {\n            type: 'category',\n            data: series.map((d) => d.label),\n            axisLine: { lineStyle: { color: theme.line } },\n            axisTick: { show: false },\n            axisLabel: { color: theme.muted, fontSize: 11, fontWeight: 600 }\n        },\n        yAxis: {\n            type: 'value',\n            axisLine: { show: false },\n            axisTick: { show: false },\n            splitLine: { lineStyle: { color: theme.line } },\n            axisLabel: { color: theme.muted, fontSize: 10, formatter: (val) => fmtCompact(val) }\n        },\n        series: [{\n            type: 'bar',\n            barMaxWidth: 72,\n            itemStyle: { borderRadius: [4, 4, 0, 0] },\n            data: series.map((d) => ({ value: d.value, itemStyle: { color: d.color } })),\n            label: { show: true, position: 'top', color: theme.ink, fontSize: 11, fontWeight: 700, formatter: (p) => fmtCompact(p.value) }\n        }]\n    });\n\n    /* ---- side-effecting render ---- */\n    const renderChart = () => {\n        if (typeof window.echarts === 'undefined') return;\n        const el = document.getElementById(CHART_EL_ID);\n        const emptyEl = document.getElementById(EMPTY_EL_ID);\n        if (!el) return;\n        const series = aggregateByBucket(getQueryData(QUERY_INDEX.aging));\n        log('aggregated buckets', series.length);\n        const prior = window.echarts.getInstanceByDom(el);\n        if (prior) { try { prior.dispose(); } catch (e) { warn('dispose failed', e); } }\n        if (!series.length) {\n            el.style.display = 'none';\n            if (emptyEl) emptyEl.hidden = false;\n            return;\n        }\n        el.style.display = '';\n        if (emptyEl) emptyEl.hidden = true;\n        const chart = window.echarts.init(el);\n        chart.setOption(buildOption(series, readThemeColors(el)));\n        if (el.__arResizeObserver) { try { el.__arResizeObserver.disconnect(); } catch (e) {} }\n        if (typeof ResizeObserver !== 'undefined') {\n            const ro = new ResizeObserver(() => { try { chart.resize(); } catch (e) {} });\n            ro.observe(el);\n            el.__arResizeObserver = ro;\n        }\n    };\n\n    /* ---- async ECharts load (AMD-define guard so UMD sets window.echarts) ---- */\n    const loadECharts = () => {\n        if (typeof window.echarts !== 'undefined') return Promise.resolve();\n        const savedDefine = window.define;\n        window.define = undefined;\n        return Promise.resolve(zPortal.resources.load(ECHARTS_URL)).finally(() => { window.define = savedDefine; });\n    };\n\n    const subscribe = () => {\n        try {\n            if (typeof zPortal === 'undefined' || !zPortal.dataSource || !zPortal.dataSource.on) return;\n            const prior = window[HANDLER_KEY];\n            if (prior && zPortal.dataSource.off) { try { zPortal.dataSource.off('load', DATASOURCE_ID, prior); } catch (e) {} }\n            const handler = () => { renderChart(); };\n            zPortal.dataSource.on('load', DATASOURCE_ID, handler);\n            window[HANDLER_KEY] = handler;\n        } catch (e) {\n            warn('subscribe failed', e);\n        }\n    };\n\n    /* ---- bottom-level orchestrator ---- */\n    const init = async () => {\n        const loaded = (typeof currentBlock !== 'undefined' && currentBlock && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : () => {};\n        try {\n            await loadECharts();\n            renderChart();\n            subscribe();\n        } catch (e) {\n            fail('init failed', e);\n        } finally {\n            loaded();\n        }\n    };\n\n    init();\n})();</script>\n</div>"
    ]
  },
