    "html": [
      "<div class=\"ind-kpis\">\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Total Revenue</span></div><div class=\"ind-kpi-val\" id=\"k-rev\">—</div><div class=\"ind-kpi-sub\" id=\"k-rev-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Units Sold</span></div><div class=\"ind-kpi-val\" id=\"k-units\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Return Rate</span></div><div class=\"ind-kpi-val\" id=\"k-return\">—</div><div class=\"ind-kpi-sub\">of units sold</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Avg Margin</span></div><div class=\"ind-kpi-val\" id=\"k-margin\">—</div><div class=\"ind-kpi-sub\">weighted by revenue</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Revenue / Unit</span></div><div class=\"ind-kpi-val\" id=\"k-rpu\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Brands</span></div><div class=\"ind-kpi-val\" id=\"k-brands\">—</div><div class=\"ind-kpi-sub\">in view</div></div>\n</div>\n<script>(function(){\n  var DS_ID=\"3e261a43-4818-46d0-8956-2ae7f4de1f5c\";\n  var D=String.fromCharCode(36);\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function fmtInt(n){return Math.round(n).toLocaleString();}\n  function fmtMoney(n){if(n>=1e6)return D+(n/1e6).toFixed(2)+'M';if(n>=1e3)return D+Math.round(n/1e3)+'K';return D+fmtInt(n);}\n  function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}\n  function render(){var d=rows();var rev=0,units=0,ret=0,mw=0,br={};d.forEach(function(r){rev+=num(r.revenue);units+=num(r.units_sold);ret+=num(r.returns);mw+=num(r.margin_pct)*num(r.revenue);if(r.brand)br[r.brand]=1;});set('k-rev',fmtMoney(rev));set('k-units',fmtInt(units));set('k-return',(units?(ret/units*100):0).toFixed(1)+'%');set('k-margin',(rev?(mw/rev):0).toFixed(1)+'%');set('k-rpu',fmtMoney(units?(rev/units):0));set('k-brands',Object.keys(br).length);set('k-rev-sub',fmtInt(ret)+' returns');}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{render();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,render);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
