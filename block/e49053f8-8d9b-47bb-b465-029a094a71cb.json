{
  "name": "CRM · Chart Tickets by Category & Priority",
  "type": "html",
  "css": [
    ".wrapper {\n  --cbp-surface: var(--block-bg-color, #15151A);\n  --cbp-surface-raised: #1B1B22;\n  --cbp-ink: var(--color-text, #F4F4F7);\n  --cbp-muted: var(--color-gray-500, #8A8A96);\n  --cbp-line: var(--color-gray-200, rgba(255,255,255,.07));\n  --cbp-accent: var(--color-primary, #FFD21E);\n  --cbp-accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  color: var(--cbp-ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n  height: 100%;\n}\n.wrapper .cbp-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  box-sizing: border-box;\n  background: var(--cbp-surface);\n  border: 1px solid var(--cbp-line);\n  border-radius: 14px;\n  padding: 14px 16px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease;\n}\n.wrapper .cbp-card:hover {\n  border-color: color-mix(in srgb, var(--cbp-accent) 28%, var(--cbp-line));\n}\n.wrapper .cbp-head {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  margin-bottom: 10px;\n  min-width: 0;\n}\n.wrapper .cbp-title {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin: 0;\n  min-width: 0;\n  overflow-wrap: anywhere;\n  font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.005em;\n  color: var(--cbp-ink);\n}\n.wrapper .cbp-title::before {\n  content: \"\";\n  flex: none;\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--cbp-accent);\n}\n.wrapper .cbp-sub {\n  margin: 0;\n  min-width: 0;\n  overflow-wrap: anywhere;\n  font: 500 11px/1.3 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--cbp-muted);\n}\n.wrapper .cbp-canvas {\n  flex: 1 1 auto;\n  width: 100%;\n  min-height: 220px;\n}\n.wrapper .cbp-canvas:focus-visible {\n  outline: 2px solid var(--cbp-accent);\n  outline-offset: 2px;\n  border-radius: 8px;\n}\n.wrapper .cbp-empty {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  min-height: 200px;\n  margin: 0;\n  text-align: center;\n  font: 500 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--cbp-muted);\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper .cbp-card { transition: none; }\n}\n/* ---- responsive: container-query collapse, scoped to this block's own width ---- */\n@container (max-width: 720px) {\n  .wrapper .cbp-canvas { min-height: 220px; }\n}\n@container (max-width: 460px) {\n  .wrapper .cbp-card { padding: 12px; }\n  .wrapper .cbp-head { margin-bottom: 8px; }\n  .wrapper .cbp-canvas { min-height: 200px; }\n}\n@container (max-width: 320px) {\n  .wrapper .cbp-card { padding: 10px; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": "<div class=\"wrapper\">\n  <section class=\"cbp-card\" role=\"group\" aria-label=\"Tickets by category and priority\">\n    <header class=\"cbp-head\">\n      <h3 class=\"cbp-title\">Tickets by Category &amp; Priority</h3>\n      <p class=\"cbp-sub\">Ticket count by category, stacked by priority</p>\n    </header>\n    <div class=\"cbp-canvas\" id=\"cbp-chart\" role=\"img\" aria-label=\"Stacked bar chart: ticket count by category, stacked by priority\" aria-live=\"polite\"></div>\n  </section>\n  <script>\n  (function () {\n    'use strict';\n\n    /* ---- top-level config ---- */\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) console.log('[CRM Tickets Cat/Prio]', ...args); };\n    const logError = (...args) => { console.error('[CRM Tickets Cat/Prio]', ...args); };\n\n    const QUERY_INDEX = { TICKETS: 0 };\n    const COL_CATEGORY = 'category';\n    const COL_PRIORITY = 'priority';\n    const PRIORITY_ORDER = ['Low', 'Medium', 'High', 'Urgent'];\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const CHART_ID = 'cbp-chart';\n\n    const rootEl = document.querySelector('.wrapper');\n    const cssVar = (name, fallback) => {\n      try {\n        const value = getComputedStyle(rootEl).getPropertyValue(name).trim();\n        return value || fallback;\n      } catch (e) {\n        return fallback;\n      }\n    };\n\n    /* Low -> Urgent severity ramp (green -> amber -> orange -> red) */\n    const PRIORITY_COLORS = {\n      'Low': cssVar('--color-success', '#36D399'),\n      'Medium': cssVar('--color-warning', '#F6C453'),\n      'High': '#FF9F45',\n      'Urgent': cssVar('--color-danger', '#FF5A6E')\n    };\n    const AXIS_LINE = 'rgba(255,255,255,.18)';\n    const SPLIT_LINE = 'rgba(255,255,255,.06)';\n    const LABEL_COLOR = '#C2C2CC';\n    const INK = cssVar('--color-text', '#F4F4F7');\n    const DARK_INK = '#0B0B0D';\n    const FONT = cssVar('--font-stack-primary', \"'Inter', system-ui, sans-serif\");\n\n    /* ---- pure helpers ---- */\n    function getQueryData(index) {\n      const q = (typeof currentBlock !== 'undefined' && currentBlock.queryResults)\n        ? currentBlock.queryResults[index]\n        : null;\n      if (!q || !q.data) return [];\n      if (q.mappedData) return q.mappedData;\n      return q.data.map((row) => Object.fromEntries(q.columns.map((col, i) => [col, row[i]])));\n    }\n\n    function aggregate(rows) {\n      const counts = {};\n      const totals = {};\n      for (const row of rows) {\n        const category = row[COL_CATEGORY];\n        const priority = row[COL_PRIORITY];\n        if (category == null || priority == null) continue;\n        if (!counts[category]) counts[category] = {};\n        counts[category][priority] = (counts[category][priority] || 0) + 1;\n        totals[category] = (totals[category] || 0) + 1;\n      }\n      const categories = Object.keys(counts).sort((a, b) => totals[b] - totals[a]);\n      return { counts, categories };\n    }\n\n    function buildOption(agg) {\n      const counts = agg.counts;\n      const categories = agg.categories;\n      const lastIndex = PRIORITY_ORDER.length - 1;\n      const series = PRIORITY_ORDER.map((priority, idx) => ({\n        name: priority,\n        type: 'bar',\n        stack: 'tickets',\n        color: PRIORITY_COLORS[priority],\n        barMaxWidth: 52,\n        emphasis: { focus: 'series' },\n        itemStyle: idx === lastIndex ? { borderRadius: [4, 4, 0, 0] } : {},\n        label: {\n          show: true,\n          position: 'inside',\n          color: DARK_INK,\n          fontSize: 10,\n          fontWeight: 600,\n          fontFamily: FONT,\n          formatter: (p) => (p.value > 0 ? p.value.toLocaleString() : '')\n        },\n        data: categories.map((cat) => (counts[cat] && counts[cat][priority]) || 0)\n      }));\n\n      return {\n        backgroundColor: 'transparent',\n        textStyle: { fontFamily: FONT },\n        grid: { left: 6, right: 16, top: 46, bottom: 6, containLabel: true },\n        legend: {\n          data: PRIORITY_ORDER,\n          top: 4,\n          left: 0,\n          itemWidth: 12,\n          itemHeight: 12,\n          itemGap: 16,\n          textStyle: { color: LABEL_COLOR, fontSize: 11, fontFamily: FONT }\n        },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: { type: 'shadow' },\n          backgroundColor: '#1B1B22',\n          borderColor: 'rgba(255,255,255,.12)',\n          borderWidth: 1,\n          textStyle: { color: INK, fontSize: 12, fontFamily: FONT }\n        },\n        xAxis: {\n          type: 'category',\n          data: categories,\n          axisLine: { lineStyle: { color: AXIS_LINE } },\n          axisTick: { show: false },\n          axisLabel: { color: LABEL_COLOR, fontSize: 11, fontFamily: FONT }\n        },\n        yAxis: {\n          type: 'value',\n          name: 'Tickets',\n          nameTextStyle: { color: LABEL_COLOR, fontSize: 10, fontFamily: FONT, padding: [0, 0, 4, 0] },\n          axisLine: { show: false },\n          axisTick: { show: false },\n          splitLine: { lineStyle: { color: SPLIT_LINE } },\n          axisLabel: { color: LABEL_COLOR, fontSize: 11, fontFamily: FONT }\n        },\n        series: series\n      };\n    }\n\n    /* ---- side-effecting render ---- */\n    function renderMessage(message) {\n      const el = document.getElementById(CHART_ID);\n      if (!el) return;\n      el.innerHTML = '';\n      const note = document.createElement('p');\n      note.className = 'cbp-empty';\n      note.textContent = message;\n      el.appendChild(note);\n    }\n\n    function renderChart(rows) {\n      const el = document.getElementById(CHART_ID);\n      if (!el || !window.echarts) return;\n      const prior = window.echarts.getInstanceByDom(el);\n      if (prior) prior.dispose();\n      const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n      chart.setOption(buildOption(aggregate(rows)));\n      if (el.__cbpResizeObserver) el.__cbpResizeObserver.disconnect();\n      const observer = new ResizeObserver(() => chart.resize());\n      observer.observe(el);\n      el.__cbpResizeObserver = observer;\n      log('rendered chart from', rows.length, 'rows');\n    }\n\n    function ensureECharts() {\n      if (window.echarts) return Promise.resolve();\n      if (typeof zPortal !== 'undefined' && zPortal.resources && zPortal.resources.load) {\n        return zPortal.resources.load(ECHARTS_URL);\n      }\n      return Promise.reject(new Error('zPortal.resources.load unavailable'));\n    }\n\n    /* ---- orchestrator ---- */\n    async function init() {\n      const onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback)\n        ? currentBlock.getOnLoadedCallback()\n        : null;\n      try {\n        const rows = getQueryData(QUERY_INDEX.TICKETS);\n        log('row count', rows.length);\n        if (!rows.length) {\n          renderMessage('No ticket data available.');\n          return;\n        }\n        await ensureECharts();\n        renderChart(rows);\n      } catch (e) {\n        logError('init failed', e);\n        renderMessage('Unable to render chart.');\n      } finally {\n        if (typeof onLoaded === 'function') onLoaded();\n      }\n    }\n\n    init();\n  })();\n  </script>\n</div>"
  },
