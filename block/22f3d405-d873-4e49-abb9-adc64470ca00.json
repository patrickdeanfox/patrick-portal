{
  "name": "SC · Chart Top Suppliers by Spend",
  "type": "html",
  "css": [
    ".wrapper-sc-suppliers {\n  --scs-surface: var(--block-bg-color, #15151A);\n  --scs-surface-raised: #1B1B22;\n  --scs-ink: var(--color-text, #F4F4F7);\n  --scs-muted: var(--color-gray-500, #8A8A96);\n  --scs-label: var(--color-gray-700, #C2C2CC);\n  --scs-line: var(--color-gray-200, rgba(255,255,255,.07));\n  --scs-accent: var(--color-primary, #FFD21E);\n  --scs-accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  box-sizing: border-box;\n  color: var(--scs-ink);\n  font-variant-numeric: tabular-nums;\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.wrapper-sc-suppliers .scs-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  box-sizing: border-box;\n  background: var(--scs-surface);\n  border: 1px solid var(--scs-line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease, box-shadow .16s ease;\n}\n.wrapper-sc-suppliers .scs-card:hover {\n  border-color: color-mix(in srgb, var(--scs-accent) 35%, var(--scs-line));\n}\n.wrapper-sc-suppliers .scs-head {\n  margin: 0 0 14px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid var(--scs-line);\n  min-width: 0;\n}\n.wrapper-sc-suppliers .scs-eyebrow {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  margin: 0 0 7px;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--scs-label);\n}\n.wrapper-sc-suppliers .scs-eyebrow::before {\n  content: \"\";\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--scs-accent);\n  flex: none;\n}\n.wrapper-sc-suppliers .scs-title {\n  margin: 0;\n  font: 800 15px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--scs-ink);\n  overflow-wrap: break-word;\n  word-break: break-word;\n}\n.wrapper-sc-suppliers .scs-sub {\n  margin: 4px 0 0;\n  font: 600 11px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--scs-muted);\n  overflow-wrap: break-word;\n}\n.wrapper-sc-suppliers .scs-chart {\n  flex: 1 1 auto;\n  width: 100%;\n  min-width: 0;\n  min-height: 320px;\n  overflow: hidden;\n  border-radius: 8px;\n}\n.wrapper-sc-suppliers .scs-chart:focus-visible {\n  outline: 2px solid var(--scs-accent);\n  outline-offset: 3px;\n  box-shadow: 0 0 18px -8px color-mix(in srgb, var(--scs-accent) 60%, transparent);\n}\n.wrapper-sc-suppliers .scs-empty {\n  margin: auto;\n  padding: 24px 12px;\n  font: 600 13px/1.45 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--scs-muted);\n  text-align: center;\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper-sc-suppliers .scs-card { transition: none; }\n}",
    "@container (max-width: 720px) {\n  .wrapper-sc-suppliers .scs-card { padding: 14px 16px; }\n}\n@container (max-width: 480px) {\n  .wrapper-sc-suppliers .scs-card { padding: 13px 14px; }\n  .wrapper-sc-suppliers .scs-head { margin-bottom: 12px; padding-bottom: 10px; }\n  .wrapper-sc-suppliers .scs-eyebrow { letter-spacing: .1em; }\n  .wrapper-sc-suppliers .scs-title { font-size: 14px; }\n  .wrapper-sc-suppliers .scs-chart { min-height: 260px; }\n}\n@container (max-width: 340px) {\n  .wrapper-sc-suppliers .scs-card { padding: 11px 12px; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper wrapper-sc-suppliers\">\n  <div class=\"scs-card\">\n    <div class=\"scs-head\">\n      <p class=\"scs-eyebrow\">Supply Chain</p>\n      <h3 class=\"scs-title\">Top Suppliers by Spend</h3>\n      <p class=\"scs-sub\">Total procurement spend &middot; top 12 suppliers</p>\n    </div>\n    <div class=\"scs-chart\" id=\"scs-chart\" tabindex=\"0\" role=\"img\" aria-label=\"Horizontal bar chart of total procurement spend for the top 12 suppliers\"></div>\n    <p class=\"scs-empty\" id=\"scs-empty\" hidden>No supplier spend data available.</p>\n  </div>\n</div>\n<script>\n(function () {\n  'use strict';\n\n  // ---- top-level config ----\n  const DEBUG = false;\n  const log = (...args) => { if (DEBUG) console.log('[SC Top Suppliers]', ...args); };\n  const warn = (...args) => { if (DEBUG) console.warn('[SC Top Suppliers]', ...args); };\n\n  const QUERY_INDEX = { suppliers: 0 };\n  const COL_NAME = 'supplier_name';\n  const COL_SPEND = 'total_spend';\n  const COL_COUNTRY = 'country';\n  const TOP_N = 12;\n\n  const WRAPPER_SELECTOR = '.wrapper-sc-suppliers';\n  const CHART_EL_ID = 'scs-chart';\n  const EMPTY_EL_ID = 'scs-empty';\n  const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n  const RO_KEY = '__scsSuppliersResizeObserver';\n  const SUB_KEY = '__scsSuppliersReloadSub';\n\n  // ---- formatters (pure) ----\n  const fmtCurrency = (value) => {\n    const v = Number(value) || 0;\n    return v.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n  };\n  const fmtCompact = (value) => {\n    const v = Number(value) || 0;\n    return v.toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n  };\n\n  // ---- data access ----\n  const getQueryData = (index) => {\n    try {\n      if (typeof currentBlock === 'undefined' || !currentBlock.queryResults) return [];\n      const q = currentBlock.queryResults[index];\n      if (!q || !q.data) return [];\n      if (q.mappedData) return q.mappedData;\n      return q.data.map((row) => Object.fromEntries(q.columns.map((col, k) => [col, row[k]])));\n    } catch (err) {\n      warn('getQueryData failed', err);\n      return [];\n    }\n  };\n\n  // ---- transforms (pure) ----\n  const prepareRows = (records) => {\n    const cleaned = records\n      .map((rec) => ({ name: rec[COL_NAME], spend: Number(rec[COL_SPEND]), country: rec[COL_COUNTRY] }))\n      .filter((d) => d.name != null && d.name !== '' && isFinite(d.spend));\n    cleaned.sort((a, b) => b.spend - a.spend);\n    const top = cleaned.slice(0, TOP_N);\n    top.reverse(); // largest sits at the top of a horizontal bar\n    log('prepared rows', top.length);\n    return top;\n  };\n\n  const resolveColors = () => {\n    const root = document.querySelector(WRAPPER_SELECTOR);\n    const cssVar = (name, fallback) => {\n      try {\n        const v = root ? getComputedStyle(root).getPropertyValue(name) : '';\n        return (v && v.trim()) || fallback;\n      } catch (err) {\n        return fallback;\n      }\n    };\n    return {\n      accent: cssVar('--color-primary', '#FFD21E'),\n      ink: cssVar('--color-text', '#F4F4F7'),\n      axis: '#C2C2CC'\n    };\n  };\n\n  // ---- option builder (pure) ----\n  const buildOption = (data, colors) => {\n    const names = data.map((d) => d.name);\n    const spends = data.map((d) => d.spend);\n    const countries = data.map((d) => d.country);\n    const maxSpend = spends.reduce((m, v) => (v > m ? v : m), 0);\n    return {\n      backgroundColor: 'transparent',\n      animationDuration: 600,\n      grid: { left: 6, right: 20, top: 10, bottom: 6, containLabel: true },\n      tooltip: {\n        trigger: 'axis',\n        axisPointer: { type: 'shadow' },\n        backgroundColor: '#1B1B22',\n        borderColor: 'rgba(255,255,255,.07)',\n        borderWidth: 1,\n        textStyle: { color: colors.ink, fontSize: 12 },\n        formatter: (params) => {\n          const p = params && params[0];\n          if (!p) return '';\n          const country = countries[p.dataIndex];\n          const sub = country ? p.name + ' &middot; ' + country : p.name;\n          return sub + '<br/>' + fmtCurrency(p.value);\n        }\n      },\n      xAxis: {\n        type: 'value',\n        max: maxSpend > 0 ? Math.ceil(maxSpend * 1.22) : null,\n        axisLine: { show: true, lineStyle: { color: 'rgba(255,255,255,.18)' } },\n        axisTick: { show: false },\n        splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } },\n        axisLabel: { color: colors.axis, fontSize: 10, formatter: (v) => fmtCompact(v) }\n      },\n      yAxis: {\n        type: 'category',\n        data: names,\n        axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n        axisTick: { show: false },\n        axisLabel: { color: colors.axis, fontSize: 11 }\n      },\n      series: [{\n        name: 'Total spend',\n        type: 'bar',\n        data: spends,\n        barMaxWidth: 20,\n        itemStyle: { color: colors.accent, borderRadius: [0, 4, 4, 0] },\n        emphasis: { itemStyle: { color: colors.accent } },\n        label: {\n          show: true,\n          position: 'right',\n          distance: 6,\n          color: colors.ink,\n          fontSize: 10.5,\n          fontWeight: 600,\n          formatter: (p) => fmtCurrency(p.value)\n        }\n      }]\n    };\n  };\n\n  // ---- side-effecting render helpers ----\n  const showEmpty = (isEmpty) => {\n    const msg = document.getElementById(EMPTY_EL_ID);\n    const el = document.getElementById(CHART_EL_ID);\n    if (msg) msg.hidden = !isEmpty;\n    if (el) el.style.display = isEmpty ? 'none' : '';\n  };\n\n  const observeResize = (el, chart) => {\n    try {\n      if (window[RO_KEY] && typeof window[RO_KEY].disconnect === 'function') window[RO_KEY].disconnect();\n      if (typeof ResizeObserver === 'undefined') return;\n      const ro = new ResizeObserver(() => { if (!chart.isDisposed()) chart.resize(); });\n      ro.observe(el);\n      window[RO_KEY] = ro;\n    } catch (err) {\n      warn('observeResize failed', err);\n    }\n  };\n\n  const renderChart = () => {\n    const el = document.getElementById(CHART_EL_ID);\n    if (!el || !window.echarts) return;\n    const prepared = prepareRows(getQueryData(QUERY_INDEX.suppliers));\n    const existing = window.echarts.getInstanceByDom(el);\n    if (existing) existing.dispose();\n    if (prepared.length === 0) {\n      showEmpty(true);\n      return;\n    }\n    showEmpty(false);\n    const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n    chart.setOption(buildOption(prepared, resolveColors()));\n    observeResize(el, chart);\n    log('chart rendered', prepared.length);\n  };\n\n  // ---- filter-reload subscription ----\n  const teardownPriorSubscription = () => {\n    try {\n      const prior = window[SUB_KEY];\n      if (prior && prior.ids && prior.handler && window.zPortal && zPortal.dataSource && typeof zPortal.dataSource.off === 'function') {\n        prior.ids.forEach((id) => {\n          try { zPortal.dataSource.off('load', id, prior.handler); } catch (e) { /* noop */ }\n        });\n      }\n    } catch (err) {\n      warn('teardown failed', err);\n    }\n    window[SUB_KEY] = null;\n  };\n\n  const subscribeReload = () => {\n    try {\n      if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') return;\n      const dsList = (typeof datasources !== 'undefined' && Array.isArray(datasources)) ? datasources : [];\n      const ids = [];\n      const handler = () => { log('datasource reload'); renderChart(); };\n      dsList.forEach((ds) => {\n        const id = ds && (ds.id || ds.datasource_id || ds.uuid);\n        if (!id) return;\n        try { zPortal.dataSource.on('load', id, handler); ids.push(id); } catch (e) { /* noop */ }\n      });\n      if (ids.length) window[SUB_KEY] = { ids: ids, handler: handler };\n    } catch (err) {\n      warn('subscribeReload failed', err);\n    }\n  };\n\n  // ---- loader ----\n  const loadECharts = () => {\n    if (window.echarts) return Promise.resolve();\n    if (window.zPortal && zPortal.resources && typeof zPortal.resources.load === 'function') {\n      return zPortal.resources.load(ECHARTS_URL);\n    }\n    return Promise.reject(new Error('zPortal.resources.load unavailable'));\n  };\n\n  // ---- single bottom-level orchestrator ----\n  const init = () => {\n    const onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : null;\n    let loadedCalled = false;\n    const done = () => {\n      if (!loadedCalled && typeof onLoaded === 'function') {\n        loadedCalled = true;\n        try { onLoaded(); } catch (e) { /* noop */ }\n      }\n    };\n    loadECharts().then(() => {\n      renderChart();\n      teardownPriorSubscription();\n      subscribeReload();\n    }).catch((err) => {\n      warn('init failed', err);\n      showEmpty(true);\n    }).finally(() => {\n      done();\n    });\n  };\n\n  init();\n})();\n</script>"
  },
