    ".wrapper-exec-funnel {\n    --surface: var(--block-bg-color, #15151A);\n    --surface-raised: #1B1B22;\n    --ink: var(--color-text, #F4F4F7);\n    --muted: var(--color-gray-500, #8A8A96);\n    --label: var(--color-gray-700, #C2C2CC);\n    --line: var(--color-gray-200, rgba(255,255,255,.07));\n    --accent: var(--color-primary, #FFD21E);\n    --accent-2: var(--color-secondary, #FF3D8B);\n    box-sizing: border-box;\n    height: 100%;\n    container-type: inline-size;\n    color: var(--ink);\n    font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n    font-variant-numeric: tabular-nums;\n}\n.wrapper-exec-funnel .funnel-card,\n.wrapper-exec-funnel .funnel-head,\n.wrapper-exec-funnel .funnel-canvas { box-sizing: border-box; }\n.wrapper-exec-funnel .funnel-card {\n    display: flex;\n    flex-direction: column;\n    height: 100%;\n    min-width: 0;\n    overflow: visible;\n    background: var(--surface);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    padding: 14px 16px 12px;\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n    transition: border-color .16s ease, background-color .16s ease;\n}\n.wrapper-exec-funnel .funnel-card:hover,\n.wrapper-exec-funnel .funnel-card:focus-within {\n    background: var(--surface-raised);\n    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));\n}\n.wrapper-exec-funnel .funnel-head {\n    display: flex;\n    flex-wrap: wrap;\n    align-items: baseline;\n    justify-content: space-between;\n    gap: 4px 10px;\n    margin-bottom: 10px;\n}\n.wrapper-exec-funnel .funnel-title {\n    margin: 0;\n    min-width: 0;\n    flex: 1 1 auto;\n    font-size: 14px;\n    font-weight: 800;\n    line-height: 1.2;\n    letter-spacing: -.01em;\n    color: var(--ink);\n    overflow-wrap: anywhere;\n}\n.wrapper-exec-funnel .funnel-sub {\n    display: inline-flex;\n    flex: 0 1 auto;\n    align-items: center;\n    gap: 7px;\n    margin: 0;\n    font-size: 11px;\n    font-weight: 700;\n    line-height: 1.2;\n    letter-spacing: .13em;\n    text-transform: uppercase;\n    color: var(--label);\n    white-space: nowrap;\n}\n.wrapper-exec-funnel .funnel-sub::before {\n    content: \"\";\n    flex: none;\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: var(--accent);\n}\n.wrapper-exec-funnel .funnel-canvas {\n    flex: 1 1 auto;\n    width: 100%;\n    min-width: 0;\n    min-height: 260px;\n}\n@container (max-width: 720px) {\n    .wrapper-exec-funnel .funnel-card { padding: 14px 14px 12px; }\n    .wrapper-exec-funnel .funnel-canvas { min-height: 240px; }\n}\n@container (max-width: 520px) {\n    .wrapper-exec-funnel .funnel-head { gap: 2px 8px; }\n    .wrapper-exec-funnel .funnel-canvas { min-height: 220px; }\n}\n@container (max-width: 420px) {\n    .wrapper-exec-funnel .funnel-card { padding: 12px 12px 10px; }\n    .wrapper-exec-funnel .funnel-canvas { min-height: 220px; }\n    .wrapper-exec-funnel .funnel-sub { display: none; }\n}\n@media (prefers-reduced-motion: reduce) {\n    .wrapper-exec-funnel .funnel-card { transition: none; }\n}"
