    "html": [
      "<div class=\"wrapper wrapper-exec-funnel\"><div class=\"funnel-card\"><div class=\"funnel-head\"><h3 class=\"funnel-title\">Pipeline by Stage</h3><span class=\"funnel-sub\">Pipeline Amount · USD</span></div><div class=\"funnel-canvas\" id=\"exec-funnel-canvas\" role=\"img\" aria-label=\"Funnel of total pipeline amount by sales stage\"></div></div><script>(function(){'use strict';const DEBUG=false;const log=(...a)=>{if(DEBUG&&window.console){console.log('[EXEC Pipeline Funnel]',...a);}};const QUERY_INDEX={PIPELINE:0};const COL={STAGE:'stage',OPPORTUNITIES:'opportunities',PIPELINE_AMOUNT:'pipeline_amount',WEIGHTED_AMOUNT:'weighted_amount',AVG_WIN_PROBABILITY:'avg_win_probability'};const DATASOURCE_ID='6c5b40d2-9365-42c6-b770-711a30cf689f';const ECHARTS_URL='https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';const CHART_EL_ID='exec-funnel-canvas';const WRAPPER_SEL='.wrapper-exec-funnel';const STAGE_ORDER=['Prospecting','Qualification','Proposal','Negotiation','Closed Won','Closed Lost'];const DEFAULT_ACCENT=[255,210,30];const DEFAULT_ACCENT_2=[255,61,139];const getQueryData=(index)=>{const q=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.queryResults)?currentBlock.queryResults[index]:null;if(!q||!q.data){return[];}if(Array.isArray(q.mappedData)){return q.mappedData;}const columns=(q.columns||[]).map((c)=>(typeof c==='string'?c:(c&&c.name)));return q.data.map((row)=>{const record={};columns.forEach((name,i)=>{record[name]=row[i];});return record;});};const toNumber=(value)=>{const parsed=parseFloat(value);return Number.isFinite(parsed)?parsed:0;};const formatMoney=(value)=>toNumber(value).toLocaleString('en-US',{style:'currency',currency:'USD',maximumFractionDigits:0});const cssVar=(el,name,fallback)=>{try{const value=getComputedStyle(el).getPropertyValue(name);return value&&value.trim()?value.trim():fallback;}catch(e){return fallback;}};const parseColor=(input,fallback)=>{if(!input){return fallback;}const text=String(input).trim();if(text.charAt(0)==='#'){let hex=text.slice(1);if(hex.length===3){hex=hex.split('').map((c)=>c+c).join('');}if(hex.length>=6){return[parseInt(hex.slice(0,2),16),parseInt(hex.slice(2,4),16),parseInt(hex.slice(4,6),16)];}return fallback;}const match=text.match(/(\\d+)[ ,]+(\\d+)[ ,]+(\\d+)/);if(match){return[parseInt(match[1],10),parseInt(match[2],10),parseInt(match[3],10)];}return fallback;};const mixColor=(from,to,t)=>{const channel=(a,b)=>Math.round(a+(b-a)*t);return'rgb('+channel(from[0],to[0])+','+channel(from[1],to[1])+','+channel(from[2],to[2])+')';};const buildFunnelData=(records,colorStart,colorEnd)=>{const byStage={};records.forEach((record)=>{const stage=record[COL.STAGE];if(stage!==null&&stage!==undefined){byStage[stage]=record;}});const ordered=STAGE_ORDER.filter((stage)=>byStage[stage]);const lastIndex=ordered.length-1;return ordered.map((stage,index)=>{const record=byStage[stage];const ratio=lastIndex>0?index/lastIndex:0;return{name:stage,value:toNumber(record[COL.PIPELINE_AMOUNT]),record:record,itemStyle:{color:mixColor(colorStart,colorEnd,ratio)}};});};const buildOption=(data)=>{const maxValue=data.reduce((max,item)=>Math.max(max,item.value),0)||1;return{backgroundColor:'transparent',tooltip:{trigger:'item',backgroundColor:'#1B1B22',borderColor:'rgba(255,255,255,0.12)',borderWidth:1,padding:[8,12],textStyle:{color:'#F4F4F7',fontSize:12},formatter:(params)=>{const record=(params.data&&params.data.record)||{};const opportunities=toNumber(record[COL.OPPORTUNITIES]).toLocaleString('en-US');const weighted=formatMoney(record[COL.WEIGHTED_AMOUNT]);const probability=toNumber(record[COL.AVG_WIN_PROBABILITY]).toFixed(1);return'<div style=\"font-weight:700;margin-bottom:6px\">'+params.name+'</div>'+'<div>Pipeline&nbsp;&nbsp;<b>'+formatMoney(params.value)+'</b></div>'+'<div>Weighted&nbsp;&nbsp;'+weighted+'</div>'+'<div>Opportunities&nbsp;&nbsp;'+opportunities+'</div>'+'<div>Avg win probability&nbsp;&nbsp;'+probability+'%</div>';}},series:[{type:'funnel',sort:'none',funnelAlign:'center',top:12,bottom:12,left:'6%',right:'6%',min:0,max:maxValue,minSize:'24%',maxSize:'100%',gap:3,label:{show:true,position:'inside',color:'#0B0B0D',fontSize:12,fontWeight:700,formatter:(params)=>params.name+'  ·  '+formatMoney(params.value)},labelLine:{show:false},itemStyle:{borderWidth:0},emphasis:{label:{fontSize:13}},data:data}]};};const renderEmpty=(chart)=>{chart.clear();chart.setOption({backgroundColor:'transparent',graphic:{type:'text',left:'center',top:'middle',style:{text:'No pipeline data',fill:'#8A8A96',fontSize:13,fontWeight:600}}});};const renderFunnel=()=>{const lib=window.echarts;const el=document.getElementById(CHART_EL_ID);if(!lib||!el){log('missing echarts or element');return null;}const existing=lib.getInstanceByDom(el);if(existing){existing.dispose();}const chart=lib.init(el);const records=getQueryData(QUERY_INDEX.PIPELINE);log('pipeline rows',records.length);const wrapper=document.querySelector(WRAPPER_SEL)||el;const colorStart=parseColor(cssVar(wrapper,'--color-primary',''),DEFAULT_ACCENT);const colorEnd=parseColor(cssVar(wrapper,'--color-secondary',''),DEFAULT_ACCENT_2);const data=buildFunnelData(records,colorStart,colorEnd);if(!data.length){log('no stages matched expected order');renderEmpty(chart);return chart;}chart.setOption(buildOption(data));return chart;};const setupResize=(chart)=>{const el=document.getElementById(CHART_EL_ID);if(!el||!chart){return;}if(el.__funnelResizeObserver){try{el.__funnelResizeObserver.disconnect();}catch(e){}}if(typeof ResizeObserver==='function'){const observer=new ResizeObserver(()=>{try{chart.resize();}catch(e){}});observer.observe(el);el.__funnelResizeObserver=observer;}};const redraw=()=>{const chart=renderFunnel();setupResize(chart);return chart;};const subscribeToFilters=()=>{const el=document.getElementById(CHART_EL_ID);const hasApi=typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on;if(!el||!hasApi){return;}if(el.__funnelLoadHandler){try{zPortal.dataSource.off('load',DATASOURCE_ID,el.__funnelLoadHandler);}catch(e){}}const handler=()=>{log('datasource reload -> redraw');redraw();};el.__funnelLoadHandler=handler;zPortal.dataSource.on('load',DATASOURCE_ID,handler);};const ensureECharts=()=>{if(window.echarts){return Promise.resolve();}const savedDefine=window.define;window.define=undefined;return Promise.resolve(zPortal.resources.load(ECHARTS_URL)).finally(()=>{window.define=savedDefine;});};const init=()=>{const loadedCallback=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};let loadedFired=false;const fireLoaded=()=>{if(!loadedFired){loadedFired=true;try{loadedCallback();}catch(e){log('loaded callback error',e);}}};ensureECharts().then(()=>{redraw();subscribeToFilters();}).catch((error)=>{log('echarts load failed',error);}).finally(()=>{fireLoaded();});};init();})();</script></div>"
