  "css": [
    ".cppf-wrap {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,.07));\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  width: 100%;\n  max-width: 100%;\n  box-sizing: border-box;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n}\n.cppf-wrap .cppf-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-width: 0;\n  box-sizing: border-box;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease, box-shadow .16s ease, background-color .16s ease;\n}\n.cppf-wrap .cppf-card:hover,\n.cppf-wrap .cppf-card:focus-within {\n  border-color: color-mix(in srgb, var(--accent) 32%, var(--line));\n}\n.cppf-wrap .cppf-head {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  min-width: 0;\n  margin: 0 0 12px;\n}\n.cppf-wrap .cppf-title {\n  display: flex;\n  align-items: center;\n  gap: 9px;\n  min-width: 0;\n  margin: 0;\n  font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--ink);\n  overflow-wrap: anywhere;\n}\n.cppf-wrap .cppf-title::before {\n  content: \"\";\n  flex: 0 0 auto;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--accent);\n  box-shadow: 0 0 10px -1px color-mix(in srgb, var(--accent) 70%, transparent);\n}\n.cppf-wrap .cppf-sub {\n  margin: 0;\n  min-width: 0;\n  font: 600 11px/1.3 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .12em;\n  text-transform: uppercase;\n  color: var(--muted);\n  overflow-wrap: anywhere;\n}\n.cppf-wrap .cppf-canvas {\n  flex: 1 1 auto;\n  width: 100%;\n  min-width: 0;\n  min-height: 240px;\n}\n.cppf-wrap .cppf-empty {\n  flex: 1 1 auto;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 200px;\n  padding: 8px;\n  text-align: center;\n  font: 600 13px/1.5 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--muted);\n}\n.cppf-wrap .cppf-empty[hidden] { display: none; }\n.cppf-wrap .cppf-card:focus-visible,\n.cppf-wrap [tabindex]:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 2px;\n}\n@container (max-width: 720px) {\n  .cppf-wrap .cppf-card { padding: 15px 16px; }\n  .cppf-wrap .cppf-canvas { min-height: 220px; }\n}\n@container (max-width: 480px) {\n  .cppf-wrap .cppf-card { padding: 14px; border-radius: 13px; }\n  .cppf-wrap .cppf-head { margin-bottom: 10px; }\n  .cppf-wrap .cppf-title { font-size: 13px; }\n  .cppf-wrap .cppf-canvas { min-height: 210px; }\n}\n@container (max-width: 360px) {\n  .cppf-wrap .cppf-card { padding: 12px 14px; border-radius: 12px; }\n  .cppf-wrap .cppf-head { margin-bottom: 10px; }\n  .cppf-wrap .cppf-canvas { min-height: 200px; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .cppf-wrap .cppf-card { transition: none; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": [
      "<div class=\"wrapper cppf-wrap\">\n  <div class=\"cppf-card\">\n    <div class=\"cppf-head\">\n      <h3 class=\"cppf-title\">Pipeline Funnel</h3>\n      <p class=\"cppf-sub\">Total pipeline by stage</p>\n    </div>\n    <div id=\"cppf-chart\" class=\"cppf-canvas\" role=\"img\" aria-label=\"Funnel chart of total pipeline amount by sales stage\" aria-live=\"polite\"></div>\n    <p class=\"cppf-empty\" hidden>No pipeline data available.</p>\n  </div>\n</div>",
      "<script>\n(function () {\n  'use strict';\n\n  // ---- Top-level config ----\n  const DEBUG = false;\n  const log = (...args) => { if (DEBUG) console.log('[CRM Pipeline Funnel]', ...args); };\n  const warn = (...args) => { if (DEBUG) console.warn('[CRM Pipeline Funnel]', ...args); };\n  const logError = (...args) => { console.error('[CRM Pipeline Funnel]', ...args); };\n\n  const QUERY_INDEX = { PIPELINE_BY_STAGE: 0 };\n  const COL = {\n    STAGE: 'stage',\n    OPPORTUNITIES: 'opportunities',\n    PIPELINE_AMOUNT: 'pipeline_amount',\n    WEIGHTED_AMOUNT: 'weighted_amount'\n  };\n  // Query returns rows amount-sorted; re-sort to the logical sales-stage order.\n  const STAGE_ORDER = ['Prospecting', 'Qualification', 'Proposal', 'Negotiation', 'Closed Won', 'Closed Lost'];\n  const DATASOURCE_ID = '6c5b40d2-9365-42c6-b770-711a30cf689f';\n  const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n  const CHART_EL_ID = 'cppf-chart';\n  const ACCENT_YELLOW = [255, 210, 30];\n  const ACCENT_PINK = [255, 61, 139];\n\n  // ---- Block scope / persistent store (survives JS re-runs) ----\n  const scope = (typeof currentBlock !== 'undefined' && currentBlock.container) ? currentBlock.container : document;\n  const store = (typeof currentBlock !== 'undefined' && currentBlock.container) ? currentBlock.container : window;\n  const chartEl = scope.querySelector('#' + CHART_EL_ID) || document.getElementById(CHART_EL_ID);\n  const rootEl = (chartEl && chartEl.closest('.cppf-wrap')) || scope.querySelector('.cppf-wrap') || (chartEl ? chartEl.parentNode : null);\n  const emptyEl = rootEl && rootEl.querySelector ? rootEl.querySelector('.cppf-empty') : null;\n\n  // ---- Loaded callback (async: echarts load) ----\n  let onLoaded = null;\n  try { onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : null; } catch (e) { onLoaded = null; }\n  let loadedFired = false;\n  const fireLoaded = () => {\n    if (loadedFired) return;\n    loadedFired = true;\n    if (typeof onLoaded === 'function') { try { onLoaded(); } catch (e) { logError('onLoaded threw', e); } }\n  };\n\n  // ---- Pure helpers ----\n  const getQueryData = (index) => {\n    const q = (typeof currentBlock !== 'undefined' && currentBlock.queryResults) ? currentBlock.queryResults[index] : null;\n    if (!q || !q.data) return [];\n    if (q.mappedData) return q.mappedData;\n    return q.data.map((row) => Object.fromEntries(q.columns.map((col, i) => [col, row[i]])));\n  };\n\n  const parseColor = (raw, fallback) => {\n    const s = (raw || '').trim();\n    let m = s.match(/^#([0-9a-fA-F]{6})$/);\n    if (m) { const h = m[1]; return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)]; }\n    m = s.match(/^#([0-9a-fA-F]{3})$/);\n    if (m) { const h = m[1]; return [parseInt(h[0] + h[0], 16), parseInt(h[1] + h[1], 16), parseInt(h[2] + h[2], 16)]; }\n    m = s.match(/rgba?\\(([^)]+)\\)/i);\n    if (m) {\n      const parts = m[1].split(',').map((x) => parseFloat(x));\n      if (parts.length >= 3 && parts.slice(0, 3).every((n) => !isNaN(n))) return [parts[0], parts[1], parts[2]];\n    }\n    return fallback;\n  };\n\n  const mixColor = (a, b, t) => {\n    const r = Math.round(a[0] + (b[0] - a[0]) * t);\n    const g = Math.round(a[1] + (b[1] - a[1]) * t);\n    const bl = Math.round(a[2] + (b[2] - a[2]) * t);\n    return 'rgb(' + r + ', ' + g + ', ' + bl + ')';\n  };\n\n  const toNumber = (v) => {\n    const n = typeof v === 'number' ? v : parseFloat(v);\n    return isFinite(n) ? n : 0;\n  };\n\n  const fmtMoney = (v) => toNumber(v).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n  const fmtCount = (v) => toNumber(v).toLocaleString('en-US');\n\n  // Build funnel data in the canonical stage order, yellow -> pink gradient.\n  const buildFunnelData = (records) => {\n    const byStage = {};\n    records.forEach((r) => { byStage[r[COL.STAGE]] = r; });\n    const rootStyle = (rootEl && rootEl.nodeType === 1) ? getComputedStyle(rootEl) : null;\n    const c1 = rootStyle ? parseColor(rootStyle.getPropertyValue('--color-primary'), ACCENT_YELLOW) : ACCENT_YELLOW;\n    const c2 = rootStyle ? parseColor(rootStyle.getPropertyValue('--color-secondary'), ACCENT_PINK) : ACCENT_PINK;\n    const present = STAGE_ORDER.filter((s) => byStage[s]);\n    const denom = present.length > 1 ? present.length - 1 : 1;\n    const data = [];\n    let pos = 0;\n    STAGE_ORDER.forEach((stage) => {\n      const rec = byStage[stage];\n      if (!rec) return;\n      const t = pos / denom;\n      pos += 1;\n      data.push({\n        name: stage,\n        value: toNumber(rec[COL.PIPELINE_AMOUNT]),\n        opportunities: toNumber(rec[COL.OPPORTUNITIES]),\n        weighted: toNumber(rec[COL.WEIGHTED_AMOUNT]),\n        itemStyle: { color: mixColor(c1, c2, t), borderWidth: 0 }\n      });\n    });\n    return data;\n  };\n\n  const buildOption = (data) => {\n    const maxValue = data.reduce((mx, d) => (d.value > mx ? d.value : mx), 0);\n    return {\n      backgroundColor: 'transparent',\n      tooltip: {\n        trigger: 'item',\n        backgroundColor: '#1B1B22',\n        borderColor: 'rgba(255,255,255,0.12)',\n        borderWidth: 1,\n        padding: [8, 12],\n        textStyle: { color: '#F4F4F7', fontSize: 12 },\n        formatter: (p) => {\n          const d = p.data || {};\n          return '<div style=\"font-weight:700;margin-bottom:4px\">' + p.name + '</div>'\n            + '<div>Pipeline: <b>' + fmtMoney(d.value) + '</b></div>'\n            + '<div>Weighted: ' + fmtMoney(d.weighted) + '</div>'\n            + '<div>Opportunities: ' + fmtCount(d.opportunities) + '</div>';\n        }\n      },\n      series: [{\n        type: 'funnel',\n        sort: 'none',\n        funnelAlign: 'center',\n        top: 12,\n        bottom: 12,\n        left: '6%',\n        right: '6%',\n        min: 0,\n        max: maxValue,\n        minSize: '0%',\n        maxSize: '100%',\n        gap: 3,\n        label: {\n          show: true,\n          position: 'inside',\n          color: '#0B0B0D',\n          fontWeight: 700,\n          fontSize: 12,\n          formatter: (p) => p.name + '  ·  ' + fmtMoney(p.value)\n        },\n        labelLine: { show: false },\n        itemStyle: { borderColor: 'rgba(0,0,0,0)', borderWidth: 0 },\n        emphasis: { label: { fontSize: 13 } },\n        data: data\n      }]\n    };\n  };\n\n  // ---- Render (disposes prior render first) ----\n  const renderChart = () => {\n    if (!chartEl || !window.echarts) return;\n    const records = getQueryData(QUERY_INDEX.PIPELINE_BY_STAGE);\n    log('rows', records.length);\n    const data = buildFunnelData(records);\n    const prior = window.echarts.getInstanceByDom(chartEl);\n\n    if (!data.length) {\n      if (prior) prior.dispose();\n      chartEl.style.display = 'none';\n      if (emptyEl) emptyEl.hidden = false;\n      return;\n    }\n    if (emptyEl) emptyEl.hidden = true;\n    chartEl.style.display = '';\n\n    if (prior) prior.dispose();\n    const chart = window.echarts.init(chartEl, null, { renderer: 'canvas' });\n    chart.setOption(buildOption(data), true);\n\n    if (store._cppfRO) { try { store._cppfRO.disconnect(); } catch (e) {} }\n    if (typeof ResizeObserver === 'function') {\n      const ro = new ResizeObserver(() => {\n        const inst = window.echarts.getInstanceByDom(chartEl);\n        if (inst) inst.resize();\n      });\n      ro.observe(chartEl);\n      store._cppfRO = ro;\n    }\n  };\n\n  // ---- React to filter / datasource reloads ----\n  const wireReload = () => {\n    if (!(window.zPortal && zPortal.dataSource && typeof zPortal.dataSource.on === 'function')) return;\n    if (store._cppfOnLoad) {\n      try { zPortal.dataSource.off('load', DATASOURCE_ID, store._cppfOnLoad); } catch (e) {}\n    }\n    const handler = () => { try { renderChart(); } catch (e) { logError('reload render failed', e); } };\n    try {\n      zPortal.dataSource.on('load', DATASOURCE_ID, handler);\n      store._cppfOnLoad = handler;\n    } catch (e) { warn('subscribe failed', e); }\n  };\n\n  // ---- Bottom-level init (only orchestrator) ----\n  const init = () => {\n    log('init');\n    if (window.echarts) {\n      try { renderChart(); wireReload(); }\n      catch (e) { logError('render failed', e); }\n      finally { fireLoaded(); }\n      return;\n    }\n    if (!(window.zPortal && zPortal.resources && typeof zPortal.resources.load === 'function')) {\n      logError('ECharts loader unavailable');\n      fireLoaded();\n      return;\n    }\n    zPortal.resources.load(ECHARTS_URL).then(() => {\n      try { renderChart(); wireReload(); }\n      catch (e) { logError('render after load failed', e); }\n      finally { fireLoaded(); }\n    }).catch((e) => {\n      logError('ECharts load failed', e);\n      fireLoaded();\n    });\n  };\n\n  init();\n})();\n</script>"
    ]
  },
