  "json_data": {
    "html": "<div class=\"wrapper sc-poline\" role=\"region\" aria-label=\"Purchase order line detail\">\n  <div class=\"po-head\">\n    <div class=\"po-head-l\">\n      <div class=\"po-eyebrow\">Procurement &amp; Inventory</div>\n      <h3 class=\"po-title\">PO Line Detail</h3>\n    </div>\n    <div class=\"po-meta\" id=\"po-meta-sc\" aria-live=\"polite\"></div>\n  </div>\n  <div class=\"po-tblwrap\" id=\"po-tblwrap-sc\">\n    <table class=\"po-table\" aria-label=\"Purchase order lines\">\n      <thead id=\"po-thead-sc\"></thead>\n      <tbody id=\"po-tbody-sc\" aria-live=\"polite\"></tbody>\n    </table>\n  </div>\n</div>\n<script>\n(function () {\n    \"use strict\";\n\n    // ── Top-level config ────────────────────────────────────────\n    const DEBUG = false;\n    const PREFIX = \"[SC Table PO Line Detail]\";\n    const log = (...a) => { if (DEBUG) console.log(PREFIX, ...a); };\n    log.warn = (...a) => { if (DEBUG) console.warn(PREFIX, ...a); };\n    log.error = (...a) => { if (DEBUG) console.error(PREFIX, ...a); };\n\n    const QUERY_INDEX = { lines: 0 };\n\n    // Column-name constants — must match the bound query aliases exactly.\n    const COL = {\n        po_number: \"po_number\",\n        order_date: \"order_date\",\n        po_status: \"po_status\",\n        supplier_name: \"supplier_name\",\n        supplier_country: \"supplier_country\",\n        product_name: \"product_name\",\n        product_category: \"product_category\",\n        quantity_ordered: \"quantity_ordered\",\n        unit_cost: \"unit_cost\",\n        line_spend: \"line_spend\",\n        payment_terms: \"payment_terms\"\n    };\n\n    // Display config — array order is the column order in the table.\n    const COLUMNS = [\n        { key: COL.po_number,        label: \"PO #\",       type: \"text\" },\n        { key: COL.order_date,       label: \"Order Date\", type: \"date\" },\n        { key: COL.po_status,        label: \"Status\",     type: \"status\" },\n        { key: COL.supplier_name,    label: \"Supplier\",   type: \"text\" },\n        { key: COL.supplier_country, label: \"Country\",    type: \"text\" },\n        { key: COL.product_name,     label: \"Product\",    type: \"text\" },\n        { key: COL.product_category, label: \"Category\",   type: \"text\" },\n        { key: COL.quantity_ordered, label: \"Qty\",        type: \"int\" },\n        { key: COL.unit_cost,        label: \"Unit Cost\",  type: \"money\", digits: 2 },\n        { key: COL.line_spend,       label: \"Line Spend\", type: \"money\", digits: 0 },\n        { key: COL.payment_terms,    label: \"Terms\",      type: \"text\" }\n    ];\n\n    // page_size is null (block receives ALL rows so sort acts on the full set);\n    // we DOM-render at most this many for responsiveness, newest/highest first.\n    const MAX_RENDER_ROWS = 1500;\n    const EMPTY = \"—\";\n\n    // Datasources backing the bound query — used to react to filter reloads.\n    const DATASOURCE_IDS = [\n        \"8291f813-bc85-4528-a528-dea8e1136e1e\",\n        \"ae44f95a-87a4-4f6b-a8fd-055fd9067bfb\",\n        \"4c75d296-0c69-4fdd-9623-e79ff1c066fb\",\n        \"3b417fa7-e096-417b-88da-8afdec2b5745\",\n        \"4e3711b1-abf9-48cc-9136-68e8a3f8f813\"\n    ];\n\n    const SEL = { thead: \"po-thead-sc\", tbody: \"po-tbody-sc\", meta: \"po-meta-sc\" };\n    const REG_KEY = \"__scPolineDetailReg\";\n\n    const state = { key: COL.line_spend, dir: \"desc\" };\n    let rows = [];\n\n    // ── Pure helpers ───────────────────────────────────────────\n    const getQueryData = (index) => {\n        const q = (currentBlock && currentBlock.queryResults) ? currentBlock.queryResults[index] : null;\n        if (!q || !q.columns) return [];\n        if (q.mappedData) return q.mappedData;\n        const data = q.data || [];\n        return data.map((row) => {\n            const obj = {};\n            for (let i = 0; i < q.columns.length; i += 1) {\n                obj[q.columns[i]] = row[i];\n            }\n            return obj;\n        });\n    };\n\n    const toNumber = (value) => {\n        if (typeof value === \"number\") return Number.isFinite(value) ? value : null;\n        if (value === null || value === undefined || value === \"\") return null;\n        const n = parseFloat(value);\n        return Number.isFinite(n) ? n : null;\n    };\n\n    const formatMoney = (value, digits) => {\n        const n = toNumber(value);\n        if (n === null) return EMPTY;\n        return n.toLocaleString(\"en-US\", { style: \"currency\", currency: \"USD\", minimumFractionDigits: digits, maximumFractionDigits: digits });\n    };\n\n    const formatInt = (value) => {\n        const n = toNumber(value);\n        if (n === null) return EMPTY;\n        return n.toLocaleString(\"en-US\");\n    };\n\n    const formatDate = (value) => {\n        if (value === null || value === undefined || value === \"\") return EMPTY;\n        const d = new Date(String(value).slice(0, 10) + \"T00:00:00\");\n        if (isNaN(d.getTime())) return String(value);\n        return d.toLocaleDateString(\"en-US\", { year: \"numeric\", month: \"short\", day: \"2-digit\" });\n    };\n\n    const escapeHtml = (value) => String(value === null || value === undefined ? \"\" : value)\n        .replace(/&/g, \"&amp;\")\n        .replace(/</g, \"&lt;\")\n        .replace(/>/g, \"&gt;\")\n        .replace(/\"/g, \"&quot;\");\n\n    const statusClass = (value) => {\n        const v = String(value === null || value === undefined ? \"\" : value).toLowerCase();\n        if (v === \"received\") return \"pill-ok\";\n        if (v === \"open\") return \"pill-open\";\n        if (v === \"cancelled\" || v === \"canceled\") return \"pill-bad\";\n        return \"pill-neutral\";\n    };\n\n    const statusPill = (value) => {\n        const text = (value === null || value === undefined || value === \"\") ? EMPTY : String(value);\n        return '<span class=\"pill ' + statusClass(value) + '\">' + escapeHtml(text) + \"</span>\";\n    };\n\n    const colByKey = (key) => COLUMNS.find((c) => c.key === key) || COLUMNS[0];\n\n    const compareRows = (a, b, col) => {\n        if (col.type === \"int\" || col.type === \"money\") {\n            const na = toNumber(a[col.key]);\n            const nb = toNumber(b[col.key]);\n            const va = na === null ? -Infinity : na;\n            const vb = nb === null ? -Infinity : nb;\n            return va - vb;\n        }\n        if (col.type === \"date\") {\n            return String(a[col.key] || \"\").localeCompare(String(b[col.key] || \"\"));\n        }\n        const sa = (a[col.key] === null || a[col.key] === undefined) ? \"\" : String(a[col.key]);\n        const sb = (b[col.key] === null || b[col.key] === undefined) ? \"\" : String(b[col.key]);\n        return sa.localeCompare(sb, undefined, { numeric: true, sensitivity: \"base\" });\n    };\n\n    const sortRows = (data) => {\n        const col = colByKey(state.key);\n        const sign = state.dir === \"asc\" ? 1 : -1;\n        return data.slice().sort((a, b) => sign * compareRows(a, b, col));\n    };\n\n    const defaultDir = (col) => (col.type === \"money\" || col.type === \"int\" || col.type === \"date\") ? \"desc\" : \"asc\";\n\n    const cellHtml = (rec, col) => {\n        const raw = rec[col.key];\n        if (col.type === \"money\") return '<td class=\"num\">' + escapeHtml(formatMoney(raw, col.digits)) + \"</td>\";\n        if (col.type === \"int\") return '<td class=\"num\">' + escapeHtml(formatInt(raw)) + \"</td>\";\n        if (col.type === \"date\") return '<td class=\"date\">' + escapeHtml(formatDate(raw)) + \"</td>\";\n        if (col.type === \"status\") return '<td class=\"status\">' + statusPill(raw) + \"</td>\";\n        const text = (raw === null || raw === undefined || raw === \"\") ? EMPTY : raw;\n        return \"<td>\" + escapeHtml(text) + \"</td>\";\n    };\n\n    const rowHtml = (rec) => {\n        let cells = \"\";\n        for (let i = 0; i < COLUMNS.length; i += 1) {\n            cells += cellHtml(rec, COLUMNS[i]);\n        }\n        return \"<tr>\" + cells + \"</tr>\";\n    };\n\n    const headHtml = () => {\n        let ths = \"\";\n        for (let i = 0; i < COLUMNS.length; i += 1) {\n            const col = COLUMNS[i];\n            const sorted = state.key === col.key;\n            const ariaSort = sorted ? (state.dir === \"asc\" ? \"ascending\" : \"descending\") : \"none\";\n            const arrow = sorted ? (state.dir === \"asc\" ? \"↑\" : \"↓\") : \"↕\";\n            const numCls = (col.type === \"money\" || col.type === \"int\") ? \" num\" : \"\";\n            ths += '<th class=\"th' + numCls + (sorted ? \" is-sorted\" : \"\") + '\" data-key=\"' + col.key + '\" role=\"columnheader\" scope=\"col\" tabindex=\"0\" aria-sort=\"' + ariaSort + '\"><span class=\"th-label\">' + escapeHtml(col.label) + '</span><span class=\"th-arrow\" aria-hidden=\"true\">' + arrow + '</span></th>';\n        }\n        return \"<tr>\" + ths + \"</tr>\";\n    };\n\n    // ── Side-effecting render ───────────────────────────────────\n    const byId = (id) => document.getElementById(id);\n\n    const renderHead = () => {\n        const head = byId(SEL.thead);\n        if (head) head.innerHTML = headHtml();\n    };\n\n    const renderMeta = (total, shown) => {\n        const meta = byId(SEL.meta);\n        if (!meta) return;\n        let text = total.toLocaleString(\"en-US\") + (total === 1 ? \" line\" : \" lines\");\n        if (shown < total) {\n            text += \" · showing first \" + shown.toLocaleString(\"en-US\") + \" · filter to narrow\";\n        }\n        meta.textContent = text;\n    };\n\n    const renderBody = () => {\n        const body = byId(SEL.tbody);\n        if (!body) return;\n        const sorted = sortRows(rows);\n        const slice = sorted.slice(0, MAX_RENDER_ROWS);\n        if (slice.length === 0) {\n            body.innerHTML = '<tr><td class=\"empty\" colspan=\"' + COLUMNS.length + '\">No purchase-order lines match the current filters.</td></tr>';\n        } else {\n            let html = \"\";\n            for (let i = 0; i < slice.length; i += 1) {\n                html += rowHtml(slice[i]);\n            }\n            body.innerHTML = html;\n        }\n        renderMeta(rows.length, slice.length);\n        log(\"rendered\", slice.length, \"of\", rows.length, \"rows; sort\", state.key, state.dir);\n    };\n\n    const readData = () => {\n        rows = getQueryData(QUERY_INDEX.lines);\n        log(\"read\", rows.length, \"rows\");\n    };\n\n    const renderAll = () => {\n        readData();\n        renderHead();\n        renderBody();\n    };\n\n    const applySort = (key) => {\n        const col = COLUMNS.find((c) => c.key === key);\n        if (!col) return;\n        if (state.key === key) {\n            state.dir = state.dir === \"asc\" ? \"desc\" : \"asc\";\n        } else {\n            state.key = key;\n            state.dir = defaultDir(col);\n        }\n        log(\"sort\", state.key, state.dir);\n        renderHead();\n        renderBody();\n    };\n\n    const onHeadClick = (event) => {\n        const th = event.target.closest(\"th[data-key]\");\n        if (th) applySort(th.getAttribute(\"data-key\"));\n    };\n\n    const onHeadKey = (event) => {\n        if (event.key !== \"Enter\" && event.key !== \" \") return;\n        const th = event.target.closest(\"th[data-key]\");\n        if (th) {\n            event.preventDefault();\n            applySort(th.getAttribute(\"data-key\"));\n        }\n    };\n\n    const wireFilterReactivity = () => {\n        try {\n            if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== \"function\") return;\n            const registry = window[REG_KEY] || (window[REG_KEY] = {});\n            if (registry.handler && typeof zPortal.dataSource.off === \"function\") {\n                DATASOURCE_IDS.forEach((id) => {\n                    try { zPortal.dataSource.off(\"load\", id, registry.handler); } catch (e) { log.error(\"off failed\", id, e); }\n                });\n            }\n            const handler = () => {\n                log(\"datasource load -> re-render\");\n                renderAll();\n            };\n            DATASOURCE_IDS.forEach((id) => {\n                try { zPortal.dataSource.on(\"load\", id, handler); } catch (e) { log.error(\"on failed\", id, e); }\n            });\n            registry.handler = handler;\n        } catch (e) {\n            log.error(\"wireFilterReactivity failed\", e);\n        }\n    };\n\n    const init = () => {\n        let onLoaded = null;\n        try {\n            if (currentBlock && typeof currentBlock.getOnLoadedCallback === \"function\") {\n                onLoaded = currentBlock.getOnLoadedCallback();\n            }\n        } catch (e) {\n            log.error(\"getOnLoadedCallback failed\", e);\n        }\n        try {\n            const head = byId(SEL.thead);\n            if (head) {\n                head.addEventListener(\"click\", onHeadClick);\n                head.addEventListener(\"keydown\", onHeadKey);\n            }\n            wireFilterReactivity();\n            renderAll();\n        } catch (e) {\n            log.error(\"init failed\", e);\n        } finally {\n            if (typeof onLoaded === \"function\") {\n                try { onLoaded(); } catch (e) { log.error(\"onLoaded failed\", e); }\n            }\n        }\n    };\n\n    init();\n}());\n</script>"
  },
