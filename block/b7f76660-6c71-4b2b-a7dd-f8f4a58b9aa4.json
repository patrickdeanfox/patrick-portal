  "css": [
    ".sc-poline {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,.07));\n  --hair: rgba(255,255,255,.06);\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  height: 100%;\n  box-sizing: border-box;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.sc-poline .po-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; flex-wrap: wrap; }\n.sc-poline .po-eyebrow { font: 700 11px/1.2 inherit; letter-spacing: .13em; text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; }\n.sc-poline .po-eyebrow::before { content: \"\"; display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 8px; background: var(--accent); }\n.sc-poline .po-title { margin: 5px 0 0; font: 800 18px/1.2 inherit; letter-spacing: -.01em; color: var(--ink); }\n.sc-poline .po-meta { font: 600 11px/1.3 inherit; color: var(--muted); font-variant-numeric: tabular-nums; text-align: right; }\n.sc-poline .po-tblwrap { flex: 1; min-height: 0; overflow: auto; -webkit-overflow-scrolling: touch; border-radius: 14px; border: 1px solid var(--line); background: var(--surface); box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5); }\n.sc-poline .po-tblwrap::-webkit-scrollbar { width: 10px; height: 10px; }\n.sc-poline .po-tblwrap::-webkit-scrollbar-track { background: transparent; }\n.sc-poline .po-tblwrap::-webkit-scrollbar-thumb { background: var(--color-gray-400, #3A3A44); border-radius: 999px; border: 2px solid var(--surface); }\n.sc-poline .po-tblwrap::-webkit-scrollbar-thumb:hover { background: var(--color-gray-500, #8A8A96); }\n.sc-poline table { width: 100%; border-collapse: separate; border-spacing: 0; font: 500 13px/1.4 inherit; }\n.sc-poline thead th { position: sticky; top: 0; z-index: 2; background: var(--surface); text-align: left; font: 700 11px/1.2 inherit; letter-spacing: .04em; text-transform: uppercase; color: var(--muted); padding: 12px 14px; border-bottom: 1px solid var(--line); white-space: nowrap; cursor: pointer; user-select: none; transition: color .15s ease, box-shadow .15s ease; }\n.sc-poline thead th.num { text-align: right; }\n.sc-poline thead th .th-label { vertical-align: middle; }\n.sc-poline thead th .th-arrow { margin-left: 6px; font-size: 11px; opacity: .4; vertical-align: middle; }\n.sc-poline thead th.num .th-arrow { margin-left: 4px; }\n.sc-poline thead th:hover { color: var(--ink); }\n.sc-poline thead th.is-sorted { color: var(--ink); box-shadow: inset 0 -2px 0 var(--accent); }\n.sc-poline thead th.is-sorted .th-arrow { opacity: 1; color: var(--accent); }\n.sc-poline thead th:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; border-radius: 4px; }\n.sc-poline tbody td { padding: 11px 14px; border-top: 1px solid var(--hair); color: var(--ink); white-space: nowrap; transition: background .15s ease; }\n.sc-poline tbody tr:first-child td { border-top: none; }\n.sc-poline tbody td:first-child { font-weight: 600; }\n.sc-poline tbody tr:hover td { background: var(--surface-raised); }\n.sc-poline td.num { text-align: right; font-variant-numeric: tabular-nums; }\n.sc-poline td.date { color: var(--muted); font-variant-numeric: tabular-nums; }\n.sc-poline td.empty { text-align: center; color: var(--muted); padding: 32px 14px; font-weight: 500; }\n.sc-poline .pill { display: inline-flex; align-items: center; gap: 7px; padding: 3px 10px; border-radius: 999px; font: 700 11px/1.5 inherit; letter-spacing: .02em; border: 1px solid var(--line); background: rgba(255,255,255,.03); color: var(--ink); white-space: nowrap; }\n.sc-poline .pill::before { content: \"\"; width: 7px; height: 7px; border-radius: 50%; background: var(--muted); flex: 0 0 auto; }\n.sc-poline .pill-ok { border-color: color-mix(in srgb, var(--color-success, #36D399) 40%, transparent); background: color-mix(in srgb, var(--color-success, #36D399) 12%, transparent); }\n.sc-poline .pill-ok::before { background: var(--color-success, #36D399); }\n.sc-poline .pill-open { border-color: color-mix(in srgb, var(--color-info, #34B9F3) 40%, transparent); background: color-mix(in srgb, var(--color-info, #34B9F3) 12%, transparent); }\n.sc-poline .pill-open::before { background: var(--color-info, #34B9F3); }\n.sc-poline .pill-bad { border-color: color-mix(in srgb, var(--color-danger, #FF5A6E) 40%, transparent); background: color-mix(in srgb, var(--color-danger, #FF5A6E) 12%, transparent); }\n.sc-poline .pill-bad::before { background: var(--color-danger, #FF5A6E); }\n@media (prefers-reduced-motion: reduce) {\n  .sc-poline thead th, .sc-poline tbody td { transition: none; }\n}\n@container (max-width: 680px) {\n  .sc-poline thead th, .sc-poline tbody td { padding: 9px 10px; }\n  .sc-poline table { font-size: 12px; }\n}"
