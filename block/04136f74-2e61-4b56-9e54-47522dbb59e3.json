).finally(function(){window.define=sd;});}\n  function loadECharts(){if(typeof echarts!=='undefined')return Promise.resolve();return loadScript(CONFIG.src);}\n  function mk(elId,R){var el=document.getElementById(elId);if(!el)return null;if(R.i){try{R.o&&R.o.disconnect();}catch(e){}try{R.i.dispose();}catch(e){}R.i=null;}var ex=echarts.getInstanceByDom(el);if(ex){try{ex.dispose();}catch(e){}}R.i=echarts.init(el);R.o=new ResizeObserver(function(){try{R.i.resize();}catch(e){}});R.o.observe(el);return R.i;}\n  function moneyBar(c,m,color){var data=Object.keys(m).map(function(k){return{name:k,value:m[k]};}).sort(function(a,b){return a.value-b.value;});var text=tv('--color-text','#2b2b2b');if(!data.length){c.clear();return;}c.setOption({grid:{left:6,right:56,top:8,bottom:4,containLabel:true},tooltip:{trigger:'axis',axisPointer:{type:'shadow'},valueFormatter:function(v){return D+Number(v).toLocaleString();}},xAxis:{type:'value',axisLabel:{color:text,fontSize:10,formatter:function(v){return v>=1e6?(v/1e6)+'M':Math.round(v/1e3)+'K';}},splitLine:{lineStyle:{color:text,opacity:.08}}},yAxis:{type:'category',data:data.map(function(d){return d.name;}),axisLabel:{color:text,fontSize:11,fontWeight:600},axisTick:{show:false},axisLine:{lineStyle:{color:text,opacity:.2}}},series:[{type:'bar',data:data.map(function(d){return d.value;}),itemStyle:{color:color,borderRadius:[0,4,4,0]},barWidth:'56%',label:{show:true,position:'right',color:text,fontSize:10,fontWeight:700,formatter:function(p){return D+(p.value>=1e6?(p.value/1e6).toFixed(2)+'M':Math.round(p.value/1e3)+'K');}}}]});}\n  function renderC1(){var c=mk(CONFIG.el1,R1);if(!c)return;var m={};rows().forEach(function(r){var k=r.sales_rep||'—';m[k]=(m[k]||0)+num(r.bookings_amount);});moneyBar(c,m,tv('--color-primary','#009fe4'));}\n  function renderC2(){var c=mk(CONFIG.el2,R2);if(!c)return;var m={};rows().forEach(function(r){var k=r.deal_stage||'—';m[k]=(m[k]||0)+num(r.pipeline_value);});moneyBar(c,m,'#7c5cff');}\n  function render(){if