    ".ind-combo{display:flex;flex-direction:column;gap:14px;height:100%;box-sizing:border-box;font-family:var(--font-stack-primary,system-ui,-apple-system,sans-serif);}\n.ind-combo .ind-charts{display:flex;flex-wrap:wrap;gap:14px;flex:1 1 46%;min-height:220px;box-sizing:border-box;}\n.ind-combo .ind-tbl-wrap{flex:1 1 54%;min-height:0;}\n.ind-charts .ind-card{flex:1 1 0;min-width:240px;background:#fff;border:1px solid rgba(0,0,0,.07);border-radius:12px;box-shadow:0 1px 3px rgba(16,24,40,.06);display:flex;flex-direction:column;padding:14px 16px 10px;}\n.ind-charts .ind-card-head{display:flex;align-items:baseline;justify-content:space-between;gap:8px;margin-bottom:4px;}\n.ind-charts .ind-card-head h3{margin:0;font-size:14px;font-weight:800;color:var(--color-text,#1f2937);}\n.ind-charts .ind-card-sub{font-size:11px;color:#9ca3af;font-weight:600;}\n.ind-charts .ind-canvas{flex:1 1 auto;min-height:180px;width:100%;}\n.ind-tbl-wrap{background:#fff;border:1px solid rgba(0,0,0,.07);border-radius:12px;box-shadow:0 1px 3px rgba(16,24,40,.06);box-sizing:border-box;display:flex;flex-direction:column;padding:14px 16px 10px;}\n.ind-tbl-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:8px;flex-wrap:wrap;}\n.ind-tbl-head h3{margin:0;font-size:14px;font-weight:800;color:var(--color-text,#1f2937);}\n.ind-tbl-head .ind-tbl-meta{display:flex;align-items:center;gap:10px;}\n.ind-tbl-count{font-size:11px;color:#9ca3af;font-weight:600;}\n.ind-tbl-search{padding:7px 10px;border:1px solid rgba(0,0,0,.15);border-radius:8px;font-size:12px;min-width:170px;font-family:inherit;}\n.ind-tbl-search:focus{outline:none;border-color:var(--color-primary,#009fe4);box-shadow:0 0 0 3px rgba(0,159,228,.15);}\n.ind-tbl-scroll{flex:1 1 auto;overflow:auto;border-radius:8px;}\ntable.ind-tbl{width:100%;border-collapse:collapse;font-size:12.5px;}\n.ind-tbl thead th{position:sticky;top:0;background:#f8fafc;color:#475569;text-align:left;font-weight:700;font-size:11px;letter-s