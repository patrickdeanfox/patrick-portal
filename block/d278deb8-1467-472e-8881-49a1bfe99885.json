{
  "name": "RT · Chart Open AR by Segment",
  "type": "html",
  "css": [
    ".wrapper {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,.07));\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n}\n.wrapper .rt-openar-seg.chart-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  box-sizing: border-box;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n}\n.wrapper .rt-openar-seg__head {\n  margin: 0 0 12px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid rgba(255,255,255,.05);\n}\n.wrapper .rt-openar-seg__eyebrow {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  margin: 0 0 6px;\n  font: 700 11px/1 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--color-gray-700, #C2C2CC);\n}\n.wrapper .rt-openar-seg__eyebrow::before {\n  content: \"\";\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--accent);\n}\n.wrapper .rt-openar-seg__head h3 {\n  margin: 0;\n  font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--ink);\n}\n.wrapper .rt-openar-seg__head .sub {\n  margin: 3px 0 0;\n  font: 500 11px/1.3 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--muted);\n}\n.wrapper .rt-openar-seg__canvas {\n  flex: 1 1 auto;\n  width: 100%;\n  min-height: 220px;\n}",
    "/* ---------- Responsive (container-query driven; block sizes to its own grid cell, not the viewport) ---------- */\n.wrapper .rt-openar-seg.chart-card {\n  min-width: 0;\n  max-width: 100%;\n}\n.wrapper .rt-openar-seg__eyebrow {\n  flex-wrap: wrap;\n  max-width: 100%;\n}\n.wrapper .rt-openar-seg__head h3,\n.wrapper .rt-openar-seg__head .sub {\n  overflow-wrap: anywhere;\n}\n.wrapper .rt-openar-seg__canvas {\n  min-width: 0;\n}\n/* Stacked-narrow (chart pair collapses at the page level): keep the plot tall enough to render */\n@container (max-width: 720px) {\n  .wrapper .rt-openar-seg__canvas { min-height: 220px; }\n}\n/* Narrow cell: tighten padding so the plot keeps room; type stays on scale */\n@container (max-width: 480px) {\n  .wrapper .rt-openar-seg.chart-card { padding: 13px; }\n  .wrapper .rt-openar-seg__head { margin: 0 0 10px; padding-bottom: 10px; }\n}\n/* Very narrow cell: relax the wide eyebrow tracking and trim padding so nothing overflows */\n@container (max-width: 340px) {\n  .wrapper .rt-openar-seg.chart-card { padding: 11px; }\n  .wrapper .rt-openar-seg__eyebrow { letter-spacing: .08em; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper\">\n  <div class=\"rt-openar-seg chart-card\">\n    <div class=\"rt-openar-seg__head\">\n      <span class=\"rt-openar-seg__eyebrow\">Receivables</span>\n      <h3>Open AR by Segment</h3>\n      <p class=\"sub\">Total outstanding receivables &middot; USD</p>\n    </div>\n    <div id=\"rtOpenArSeg-canvas\" class=\"rt-openar-seg__canvas\" role=\"img\" aria-label=\"Bar chart of open accounts receivable by customer segment\" aria-live=\"polite\"></div>\n  </div>\n  <script>\n  (function () {\n      'use strict';\n\n      /* ---------- top-level config ---------- */\n      const DEBUG = false;\n      const log = (...args) => { if (DEBUG && window.console) console.log('[RT Open AR by Segment]', ...args); };\n      const warn = (...args) => { if (DEBUG && window.console) console.warn('[RT Open AR by Segment]', ...args); };\n\n      const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n      const QUERY_INDEX = { customer360: 0 };\n      const COL_SEGMENT = 'customer_segment';\n      const COL_OPEN_AR = 'open_ar';\n      const CHART_EL_ID = 'rtOpenArSeg-canvas';\n      const PRIMARY_DS_ID = '8e9b7e82-7b1a-4b42-ba11-4b613909c864';\n      const HANDLER_KEY = '__rtOpenArSegLoadHandler';\n      const AXIS_LINE = 'rgba(255,255,255,.18)';\n      const SPLIT_LINE = 'rgba(255,255,255,.06)';\n      const AXIS_LABEL = '#C2C2CC';\n\n      /* ---------- module state ---------- */\n      let onLoaded = null;\n      try { onLoaded = currentBlock.getOnLoadedCallback(); } catch (e) { warn('no onLoaded callback', e); }\n      let resizeObserver = null;\n\n      /* ---------- pure helpers ---------- */\n      const cssVar = (rootEl, name, fallback) => {\n          try {\n              const v = getComputedStyle(rootEl).getPropertyValue(name).trim();\n              return v || fallback;\n          } catch (e) {\n              return fallback;\n          }\n      };\n\n      const fmtCurrency = (value) => Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n      const fmtCompact = (value) => Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n      const getQueryData = (index) => {\n          const r = currentBlock.queryResults[index];\n          const rows = (r && r.data) ? r.data.map(d => Object.fromEntries(r.columns.map((c, k) => [c, d[k]]))) : [];\n          return rows;\n      };\n\n      const aggregateOpenArBySegment = (rows) => {\n          const totals = new Map();\n          rows.forEach(row => {\n              const segment = (row[COL_SEGMENT] === null || row[COL_SEGMENT] === undefined || row[COL_SEGMENT] === '') ? 'Unknown' : String(row[COL_SEGMENT]);\n              const amount = Number(row[COL_OPEN_AR]) || 0;\n              totals.set(segment, (totals.get(segment) || 0) + amount);\n          });\n          return Array.from(totals, ([segment, total]) => ({ segment, total }))\n              .sort((a, b) => a.total - b.total);\n      };\n\n      const buildOption = (segments) => {\n          const rootEl = document.getElementById(CHART_EL_ID).closest('.wrapper') || document.getElementById(CHART_EL_ID);\n          const ink = cssVar(rootEl, '--color-text', '#F4F4F7');\n          const amber = cssVar(rootEl, '--color-warning', '#F6C453');\n          const danger = cssVar(rootEl, '--color-danger', '#FF5A6E');\n          const barColor = new echarts.graphic.LinearGradient(0, 0, 1, 0, [\n              { offset: 0, color: amber },\n              { offset: 1, color: danger }\n          ]);\n          return {\n              backgroundColor: 'transparent',\n              animationDuration: 480,\n              grid: { left: 6, right: 70, top: 10, bottom: 6, containLabel: true },\n              tooltip: {\n                  trigger: 'axis',\n                  axisPointer: { type: 'shadow' },\n                  backgroundColor: '#1B1B22',\n                  borderColor: 'rgba(255,255,255,.12)',\n                  borderWidth: 1,\n                  textStyle: { color: ink, fontSize: 12 },\n                  formatter: (params) => {\n                      const p = Array.isArray(params) ? params[0] : params;\n                      return p.name + '<br/><strong>' + fmtCurrency(p.value) + '</strong> open AR';\n                  }\n              },\n              xAxis: {\n                  type: 'value',\n                  axisLine: { lineStyle: { color: AXIS_LINE } },\n                  axisTick: { show: false },\n                  splitLine: { lineStyle: { color: SPLIT_LINE } },\n                  axisLabel: { color: AXIS_LABEL, fontSize: 11, formatter: (v) => fmtCompact(v) }\n              },\n              yAxis: {\n                  type: 'category',\n                  data: segments.map(s => s.segment),\n                  axisLine: { lineStyle: { color: AXIS_LINE } },\n                  axisTick: { show: false },\n                  axisLabel: { color: AXIS_LABEL, fontSize: 12 }\n              },\n              series: [{\n                  name: 'Open AR',\n                  type: 'bar',\n                  data: segments.map(s => s.total),\n                  barWidth: '58%',\n                  itemStyle: { color: barColor, borderRadius: [0, 4, 4, 0] },\n                  label: {\n                      show: true,\n                      position: 'right',\n                      color: ink,\n                      fontSize: 11,\n                      fontWeight: 600,\n                      formatter: (p) => fmtCurrency(p.value)\n                  }\n              }]\n          };\n      };\n\n      /* ---------- side-effecting render ---------- */\n      const renderChart = () => {\n          const el = document.getElementById(CHART_EL_ID);\n          if (!el || !window.echarts) { warn('chart element or echarts missing'); return; }\n\n          const existing = echarts.getInstanceByDom(el);\n          if (existing) existing.dispose();\n          if (resizeObserver) { resizeObserver.disconnect(); resizeObserver = null; }\n\n          const chart = echarts.init(el, null, { renderer: 'canvas' });\n          const rows = getQueryData(QUERY_INDEX.customer360);\n          const segments = aggregateOpenArBySegment(rows);\n          log('rows', rows.length, 'segments', segments.length);\n\n          if (!segments.length) {\n              chart.setOption({\n                  backgroundColor: 'transparent',\n                  graphic: { type: 'text', left: 'center', top: 'middle', style: { text: 'No open AR data', fill: '#8A8A96', font: '600 13px Inter, system-ui, sans-serif' } }\n              });\n          } else {\n              chart.setOption(buildOption(segments));\n          }\n\n          if (window.ResizeObserver) {\n              resizeObserver = new ResizeObserver(() => { const c = echarts.getInstanceByDom(el); if (c) c.resize(); });\n              resizeObserver.observe(el);\n          }\n      };\n\n      const wireFilterSubscription = () => {\n          try {\n              if (!window.zPortal || !zPortal.dataSource) return;\n              if (window[HANDLER_KEY] && zPortal.dataSource.off) {\n                  zPortal.dataSource.off('load', PRIMARY_DS_ID, window[HANDLER_KEY]);\n              }\n              if (zPortal.dataSource.on) {\n                  const handler = () => { log('datasource load -> redraw'); renderChart(); };\n                  window[HANDLER_KEY] = handler;\n                  zPortal.dataSource.on('load', PRIMARY_DS_ID, handler);\n              }\n          } catch (e) {\n              warn('filter subscription failed', e);\n          }\n      };\n\n      /* ---------- orchestration ---------- */\n      const init = () => {\n          const start = () => {\n              try {\n                  renderChart();\n                  wireFilterSubscription();\n              } catch (e) {\n                  warn('render error', e);\n              } finally {\n                  if (typeof onLoaded === 'function') { onLoaded(); onLoaded = null; }\n              }\n          };\n          if (window.echarts) {\n              start();\n          } else {\n              zPortal.resources.load(ECHARTS_URL).then(start).catch((e) => {\n                  warn('echarts load failed', e);\n                  if (typeof onLoaded === 'function') { onLoaded(); onLoaded = null; }\n              });\n          }\n      };\n\n      init();\n  })();\n  </script>\n</div>"
  },
