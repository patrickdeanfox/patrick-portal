    "html": [
      "<div class=\"ind-kpis\">\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Total Shipments</span></div><div class=\"ind-kpi-val\" id=\"k-ship\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Avg On-Time</span></div><div class=\"ind-kpi-val\" id=\"k-ontime\">—</div><div class=\"ind-kpi-sub\">weighted by shipments</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Avg Transit</span></div><div class=\"ind-kpi-val\" id=\"k-transit\">—</div><div class=\"ind-kpi-sub\">days, weighted</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Freight Cost</span></div><div class=\"ind-kpi-val\" id=\"k-freight\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Cost / Shipment</span></div><div class=\"ind-kpi-val\" id=\"k-cps\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Carriers</span></div><div class=\"ind-kpi-val\" id=\"k-carriers\">—</div><div class=\"ind-kpi-sub\">in view</div></div>\n</div>\n<script>(function(){\n  var DS_ID=\"9e8e01cf-0ab1-4984-9023-fd811810f062\";\n  var D=String.fromCharCode(36);\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function fmtInt(n){return Math.round(n).toLocaleString();}\n  function fmtMoney(n){if(n>=1e6)return D+(n/1e6).toFixed(2)+'M';if(n>=1e3)return D+Math.round(n/1e3)+'K';return D+fmtInt(n);}\n  function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}\n  function render(){var d=rows();var ship=0,otw=0,trw=0,fr=0,car={};d.forEach(function(r){var s=num(r.shipments);ship+=s;otw+=num(r.on_time_pct)*s;trw+=num(r.avg_transit_days)*s;fr+=num(r.freight_cost);if(r.carrier)car[r.carrier]=1;});set('k-ship',fmtInt(ship));set('k-ontime',(ship?(otw/ship):0).toFixed(1)+'%');set('k-transit',(ship?(trw/ship):0).toFixed(1)+' d');set('k-freight',fmtMoney(fr));set('k-cps',fmtMoney(ship?(fr/ship):0));set('k-carriers',Object.keys(car).length);}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{render();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,render);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
