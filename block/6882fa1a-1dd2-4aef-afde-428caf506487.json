    ".ind-kpis{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;height:100%;box-sizing:border-box;font-family:var(--font-stack-primary,system-ui,-apple-system,sans-serif);}\n.ind-kpis .ind-kpi{background:#fff;border:1px solid rgba(0,0,0,.07);border-radius:12px;box-shadow:0 1px 3px rgba(16,24,40,.06);padding:14px 16px;display:flex;flex-direction:column;justify-content:center;gap:6px;min-width:0;}\n.ind-kpis .ind-kpi-top{display:flex;align-items:center;gap:8px;}\n.ind-kpis .ind-kpi-dot{width:8px;height:8px;border-radius:50%;background:var(--color-primary,#009fe4);flex:0 0 auto;}\n.ind-kpis .ind-kpi-label{font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;color:#6b7280;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}\n.ind-kpis .ind-kpi-val{font-size:26px;font-weight:800;color:var(--color-text,#1f2937);line-height:1;letter-spacing:-.01em;}\n.ind-kpis .ind-kpi-sub{font-size:11px;color:#9ca3af;font-weight:600;}\n@media(max-width:1100px){.ind-kpis{grid-template-columns:repeat(3,1fr);}}\n@media(max-width:640px){.ind-kpis{grid-template-columns:repeat(2,1fr);}}"
