      "<div class=\"ind-kpis\">\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Total Alerts</span></div><div class=\"ind-kpi-val\" id=\"k-alerts\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Availability</span></div><div class=\"ind-kpi-val\" id=\"k-avail\">—</div><div class=\"ind-kpi-sub\">uptime / total</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Downtime</span></div><div class=\"ind-kpi-val\" id=\"k-downtime\">—</div><div class=\"ind-kpi-sub\">hours</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Uptime</span></div><div class=\"ind-kpi-val\" id=\"k-uptimeh\">—</div><div class=\"ind-kpi-sub\">hours</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Facilities</span></div><div class=\"ind-kpi-val\" id=\"k-fac\">—</div><div class=\"ind-kpi-sub\">in view</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Equipment Types</span></div><div class=\"ind-kpi-val\" id=\"k-equip\">—</div><div class=\"ind-kpi-sub\">in view</div></div>\n</div>\n<script>(function(){\n  var DS_ID=\"496fad86-25e2-4483-b971-a82702cb714c\";\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function fmtInt(n){return Math.round(n).toLocaleString();}\n  function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}\n  function render(){var d=rows();var al=0,up=0,dn=0,fac={},eq={};d.forEach(function(r){al+=num(r.alerts);up+=num(r.uptime_minutes);dn+=num(r.downtime_minutes);if(r.facility)fac[r.facility]=1;if(r.equipment_type)eq[r.equipment_type]=1;});set('k-alerts',fmtInt(al));set('k-avail',((up+dn)?(up/(up+dn)*100):0).toFixed(1)+'%');set('k-downtime',(dn/60).toFixed(1)+' h');set('k-uptimeh',fmtInt(up/60)+' h');set('k-fac',Object.keys(fac).length);set('k-equip',Object.keys(eq).length);}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{render();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,render);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
