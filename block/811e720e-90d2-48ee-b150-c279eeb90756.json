    ".ind-charts{display:flex;flex-wrap:wrap;gap:14px;height:100%;box-sizing:border-box;font-family:var(--font-stack-primary,system-ui,-apple-system,sans-serif);}\n.ind-charts .ind-card{flex:1 1 0;min-width:240px;background:#fff;border:1px solid rgba(0,0,0,.07);border-radius:12px;box-shadow:0 1px 3px rgba(16,24,40,.06);display:flex;flex-direction:column;padding:14px 16px 10px;}\n.ind-charts .ind-card-head{display:flex;align-items:baseline;justify-content:space-between;gap:8px;margin-bottom:4px;}\n.ind-charts .ind-card-head h3{margin:0;font-size:14px;font-weight:800;color:var(--color-text,#1f2937);}\n.ind-charts .ind-card-sub{font-size:11px;color:#9ca3af;font-weight:600;}\n.ind-charts .ind-canvas{flex:1 1 auto;min-height:200px;width:100%;}"
