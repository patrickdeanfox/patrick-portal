{
  "name": "SC · Chart Supplier Risk",
  "type": "html",
  "css": [
    ".sc-risk-wrapper {\n  --sc-surface: var(--block-bg-color, #15151A);\n  --sc-ink: var(--color-text, #F4F4F7);\n  --sc-muted: var(--color-gray-500, #8A8A96);\n  --sc-line: var(--color-gray-200, rgba(255,255,255,.07));\n  --sc-accent: var(--color-primary, #FFD21E);\n  container-type: inline-size;\n  width: 100%;\n  height: 100%;\n  box-sizing: border-box;\n  color: var(--sc-ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.sc-risk-wrapper .sc-risk-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-height: 300px;\n  box-sizing: border-box;\n  background: var(--sc-surface);\n  border: 1px solid var(--sc-line);\n  border-radius: 14px;\n  padding: 14px 16px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n}\n.sc-risk-wrapper .sc-risk-head { margin-bottom: 8px; }\n.sc-risk-wrapper .sc-risk-title {\n  margin: 0;\n  font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--sc-ink);\n}\n.sc-risk-wrapper .sc-risk-sub {\n  margin: 2px 0 0;\n  font: 500 11px/1.3 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--sc-muted);\n}\n.sc-risk-wrapper .sc-risk-canvas {\n  flex: 1 1 auto;\n  width: 100%;\n  min-height: 240px;\n}\n.sc-risk-wrapper .sc-risk-empty {\n  flex: 1 1 auto;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin: 0;\n  color: var(--sc-muted);\n  font: 600 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n}\n.sc-risk-wrapper .sc-risk-empty[hidden] { display: none; }"
  ],
  "json_data": {
    "isolated": false,
    "html": "<div class=\"wrapper sc-risk-wrapper\">\n  <div class=\"sc-risk-card\">\n    <div class=\"sc-risk-head\">\n      <h3 class=\"sc-risk-title\">Supplier Risk Matrix</h3>\n      <p class=\"sc-risk-sub\">Lead time vs. quality &middot; bubble size = total spend &middot; color = country</p>\n    </div>\n    <div id=\"sc-risk-chart\" class=\"sc-risk-canvas\" role=\"img\" aria-label=\"Scatter plot of supplier lead time versus quality rating, bubble size by total spend, color by country\"></div>\n    <p id=\"sc-risk-empty\" class=\"sc-risk-empty\" hidden>No supplier data available.</p>\n  </div>\n  <script>\n  (function () {\n      'use strict';\n\n      // ---- Top-level config ---------------------------------------------\n      const DEBUG = false;\n      const log = (...args) => { if (DEBUG) console.log('[SC Chart Supplier Risk]', ...args); };\n      const warn = (...args) => { if (DEBUG) console.warn('[SC Chart Supplier Risk]', ...args); };\n      const err = (...args) => { if (DEBUG) console.error('[SC Chart Supplier Risk]', ...args); };\n\n      const QUERY_INDEX = { SUPPLIER_RISK: 0 };\n      const COL = {\n          SUPPLIER: 'supplier_name',\n          COUNTRY: 'country',\n          QUALITY: 'quality_rating',\n          LEAD: 'lead_time_days',\n          SPEND: 'total_spend'\n      };\n\n      const SUPPLIER_DS_ID = '4c75d296-0c69-4fdd-9623-e79ff1c066fb';\n      const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n      const PALETTE = ['#FFD21E', '#FF3D8B', '#34B9F3', '#36D399', '#A78BFA', '#FF9F45', '#2DD4BF'];\n\n      const SYMBOL_MIN = 9;\n      const SYMBOL_MAX = 42;\n      const AXIS_LINE = 'rgba(255,255,255,.18)';\n      const SPLIT_LINE = 'rgba(255,255,255,.06)';\n      const LABEL_INK = '#C2C2CC';\n      const MUTED = '#8A8A96';\n      const TOOLTIP_BG = '#1B1B22';\n      const FONT_STACK = \"'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif\";\n\n      const WRAP_SEL = '.sc-risk-wrapper';\n      const CHART_ID = 'sc-risk-chart';\n      const EMPTY_ID = 'sc-risk-empty';\n\n      // persistent stash across script re-runs (a filter reload re-runs this IIFE)\n      const STASH_KEY = '__scRiskState__';\n      window[STASH_KEY] = window[STASH_KEY] || { onLoadHandler: null, resizeObs: null };\n      const state = window[STASH_KEY];\n\n      // ---- Pure helpers -------------------------------------------------\n      function getQueryData(index) {\n          const q = currentBlock.queryResults[index];\n          if (!q || !q.data) return [];\n          return q.mappedData || q.data.map((row) => Object.fromEntries(q.columns.map((c, i) => [c, row[i]])));\n      }\n\n      function toNumber(value) {\n          const n = typeof value === 'number' ? value : parseFloat(value);\n          return Number.isFinite(n) ? n : null;\n      }\n\n      function median(values) {\n          const sorted = values.filter((v) => Number.isFinite(v)).sort((a, b) => a - b);\n          if (!sorted.length) return null;\n          const mid = Math.floor(sorted.length / 2);\n          return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;\n      }\n\n      function formatMoney(value) {\n          const n = toNumber(value);\n          if (n === null) return String.fromCharCode(8212);\n          return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n      }\n\n      function buildPoints(rows) {\n          // each point: [leadTime, qualityRating, totalSpend, supplierName, country]\n          const points = [];\n          rows.forEach((r) => {\n              const lead = toNumber(r[COL.LEAD]);\n              const quality = toNumber(r[COL.QUALITY]);\n              const spend = toNumber(r[COL.SPEND]);\n              if (lead === null || quality === null) return;\n              points.push([lead, quality, spend === null ? 0 : spend, r[COL.SUPPLIER] || 'Unknown', r[COL.COUNTRY] || 'Unknown']);\n          });\n          return points;\n      }\n\n      function colorForCountries(countries) {\n          const map = {};\n          countries.forEach((country, i) => { map[country] = PALETTE[i % PALETTE.length]; });\n          return map;\n      }\n\n      function makeSizeScaler(points) {\n          const spends = points.map((p) => p[2]).filter((v) => v > 0);\n          const min = spends.length ? Math.min.apply(null, spends) : 0;\n          const max = spends.length ? Math.max.apply(null, spends) : 0;\n          const sqMin = Math.sqrt(min);\n          const sqMax = Math.sqrt(max);\n          return function (spend) {\n              if (!(spend > 0) || sqMax === sqMin) return SYMBOL_MIN;\n              const t = (Math.sqrt(spend) - sqMin) / (sqMax - sqMin);\n              return SYMBOL_MIN + t * (SYMBOL_MAX - SYMBOL_MIN);\n          };\n      }\n\n      function buildChartOption(points) {\n          const countries = Array.from(new Set(points.map((p) => p[4]))).sort();\n          const colorMap = colorForCountries(countries);\n          const scaleSize = makeSizeScaler(points);\n          const medianLead = median(points.map((p) => p[0]));\n          const medianQuality = median(points.map((p) => p[1]));\n\n          const series = countries.map((country) => ({\n              name: country,\n              type: 'scatter',\n              data: points.filter((p) => p[4] === country),\n              symbolSize: (val) => scaleSize(val[2]),\n              itemStyle: {\n                  color: colorMap[country],\n                  opacity: 0.82,\n                  borderColor: 'rgba(11,11,13,.55)',\n                  borderWidth: 1\n              },\n              emphasis: { focus: 'series', itemStyle: { opacity: 1, borderColor: '#0B0B0D', borderWidth: 1.5 } }\n          }));\n\n          // quadrant median lines on a dedicated, legend-excluded series so toggling a country keeps them\n          if (medianLead !== null || medianQuality !== null) {\n              const markLineData = [];\n              if (medianLead !== null) markLineData.push({ xAxis: medianLead, name: 'Median lead ' + Math.round(medianLead) + 'd' });\n              if (medianQuality !== null) markLineData.push({ yAxis: medianQuality, name: 'Median quality ' + medianQuality.toFixed(2) });\n              series.push({\n                  name: '__median__',\n                  type: 'scatter',\n                  data: [],\n                  silent: true,\n                  markLine: {\n                      silent: true,\n                      symbol: 'none',\n                      lineStyle: { color: 'rgba(255,255,255,.30)', type: 'dashed', width: 1 },\n                      label: { show: true, color: MUTED, fontSize: 10, formatter: (p) => p.name },\n                      data: markLineData\n                  }\n              });\n          }\n\n          return {\n              backgroundColor: 'transparent',\n              textStyle: { fontFamily: FONT_STACK },\n              grid: { left: 50, right: 24, top: 16, bottom: 72, containLabel: true },\n              legend: {\n                  data: countries,\n                  bottom: 4,\n                  icon: 'circle',\n                  itemWidth: 9,\n                  itemHeight: 9,\n                  textStyle: { color: LABEL_INK, fontSize: 11 },\n                  inactiveColor: 'rgba(255,255,255,.25)'\n              },\n              tooltip: {\n                  trigger: 'item',\n                  backgroundColor: TOOLTIP_BG,\n                  borderColor: 'rgba(255,255,255,.10)',\n                  borderWidth: 1,\n                  textStyle: { color: '#F4F4F7', fontSize: 12 },\n                  formatter: (p) => {\n                      const d = p.data;\n                      return [\n                          '<strong>' + d[3] + '</strong>',\n                          '<span style=\"color:' + MUTED + '\">' + d[4] + '</span>',\n                          'Lead time: ' + d[0] + ' days',\n                          'Quality: ' + Number(d[1]).toFixed(2),\n                          'Spend: ' + formatMoney(d[2])\n                      ].join('<br/>');\n                  }\n              },\n              xAxis: {\n                  type: 'value',\n                  name: 'Lead time (days)',\n                  nameLocation: 'middle',\n                  nameGap: 30,\n                  nameTextStyle: { color: MUTED, fontSize: 11 },\n                  min: 0,\n                  axisLine: { lineStyle: { color: AXIS_LINE } },\n                  axisTick: { show: false },\n                  axisLabel: { color: LABEL_INK, fontSize: 10 },\n                  splitLine: { lineStyle: { color: SPLIT_LINE } }\n              },\n              yAxis: {\n                  type: 'value',\n                  name: 'Quality rating',\n                  nameLocation: 'middle',\n                  nameGap: 36,\n                  nameTextStyle: { color: MUTED, fontSize: 11 },\n                  min: (v) => Math.max(0, Math.floor((v.min - 0.2) * 2) / 2),\n                  max: 5,\n                  axisLine: { lineStyle: { color: AXIS_LINE } },\n                  axisTick: { show: false },\n                  axisLabel: { color: LABEL_INK, fontSize: 10 },\n                  splitLine: { lineStyle: { color: SPLIT_LINE } }\n              },\n              series: series\n          };\n      }\n\n      // ---- Side-effecting render ----------------------------------------\n      function disposeChart(el) {\n          if (window.echarts) {\n              const existing = window.echarts.getInstanceByDom(el);\n              if (existing) existing.dispose();\n          }\n      }\n\n      function renderChart(el, emptyEl, points) {\n          disposeChart(el);\n          if (!points.length) {\n              if (emptyEl) emptyEl.hidden = false;\n              return;\n          }\n          if (emptyEl) emptyEl.hidden = true;\n          const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n          chart.setOption(buildChartOption(points));\n      }\n\n      function attachResize(el) {\n          if (state.resizeObs) {\n              state.resizeObs.disconnect();\n              state.resizeObs = null;\n          }\n          if (typeof ResizeObserver === 'function') {\n              const obs = new ResizeObserver(() => {\n                  const chart = window.echarts && window.echarts.getInstanceByDom(el);\n                  if (chart) chart.resize();\n              });\n              obs.observe(el);\n              state.resizeObs = obs;\n          }\n      }\n\n      function subscribeToFilters(renderNow) {\n          if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') return;\n          if (state.onLoadHandler && typeof zPortal.dataSource.off === 'function') {\n              zPortal.dataSource.off('load', SUPPLIER_DS_ID, state.onLoadHandler);\n          }\n          const handler = () => { log('datasource reload - redraw'); renderNow(); };\n          zPortal.dataSource.on('load', SUPPLIER_DS_ID, handler);\n          state.onLoadHandler = handler;\n      }\n\n      // ---- Orchestrator -------------------------------------------------\n      async function init() {\n          let onLoaded = null;\n          let loadedFired = false;\n          try {\n              onLoaded = currentBlock.getOnLoadedCallback ? currentBlock.getOnLoadedCallback() : null;\n          } catch (e) {\n              onLoaded = null;\n          }\n\n          const root = document.querySelector(WRAP_SEL);\n          const el = root ? root.querySelector('#' + CHART_ID) : null;\n          const emptyEl = root ? root.querySelector('#' + EMPTY_ID) : null;\n\n          try {\n              if (!el) { warn('chart container not found'); return; }\n              if (!window.echarts) {\n                  await zPortal.resources.load(ECHARTS_URL);\n              }\n              const renderNow = () => {\n                  const rows = getQueryData(QUERY_INDEX.SUPPLIER_RISK);\n                  log('rows', rows.length);\n                  renderChart(el, emptyEl, buildPoints(rows));\n              };\n              renderNow();\n              attachResize(el);\n              subscribeToFilters(renderNow);\n          } catch (e) {\n              err('init failed', e);\n          } finally {\n              if (onLoaded && !loadedFired) {\n                  loadedFired = true;\n                  onLoaded();\n              }\n          }\n      }\n\n      init();\n  })();\n  </script>\n</div>"
  },
