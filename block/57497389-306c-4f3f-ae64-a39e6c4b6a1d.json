{
  "name": "SC · Chart Spend by Country",
  "type": "html",
  "css": [
    ".wrapper .chart-card-sc {\n    --surface: var(--block-bg-color, #15151A);\n    --surface-raised: #1B1B22;\n    --ink: var(--color-text, #F4F4F7);\n    --muted: var(--color-gray-500, #8A8A96);\n    --line: var(--color-gray-200, rgba(255,255,255,.07));\n    --accent: var(--color-primary, #FFD21E);\n    --accent-2: var(--color-secondary, #FF3D8B);\n\n    display: flex;\n    flex-direction: column;\n    height: 100%;\n    box-sizing: border-box;\n    container-type: inline-size;\n    background: var(--surface);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    padding: 16px 18px;\n    color: var(--ink);\n    font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n    font-variant-numeric: tabular-nums;\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n    transition: border-color .16s ease, box-shadow .16s ease;\n}\n.wrapper .chart-card-sc:hover {\n    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 8px 22px rgba(0,0,0,.55), 0 0 22px -12px color-mix(in srgb, var(--accent) 45%, transparent);\n}\n.wrapper .head-sc {\n    display: flex;\n    flex-direction: column;\n    gap: 3px;\n    margin-bottom: 12px;\n}\n.wrapper .title-sc {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin: 0;\n    font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n    color: var(--ink);\n    letter-spacing: -.01em;\n}\n.wrapper .title-sc::before {\n    content: \"\";\n    flex: 0 0 auto;\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: var(--accent);\n}\n.wrapper .sub-sc {\n    margin: 0;\n    padding-left: 15px;\n    font: 500 11px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n    color: var(--muted);\n}\n.wrapper .canvas-sc {\n    flex: 1 1 auto;\n    width: 100%;\n    min-height: 240px;\n}\n.wrapper .empty-sc {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    height: 100%;\n    min-height: 200px;\n    color: var(--muted);\n    font: 500 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n}\n@container (max-width: 420px) {\n    .wrapper .chart-card-sc { padding: 12px 14px; }\n    .wrapper .head-sc { margin-bottom: 10px; }\n    .wrapper .canvas-sc { min-height: 200px; }\n}\n@media (prefers-reduced-motion: reduce) {\n    .wrapper .chart-card-sc { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper sc-spend-country\">\n  <div class=\"chart-card-sc\">\n    <div class=\"head-sc\">\n      <h3 class=\"title-sc\">Spend by Country</h3>\n      <div class=\"sub-sc\">Total procurement spend (USD) &middot; click a bar to filter</div>\n    </div>\n    <div id=\"sc-spend-country-canvas\" class=\"canvas-sc\" role=\"img\" aria-label=\"Bar chart of total procurement spend by supplier country\"></div>\n  </div>\n  <script>\n  (function () {\n      'use strict';\n\n      /* ---------- top-level config ---------- */\n      const DEBUG = false;\n      const log = (...args) => { if (DEBUG) console.log('[SC Chart Spend by Country]', ...args); };\n      const warn = (...args) => { if (DEBUG) console.warn('[SC Chart Spend by Country]', ...args); };\n      const fail = (...args) => { if (DEBUG) console.error('[SC Chart Spend by Country]', ...args); };\n\n      const QUERY_INDEX = { spend: 0 };\n      const COL_COUNTRY = 'country';\n      const COL_SPEND = 'total_spend';\n      const FILTER_COL = 'supplier_country';\n      const CANVAS_ID = 'sc-spend-country-canvas';\n      const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n      const PALETTE = {\n          accent: '#FFD21E',\n          accent2: '#FF3D8B',\n          ink: '#F4F4F7',\n          muted: '#C2C2CC',\n          axisLine: 'rgba(255,255,255,.18)',\n          splitLine: 'rgba(255,255,255,.06)',\n          tooltipBg: '#1B1B22'\n      };\n\n      /* ---------- formatters ---------- */\n      const usd = (value) => Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n      const usdCompact = (value) => Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n      /* ---------- pure helpers ---------- */\n      const getQueryData = (index) => {\n          const q = currentBlock.queryResults[index];\n          if (!q || !q.data) return [];\n          return q.mappedData || q.data.map((row) => Object.fromEntries(q.columns.map((col, i) => [col, row[i]])));\n      };\n\n      const readToken = (el, name, fallback) => {\n          try {\n              const value = getComputedStyle(el).getPropertyValue(name);\n              return value && value.trim() ? value.trim() : fallback;\n          } catch (err) {\n              return fallback;\n          }\n      };\n\n      const spendByCountry = (rows) => {\n          const totals = new Map();\n          rows.forEach((row) => {\n              const country = row[COL_COUNTRY];\n              if (country === null || country === undefined || country === '') return;\n              const spend = Number(row[COL_SPEND]) || 0;\n              totals.set(country, (totals.get(country) || 0) + spend);\n          });\n          return Array.from(totals, ([country, spend]) => ({ country, spend }))\n              .sort((a, b) => b.spend - a.spend);\n      };\n\n      /* ---------- render ---------- */\n      const renderChart = (el, series) => {\n          const existing = window.echarts.getInstanceByDom(el);\n          if (existing) existing.dispose();\n          if (el._scResize) { el._scResize.disconnect(); el._scResize = null; }\n          el.innerHTML = '';\n\n          const accent = readToken(el, '--color-primary', PALETTE.accent);\n          const accent2 = readToken(el, '--color-secondary', PALETTE.accent2);\n          const ink = readToken(el, '--color-text', PALETTE.ink);\n          const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n\n          chart.setOption({\n              backgroundColor: 'transparent',\n              grid: { left: 8, right: 18, top: 26, bottom: 6, containLabel: true },\n              tooltip: {\n                  trigger: 'axis',\n                  axisPointer: { type: 'shadow' },\n                  backgroundColor: PALETTE.tooltipBg,\n                  borderColor: 'rgba(255,255,255,.12)',\n                  borderWidth: 1,\n                  textStyle: { color: ink, fontSize: 12 },\n                  formatter: (params) => {\n                      const p = params && params[0];\n                      if (!p) return '';\n                      return p.name + '<br/><strong>' + usd(p.value) + '</strong>';\n                  }\n              },\n              xAxis: {\n                  type: 'category',\n                  data: series.map((d) => d.country),\n                  axisLine: { lineStyle: { color: PALETTE.axisLine } },\n                  axisTick: { show: false },\n                  axisLabel: { color: PALETTE.muted, fontSize: 11 }\n              },\n              yAxis: {\n                  type: 'value',\n                  axisLine: { show: false },\n                  axisTick: { show: false },\n                  splitLine: { lineStyle: { color: PALETTE.splitLine } },\n                  axisLabel: { color: PALETTE.muted, fontSize: 10, formatter: (v) => usdCompact(v) }\n              },\n              series: [{\n                  type: 'bar',\n                  data: series.map((d) => d.spend),\n                  barMaxWidth: 56,\n                  itemStyle: { color: accent, borderRadius: [4, 4, 0, 0] },\n                  emphasis: { itemStyle: { color: accent2 } },\n                  cursor: 'pointer',\n                  label: { show: true, position: 'top', color: ink, fontSize: 10, formatter: (p) => usdCompact(p.value) }\n              }]\n          });\n\n          chart.off('click');\n          chart.on('click', (params) => {\n              if (!params || params.componentType !== 'series') return;\n              const country = params.name;\n              log('bar click -> setFilters', FILTER_COL, country);\n              try {\n                  zPortal.dataSource.setFilters(FILTER_COL, country ? [country] : []);\n              } catch (err) {\n                  fail('setFilters failed', err);\n              }\n          });\n\n          const ro = new ResizeObserver(() => chart.resize());\n          ro.observe(el);\n          el._scResize = ro;\n          return chart;\n      };\n\n      /* ---------- orchestrator ---------- */\n      const init = async () => {\n          const onLoaded = (typeof currentBlock.getOnLoadedCallback === 'function') ? currentBlock.getOnLoadedCallback() : null;\n          try {\n              const rows = getQueryData(QUERY_INDEX.spend);\n              log('rows from queryResults', rows.length);\n              const series = spendByCountry(rows);\n              log('countries', series.length, series);\n\n              const el = document.getElementById(CANVAS_ID);\n              if (!el) { warn('canvas element missing'); return; }\n\n              if (!series.length) {\n                  el.innerHTML = '<div class=\"empty-sc\">No spend data available.</div>';\n                  return;\n              }\n\n              if (!window.echarts) {\n                  await zPortal.resources.load(ECHARTS_URL);\n              }\n              if (!window.echarts) { fail('ECharts failed to load'); return; }\n\n              renderChart(el, series);\n          } catch (err) {\n              fail('init failed', err);\n          } finally {\n              if (typeof onLoaded === 'function') onLoaded();\n          }\n      };\n\n      init();\n  })();\n  </script>\n</div>",
    "isolated": false
  },
