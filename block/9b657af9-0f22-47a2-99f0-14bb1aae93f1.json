{
  "name": "CRM · Chart Opps Created Over Time",
  "type": "html",
  "css": [
    ".crm-opps-time {\n    --surface: var(--block-bg-color, #15151A);\n    --surface-raised: #1B1B22;\n    --ink: var(--color-text, #F4F4F7);\n    --muted: var(--color-gray-500, #8A8A96);\n    --line: var(--color-gray-200, rgba(255,255,255,.07));\n    --accent: var(--color-primary, #FFD21E);\n    --accent-2: var(--color-secondary, #FF3D8B);\n    display: block;\n    height: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    container-type: inline-size;\n    color: var(--ink);\n    font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n    font-variant-numeric: tabular-nums;\n}\n.crm-opps-time .chart-card {\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    height: 100%;\n    min-width: 0;\n    max-width: 100%;\n    min-height: 280px;\n    background: var(--surface);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    padding: 16px 18px;\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n}\n.crm-opps-time .card-head { display: flex; flex-direction: column; gap: 3px; margin-bottom: 12px; min-width: 0; }\n.crm-opps-time .eyebrow {\n    display: inline-flex;\n    align-items: center;\n    gap: 7px;\n    min-width: 0;\n    font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n    letter-spacing: .13em;\n    text-transform: uppercase;\n    color: var(--accent);\n}\n.crm-opps-time .eyebrow::before {\n    content: \"\";\n    flex: none;\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: var(--accent);\n}\n.crm-opps-time h3 {\n    margin: 0;\n    min-width: 0;\n    overflow-wrap: break-word;\n    font: 800 15px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n    letter-spacing: -.01em;\n    color: var(--ink);\n}\n.crm-opps-time .sub {\n    margin: 0;\n    min-width: 0;\n    overflow-wrap: break-word;\n    font: 500 11.5px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n    color: var(--muted);\n}\n.crm-opps-time .canvas { flex: 1 1 auto; width: 100%; min-width: 0; max-width: 100%; min-height: 240px; }\n\n/* Section 9 responsive: container-query compaction on the block's own width.\n   This is a single chart card, so the ladder reduces to chart-card reflow +\n   the 220px canvas floor (chart-pair stacking is a page-grid concern). */\n@container (max-width: 720px) {\n    .crm-opps-time .chart-card { padding: 15px 16px; }\n}\n@container (max-width: 520px) {\n    .crm-opps-time .chart-card { padding: 14px; min-height: 240px; }\n    .crm-opps-time .card-head { margin-bottom: 10px; }\n    .crm-opps-time h3 { font-size: 14px; }\n    .crm-opps-time .canvas { min-height: 220px; }\n}\n@container (max-width: 360px) {\n    .crm-opps-time .chart-card { padding: 12px; min-height: 220px; }\n    .crm-opps-time .card-head { margin-bottom: 8px; }\n    .crm-opps-time .eyebrow { letter-spacing: .1em; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": "<div class=\"wrapper crm-opps-time\">\n  <section class=\"chart-card\" aria-labelledby=\"crm-opps-time-title\">\n    <header class=\"card-head\">\n      <span class=\"eyebrow\">CRM &middot; Pipeline</span>\n      <h3 id=\"crm-opps-time-title\">Opportunities Created Over Time</h3>\n      <p class=\"sub\">Monthly new opportunities &mdash; count and total pipeline amount</p>\n    </header>\n    <div id=\"crm-opps-time-canvas\" class=\"canvas\" role=\"img\" aria-live=\"polite\" aria-label=\"Line chart of opportunities created and total pipeline amount by month\"></div>\n  </section>\n</div>\n<script>\n(function () {\n    'use strict';\n\n    // ---- Top-level config -------------------------------------------------\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) console.log('[CRM Opps Over Time]', ...args); };\n    const warn = (...args) => { if (DEBUG) console.warn('[CRM Opps Over Time]', ...args); };\n\n    const QUERY_INDEX = { oppsByMonth: 0 };\n    const COL_MONTH = 'created_month';\n    const COL_OPPS = 'opps';\n    const COL_AMOUNT = 'amount';\n\n    const EL_CANVAS = 'crm-opps-time-canvas';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const DS_ID = '6c5b40d2-9365-42c6-b770-711a30cf689f';\n    const HANDLER_KEY = '__crmOppsTimeDsHandler';\n\n    // Brand series colors. CSS var() strings are NOT resolvable by the canvas\n    // renderer, so we resolve the live theme token in JS at render time and\n    // fall back to the Helios palette hex (design.md section 2).\n    const COLOR_OPPS_FALLBACK = '#FFD21E';\n    const COLOR_AMOUNT_FALLBACK = '#FF3D8B';\n    const AXIS_LINE = 'rgba(255,255,255,.18)';\n    const SPLIT_LINE = 'rgba(255,255,255,.06)';\n    const LABEL_INK = '#C2C2CC';\n    const MUTED_INK = '#8A8A96';\n    const TOOLTIP_BG = '#1B1B22';\n\n    const DOLLAR = String.fromCharCode(36);\n    const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n\n    let chartInstance = null;\n\n    // ---- Pure helpers -----------------------------------------------------\n    function getQueryData(index) {\n        const r = currentBlock.queryResults[index];\n        return (r && r.data)\n            ? r.data.map((d) => Object.fromEntries(r.columns.map((c, k) => [c, d[k]])))\n            : [];\n    }\n\n    function resolveThemeColor(varName, fallback) {\n        try {\n            const el = document.getElementById(EL_CANVAS) || document.documentElement;\n            const value = getComputedStyle(el).getPropertyValue(varName).trim();\n            if (value) return value;\n        } catch (e) {\n            warn('resolveThemeColor failed', varName, e);\n        }\n        return fallback;\n    }\n\n    function prefersReducedMotion() {\n        return !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);\n    }\n\n    function formatMonth(value) {\n        if (!value) return '';\n        const parts = String(value).split('-');\n        if (parts.length < 2) return String(value);\n        const monthIdx = parseInt(parts[1], 10) - 1;\n        const name = MONTHS[monthIdx] || parts[1];\n        return name + \" '\" + parts[0].slice(2);\n    }\n\n    function abbreviateMoney(value) {\n        const n = Number(value) || 0;\n        if (n >= 1e9) return DOLLAR + (n / 1e9).toFixed(1) + 'B';\n        if (n >= 1e6) return DOLLAR + (n / 1e6).toFixed(1) + 'M';\n        if (n >= 1e3) return DOLLAR + Math.round(n / 1e3) + 'K';\n        return DOLLAR + Math.round(n);\n    }\n\n    function formatMoney(value) {\n        return (Number(value) || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n    }\n\n    function tooltipFormatter(params) {\n        if (!params || !params.length) return '';\n        let html = '<div style=\"font-weight:700;margin-bottom:4px;color:#F4F4F7;\">' + params[0].axisValueLabel + '</div>';\n        params.forEach((p) => {\n            const isMoney = p.seriesName === 'Pipeline Amount';\n            const text = isMoney ? formatMoney(p.value) : (Number(p.value) || 0).toLocaleString();\n            html += '<div style=\"color:#C2C2CC;\">' + p.marker + ' ' + p.seriesName + ': <b style=\"color:#F4F4F7;\">' + text + '</b></div>';\n        });\n        return html;\n    }\n\n    function buildAriaSummary(rows) {\n        if (!rows.length) {\n            return 'Line chart of opportunities created and total pipeline amount by month. No data available.';\n        }\n        const latest = rows[rows.length - 1];\n        const totalOpps = rows.reduce((sum, r) => sum + (Number(r[COL_OPPS]) || 0), 0);\n        const latestMonth = formatMonth(latest[COL_MONTH]);\n        const latestOpps = (Number(latest[COL_OPPS]) || 0).toLocaleString();\n        const latestAmount = formatMoney(latest[COL_AMOUNT]);\n        return 'Line chart of opportunities created and total pipeline amount by month. '\n            + rows.length + ' months, ' + totalOpps.toLocaleString() + ' opportunities total. Latest '\n            + latestMonth + ': ' + latestOpps + ' opportunities, ' + latestAmount + ' pipeline.';\n    }\n\n    function buildOption(rows, colors) {\n        const ec = window.echarts;\n        const labels = rows.map((r) => formatMonth(r[COL_MONTH]));\n        const oppsData = rows.map((r) => Number(r[COL_OPPS]) || 0);\n        const amountData = rows.map((r) => Number(r[COL_AMOUNT]) || 0);\n        const showSymbol = rows.length === 1;\n        const animate = !prefersReducedMotion();\n\n        const oppsArea = new ec.graphic.LinearGradient(0, 0, 0, 1, [\n            { offset: 0, color: 'rgba(255,210,30,0.26)' },\n            { offset: 1, color: 'rgba(255,210,30,0.02)' }\n        ]);\n\n        return {\n            animation: animate,\n            backgroundColor: 'transparent',\n            color: [colors.opps, colors.amount],\n            grid: { left: 6, right: 10, top: 44, bottom: 6, containLabel: true },\n            legend: {\n                top: 4,\n                left: 0,\n                icon: 'roundRect',\n                itemWidth: 12,\n                itemHeight: 8,\n                textStyle: { color: LABEL_INK, fontSize: 12 },\n                data: ['Opportunities', 'Pipeline Amount']\n            },\n            tooltip: {\n                trigger: 'axis',\n                backgroundColor: TOOLTIP_BG,\n                borderColor: 'rgba(255,255,255,.12)',\n                borderWidth: 1,\n                padding: 10,\n                textStyle: { color: '#F4F4F7', fontSize: 12 },\n                axisPointer: { type: 'line', lineStyle: { color: 'rgba(255,255,255,.22)' } },\n                formatter: tooltipFormatter\n            },\n            xAxis: {\n                type: 'category',\n                boundaryGap: false,\n                data: labels,\n                axisLine: { lineStyle: { color: AXIS_LINE } },\n                axisTick: { show: false },\n                axisLabel: { color: LABEL_INK, fontSize: 11 }\n            },\n            yAxis: [\n                {\n                    type: 'value',\n                    name: 'Opps',\n                    nameTextStyle: { color: MUTED_INK, fontSize: 11, padding: [0, 0, 0, -28] },\n                    minInterval: 1,\n                    axisLine: { show: false },\n                    axisTick: { show: false },\n                    axisLabel: { color: LABEL_INK, fontSize: 11 },\n                    splitLine: { lineStyle: { color: SPLIT_LINE } }\n                },\n                {\n                    type: 'value',\n                    name: 'Amount',\n                    nameTextStyle: { color: MUTED_INK, fontSize: 11, padding: [0, -24, 0, 0] },\n                    axisLine: { show: false },\n                    axisTick: { show: false },\n                    axisLabel: { color: LABEL_INK, fontSize: 11, formatter: abbreviateMoney },\n                    splitLine: { show: false }\n                }\n            ],\n            series: [\n                {\n                    name: 'Opportunities',\n                    type: 'line',\n                    yAxisIndex: 0,\n                    smooth: true,\n                    symbol: 'circle',\n                    symbolSize: 6,\n                    showSymbol: showSymbol,\n                    lineStyle: { width: 2.5, color: colors.opps },\n                    itemStyle: { color: colors.opps },\n                    areaStyle: { color: oppsArea },\n                    emphasis: { focus: 'series' },\n                    data: oppsData\n                },\n                {\n                    name: 'Pipeline Amount',\n                    type: 'line',\n                    yAxisIndex: 1,\n                    smooth: true,\n                    symbol: 'circle',\n                    symbolSize: 6,\n                    showSymbol: showSymbol,\n                    lineStyle: { width: 2.5, color: colors.amount },\n                    itemStyle: { color: colors.amount },\n                    emphasis: { focus: 'series' },\n                    data: amountData\n                }\n            ]\n        };\n    }\n\n    // ---- Side-effecting render -------------------------------------------\n    function renderChart() {\n        const el = document.getElementById(EL_CANVAS);\n        if (!el || !window.echarts) return;\n        const existing = window.echarts.getInstanceByDom(el);\n        if (existing) existing.dispose();\n        chartInstance = window.echarts.init(el, null, { renderer: 'canvas' });\n\n        const rows = getQueryData(QUERY_INDEX.oppsByMonth);\n        log('rows for chart', rows.length);\n        el.setAttribute('aria-label', buildAriaSummary(rows));\n        if (!rows.length) {\n            chartInstance.setOption({\n                backgroundColor: 'transparent',\n                title: { text: 'No data', left: 'center', top: 'middle', textStyle: { color: MUTED_INK, fontSize: 13, fontWeight: 500 } }\n            });\n            return;\n        }\n        const colors = {\n            opps: resolveThemeColor('--color-primary', COLOR_OPPS_FALLBACK),\n            amount: resolveThemeColor('--color-secondary', COLOR_AMOUNT_FALLBACK)\n        };\n        chartInstance.setOption(buildOption(rows, colors));\n    }\n\n    function handleResize() {\n        if (chartInstance) chartInstance.resize();\n    }\n\n    function attachResizeObserver(el) {\n        if (!el || !window.ResizeObserver || el._croResize) return;\n        const ro = new ResizeObserver(handleResize);\n        ro.observe(el);\n        el._croResize = ro;\n    }\n\n    function subscribeFilterReload() {\n        if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') return;\n        try {\n            const prev = window[HANDLER_KEY];\n            if (prev && typeof zPortal.dataSource.off === 'function') {\n                zPortal.dataSource.off('load', DS_ID, prev);\n            }\n        } catch (e) {\n            warn('off previous handler failed', e);\n        }\n        const handler = () => {\n            try { renderChart(); }\n            catch (e) { warn('redraw on filter change failed', e); }\n        };\n        window[HANDLER_KEY] = handler;\n        try { zPortal.dataSource.on('load', DS_ID, handler); }\n        catch (e) { warn('subscribe to load failed', e); }\n    }\n\n    // ---- Orchestrator -----------------------------------------------------\n    function init() {\n        const onLoaded = currentBlock.getOnLoadedCallback();\n        let finished = false;\n        const finish = () => {\n            if (finished) return;\n            finished = true;\n            try { if (onLoaded) onLoaded(); } catch (e) { warn('onLoaded callback failed', e); }\n        };\n\n        const start = () => {\n            try {\n                renderChart();\n                attachResizeObserver(document.getElementById(EL_CANVAS));\n                subscribeFilterReload();\n            } catch (e) {\n                warn('render failed', e);\n            } finally {\n                finish();\n            }\n        };\n\n        if (window.echarts) {\n            start();\n        } else {\n            zPortal.resources.load(ECHARTS_URL)\n                .then(start)\n                .catch((e) => { warn('echarts load failed', e); finish(); });\n        }\n    }\n\n    init();\n})();\n</script>"
  },
