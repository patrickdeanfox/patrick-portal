  "json_data": {
    "isolated": false,
    "html": [
      "<div class=\"wrapper\">",
      "    <div class=\"form-container\">",
      "        <button id=\"triggerButton\">Start Runner Job</button>",
      "    </div>",
      "</div>",
      "",
      "<script type=\"text/javascript\">",
      "    const JOB_ID = 7721;",
      "    const BASE_URL = 'https://civicarx-mitto.zuarbase.net';",
      "    const API_KEY = 'ae9c1ab83ecfc5a089fb7ce19fb7c5aa';",
      "",
      "    // ─── Logger ───────────────────────────────────────────────────────────────",
      "    const Logger = {",
      "        _format(level) {",
      "            return `[${new Date().toISOString()}] [${level.toUpperCase().padEnd(5)}]`;",
      "        },",
      "        debug(message, data = null) {",
      "            data",
      "                ? console.debug(`${this._format('debug')} 🔍 ${message}`, data)",
      "                : console.debug(`${this._format('debug')} 🔍 ${message}`);",
      "        },",
      "        info(message, data = null) {",
      "            data",
      "                ? console.info(`${this._format('info')} ℹ️  ${message}`, data)",
      "                : console.info(`${this._format('info')} ℹ️  ${message}`);",
      "        },",
      "        warn(message, data = null) {",
      "            data",
      "                ? console.warn(`${this._format('warn')} ⚠️  ${message}`, data)",
      "                : console.warn(`${this._format('warn')} ⚠️  ${message}`);",
      "        },",
      "        error(message, data = null) {",
      "            data",
      "                ? console.error(`${this._format('error')} ❌ ${message}`, data)",
      "                : console.error(`${this._format('error')} ❌ ${message}`);",
      "        },",
      "        group(label) { console.group(label); },",
      "        groupEnd()   { console.groupEnd(); },",
      "        table(data)  { console.table(data); }",
      "    };",
      "",
      "    // ─── Main Trigger ─────────────────────────────────────────────────────────",
      "    function triggerAction() {",
      "        Logger.group('🚀 Runner Job Trigger — Full Debug Session');",
      "",
      "        // --- Environment ---",
      "        Logger.group('📋 Environment');",
      "        Logger.debug('Browser info', {",
      "            userAgent: navigator.userAgent,",
      "            language:  navigator.language,",
      "            onLine:    navigator.onLine",
      "        });",
      "        Logger.debug('Page context', {",
      "            origin:   window.location.origin,",
      "            pathname: window.location.pathname,",
      "            protocol: window.location.protocol",
      "        });",
      "        Logger.groupEnd();",
      "",
      "        // --- Config ---",
      "        Logger.group('⚙️ Request Configuration');",
      "        Logger.debug('Job config', { JOB_ID, BASE_URL });",
      "        Logger.debug('API key present', { apiKey: '***REDACTED***' });",
      "        Logger.groupEnd();",
      "",
      "        // --- Button State ---",
      "        Logger.group('🖱️ Button State');",
      "        const button = document.getElementById('triggerButton');",
      "        Logger.debug('Button found', { id: button.id, disabled: button.disabled });",
      "        button.disabled = true;",
      "        Logger.debug('Button disabled to prevent duplicate requests');",
      "        Logger.groupEnd();",
      "",
      "        // --- Request Body ---",
      "        const requestBody = { \"action\": \"START\" };",
      "        const serializedBody = JSON.stringify(requestBody);",
      "",
      "        Logger.group('📦 Request Body');",
      "        Logger.debug('Raw object', requestBody);",
      "        Logger.debug('Serialized JSON', { serializedBody, byteLength: new Blob([serializedBody]).size + ' bytes' });",
      "        Logger.groupEnd();",
      "",
      "        // --- URL Construction ---",
      "        const url = `${BASE_URL}/v2/jobs/${JOB_ID}/:actions?API_KEY=${API_KEY}`;",
      "        const redactedUrl = url.replace(/API_KEY=[^&]+/, 'API_KEY=***REDACTED***');",
      "",
      "        Logger.group('🔗 URL Construction');",
      "        Logger.debug('Constructed URL (redacted)', redactedUrl);",
      "        Logger.debug('URL breakdown', {",
      "            base:  BASE_URL,",
      "            path:  `/v2/jobs/${JOB_ID}/:actions`,",
      "            query: 'API_KEY=***REDACTED***'",
      "        });",
      "        Logger.groupEnd();",
      "",
      "        // --- Headers ---",
      "        const headers = {",
      "            'Accept': 'application/json',",
      "            'Content-Type': 'application/json'",
      "        };",
      "",
      "        Logger.group('📨 Request Headers');",
      "        Logger.table(Object.entries(headers).map(([k, v]) => ({ Header: k, Value: v })));",
      "        Logger.groupEnd();",
      "",
      "        // --- Fetch ---",
      "        Logger.group('📡 Fetch Execution');",
      "        Logger.info(`Sending POST → ${redactedUrl}`);",
      "        const startTime = performance.now();",
      "",
      "        fetch(url, { method: 'POST', headers, body: serializedBody })",
      "            .then(response => {",
      "                const ttfb = (performance.now() - startTime).toFixed(2);",
      "",
      "                Logger.group('📥 Response Received');",
      "                Logger.info(`Status: ${response.status} ${response.statusText} — TTFB: ${ttfb}ms`);",
      "                Logger.debug('Response metadata', {",
      "                    status:     response.status,",
      "                    statusText: response.statusText,",
      "                    ok:         response.ok,",
      "                    redirected: response.redirected,",
      "                    type:       response.type,",
      "                    ttfb:       ttfb + 'ms'",
      "                });",
      "",
      "                const responseHeaders = {};",
      "                response.headers.forEach((value, key) => { responseHeaders[key] = value; });",
      "                Logger.debug('Response headers', responseHeaders);",
      "                Logger.groupEnd();",
      "",
      "                if (!response.ok) {",
      "                    Logger.error(`Non-2xx response — ${response.status}: ${response.statusText}`);",
      "                    throw new Error(`HTTP error: ${response.status} ${response.statusText}`);",
      "                }",
      "",
      "                Logger.debug('Parsing response body as JSON...');",
      "                return response.json();",
      "            })",
      "            .then(data => {",
      "                const totalDuration = (performance.now() - startTime).toFixed(2);",
      "",
      "                Logger.group('✅ Success');",
      "                Logger.info(`Job triggered successfully — total round-trip: ${totalDuration}ms`);",
      "                Logger.debug('Response payload', data);",
      "                Logger.table(typeof data === 'object' && !Array.isArray(data)",
      "                    ? Object.entries(data).map(([k, v]) => ({ Key: k, Value: JSON.stringify(v) }))",
      "                    : [{ Value: JSON.stringify(data) }]",
      "                );",
      "                Logger.groupEnd();",
      "",
      "                button.disabled = false;",
      "                Logger.debug('Button re-enabled after success');",
      "            })",
      "            .catch(error => {",
      "                const duration = (performance.now() - startTime).toFixed(2);",
      "",
      "                Logger.group('❌ Error');",
      "                Logger.error(`Request failed after ${duration}ms`);",
      "                Logger.error('Error details', {",
      "                    name:    error.name,",
      "                    message: error.message,",
      "                    stack:   error.stack",
      "                });",
      "",
      "                if (error.name === 'TypeError') {",
      "                    Logger.warn('TypeError detected — likely causes:', {",
      "                        possibleCauses: [",
      "                            'CORS policy blocking the request',",
      "                            'Network connectivity issue',",
      "                            'Invalid URL format',",
      "                            'Server unreachable'",
      "                        ]",
      "                    });",
      "                    Logger.debug('CORS tip: Check the Network tab in DevTools for a preflight OPTIONS request');",
      "                } else if (error.message.includes('HTTP error')) {",
      "                    Logger.debug('Common causes by status', {",
      "                        '400': 'Bad request — check request body format',",
      "                        '401': 'Unauthorized — API key may be invalid or expired',",
      "                        '403': 'Forbidden — API key may lack permissions',",
      "                        '404': 'Not found — check JOB_ID and URL path',",
      "                        '500': 'Server error — issue on the Runner side'",
      "                    });",
      "                }",
      "                Logger.groupEnd();",
      "",
      "                button.disabled = false;",
      "                Logger.warn('Button re-enabled after error');",
      "            })",
      "            .finally(() => {",
      "                Logger.groupEnd(); // Fetch Execution",
      "                Logger.groupEnd(); // Root group",
      "            });",
      "    }",
      "",
      "    // ─── Init ─────────────────────────────────────────────────────────────────",
      "    Logger.group('🔧 Initialisation');",
      "    Logger.info('Script loaded');",
      "    Logger.debug('DOM state', { readyState: document.readyState });",
      "    const btn = document.getElementById('triggerButton');",
      "    if (!btn) {",
      "        Logger.error('triggerButton element not found in DOM — listener not attached');",
      "    } else {",
      "        btn.addEventListener('click', triggerAction);",
      "        Logger.info('Click listener attached to #triggerButton ✅');",
      "    }",
      "    Logger.groupEnd();",
      "</script>"
    ]
  },
  "ui_queries": [],
  "tags": [
    "runner",
    "system"
  ],
  "access": {
    "groups": []
  },
