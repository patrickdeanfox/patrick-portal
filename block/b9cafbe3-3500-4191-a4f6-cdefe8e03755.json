      "<div class=\"ind-kpis\">\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Loan Volume</span></div><div class=\"ind-kpi-val\" id=\"k-loan\">—</div><div class=\"ind-kpi-sub\" id=\"k-loan-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Deposit Volume</span></div><div class=\"ind-kpi-val\" id=\"k-deposit\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">New Accounts</span></div><div class=\"ind-kpi-val\" id=\"k-accounts\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Avg NPS</span></div><div class=\"ind-kpi-val\" id=\"k-nps\">—</div><div class=\"ind-kpi-sub\">weighted by accounts</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Loan / Deposit</span></div><div class=\"ind-kpi-val\" id=\"k-ld\">—</div><div class=\"ind-kpi-sub\">coverage ratio</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Branches</span></div><div class=\"ind-kpi-val\" id=\"k-branches\">—</div><div class=\"ind-kpi-sub\">in view</div></div>\n</div>\n<script>(function(){\n  var DS_ID=\"0b475da2-7aa9-4903-b604-ef21f89dc412\";\n  var D=String.fromCharCode(36);\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function fmtInt(n){return Math.round(n).toLocaleString();}\n  function fmtMoney(n){if(n>=1e6)return D+(n/1e6).toFixed(2)+'M';if(n>=1e3)return D+Math.round(n/1e3)+'K';return D+fmtInt(n);}\n  function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}\n  function render(){var d=rows();var loan=0,dep=0,acc=0,npsw=0,br={};d.forEach(function(r){loan+=num(r.loan_volume);dep+=num(r.deposit_volume);acc+=num(r.new_accounts);npsw+=num(r.nps_score)*num(r.new_accounts);if(r.branch)br[r.branch]=1;});set('k-loan',fmtMoney(loan));set('k-deposit',fmtMoney(dep));set('k-accounts',fmtInt(acc));set('k-nps',(acc?(npsw/acc):0).toFixed(1));set('k-ld',(dep?(loan/dep):0).toFixed(2)+'x');set('k-branches',Object.keys(br).length);set('k-loan-sub',acc?(fmtMoney(loan/acc)+' / account'):' ');}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{render();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,render);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
