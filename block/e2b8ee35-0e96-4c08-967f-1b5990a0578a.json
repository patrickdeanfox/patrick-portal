{
  "name": "SC · Chart Spend by Category & PO Status",
  "type": "html",
  "css": [
    ".wrapper {\n  --sc-surface: var(--block-bg-color, #15151A);\n  --sc-surface-raised: #1B1B22;\n  --sc-ink: var(--color-text, #F4F4F7);\n  --sc-muted: var(--color-gray-500, #8A8A96);\n  --sc-line: var(--color-gray-200, rgba(255,255,255,.07));\n  --sc-accent: var(--color-primary, #FFD21E);\n  --sc-accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  color: var(--sc-ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.wrapper .sc-spend {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-height: 320px;\n  box-sizing: border-box;\n  background: var(--sc-surface);\n  border: 1px solid var(--sc-line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease, box-shadow .16s ease;\n}\n.wrapper .sc-spend:hover {\n  border-color: color-mix(in srgb, var(--sc-accent) 28%, var(--sc-line));\n}\n.wrapper .sc-spend__head {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: 16px;\n  margin-bottom: 14px;\n}\n.wrapper .sc-spend__titles { min-width: 0; }\n.wrapper .sc-spend__title {\n  margin: 0;\n  font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--sc-ink);\n  letter-spacing: -.01em;\n}\n.wrapper .sc-spend__sub {\n  margin: 3px 0 0;\n  font: 500 11px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--sc-muted);\n}\n.wrapper .sc-spend__total {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-end;\n  gap: 3px;\n  white-space: nowrap;\n  padding: 7px 12px;\n  border-radius: 12px;\n  background: color-mix(in srgb, var(--sc-accent) 8%, transparent);\n  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sc-accent) 30%, transparent);\n}\n.wrapper .sc-spend__total-label {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  font: 700 10px/1.1 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--sc-muted);\n}\n.wrapper .sc-spend__total-label::before {\n  content: \"\";\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--sc-accent);\n  box-shadow: 0 0 8px -1px color-mix(in srgb, var(--sc-accent) 70%, transparent);\n}\n.wrapper .sc-spend__total-value {\n  font: 800 22px/1.05 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  font-variant-numeric: tabular-nums;\n  color: var(--sc-accent);\n}\n.wrapper .sc-spend__chart {\n  flex: 1 1 auto;\n  width: 100%;\n  min-height: 280px;\n}\n.wrapper .sc-spend__empty {\n  display: flex;\n  flex: 1 1 auto;\n  align-items: center;\n  justify-content: center;\n  margin: 0;\n  font: 500 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--sc-muted);\n}\n@container (max-width: 520px) {\n  .wrapper .sc-spend__head { flex-direction: column; gap: 10px; }\n  .wrapper .sc-spend__total { align-items: flex-start; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper .sc-spend { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper\">\n  <section class=\"sc-spend\">\n    <header class=\"sc-spend__head\">\n      <div class=\"sc-spend__titles\">\n        <h3 class=\"sc-spend__title\">Spend by Category &amp; PO Status</h3>\n        <p class=\"sc-spend__sub\">Total line spend stacked by purchase-order status</p>\n      </div>\n      <div class=\"sc-spend__total\">\n        <span class=\"sc-spend__total-label\">Total spend</span>\n        <span class=\"sc-spend__total-value\" id=\"sc-spend-total\" aria-live=\"polite\">&mdash;</span>\n      </div>\n    </header>\n    <div class=\"sc-spend__chart\" id=\"sc-spend-chart\" role=\"img\" aria-label=\"Stacked bar chart: total spend by product category, segmented by purchase-order status\"></div>\n    <p class=\"sc-spend__empty\" id=\"sc-spend-empty\" hidden>No purchase-order spend to display.</p>\n  </section>\n  <script>\n  (function () {\n    'use strict';\n\n    // ---- Top-level config ----\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) { console.log('[SC Spend by Category/Status]', ...args); } };\n\n    const QUERY_INDEX = { SPEND: 0 };\n    const COL = { CATEGORY: 'product_category', STATUS: 'po_status', SPEND: 'line_spend' };\n    const STATUS_ORDER = ['Received', 'Open', 'Cancelled'];\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const SEL = { chart: 'sc-spend-chart', total: 'sc-spend-total', empty: 'sc-spend-empty' };\n    const EXTRA_PALETTE = ['#36D399', '#A78BFA', '#FF9F45', '#2DD4BF'];\n\n    // ---- Pure helpers ----\n    const getQueryData = (index) => {\n      const q = currentBlock.queryResults[index];\n      if (!q || q.data === undefined || q.data === null) { return []; }\n      if (q.mappedData) { return q.mappedData; }\n      return q.data.map((row) => {\n        const obj = {};\n        q.columns.forEach((col, i) => { obj[col] = row[i]; });\n        return obj;\n      });\n    };\n\n    const fmtMoney = (value) => {\n      const n = Number(value) || 0;\n      return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n    };\n\n    const fmtCompact = (value) => {\n      const n = Number(value) || 0;\n      const sign = String.fromCharCode(36);\n      if (Math.abs(n) >= 1e6) { return sign + (n / 1e6).toFixed(1) + 'M'; }\n      if (Math.abs(n) >= 1e3) { return sign + Math.round(n / 1e3) + 'K'; }\n      return sign + Math.round(n);\n    };\n\n    const cssVar = (el, name, fallback) => {\n      try {\n        const v = getComputedStyle(el).getPropertyValue(name).trim();\n        return v || fallback;\n      } catch (e) { return fallback; }\n    };\n\n    const aggregate = (records) => {\n      const catMap = {};\n      const catOrder = [];\n      const statusesSeen = {};\n      records.forEach((r) => {\n        let cat = r[COL.CATEGORY];\n        if (cat === null || cat === undefined || cat === '') { cat = 'Unknown'; }\n        let status = r[COL.STATUS];\n        if (status === null || status === undefined || status === '') { status = 'Unknown'; }\n        const spend = Number(r[COL.SPEND]) || 0;\n        if (!catMap[cat]) { catMap[cat] = {}; catOrder.push(cat); }\n        catMap[cat][status] = (catMap[cat][status] || 0) + spend;\n        statusesSeen[status] = true;\n      });\n      const statuses = STATUS_ORDER.filter((s) => statusesSeen[s]);\n      Object.keys(statusesSeen).forEach((s) => { if (statuses.indexOf(s) === -1) { statuses.push(s); } });\n      const totals = {};\n      catOrder.forEach((cat) => {\n        let t = 0;\n        statuses.forEach((s) => { t += (catMap[cat][s] || 0); });\n        totals[cat] = t;\n      });\n      catOrder.sort((a, b) => totals[b] - totals[a]);\n      return { categories: catOrder, statuses, catMap, totals };\n    };\n\n    // ---- Render (disposes any prior instance first) ----\n    const renderChart = (records) => {\n      const el = document.getElementById(SEL.chart);\n      const emptyEl = document.getElementById(SEL.empty);\n      const totalEl = document.getElementById(SEL.total);\n      if (!el) { return; }\n\n      const prior = window.echarts.getInstanceByDom(el);\n      if (prior) { prior.dispose(); }\n      if (el._scSpendRO) { el._scSpendRO.disconnect(); el._scSpendRO = null; }\n\n      if (!records.length) {\n        el.style.display = 'none';\n        if (emptyEl) { emptyEl.hidden = false; }\n        if (totalEl) { totalEl.textContent = fmtMoney(0); }\n        return;\n      }\n      el.style.display = '';\n      if (emptyEl) { emptyEl.hidden = true; }\n\n      const agg = aggregate(records);\n      const grandTotal = agg.categories.reduce((sum, c) => sum + agg.totals[c], 0);\n      if (totalEl) { totalEl.textContent = fmtMoney(grandTotal); }\n\n      const ink = cssVar(el, '--color-text', '#F4F4F7');\n      const fontFamily = cssVar(el, '--font-stack-primary', \"'Inter', system-ui, sans-serif\");\n      const statusColors = {\n        Received: cssVar(el, '--color-primary', '#FFD21E'),\n        Open: cssVar(el, '--color-info', '#34B9F3'),\n        Cancelled: cssVar(el, '--color-secondary', '#FF3D8B')\n      };\n\n      const totalsByIndex = agg.categories.map((c) => agg.totals[c]);\n      const lastIndex = agg.statuses.length - 1;\n\n      const series = agg.statuses.map((status, sIdx) => {\n        const isTop = sIdx === lastIndex;\n        return {\n          name: status,\n          type: 'bar',\n          stack: 'spend',\n          barMaxWidth: 54,\n          emphasis: { focus: 'series' },\n          itemStyle: {\n            color: statusColors[status] || EXTRA_PALETTE[sIdx % EXTRA_PALETTE.length],\n            borderRadius: isTop ? [4, 4, 0, 0] : [0, 0, 0, 0]\n          },\n          label: isTop ? {\n            show: true,\n            position: 'top',\n            color: ink,\n            fontSize: 11,\n            fontWeight: 600,\n            formatter: (p) => fmtCompact(totalsByIndex[p.dataIndex])\n          } : { show: false },\n          data: agg.categories.map((cat) => Math.round((agg.catMap[cat][status] || 0) * 100) / 100)\n        };\n      });\n\n      const option = {\n        backgroundColor: 'transparent',\n        textStyle: { fontFamily },\n        grid: { left: 6, right: 18, top: 36, bottom: 6, containLabel: true },\n        legend: {\n          top: 2,\n          right: 0,\n          icon: 'roundRect',\n          itemWidth: 11,\n          itemHeight: 11,\n          itemGap: 16,\n          textStyle: { color: '#C2C2CC', fontSize: 11 }\n        },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: { type: 'shadow' },\n          backgroundColor: '#1B1B22',\n          borderColor: 'rgba(255,255,255,.12)',\n          borderWidth: 1,\n          textStyle: { color: '#F4F4F7', fontSize: 12 },\n          formatter: (params) => {\n            if (!params || !params.length) { return ''; }\n            let total = 0;\n            let body = '';\n            params.forEach((p) => {\n              const val = Number(p.value) || 0;\n              total += val;\n              body += '<div style=\"display:flex;justify-content:space-between;gap:20px;line-height:1.7;\">'\n                + '<span>' + p.marker + p.seriesName + '</span>'\n                + '<span style=\"font-variant-numeric:tabular-nums;font-weight:600;\">' + fmtMoney(val) + '</span></div>';\n            });\n            const head = '<div style=\"font-weight:700;margin-bottom:2px;\">' + params[0].axisValueLabel + '</div>';\n            const foot = '<div style=\"display:flex;justify-content:space-between;gap:20px;margin-top:4px;padding-top:4px;border-top:1px solid rgba(255,255,255,.14);line-height:1.7;\">'\n              + '<span style=\"color:#8A8A96;\">Total</span>'\n              + '<span style=\"font-variant-numeric:tabular-nums;font-weight:700;\">' + fmtMoney(total) + '</span></div>';\n            return head + body + foot;\n          }\n        },\n        xAxis: {\n          type: 'category',\n          data: agg.categories,\n          axisTick: { show: false },\n          axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n          axisLabel: { color: '#C2C2CC', fontSize: 11, fontWeight: 600 }\n        },\n        yAxis: {\n          type: 'value',\n          axisLine: { show: false },\n          axisTick: { show: false },\n          splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } },\n          axisLabel: { color: '#C2C2CC', fontSize: 10, formatter: (v) => fmtCompact(v) }\n        },\n        series\n      };\n\n      const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n      chart.setOption(option);\n\n      if (typeof ResizeObserver !== 'undefined') {\n        const ro = new ResizeObserver(() => { chart.resize(); });\n        ro.observe(el);\n        el._scSpendRO = ro;\n      }\n      log('rendered', agg.categories.length, 'categories x', agg.statuses.length, 'statuses; total', grandTotal);\n    };\n\n    const showError = () => {\n      const el = document.getElementById(SEL.chart);\n      const emptyEl = document.getElementById(SEL.empty);\n      if (el) { el.style.display = 'none'; }\n      if (emptyEl) { emptyEl.hidden = false; emptyEl.textContent = 'Unable to render spend chart.'; }\n    };\n\n    // ---- Orchestrator ----\n    async function init() {\n      const done = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : null;\n      try {\n        if (!window.echarts) { await zPortal.resources.load(ECHARTS_URL); }\n        const records = getQueryData(QUERY_INDEX.SPEND);\n        log('rows', records.length);\n        renderChart(records);\n      } catch (err) {\n        log('init failed', err && err.message ? err.message : err);\n        showError();\n      } finally {\n        if (typeof done === 'function') { done(); }\n      }\n    }\n\n    init();\n  })();\n  </script>\n</div>"
  },
