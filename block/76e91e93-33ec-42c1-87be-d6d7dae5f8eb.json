    "html": "<div class=\"wrapper wrapper-rt-cust-state\">\n  <div class=\"rcs-card\">\n    <div class=\"rcs-head\">\n      <div class=\"rcs-headtext\">\n        <p class=\"rcs-eyebrow\">Retail</p>\n        <h3 class=\"rcs-title\">Customers by State</h3>\n        <p class=\"rcs-sub\" id=\"rcs-sub\">Customer count by state &middot; click a bar to filter</p>\n      </div>\n      <div class=\"rcs-toggle\" role=\"group\" aria-label=\"Choose metric\">\n        <button type=\"button\" class=\"rcs-btn is-active\" data-metric=\"count\" aria-pressed=\"true\">Customers</button>\n        <button type=\"button\" class=\"rcs-btn\" data-metric=\"revenue\" aria-pressed=\"false\">Net Revenue</button>\n      </div>\n    </div>\n    <div class=\"rcs-chart\" id=\"rcs-chart\" tabindex=\"0\" role=\"img\" aria-label=\"Sorted bar chart of customers by state; click a bar to filter the page by that state\"></div>\n    <p class=\"rcs-empty\" id=\"rcs-empty\" hidden>No customer data available.</p>\n  </div>\n</div>\n<script>\n(function () {\n  'use strict';\n\n  // ---- top-level config ----\n  const DEBUG = false;\n  const log = (...args) => { if (DEBUG) { console.log('[RT Customers by State]', ...args); } };\n  const warn = (...args) => { if (DEBUG) { console.warn('[RT Customers by State]', ...args); } };\n\n  const QUERY_INDEX = { customer360: 0 };\n  const COL_STATE = 'state';\n  const COL_REVENUE = 'net_revenue';\n  const FILTER_COLUMN = 'state';\n\n  const WRAPPER_SELECTOR = '.wrapper-rt-cust-state';\n  const CHART_EL_ID = 'rcs-chart';\n  const EMPTY_EL_ID = 'rcs-empty';\n  const SUB_EL_ID = 'rcs-sub';\n  const BTN_SELECTOR = '.wrapper-rt-cust-state .rcs-btn';\n  const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n  const RO_KEY = '__rcsResizeObserver';\n  const SUB_KEY = '__rcsReloadSub';\n  const METRIC_KEY = '__rcsMetric';\n  const METRIC_COUNT = 'count';\n  const METRIC_REVENUE = 'revenue';\n\n  // ---- formatters (pure) ----\n  const fmtCount = (value) => (Number(value) || 0).toLocaleString('en-US');\n  const fmtCurrency = (value) => (Number(value) || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n  const fmtCompactCurrency = (value) => (Number(value) || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n  // ---- view state (persists across script re-runs) ----\n  const getMetric = () => (window[METRIC_KEY] === METRIC_REVENUE ? METRIC_REVENUE : METRIC_COUNT);\n  const setMetric = (m) => { window[METRIC_KEY] = (m === METRIC_REVENUE ? METRIC_REVENUE : METRIC_COUNT); };\n\n  // ---- data access (pure) ----\n  const getQueryData = (index) => {\n    try {\n      if (typeof currentBlock === 'undefined' || !currentBlock.queryResults) { return []; }\n      const q = currentBlock.queryResults[index];\n      if (!q || !q.data) { return []; }\n      if (q.mappedData) { return q.mappedData; }\n      return q.data.map((row) => Object.fromEntries(q.columns.map((col, k) => [col, row[k]])));\n    } catch (err) {\n      warn('getQueryData failed', err);\n      return [];\n    }\n  };\n\n  const aggregateByState = (records) => {\n    const byState = new Map();\n    records.forEach((rec) => {\n      const raw = rec[COL_STATE];\n      if (raw == null || raw === '') { return; }\n      const state = String(raw);\n      let entry = byState.get(state);\n      if (!entry) { entry = { state: state, count: 0, revenue: 0 }; byState.set(state, entry); }\n      entry.count += 1;\n      const rev = Number(rec[COL_REVENUE]);\n      if (isFinite(rev)) { entry.revenue += rev; }\n    });\n    return Array.from(byState.values());\n  };\n\n  const prepareRows = (records, metric) => {\n    const agg = aggregateByState(records);\n    const valueOf = (d) => (metric === METRIC_REVENUE ? d.revenue : d.count);\n    agg.sort((a, b) => valueOf(b) - valueOf(a));\n    agg.reverse();\n    log('prepared states', agg.length);\n    return agg;\n  };\n\n  const resolveColors = () => {\n    const root = document.querySelector(WRAPPER_SELECTOR);\n    const cssVar = (name, fallback) => {\n      try {\n        const v = root ? getComputedStyle(root).getPropertyValue(name) : '';\n        return (v && v.trim()) || fallback;\n      } catch (err) { return fallback; }\n    };\n    return {\n      accent: cssVar('--color-primary', '#FFD21E'),\n      accent2: cssVar('--color-secondary', '#FF3D8B'),\n      ink: cssVar('--color-text', '#F4F4F7'),\n      axis: '#C2C2CC'\n    };\n  };\n\n  // ---- option builder (pure) ----\n  const buildOption = (data, metric, colors) => {\n    const isRevenue = metric === METRIC_REVENUE;\n    const states = data.map((d) => d.state);\n    const values = data.map((d) => (isRevenue ? d.revenue : d.count));\n    const maxValue = values.reduce((m, v) => (v > m ? v : m), 0);\n    const isDrilled = states.length === 1;\n    const formatValue = (v) => (isRevenue ? fmtCurrency(v) : fmtCount(v));\n    const formatAxis = (v) => (isRevenue ? fmtCompactCurrency(v) : fmtCount(v));\n    return {\n      backgroundColor: 'transparent',\n      animationDuration: 600,\n      grid: { left: 6, right: 18, top: 10, bottom: 6, containLabel: true },\n      tooltip: {\n        trigger: 'axis',\n        axisPointer: { type: 'shadow' },\n        backgroundColor: '#1B1B22',\n        borderColor: 'rgba(255,255,255,.07)',\n        borderWidth: 1,\n        textStyle: { color: colors.ink, fontSize: 12 },\n        formatter: (params) => {\n          const p = params && params[0];\n          if (!p) { return ''; }\n          const suffix = isRevenue ? '' : ' customers';\n          return p.name + '<br/>' + formatValue(p.value) + suffix;\n        }\n      },\n      xAxis: {\n        type: 'value',\n        max: maxValue > 0 ? Math.ceil(maxValue * 1.22) : null,\n        axisLine: { show: true, lineStyle: { color: 'rgba(255,255,255,.18)' } },\n        axisTick: { show: false },\n        splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } },\n        axisLabel: { color: colors.axis, fontSize: 10, formatter: (v) => formatAxis(v) }\n      },\n      yAxis: {\n        type: 'category',\n        data: states,\n        axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n        axisTick: { show: false },\n        axisLabel: { color: colors.axis, fontSize: 11 }\n      },\n      series: [{\n        name: isRevenue ? 'Net revenue' : 'Customers',\n        type: 'bar',\n        data: values,\n        barMaxWidth: 26,\n        cursor: 'pointer',\n        itemStyle: { color: isDrilled ? colors.accent2 : colors.accent, borderRadius: [0, 4, 4, 0] },\n        emphasis: { itemStyle: { color: colors.accent2 } },\n        label: {\n          show: true,\n          position: 'right',\n          distance: 6,\n          color: colors.ink,\n          fontSize: 11,\n          fontWeight: 600,\n          formatter: (p) => formatValue(p.value)\n        }\n      }]\n    };\n  };\n\n  // ---- side-effecting helpers ----\n  const updateSub = (data, metric) => {\n    const el = document.getElementById(SUB_EL_ID);\n    if (!el) { return; }\n    const total = data.reduce((s, d) => s + (metric === METRIC_REVENUE ? d.revenue : d.count), 0);\n    const lead = metric === METRIC_REVENUE\n      ? 'Net revenue by state · ' + fmtCurrency(total) + ' total'\n      : 'Customer count by state · ' + fmtCount(total) + ' customers';\n    el.textContent = lead + ' · click a bar to filter';\n  };\n\n  const updateToggleUI = () => {\n    const metric = getMetric();\n    document.querySelectorAll(BTN_SELECTOR).forEach((btn) => {\n      const active = btn.getAttribute('data-metric') === metric;\n      btn.classList.toggle('is-active', active);\n      btn.setAttribute('aria-pressed', active ? 'true' : 'false');\n    });\n  };\n\n  const showEmpty = (isEmpty) => {\n    const msg = document.getElementById(EMPTY_EL_ID);\n    const el = document.getElementById(CHART_EL_ID);\n    if (msg) { msg.hidden = !isEmpty; }\n    if (el) { el.style.display = isEmpty ? 'none' : ''; }\n  };\n\n  const observeResize = (el, chart) => {\n    try {\n      if (window[RO_KEY] && typeof window[RO_KEY].disconnect === 'function') { window[RO_KEY].disconnect(); }\n      if (typeof ResizeObserver === 'undefined') { return; }\n      const ro = new ResizeObserver(() => { if (!chart.isDisposed()) { chart.resize(); } });\n      ro.observe(el);\n      window[RO_KEY] = ro;\n    } catch (err) { warn('observeResize failed', err); }\n  };\n\n  const applyStateFilter = (state, drilled) => {\n    try {\n      if (!(window.zPortal && zPortal.dataSource && typeof zPortal.dataSource.setFilters === 'function')) { return; }\n      if (drilled) {\n        log('clear state filter');\n        zPortal.dataSource.setFilters(FILTER_COLUMN, []);\n        return;\n      }\n      if (state == null || state === '') { return; }\n      log('setFilters state', state);\n      zPortal.dataSource.setFilters(FILTER_COLUMN, [String(state)]);\n    } catch (err) { warn('applyStateFilter failed', err); }\n  };\n\n  const renderChart = () => {\n    const el = document.getElementById(CHART_EL_ID);\n    if (!el || !window.echarts) { return; }\n    const metric = getMetric();\n    const prepared = prepareRows(getQueryData(QUERY_INDEX.customer360), metric);\n    const existing = window.echarts.getInstanceByDom(el);\n    if (existing) { existing.dispose(); }\n    updateToggleUI();\n    if (prepared.length === 0) {\n      updateSub(prepared, metric);\n      showEmpty(true);\n      return;\n    }\n    showEmpty(false);\n    updateSub(prepared, metric);\n    const isDrilled = prepared.length === 1;\n    const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n    chart.setOption(buildOption(prepared, metric, resolveColors()));\n    chart.off('click');\n    chart.on('click', (params) => {\n      if (params && params.componentType === 'series') {\n        applyStateFilter(params.name, isDrilled);\n      }\n    });\n    observeResize(el, chart);\n    log('chart rendered', prepared.length, metric);\n  };\n\n  // ---- toggle wiring ----\n  const wireToggle = () => {\n    document.querySelectorAll(BTN_SELECTOR).forEach((btn) => {\n      if (btn.__rcsWired) { return; }\n      btn.__rcsWired = true;\n      btn.addEventListener('click', () => {\n        setMetric(btn.getAttribute('data-metric'));\n        renderChart();\n      });\n    });\n  };\n\n  // ---- filter-reload subscription ----\n  const teardownPriorSubscription = () => {\n    try {\n      const prior = window[SUB_KEY];\n      if (prior && prior.ids && prior.handler && window.zPortal && zPortal.dataSource && typeof zPortal.dataSource.off === 'function') {\n        prior.ids.forEach((id) => {\n          try { zPortal.dataSource.off('load', id, prior.handler); } catch (e) { /* noop */ }\n        });\n      }\n    } catch (err) { warn('teardown failed', err); }\n    window[SUB_KEY] = null;\n  };\n\n  const subscribeReload = () => {\n    try {\n      if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') { return; }\n      const dsList = (typeof datasources !== 'undefined' && Array.isArray(datasources)) ? datasources : [];\n      const ids = [];\n      const handler = () => { log('datasource reload'); renderChart(); };\n      dsList.forEach((ds) => {\n        const id = ds && (ds.id || ds.datasource_id || ds.uuid);\n        if (!id) { return; }\n        try { zPortal.dataSource.on('load', id, handler); ids.push(id); } catch (e) { /* noop */ }\n      });\n      if (ids.length) { window[SUB_KEY] = { ids: ids, handler: handler }; }\n    } catch (err) { warn('subscribeReload failed', err); }\n  };\n\n  // ---- loader ----\n  const loadECharts = () => {\n    if (window.echarts) { return Promise.resolve(); }\n    if (window.zPortal && zPortal.resources && typeof zPortal.resources.load === 'function') {\n      return zPortal.resources.load(ECHARTS_URL);\n    }\n    return Promise.reject(new Error('zPortal.resources.load unavailable'));\n  };\n\n  // ---- single bottom-level orchestrator ----\n  const init = () => {\n    const onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : null;\n    let loadedCalled = false;\n    const done = () => {\n      if (!loadedCalled && typeof onLoaded === 'function') {\n        loadedCalled = true;\n        try { onLoaded(); } catch (e) { /* noop */ }\n      }\n    };\n    updateToggleUI();\n    wireToggle();\n    loadECharts().then(() => {\n      renderChart();\n      teardownPriorSubscription();\n      subscribeReload();\n    }).catch((err) => {\n      warn('init failed', err);\n      showEmpty(true);\n    }).finally(() => {\n      done();\n    });\n  };\n\n  init();\n})();\n</script>"
