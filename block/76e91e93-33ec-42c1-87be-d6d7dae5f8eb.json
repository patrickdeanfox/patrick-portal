    ".wrapper-rt-cust-state {\n  --rcs-surface: var(--block-bg-color, #15151A);\n  --rcs-surface-raised: #1B1B22;\n  --rcs-ink: var(--color-text, #F4F4F7);\n  --rcs-muted: var(--color-gray-500, #8A8A96);\n  --rcs-muted-strong: var(--color-gray-600, #A0A0AC);\n  --rcs-label: var(--color-gray-700, #C2C2CC);\n  --rcs-line: var(--color-gray-200, rgba(255,255,255,.07));\n  --rcs-accent: var(--color-primary, #FFD21E);\n  --rcs-accent-2: var(--color-secondary, #FF3D8B);\n  --rcs-ink-on-accent: #0B0B0D;\n  container-type: inline-size;\n  height: 100%;\n  width: 100%;\n  max-width: 100%;\n  box-sizing: border-box;\n  color: var(--rcs-ink);\n  font-variant-numeric: tabular-nums;\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.wrapper-rt-cust-state .rcs-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  box-sizing: border-box;\n  background: var(--rcs-surface);\n  border: 1px solid var(--rcs-line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease, box-shadow .16s ease;\n}\n.wrapper-rt-cust-state .rcs-card:hover {\n  border-color: color-mix(in srgb, var(--rcs-accent) 28%, var(--rcs-line));\n}\n.wrapper-rt-cust-state .rcs-head {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  flex-wrap: wrap;\n  gap: 12px;\n  margin: 0 0 14px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid var(--rcs-line);\n  min-width: 0;\n}\n.wrapper-rt-cust-state .rcs-headtext { min-width: 0; flex: 1 1 200px; }\n.wrapper-rt-cust-state .rcs-eyebrow {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  margin: 0 0 7px;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--rcs-label);\n}\n.wrapper-rt-cust-state .rcs-eyebrow::before {\n  content: \"\";\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--rcs-accent);\n}\n.wrapper-rt-cust-state .rcs-title {\n  margin: 0;\n  font: 800 14px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--rcs-ink);\n  overflow-wrap: break-word;\n  word-break: break-word;\n}\n.wrapper-rt-cust-state .rcs-sub {\n  margin: 4px 0 0;\n  font: 500 11px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--rcs-muted);\n  overflow-wrap: break-word;\n  word-break: break-word;\n}\n.wrapper-rt-cust-state .rcs-toggle {\n  display: inline-flex;\n  flex: 0 0 auto;\n  border: 1px solid var(--rcs-line);\n  border-radius: 10px;\n  overflow: hidden;\n}\n.wrapper-rt-cust-state .rcs-btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 44px;\n  font: 700 11px/1.1 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .02em;\n  padding: 8px 14px;\n  border: 0;\n  background: var(--rcs-surface-raised);\n  color: var(--rcs-muted-strong);\n  cursor: pointer;\n  white-space: nowrap;\n  transition: color .15s ease, background-color .15s ease, box-shadow .15s ease;\n}\n.wrapper-rt-cust-state .rcs-btn + .rcs-btn { border-left: 1px solid var(--rcs-line); }\n.wrapper-rt-cust-state .rcs-btn:hover {\n  color: var(--rcs-ink);\n  background: color-mix(in srgb, var(--rcs-accent) 10%, var(--rcs-surface-raised));\n}\n.wrapper-rt-cust-state .rcs-btn:active {\n  background: color-mix(in srgb, var(--rcs-accent) 18%, var(--rcs-surface-raised));\n}\n.wrapper-rt-cust-state .rcs-btn.is-active {\n  background: var(--rcs-accent);\n  color: var(--rcs-ink-on-accent);\n  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--rcs-accent) 40%, transparent), 0 0 16px -6px color-mix(in srgb, var(--rcs-accent) 60%, transparent);\n}\n.wrapper-rt-cust-state .rcs-btn.is-active:hover {\n  background: var(--rcs-accent);\n  color: var(--rcs-ink-on-accent);\n}\n.wrapper-rt-cust-state .rcs-btn:focus-visible { outline: 2px solid var(--rcs-accent); outline-offset: 2px; }\n.wrapper-rt-cust-state .rcs-chart {\n  flex: 1 1 auto;\n  width: 100%;\n  min-width: 0;\n  min-height: 240px;\n  overflow: hidden;\n  border-radius: 8px;\n  transition: box-shadow .16s ease;\n}\n.wrapper-rt-cust-state .rcs-chart:focus-visible {\n  outline: 2px solid var(--rcs-accent);\n  outline-offset: 3px;\n  box-shadow: 0 0 24px -6px color-mix(in srgb, var(--rcs-accent) 55%, transparent);\n}\n.wrapper-rt-cust-state .rcs-empty {\n  margin: auto;\n  font: 600 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--rcs-muted);\n  text-align: center;\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper-rt-cust-state .rcs-card,\n  .wrapper-rt-cust-state .rcs-chart,\n  .wrapper-rt-cust-state .rcs-btn { transition: none; }\n}",
    "@container (max-width: 720px) {\n  .wrapper-rt-cust-state .rcs-card { padding: 14px 16px; }\n  .wrapper-rt-cust-state .rcs-chart { min-height: 240px; }\n}\n@container (max-width: 520px) {\n  .wrapper-rt-cust-state .rcs-head { flex-direction: column; align-items: stretch; }\n  .wrapper-rt-cust-state .rcs-toggle { align-self: stretch; width: 100%; }\n  .wrapper-rt-cust-state .rcs-btn { flex: 1 1 0; }\n}\n@container (max-width: 480px) {\n  .wrapper-rt-cust-state .rcs-card { padding: 13px 14px; }\n  .wrapper-rt-cust-state .rcs-title { font-size: 13px; }\n  .wrapper-rt-cust-state .rcs-sub { font-size: 10.5px; }\n  .wrapper-rt-cust-state .rcs-chart { min-height: 220px; }\n}"
