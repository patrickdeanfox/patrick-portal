      "<div class=\"hc-kpis\">\n  <div class=\"hc-kpi\"><div class=\"hc-kpi-top\"><span class=\"hc-kpi-dot\"></span><span class=\"hc-kpi-label\">Total Patients</span></div><div class=\"hc-kpi-val\" id=\"k-patients\">—</div><div class=\"hc-kpi-sub\" id=\"k-patients-sub\">&nbsp;</div></div>\n  <div class=\"hc-kpi\"><div class=\"hc-kpi-top\"><span class=\"hc-kpi-dot\"></span><span class=\"hc-kpi-label\">Total Revenue</span></div><div class=\"hc-kpi-val\" id=\"k-revenue\">—</div><div class=\"hc-kpi-sub\" id=\"k-revenue-sub\">&nbsp;</div></div>\n  <div class=\"hc-kpi\"><div class=\"hc-kpi-top\"><span class=\"hc-kpi-dot\"></span><span class=\"hc-kpi-label\">Avg Length of Stay</span></div><div class=\"hc-kpi-val\" id=\"k-los\">—</div><div class=\"hc-kpi-sub\">weighted by patients</div></div>\n  <div class=\"hc-kpi\"><div class=\"hc-kpi-top\"><span class=\"hc-kpi-dot\"></span><span class=\"hc-kpi-label\">Readmission Rate</span></div><div class=\"hc-kpi-val\" id=\"k-readmit\">—</div><div class=\"hc-kpi-sub\" id=\"k-readmit-sub\">&nbsp;</div></div>\n  <div class=\"hc-kpi\"><div class=\"hc-kpi-top\"><span class=\"hc-kpi-dot\"></span><span class=\"hc-kpi-label\">Departments</span></div><div class=\"hc-kpi-val\" id=\"k-depts\">—</div><div class=\"hc-kpi-sub\">in view</div></div>\n  <div class=\"hc-kpi\"><div class=\"hc-kpi-top\"><span class=\"hc-kpi-dot\"></span><span class=\"hc-kpi-label\">Physicians</span></div><div class=\"hc-kpi-val\" id=\"k-phys\">—</div><div class=\"hc-kpi-sub\">in view</div></div>\n</div>\n<script>(function(){\n  var DS_ID=\"dd2191e6-9dc3-4ff3-8b63-6f2e33c07c2a\";\n  var D=String.fromCharCode(36);\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function fmtInt(n){return Math.round(n).toLocaleString();}\n  function fmtMoney(n){if(n>=1e6)return D+(n/1e6).toFixed(2)+'M';if(n>=1e3)return D+Math.round(n/1e3)+'K';return D+fmtInt(n);}\n  function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}\n  function render(){var d=rows();var pat=0,rev=0,re=0,losw=0,deps={},phys={};d.forEach(function(r){var pc=num(r.patient_count);pat+=pc;rev+=num(r.revenue);re+=num(r.readmissions);losw+=num(r.avg_los_days)*pc;if(r.department)deps[r.department]=1;if(r.physician)phys[r.physician]=1;});set('k-patients',fmtInt(pat));set('k-revenue',fmtMoney(rev));set('k-revenue-sub',pat?(D+fmtInt(rev/pat)+' / patient'):' ');set('k-los',(pat?(losw/pat):0).toFixed(1)+' d');set('k-readmit',(pat?(re/pat*100):0).toFixed(1)+'%');set('k-readmit-sub',fmtInt(re)+' readmissions');set('k-depts',Object.keys(deps).length);set('k-phys',Object.keys(phys).length);set('k-patients-sub',(Object.keys(deps).length)+' depts');}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{render();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,render);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
