  "json_data": {
    "html": "<div class=\"wrapper wrapper-exec-suppliers\">\n  <div class=\"exs-card\">\n    <div class=\"exs-head\">\n      <p class=\"exs-eyebrow\">Procurement</p>\n      <h3 class=\"exs-title\">Top Suppliers by Spend</h3>\n      <p class=\"exs-sub\">Total purchase spend &middot; top 10 suppliers</p>\n    </div>\n    <div class=\"exs-chart\" id=\"exs-chart\" tabindex=\"0\" role=\"img\" aria-label=\"Horizontal bar chart of total purchase spend for the top 10 suppliers\"></div>\n    <p class=\"exs-empty\" id=\"exs-empty\" hidden>No supplier spend data available.</p>\n  </div>\n</div>\n<script>\n(function () {\n  'use strict';\n\n  // ---- top-level config ----\n  var DEBUG = false;\n  var log = function () { if (DEBUG) { console.log.apply(console, ['[EXEC Top Suppliers]'].concat([].slice.call(arguments))); } };\n  var QUERY_INDEX = { suppliers: 0 };\n  var COL_NAME = 'supplier_name';\n  var COL_SPEND = 'total_spend';\n  var TOP_N = 10;\n  var WRAPPER_SELECTOR = '.wrapper-exec-suppliers';\n  var CHART_EL_ID = 'exs-chart';\n  var EMPTY_EL_ID = 'exs-empty';\n  var ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n  var RO_KEY = '__exsSuppliersResizeObserver';\n  var SUB_KEY = '__exsSuppliersReloadSub';\n\n  // ---- formatters (pure) ----\n  function fmtCurrency(value) {\n    var v = Number(value) || 0;\n    return v.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n  }\n  function fmtCompact(value) {\n    var v = Number(value) || 0;\n    return v.toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n  }\n\n  // ---- data access ----\n  function getQueryData(index) {\n    try {\n      if (typeof currentBlock === 'undefined' || !currentBlock.queryResults) { return []; }\n      var q = currentBlock.queryResults[index];\n      if (!q || !q.data) { return []; }\n      if (q.mappedData) { return q.mappedData; }\n      return q.data.map(function (row) {\n        return Object.fromEntries(q.columns.map(function (col, k) { return [col, row[k]]; }));\n      });\n    } catch (err) {\n      log('getQueryData failed', err);\n      return [];\n    }\n  }\n\n  function prepareRows(records) {\n    var cleaned = records.map(function (rec) {\n      return { name: rec[COL_NAME], spend: Number(rec[COL_SPEND]) };\n    }).filter(function (d) {\n      return d.name != null && d.name !== '' && isFinite(d.spend);\n    });\n    cleaned.sort(function (a, b) { return b.spend - a.spend; });\n    var top = cleaned.slice(0, TOP_N);\n    top.reverse(); // largest sits at the top of a horizontal bar\n    log('prepared rows', top.length);\n    return top;\n  }\n\n  function resolveColors() {\n    var root = document.querySelector(WRAPPER_SELECTOR);\n    function cssVar(name, fallback) {\n      try {\n        var v = root ? getComputedStyle(root).getPropertyValue(name) : '';\n        return (v && v.trim()) || fallback;\n      } catch (err) { return fallback; }\n    }\n    return {\n      accent: cssVar('--color-primary', '#FFD21E'),\n      ink: cssVar('--color-text', '#F4F4F7'),\n      axis: '#C2C2CC'\n    };\n  }\n\n  // ---- option builder (pure) ----\n  function buildOption(data, colors) {\n    var names = data.map(function (d) { return d.name; });\n    var spends = data.map(function (d) { return d.spend; });\n    var maxSpend = spends.reduce(function (m, v) { return v > m ? v : m; }, 0);\n    return {\n      backgroundColor: 'transparent',\n      animationDuration: 600,\n      grid: { left: 6, right: 18, top: 10, bottom: 6, containLabel: true },\n      tooltip: {\n        trigger: 'axis',\n        axisPointer: { type: 'shadow' },\n        backgroundColor: '#1B1B22',\n        borderColor: 'rgba(255,255,255,.07)',\n        borderWidth: 1,\n        textStyle: { color: colors.ink, fontSize: 12 },\n        formatter: function (params) {\n          var p = params && params[0];\n          if (!p) { return ''; }\n          return p.name + '<br/>' + fmtCurrency(p.value);\n        }\n      },\n      xAxis: {\n        type: 'value',\n        max: maxSpend > 0 ? Math.ceil(maxSpend * 1.22) : null,\n        axisLine: { show: true, lineStyle: { color: 'rgba(255,255,255,.18)' } },\n        axisTick: { show: false },\n        splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } },\n        axisLabel: { color: colors.axis, fontSize: 10, formatter: function (v) { return fmtCompact(v); } }\n      },\n      yAxis: {\n        type: 'category',\n        data: names,\n        axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n        axisTick: { show: false },\n        axisLabel: { color: colors.axis, fontSize: 11 }\n      },\n      series: [{\n        name: 'Total spend',\n        type: 'bar',\n        data: spends,\n        barMaxWidth: 22,\n        itemStyle: { color: colors.accent, borderRadius: [0, 4, 4, 0] },\n        emphasis: { itemStyle: { color: colors.accent } },\n        label: {\n          show: true,\n          position: 'right',\n          distance: 6,\n          color: colors.ink,\n          fontSize: 11,\n          fontWeight: 600,\n          formatter: function (p) { return fmtCurrency(p.value); }\n        }\n      }]\n    };\n  }\n\n  // ---- side-effecting render helpers ----\n  function showEmpty(isEmpty) {\n    var msg = document.getElementById(EMPTY_EL_ID);\n    var el = document.getElementById(CHART_EL_ID);\n    if (msg) { msg.hidden = !isEmpty; }\n    if (el) { el.style.display = isEmpty ? 'none' : ''; }\n  }\n\n  function observeResize(el, chart) {\n    try {\n      if (window[RO_KEY] && typeof window[RO_KEY].disconnect === 'function') { window[RO_KEY].disconnect(); }\n      if (typeof ResizeObserver === 'undefined') { return; }\n      var ro = new ResizeObserver(function () { if (!chart.isDisposed()) { chart.resize(); } });\n      ro.observe(el);\n      window[RO_KEY] = ro;\n    } catch (err) { log('observeResize failed', err); }\n  }\n\n  function renderChart() {\n    var el = document.getElementById(CHART_EL_ID);\n    if (!el || !window.echarts) { return; }\n    var prepared = prepareRows(getQueryData(QUERY_INDEX.suppliers));\n    var existing = window.echarts.getInstanceByDom(el);\n    if (existing) { existing.dispose(); }\n    if (prepared.length === 0) {\n      showEmpty(true);\n      return;\n    }\n    showEmpty(false);\n    var chart = window.echarts.init(el, null, { renderer: 'canvas' });\n    chart.setOption(buildOption(prepared, resolveColors()));\n    observeResize(el, chart);\n    log('chart rendered', prepared.length);\n  }\n\n  // ---- filter-reload subscription ----\n  function teardownPriorSubscription() {\n    try {\n      var prior = window[SUB_KEY];\n      if (prior && prior.ids && prior.handler && window.zPortal && zPortal.dataSource && typeof zPortal.dataSource.off === 'function') {\n        prior.ids.forEach(function (id) {\n          try { zPortal.dataSource.off('load', id, prior.handler); } catch (e) { /* noop */ }\n        });\n      }\n    } catch (err) { log('teardown failed', err); }\n    window[SUB_KEY] = null;\n  }\n\n  function subscribeReload() {\n    try {\n      if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') { return; }\n      var dsList = (typeof datasources !== 'undefined' && Array.isArray(datasources)) ? datasources : [];\n      var ids = [];\n      var handler = function () { log('datasource reload'); renderChart(); };\n      dsList.forEach(function (ds) {\n        var id = ds && (ds.id || ds.datasource_id || ds.uuid);\n        if (!id) { return; }\n        try { zPortal.dataSource.on('load', id, handler); ids.push(id); } catch (e) { /* noop */ }\n      });\n      if (ids.length) { window[SUB_KEY] = { ids: ids, handler: handler }; }\n    } catch (err) { log('subscribeReload failed', err); }\n  }\n\n  // ---- loader ----\n  function loadECharts() {\n    if (window.echarts) { return Promise.resolve(); }\n    if (window.zPortal && zPortal.resources && typeof zPortal.resources.load === 'function') {\n      return zPortal.resources.load(ECHARTS_URL);\n    }\n    return Promise.reject(new Error('zPortal.resources.load unavailable'));\n  }\n\n  // ---- single bottom-level orchestrator ----\n  function init() {\n    var onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : null;\n    var loadedCalled = false;\n    function done() {\n      if (!loadedCalled && typeof onLoaded === 'function') {\n        loadedCalled = true;\n        try { onLoaded(); } catch (e) { /* noop */ }\n      }\n    }\n    loadECharts().then(function () {\n      renderChart();\n      teardownPriorSubscription();\n      subscribeReload();\n    }).catch(function (err) {\n      log('init failed', err);\n      showEmpty(true);\n    }).finally(function () {\n      done();\n    });\n  }\n\n  init();\n})();\n</script>"
  },
