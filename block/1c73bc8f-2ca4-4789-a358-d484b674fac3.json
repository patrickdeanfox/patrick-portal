  "css": [
    ".wrapper-exec-suppliers {\n  --exs-surface: var(--block-bg-color, #15151A);\n  --exs-surface-raised: #1B1B22;\n  --exs-ink: var(--color-text, #F4F4F7);\n  --exs-muted: var(--color-gray-500, #8A8A96);\n  --exs-label: var(--color-gray-700, #C2C2CC);\n  --exs-line: var(--color-gray-200, rgba(255,255,255,.07));\n  --exs-accent: var(--color-primary, #FFD21E);\n  --exs-accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  box-sizing: border-box;\n  color: var(--exs-ink);\n  font-variant-numeric: tabular-nums;\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.wrapper-exec-suppliers .exs-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  box-sizing: border-box;\n  background: var(--exs-surface);\n  border: 1px solid var(--exs-line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease, box-shadow .16s ease;\n}\n.wrapper-exec-suppliers .exs-card:hover {\n  border-color: color-mix(in srgb, var(--exs-accent, #FFD21E) 30%, var(--exs-line));\n}\n.wrapper-exec-suppliers .exs-head {\n  margin: 0 0 14px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid var(--exs-line);\n}\n.wrapper-exec-suppliers .exs-eyebrow {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  margin: 0 0 7px;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--exs-label);\n}\n.wrapper-exec-suppliers .exs-eyebrow::before {\n  content: \"\";\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--exs-accent);\n}\n.wrapper-exec-suppliers .exs-title {\n  margin: 0;\n  font: 800 15px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--exs-ink);\n}\n.wrapper-exec-suppliers .exs-sub {\n  margin: 4px 0 0;\n  font: 500 11.5px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--exs-muted);\n}\n.wrapper-exec-suppliers .exs-chart {\n  flex: 1 1 auto;\n  width: 100%;\n  min-height: 240px;\n}\n.wrapper-exec-suppliers .exs-chart:focus-visible {\n  outline: 2px solid var(--exs-accent, #FFD21E);\n  outline-offset: 3px;\n  border-radius: 8px;\n}\n.wrapper-exec-suppliers .exs-empty {\n  margin: auto;\n  font: 600 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--exs-muted);\n  text-align: center;\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper-exec-suppliers .exs-card { transition: none; }\n}",
    "/* ---- responsive (design.md section 9): width-first, container queries ---- */\n.wrapper-exec-suppliers .exs-head {\n  min-width: 0;\n}\n.wrapper-exec-suppliers .exs-title,\n.wrapper-exec-suppliers .exs-sub {\n  overflow-wrap: break-word;\n  word-break: break-word;\n}\n.wrapper-exec-suppliers .exs-chart {\n  min-width: 0;\n  overflow: hidden;\n}\n@container (max-width: 720px) {\n  .wrapper-exec-suppliers .exs-card {\n    padding: 14px 16px;\n  }\n}\n@container (max-width: 480px) {\n  .wrapper-exec-suppliers .exs-card {\n    padding: 13px 14px;\n  }\n  .wrapper-exec-suppliers .exs-head {\n    margin-bottom: 12px;\n    padding-bottom: 10px;\n  }\n  .wrapper-exec-suppliers .exs-eyebrow {\n    letter-spacing: .1em;\n  }\n  .wrapper-exec-suppliers .exs-title {\n    font-size: 14px;\n  }\n  .wrapper-exec-suppliers .exs-sub {\n    font-size: 11px;\n  }\n}\n@container (max-width: 340px) {\n  .wrapper-exec-suppliers .exs-card {\n    padding: 11px 12px;\n  }\n}"
