    "html": [
      "<div class=\"ind-kpis\">\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Total Spend</span></div><div class=\"ind-kpi-val\" id=\"k-spend\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Total Revenue</span></div><div class=\"ind-kpi-val\" id=\"k-rev\">—</div><div class=\"ind-kpi-sub\">&nbsp;</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">ROAS</span></div><div class=\"ind-kpi-val\" id=\"k-roas\">—</div><div class=\"ind-kpi-sub\">revenue / spend</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">CTR</span></div><div class=\"ind-kpi-val\" id=\"k-ctr\">—</div><div class=\"ind-kpi-sub\">clicks / impressions</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Conv Rate</span></div><div class=\"ind-kpi-val\" id=\"k-cvr\">—</div><div class=\"ind-kpi-sub\">conv / clicks</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">CPA</span></div><div class=\"ind-kpi-val\" id=\"k-cpa\">—</div><div class=\"ind-kpi-sub\">cost / conversion</div></div>\n</div>\n<script>(function(){\n  var DS_ID=\"32f80cc4-7102-4074-aad7-b916da9bc28d\";\n  var D=String.fromCharCode(36);\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function fmtInt(n){return Math.round(n).toLocaleString();}\n  function fmtMoney(n){if(n>=1e6)return D+(n/1e6).toFixed(2)+'M';if(n>=1e3)return D+Math.round(n/1e3)+'K';return D+fmtInt(n);}\n  function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}\n  function render(){var d=rows();var spend=0,rev=0,impr=0,clk=0,conv=0;d.forEach(function(r){spend+=num(r.spend);rev+=num(r.revenue);impr+=num(r.impressions);clk+=num(r.clicks);conv+=num(r.conversions);});set('k-spend',fmtMoney(spend));set('k-rev',fmtMoney(rev));set('k-roas',(spend?(rev/spend):0).toFixed(2)+'x');set('k-ctr',(impr?(clk/impr*100):0).toFixed(2)+'%');set('k-cvr',(clk?(conv/clk*100):0).toFixed(1)+'%');set('k-cpa',fmtMoney(conv?(spend/conv):0));}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{render();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,render);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
