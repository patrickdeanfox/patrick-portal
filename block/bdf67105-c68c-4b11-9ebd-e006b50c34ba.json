{
  "name": "EXEC · Chart Booked Revenue by Channel",
  "type": "html",
  "css": [
    ".wrapper-exec-brc {\n    --surface: var(--block-bg-color, #15151A);\n    --surface-raised: var(--color-gray-100, #1B1B22);\n    --ink: var(--color-text, #F4F4F7);\n    --muted: var(--color-gray-500, #8A8A96);\n    --muted-strong: var(--color-gray-700, #C2C2CC);\n    --line: var(--color-gray-200, rgba(255,255,255,.07));\n    --accent: var(--color-primary, #FFD21E);\n    --accent-2: var(--color-secondary, #FF3D8B);\n    container-type: inline-size;\n    display: block;\n    box-sizing: border-box;\n    width: 100%;\n    max-width: 100%;\n    height: 100%;\n    color: var(--ink);\n    font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n    font-variant-numeric: tabular-nums;\n}\n.wrapper-exec-brc .chart-card-brc {\n    display: flex;\n    flex-direction: column;\n    box-sizing: border-box;\n    min-width: 0;\n    width: 100%;\n    max-width: 100%;\n    height: 100%;\n    min-height: 320px;\n    background: var(--surface);\n    border: 1px solid var(--line);\n    border-radius: 14px;\n    padding: 16px;\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n    transition: border-color .16s ease, box-shadow .16s ease;\n}\n.wrapper-exec-brc .chart-card-brc:hover {\n    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));\n}\n.wrapper-exec-brc .chart-card-brc:focus-within {\n    border-color: color-mix(in srgb, var(--accent) 40%, var(--line));\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5), 0 0 0 1px color-mix(in srgb, var(--accent) 35%, transparent);\n}\n.wrapper-exec-brc .hd-brc {\n    flex: 0 0 auto;\n    min-width: 0;\n    margin-bottom: 12px;\n}\n.wrapper-exec-brc h3 {\n    display: flex;\n    align-items: center;\n    gap: 9px;\n    min-width: 0;\n    margin: 0;\n    font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n    letter-spacing: -.01em;\n    color: var(--ink);\n    overflow-wrap: break-word;\n    word-break: break-word;\n}\n.wrapper-exec-brc h3::before {\n    content: \"\";\n    flex: 0 0 auto;\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: var(--accent);\n}\n.wrapper-exec-brc .sub-brc {\n    min-width: 0;\n    margin: 4px 0 0;\n    font: 500 11px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n    color: var(--muted);\n    overflow-wrap: break-word;\n}\n.wrapper-exec-brc .canvas-brc {\n    flex: 1 1 auto;\n    width: 100%;\n    max-width: 100%;\n    min-width: 0;\n    min-height: 260px;\n}\n@container (max-width: 720px) {\n    .wrapper-exec-brc .chart-card-brc { padding: 14px; }\n    .wrapper-exec-brc .hd-brc { margin-bottom: 10px; }\n    .wrapper-exec-brc .canvas-brc { min-height: 240px; }\n}\n@container (max-width: 520px) {\n    .wrapper-exec-brc .chart-card-brc { padding: 12px; min-height: 280px; }\n    .wrapper-exec-brc .canvas-brc { min-height: 220px; }\n}\n@container (max-width: 360px) {\n    .wrapper-exec-brc .chart-card-brc { padding: 10px; min-height: 260px; }\n    .wrapper-exec-brc .hd-brc { margin-bottom: 8px; }\n    .wrapper-exec-brc .sub-brc { font-size: 10.5px; }\n    .wrapper-exec-brc .canvas-brc { min-height: 220px; }\n}\n@media (prefers-reduced-motion: reduce) {\n    .wrapper-exec-brc .chart-card-brc { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper wrapper-exec-brc\">\n    <div class=\"chart-card-brc\">\n        <div class=\"hd-brc\">\n            <h3>Booked Revenue by Channel</h3>\n            <p class=\"sub-brc\">Net booked revenue per month, stacked by sales channel (USD)</p>\n        </div>\n        <div id=\"chart-exec-brc\" class=\"canvas-brc\" role=\"img\" aria-label=\"Stacked area chart of net booked revenue by month, one band per sales channel\"></div>\n    </div>\n    <script>\n    (function () {\n        'use strict';\n\n        // ---- top-level config ----\n        const DEBUG = false;\n        const TAG = '[EXEC Booked Revenue by Channel]';\n        const log = (...a) => { if (DEBUG) { console.log(TAG, ...a); } };\n        const warn = (...a) => { if (DEBUG) { console.warn(TAG, ...a); } };\n\n        const QUERY_INDEX = { bookedRevenue: 0 };\n        const COL = {\n            month: 'order_month',\n            channel: 'order_channel',\n            revenue: 'net_revenue'\n        };\n\n        const WRAPPER_CLASS = 'wrapper-exec-brc';\n        const CHART_ID = 'chart-exec-brc';\n        const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n        const CHART_TYPE = 'line';        // stacked area = line + stack + areaStyle\n        const STACK_NAME = 'booked-revenue';\n        const AREA_OPACITY = 0.85;\n\n        // channel -> [theme token, dark fallback]: yellow / pink / cyan / green\n        const CHANNEL_STYLE = [\n            ['Web', '--color-primary', '#FFD21E'],\n            ['Phone', '--color-secondary', '#FF3D8B'],\n            ['In-Store', '--color-info', '#34B9F3'],\n            ['Partner', '--color-success', '#36D399']\n        ];\n        const FALLBACK_PALETTE = ['#A78BFA', '#FF9F45', '#2DD4BF'];\n        const CHANNEL_ORDER = CHANNEL_STYLE.map((s) => s[0]);\n\n        const AXIS_LINE_COLOR = 'rgba(255,255,255,.18)';\n        const SPLIT_LINE_COLOR = 'rgba(255,255,255,.06)';\n        const LABEL_COLOR = '#C2C2CC';\n        const TOOLTIP_BG = '#1B1B22';\n        const TOOLTIP_BORDER = 'rgba(255,255,255,.12)';\n        const TOOLTIP_INK = '#F4F4F7';\n\n        // datasources behind the bound query (sol join so) - for filter-reload re-render\n        const DS_IDS = ['5d54ac03-6f8e-4031-9cf6-1f9e42c55f22', '4993d6b7-01aa-494f-bf47-49bf7a183b91'];\n        const MONTH_ABBR = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n\n        // ---- pure helpers ----\n        const getQueryData = (index) => {\n            const q = (currentBlock && currentBlock.queryResults) ? currentBlock.queryResults[index] : null;\n            if (!q || !q.columns) { return []; }\n            if (q.mappedData) { return q.mappedData; }\n            if (!q.data) { return []; }\n            return q.data.map((row) => Object.fromEntries(q.columns.map((c, i) => [c, row[i]])));\n        };\n\n        const fmtMoney = (n) => Number(n || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n        const fmtMoneyCompact = (n) => Number(n || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n        const fmtMonth = (iso) => {\n            if (typeof iso !== 'string') { return String(iso == null ? '' : iso); }\n            const parts = iso.split('-');\n            if (parts.length < 2) { return iso; }\n            const monthIndex = parseInt(parts[1], 10) - 1;\n            return (MONTH_ABBR[monthIndex] || parts[1]) + ' ' + parts[0];\n        };\n\n        const cssVar = (el, name, fallback) => {\n            try {\n                const v = getComputedStyle(el).getPropertyValue(name);\n                return (v && v.trim()) ? v.trim() : fallback;\n            } catch (e) {\n                return fallback;\n            }\n        };\n\n        function shapeData(rows) {\n            const monthSet = new Set();\n            const lookup = {};\n            rows.forEach((r) => {\n                const month = r[COL.month];\n                const channel = r[COL.channel];\n                if (month == null || channel == null) { return; }\n                monthSet.add(month);\n                if (!lookup[channel]) { lookup[channel] = {}; }\n                const prev = lookup[channel][month] || 0;\n                lookup[channel][month] = prev + (Number(r[COL.revenue]) || 0);\n            });\n            const months = Array.from(monthSet).sort();\n            const present = Object.keys(lookup);\n            const orderedChannels = CHANNEL_ORDER.filter((c) => present.indexOf(c) !== -1)\n                .concat(present.filter((c) => CHANNEL_ORDER.indexOf(c) === -1).sort());\n            return { months: months, orderedChannels: orderedChannels, lookup: lookup };\n        }\n\n        function channelColors(wrapperEl, orderedChannels) {\n            const tokenByChannel = {};\n            CHANNEL_STYLE.forEach((s) => { tokenByChannel[s[0]] = { token: s[1], fallback: s[2] }; });\n            const map = {};\n            let fb = 0;\n            orderedChannels.forEach((c) => {\n                const def = tokenByChannel[c];\n                if (def) {\n                    map[c] = cssVar(wrapperEl, def.token, def.fallback);\n                } else {\n                    map[c] = FALLBACK_PALETTE[fb % FALLBACK_PALETTE.length];\n                    fb += 1;\n                }\n            });\n            return map;\n        }\n\n        function buildSeries(shaped, colorMap) {\n            return shaped.orderedChannels.map((channel) => {\n                const color = colorMap[channel];\n                return {\n                    name: channel,\n                    type: CHART_TYPE,\n                    stack: STACK_NAME,\n                    smooth: false,\n                    showSymbol: false,\n                    symbolSize: 6,\n                    emphasis: { focus: 'series' },\n                    lineStyle: { width: 2, color: color },\n                    itemStyle: { color: color },\n                    areaStyle: { opacity: AREA_OPACITY },\n                    data: shaped.months.map((m) => {\n                        const v = shaped.lookup[channel] ? shaped.lookup[channel][m] : null;\n                        return (v == null) ? 0 : Math.round(v * 100) / 100;\n                    })\n                };\n            });\n        }\n\n        function tooltipFormatter(params) {\n            if (!params || !params.length) { return ''; }\n            let total = 0;\n            let html = '<div style=\"font-weight:700;margin-bottom:6px\">' + params[0].axisValueLabel + '</div>';\n            params.forEach((p) => {\n                const val = (typeof p.value === 'number') ? p.value : 0;\n                total += val;\n                html += '<div style=\"display:flex;justify-content:space-between;gap:18px\">'\n                    + '<span>' + p.marker + p.seriesName + '</span>'\n                    + '<span style=\"font-variant-numeric:tabular-nums\">' + fmtMoney(val) + '</span>'\n                    + '</div>';\n            });\n            html += '<div style=\"display:flex;justify-content:space-between;gap:18px;margin-top:6px;'\n                + 'border-top:1px solid rgba(255,255,255,.12);padding-top:5px;font-weight:700\">'\n                + '<span>Total</span>'\n                + '<span style=\"font-variant-numeric:tabular-nums\">' + fmtMoney(total) + '</span>'\n                + '</div>';\n            return html;\n        }\n\n        function buildOption(shaped, colorMap) {\n            const monthLabels = shaped.months.map(fmtMonth);\n            return {\n                backgroundColor: 'transparent',\n                color: shaped.orderedChannels.map((c) => colorMap[c]),\n                grid: { left: 8, right: 14, top: 38, bottom: 6, containLabel: true },\n                legend: {\n                    top: 4,\n                    right: 4,\n                    icon: 'roundRect',\n                    itemWidth: 12,\n                    itemHeight: 12,\n                    itemGap: 14,\n                    textStyle: { color: LABEL_COLOR, fontSize: 11 }\n                },\n                tooltip: {\n                    trigger: 'axis',\n                    backgroundColor: TOOLTIP_BG,\n                    borderColor: TOOLTIP_BORDER,\n                    borderWidth: 1,\n                    padding: 10,\n                    textStyle: { color: TOOLTIP_INK, fontSize: 12 },\n                    formatter: tooltipFormatter\n                },\n                xAxis: {\n                    type: 'category',\n                    boundaryGap: false,\n                    data: monthLabels,\n                    axisLine: { lineStyle: { color: AXIS_LINE_COLOR } },\n                    axisTick: { show: false },\n                    axisLabel: { color: LABEL_COLOR, fontSize: 10, hideOverlap: true }\n                },\n                yAxis: {\n                    type: 'value',\n                    axisLine: { show: false },\n                    axisTick: { show: false },\n                    splitLine: { lineStyle: { color: SPLIT_LINE_COLOR } },\n                    axisLabel: {\n                        color: LABEL_COLOR,\n                        fontSize: 10,\n                        formatter: (v) => fmtMoneyCompact(v)\n                    }\n                },\n                series: buildSeries(shaped, colorMap)\n            };\n        }\n\n        // ---- side-effecting IO ----\n        async function ensureECharts() {\n            if (window.echarts) { return window.echarts; }\n            if (typeof zPortal === 'undefined' || !zPortal.resources || typeof zPortal.resources.load !== 'function') {\n                warn('zPortal.resources.load unavailable');\n                return null;\n            }\n            try {\n                await zPortal.resources.load(ECHARTS_URL);\n            } catch (e) {\n                warn('ECharts load failed', e);\n                return null;\n            }\n            return window.echarts || null;\n        }\n\n        function attachResize(echartsLib, chartEl) {\n            if (typeof ResizeObserver === 'undefined') { return; }\n            if (currentBlock._execBrcRO) {\n                try { currentBlock._execBrcRO.disconnect(); } catch (e) { warn('RO disconnect failed', e); }\n            }\n            const ro = new ResizeObserver(() => {\n                const inst = echartsLib.getInstanceByDom(chartEl);\n                if (inst) { inst.resize(); }\n            });\n            ro.observe(chartEl);\n            currentBlock._execBrcRO = ro;\n        }\n\n        function render(echartsLib) {\n            const chartEl = document.getElementById(CHART_ID);\n            if (!chartEl) { warn('chart container missing'); return; }\n            const prior = echartsLib.getInstanceByDom(chartEl);\n            if (prior) { prior.dispose(); }\n\n            const rows = getQueryData(QUERY_INDEX.bookedRevenue);\n            log('rows', rows.length);\n            if (!rows.length) { chartEl.innerHTML = ''; return; }\n\n            const wrapperEl = document.querySelector('.' + WRAPPER_CLASS) || chartEl;\n            const shaped = shapeData(rows);\n            const colorMap = channelColors(wrapperEl, shaped.orderedChannels);\n            log('months', shaped.months.length, 'channels', shaped.orderedChannels);\n\n            const chart = echartsLib.init(chartEl, null, { renderer: 'canvas' });\n            chart.setOption(buildOption(shaped, colorMap), true);\n            attachResize(echartsLib, chartEl);\n        }\n\n        function subscribeReload(echartsLib) {\n            if (typeof zPortal === 'undefined' || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') { return; }\n            if (currentBlock._execBrcHandler && typeof zPortal.dataSource.off === 'function') {\n                DS_IDS.forEach((id) => {\n                    try { zPortal.dataSource.off('load', id, currentBlock._execBrcHandler); } catch (e) { warn('off failed', e); }\n                });\n            }\n            const handler = () => {\n                try { render(echartsLib); } catch (e) { warn('reload render failed', e); }\n            };\n            currentBlock._execBrcHandler = handler;\n            DS_IDS.forEach((id) => {\n                try { zPortal.dataSource.on('load', id, handler); } catch (e) { warn('subscribe failed', id, e); }\n            });\n        }\n\n        // ---- single orchestrator ----\n        async function init() {\n            const onLoaded = (currentBlock && typeof currentBlock.getOnLoadedCallback === 'function')\n                ? currentBlock.getOnLoadedCallback()\n                : null;\n            let calledBack = false;\n            const done = () => {\n                if (!calledBack && typeof onLoaded === 'function') { calledBack = true; onLoaded(); }\n            };\n            try {\n                const echartsLib = await ensureECharts();\n                if (!echartsLib) { warn('ECharts unavailable'); return; }\n                render(echartsLib);\n                subscribeReload(echartsLib);\n            } catch (e) {\n                warn('init failed', e);\n            } finally {\n                done();\n            }\n        }\n\n        init();\n    })();\n    </script>\n</div>"
  },
