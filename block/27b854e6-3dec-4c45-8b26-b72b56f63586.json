{
  "name": "RT · Chart LTV Distribution",
  "type": "html",
  "css": [
    ".wrapper.ltvdist {\n  --ltv-surface: var(--block-bg-color, #15151A);\n  --ltv-surface-raised: #1B1B22;\n  --ltv-ink: var(--color-text, #F4F4F7);\n  --ltv-muted: var(--color-gray-500, #8A8A96);\n  --ltv-line: var(--color-gray-200, rgba(255,255,255,0.07));\n  --ltv-accent: var(--color-primary, #FFD21E);\n  height: 100%;\n  max-width: 100%;\n  box-sizing: border-box;\n  container-type: inline-size;\n  color: var(--ltv-ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n}\n.wrapper.ltvdist .ltvdist-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-width: 0;\n  box-sizing: border-box;\n  background: var(--ltv-surface);\n  border: 1px solid var(--ltv-line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 6px 18px rgba(0,0,0,0.5);\n  transition: border-color .18s ease;\n}\n.wrapper.ltvdist .ltvdist-card:hover {\n  border-color: color-mix(in srgb, var(--ltv-accent) 30%, var(--ltv-line));\n}\n.wrapper.ltvdist .ltvdist-hdr {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: 10px 14px;\n  margin-bottom: 12px;\n}\n.wrapper.ltvdist .ltvdist-titles {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  min-width: 0;\n  flex: 1 1 auto;\n}\n.wrapper.ltvdist .ltvdist-eyebrow {\n  display: flex;\n  align-items: center;\n  gap: 7px;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: 0.13em;\n  text-transform: uppercase;\n  color: var(--ltv-muted);\n}\n.wrapper.ltvdist .ltvdist-eyebrow::before {\n  content: \"\";\n  flex: none;\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--ltv-accent);\n}\n.wrapper.ltvdist h3 {\n  margin: 0;\n  min-width: 0;\n  font: 800 16px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -0.01em;\n  color: var(--ltv-ink);\n  overflow-wrap: anywhere;\n}\n.wrapper.ltvdist .ltvdist-sub {\n  flex: none;\n  padding-top: 2px;\n  font: 600 11px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: 0.01em;\n  color: var(--ltv-muted);\n  font-variant-numeric: tabular-nums;\n  white-space: nowrap;\n  text-align: right;\n}\n.wrapper.ltvdist .ltvdist-canvas {\n  flex: 1 1 auto;\n  width: 100%;\n  max-width: 100%;\n  min-height: 240px;\n}\n.wrapper.ltvdist .ltvdist-empty {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  min-height: 200px;\n  color: var(--ltv-muted);\n  font: 600 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n}\n@container (max-width: 720px) {\n  .wrapper.ltvdist .ltvdist-sub { text-align: right; }\n}\n@container (max-width: 520px) {\n  .wrapper.ltvdist .ltvdist-card { padding: 14px; }\n  .wrapper.ltvdist .ltvdist-hdr { flex-direction: column; align-items: flex-start; gap: 4px; }\n  .wrapper.ltvdist .ltvdist-sub { white-space: normal; text-align: left; padding-top: 0; }\n}\n@container (max-width: 360px) {\n  .wrapper.ltvdist .ltvdist-card { padding: 12px; border-radius: 12px; }\n  .wrapper.ltvdist h3 { font-size: 15px; }\n  .wrapper.ltvdist .ltvdist-canvas { min-height: 220px; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper.ltvdist .ltvdist-card { transition: none; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": "<div class=\"wrapper ltvdist\">\n  <div class=\"ltvdist-card\">\n    <div class=\"ltvdist-hdr\">\n      <div class=\"ltvdist-titles\">\n        <div class=\"ltvdist-eyebrow\">Retail · Customers</div>\n        <h3>Lifetime Value Distribution</h3>\n      </div>\n      <div class=\"ltvdist-sub\" id=\"ltvdist-sub\" aria-live=\"polite\"></div>\n    </div>\n    <div class=\"ltvdist-canvas\" id=\"ltvdist-chart\" role=\"img\" aria-label=\"Histogram of customer lifetime value\"></div>\n  </div>\n  <script>\n  (function () {\n      'use strict';\n\n      // ===== Top-level config =====\n      const DEBUG = false;\n      const log = (...args) => { if (DEBUG) console.log('[RT LTV Distribution]', ...args); };\n      const logError = (...args) => { if (DEBUG) console.error('[RT LTV Distribution]', ...args); };\n\n      const QUERY_INDEX = { customers: 0 };\n      const COL_LTV = 'lifetime_value';\n      const BUCKET_COUNT = 8;\n\n      const CHART_EL_ID = 'ltvdist-chart';\n      const SUB_EL_ID = 'ltvdist-sub';\n      const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n      const ACCENT_FALLBACK = '#FFD21E';\n      const INK = '#F4F4F7';\n      const MUTED = '#8A8A96';\n      const LABEL_INK = '#C2C2CC';\n      const AXIS_LINE = 'rgba(255,255,255,0.18)';\n      const SPLIT_LINE = 'rgba(255,255,255,0.06)';\n      const TOOLTIP_BG = '#1B1B22';\n      const TOOLTIP_BORDER = 'rgba(255,255,255,0.12)';\n\n      // Async block (library load + render): resolve the loaded callback early.\n      let onLoaded = null;\n      try {\n          onLoaded = currentBlock.getOnLoadedCallback();\n      } catch (err) {\n          onLoaded = null;\n      }\n\n      // ===== Pure helpers =====\n      const getQueryData = (index) => {\n          const q = currentBlock.queryResults[index];\n          if (!q || !q.data) return [];\n          return q.mappedData || q.data.map((row) => Object.fromEntries(q.columns.map((col, k) => [col, row[k]])));\n      };\n\n      const toNumber = (value) => {\n          const n = typeof value === 'number' ? value : parseFloat(value);\n          return Number.isFinite(n) ? n : null;\n      };\n\n      const fmtCurrency = (value) => Number(value).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n\n      const fmtCompact = (value) => Number(value).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n      const buildBuckets = (values, count) => {\n          if (!values.length) return [];\n          let min = values[0];\n          let max = values[0];\n          for (let i = 1; i < values.length; i += 1) {\n              if (values[i] < min) min = values[i];\n              if (values[i] > max) max = values[i];\n          }\n          const span = max - min;\n          const width = span > 0 ? span / count : 1;\n          const buckets = [];\n          for (let i = 0; i < count; i += 1) {\n              const lo = min + (i * width);\n              const hi = i === count - 1 ? max : min + ((i + 1) * width);\n              buckets.push({ lo: lo, hi: hi, count: 0 });\n          }\n          values.forEach((v) => {\n              let idx = Math.floor((v - min) / width);\n              if (idx < 0) idx = 0;\n              if (idx >= count) idx = count - 1;\n              buckets[idx].count += 1;\n          });\n          return buckets;\n      };\n\n      const readAccent = (el) => {\n          const value = getComputedStyle(el).getPropertyValue('--color-primary').trim();\n          return value || ACCENT_FALLBACK;\n      };\n\n      const buildOption = (buckets, accent) => {\n          const axisLabels = buckets.map((b) => fmtCompact(b.lo));\n          const counts = buckets.map((b) => b.count);\n          return {\n              backgroundColor: 'transparent',\n              grid: { left: 6, right: 18, top: 28, bottom: 6, containLabel: true },\n              tooltip: {\n                  trigger: 'axis',\n                  axisPointer: { type: 'shadow', shadowStyle: { color: 'rgba(255,255,255,0.04)' } },\n                  backgroundColor: TOOLTIP_BG,\n                  borderColor: TOOLTIP_BORDER,\n                  borderWidth: 1,\n                  textStyle: { color: INK, fontSize: 12 },\n                  formatter: (params) => {\n                      const p = params[0];\n                      const b = buckets[p.dataIndex];\n                      const range = fmtCurrency(b.lo) + ' - ' + fmtCurrency(b.hi);\n                      return range + '<br/>' + Number(p.value).toLocaleString() + ' customers';\n                  }\n              },\n              xAxis: {\n                  type: 'category',\n                  data: axisLabels,\n                  axisLine: { lineStyle: { color: AXIS_LINE } },\n                  axisTick: { show: false },\n                  axisLabel: { color: LABEL_INK, fontSize: 10, interval: 0, hideOverlap: true }\n              },\n              yAxis: {\n                  type: 'value',\n                  name: 'Customers',\n                  nameTextStyle: { color: MUTED, fontSize: 10, align: 'left' },\n                  axisLine: { show: false },\n                  axisTick: { show: false },\n                  splitLine: { lineStyle: { color: SPLIT_LINE } },\n                  axisLabel: { color: LABEL_INK, fontSize: 10 }\n              },\n              series: [{\n                  type: 'bar',\n                  name: 'Customers',\n                  data: counts,\n                  barWidth: '68%',\n                  itemStyle: { color: accent, borderRadius: [4, 4, 0, 0] },\n                  emphasis: { itemStyle: { color: accent } },\n                  label: {\n                      show: true,\n                      position: 'top',\n                      color: INK,\n                      fontSize: 11,\n                      fontWeight: 600,\n                      formatter: (p) => (p.value > 0 ? Number(p.value).toLocaleString() : '')\n                  }\n              }]\n          };\n      };\n\n      // ===== Side-effecting render =====\n      const renderChart = (buckets, total) => {\n          const el = document.getElementById(CHART_EL_ID);\n          if (!el) {\n              logError('chart element missing', CHART_EL_ID);\n              return;\n          }\n\n          const sub = document.getElementById(SUB_EL_ID);\n          if (sub) {\n              sub.textContent = total ? (total.toLocaleString() + ' customers across ' + BUCKET_COUNT + ' value bands (USD)') : 'No lifetime value data';\n          }\n\n          // Dispose prior render (script re-runs on every query/filter reload).\n          const prior = echarts.getInstanceByDom(el);\n          if (prior) prior.dispose();\n          if (el.__ltvResizeObserver) {\n              el.__ltvResizeObserver.disconnect();\n              el.__ltvResizeObserver = null;\n          }\n\n          if (!buckets.length) {\n              el.innerHTML = '<div class=\"ltvdist-empty\">No lifetime value data</div>';\n              return;\n          }\n          el.innerHTML = '';\n\n          const chart = echarts.init(el, null, { renderer: 'canvas' });\n          chart.setOption(buildOption(buckets, readAccent(el)));\n\n          const observer = new ResizeObserver(() => chart.resize());\n          observer.observe(el);\n          el.__ltvResizeObserver = observer;\n          log('rendered', buckets.length, 'buckets for', total, 'customers');\n      };\n\n      const ensureECharts = () => {\n          if (window.echarts) return Promise.resolve();\n          return zPortal.resources.load(ECHARTS_URL);\n      };\n\n      // ===== Orchestrator =====\n      const init = () => {\n          const rows = getQueryData(QUERY_INDEX.customers);\n          const values = rows\n              .map((r) => toNumber(r[COL_LTV]))\n              .filter((v) => v !== null);\n          log('rows', rows.length, 'numeric lifetime_value', values.length);\n\n          const buckets = buildBuckets(values, BUCKET_COUNT);\n\n          ensureECharts()\n              .then(() => { renderChart(buckets, values.length); })\n              .catch((err) => { logError('echarts load/render failed', err && err.message ? err.message : err); })\n              .finally(() => {\n                  if (onLoaded) {\n                      onLoaded();\n                      onLoaded = null;\n                  }\n              });\n      };\n\n      init();\n  })();\n  </script>\n</div>"
  },
