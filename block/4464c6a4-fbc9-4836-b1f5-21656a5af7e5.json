{
  "name": "SC · Chart Stock Value by Category",
  "type": "html",
  "css": [
    "/* SC · Chart Stock Value by Category — scoped to .sc-stockval */\n.sc-stockval {\n  --scv-surface: var(--block-bg-color, #15151A);\n  --scv-ink: var(--color-text, #F4F4F7);\n  --scv-muted: var(--color-gray-500, #8A8A96);\n  --scv-line: var(--color-gray-200, rgba(255,255,255,.07));\n  --scv-accent: var(--color-primary, #FFD21E);\n  --scv-accent-2: var(--color-secondary, #FF3D8B);\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-height: 320px;\n  box-sizing: border-box;\n  background: var(--scv-surface);\n  border: 1px solid var(--scv-line);\n  border-radius: 14px;\n  padding: 14px 16px;\n  color: var(--scv-ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  container-type: inline-size;\n}\n.sc-stockval .scv-head, .sc-stockval .scv-titles, .sc-stockval .scv-title, .sc-stockval .scv-sub, .sc-stockval .scv-toggle, .sc-stockval .scv-tog, .sc-stockval .scv-chart, .sc-stockval .scv-empty { box-sizing: border-box; }\n.sc-stockval .scv-head {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: 12px;\n  flex-wrap: wrap;\n  margin-bottom: 10px;\n}\n.sc-stockval .scv-titles { min-width: 0; }\n.sc-stockval .scv-title {\n  margin: 0;\n  font-size: 14px;\n  font-weight: 800;\n  line-height: 1.2;\n  color: var(--scv-ink);\n}\n.sc-stockval .scv-sub {\n  margin: 2px 0 0;\n  font-size: 11px;\n  font-weight: 600;\n  line-height: 1.3;\n  color: var(--scv-muted);\n  font-variant-numeric: tabular-nums;\n}\n.sc-stockval .scv-toggle {\n  display: inline-flex;\n  gap: 2px;\n  padding: 3px;\n  background: rgba(255,255,255,.04);\n  border: 1px solid var(--scv-line);\n  border-radius: 10px;\n}\n.sc-stockval .scv-tog {\n  appearance: none;\n  cursor: pointer;\n  border: 0;\n  background: transparent;\n  color: var(--scv-muted);\n  font-family: inherit;\n  font-size: 11px;\n  font-weight: 700;\n  letter-spacing: .02em;\n  padding: 6px 11px;\n  border-radius: 8px;\n  transition: color .15s ease, background .15s ease;\n}\n.sc-stockval .scv-tog:hover { color: var(--scv-ink); }\n.sc-stockval .scv-tog.is-active { background: var(--scv-accent); color: #0B0B0D; }\n.sc-stockval .scv-tog[data-dim=\"store_region\"].is-active { background: var(--scv-accent-2); color: #0B0B0D; }\n.sc-stockval .scv-tog:focus-visible { outline: 2px solid var(--scv-accent); outline-offset: 2px; }\n.sc-stockval .scv-chart { flex: 1 1 auto; width: 100%; min-height: 260px; }\n.sc-stockval .scv-empty {\n  flex: 1 1 auto;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin: 0;\n  min-height: 200px;\n  color: var(--scv-muted);\n  font-size: 12px;\n  text-align: center;\n}\n@container (max-width: 420px) {\n  .sc-stockval .scv-chart { min-height: 220px; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .sc-stockval .scv-tog { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper sc-stockval\" role=\"group\" aria-label=\"Stock value by dimension\">\n  <div class=\"scv-head\">\n    <div class=\"scv-titles\">\n      <h3 class=\"scv-title\">Stock Value</h3>\n      <p class=\"scv-sub\" id=\"scv-sub\">Total inventory value by product category</p>\n    </div>\n    <div class=\"scv-toggle\" role=\"group\" aria-label=\"Choose dimension\">\n      <button type=\"button\" class=\"scv-tog is-active\" data-dim=\"product_category\" aria-pressed=\"true\">By Category</button>\n      <button type=\"button\" class=\"scv-tog\" data-dim=\"store_region\" aria-pressed=\"false\">By Region</button>\n    </div>\n  </div>\n  <div class=\"scv-chart\" id=\"scv-chart\" role=\"img\" aria-label=\"Bar chart of total stock value\" aria-live=\"polite\"></div>\n  <p class=\"scv-empty\" id=\"scv-empty\" hidden>No stock value data for the current filters.</p>\n  <script>\n  (function () {\n    'use strict';\n\n    /* ---------- top-level config ---------- */\n    const DEBUG = false;\n    const log = (...a) => { if (DEBUG) console.log('[SC Stock Value]', ...a); };\n    const err = (...a) => { if (DEBUG) console.error('[SC Stock Value]', ...a); };\n\n    const QUERY_INDEX = { inventory: 0 };\n    const COL = { category: 'product_category', region: 'store_region', value: 'stock_value' };\n    const DEFAULT_DIM = 'product_category';\n    const DIMS = {\n      product_category: { col: COL.category, sub: 'Total inventory value by product category', accentVar: '--color-primary', accentFallback: '#FFD21E' },\n      store_region: { col: COL.region, sub: 'Total inventory value by store region', accentVar: '--color-secondary', accentFallback: '#FF3D8B' }\n    };\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const CHART_ID = 'scv-chart';\n    const SUB_ID = 'scv-sub';\n    const EMPTY_ID = 'scv-empty';\n    const DS_IDS = ['20cee369-59e4-46fd-a9d2-a62d86d5165a', '3b417fa7-e096-417b-88da-8afdec2b5745', '4a8709a5-6910-446a-9744-a70d64e6581c'];\n    const STATE_DIM = '_scvDim';\n    const STATE_RO = '_scvResizeObs';\n    const STATE_HND = '_scvLoadHandler';\n    const STATE_GEN = '_scvGen';\n\n    const cb = (typeof currentBlock !== 'undefined') ? currentBlock : null;\n\n    /* loaded callback (async: ECharts load) */\n    const onLoaded = (cb && typeof cb.getOnLoadedCallback === 'function') ? cb.getOnLoadedCallback() : null;\n    let loadedDone = false;\n    const fireLoaded = () => { if (!loadedDone) { loadedDone = true; if (onLoaded) { try { onLoaded(); } catch (e) { err('onLoaded failed', e); } } } };\n\n    /* ---------- pure helpers ---------- */\n    const getQueryData = (index) => {\n      const q = cb && cb.queryResults && cb.queryResults[index];\n      if (!q || !q.data) return [];\n      if (q.mappedData) return q.mappedData;\n      return q.data.map((row) => Object.fromEntries(q.columns.map((c, i) => [c, row[i]])));\n    };\n\n    const fmtFull = (v) => Number(v || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n    const fmtCompact = (v) => Number(v || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n    const themeColor = (varName, fallback) => {\n      try {\n        const host = document.querySelector('.sc-stockval');\n        if (host) {\n          const v = getComputedStyle(host).getPropertyValue(varName).trim();\n          if (v) return v;\n        }\n      } catch (e) { err('themeColor', e); }\n      return fallback;\n    };\n\n    const aggregate = (rows, dimCol) => {\n      const totals = new Map();\n      for (const row of rows) {\n        const raw = row[dimCol];\n        const key = (raw === null || raw === undefined || raw === '') ? 'Unknown' : String(raw);\n        const val = Number(row[COL.value]) || 0;\n        totals.set(key, (totals.get(key) || 0) + val);\n      }\n      return Array.from(totals, ([name, value]) => ({ name, value })).sort((a, b) => a.value - b.value);\n    };\n\n    /* ---------- render ---------- */\n    const ensureECharts = () => {\n      if (window.echarts) return Promise.resolve();\n      if (window.zPortal && zPortal.resources && typeof zPortal.resources.load === 'function') {\n        return zPortal.resources.load(ECHARTS_URL);\n      }\n      return Promise.reject(new Error('zPortal.resources.load unavailable'));\n    };\n\n    const renderChart = (rows, dimKey) => {\n      const el = document.getElementById(CHART_ID);\n      const empty = document.getElementById(EMPTY_ID);\n      if (!el || !window.echarts) return;\n\n      const dim = DIMS[dimKey] || DIMS[DEFAULT_DIM];\n      const agg = aggregate(rows, dim.col);\n\n      const prior = window.echarts.getInstanceByDom(el);\n      if (prior) prior.dispose();\n\n      if (!agg.length) {\n        if (empty) empty.hidden = false;\n        el.style.display = 'none';\n        return;\n      }\n      if (empty) empty.hidden = true;\n      el.style.display = '';\n\n      const accent = themeColor(dim.accentVar, dim.accentFallback);\n      const ink = themeColor('--color-text', '#F4F4F7');\n      const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n      chart.setOption({\n        backgroundColor: 'transparent',\n        animationDuration: 400,\n        grid: { left: 6, right: 70, top: 12, bottom: 6, containLabel: true },\n        tooltip: {\n          trigger: 'item',\n          backgroundColor: '#1B1B22',\n          borderColor: 'rgba(255,255,255,.12)',\n          borderWidth: 1,\n          textStyle: { color: ink, fontSize: 12 },\n          formatter: (p) => `${p.name}<br/>${fmtFull(p.value)}`\n        },\n        xAxis: {\n          type: 'value',\n          axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n          axisTick: { show: false },\n          splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } },\n          axisLabel: { color: '#C2C2CC', fontSize: 10, formatter: (v) => fmtCompact(v) }\n        },\n        yAxis: {\n          type: 'category',\n          data: agg.map((d) => d.name),\n          axisLine: { lineStyle: { color: 'rgba(255,255,255,.18)' } },\n          axisTick: { show: false },\n          axisLabel: { color: '#C2C2CC', fontSize: 11 }\n        },\n        series: [{\n          type: 'bar',\n          data: agg.map((d) => d.value),\n          barMaxWidth: 30,\n          itemStyle: { color: accent, borderRadius: [0, 4, 4, 0] },\n          label: { show: true, position: 'right', color: ink, fontSize: 10, formatter: (p) => fmtCompact(p.value) }\n        }]\n      });\n\n      if (cb && cb[STATE_RO] && typeof cb[STATE_RO].disconnect === 'function') {\n        try { cb[STATE_RO].disconnect(); } catch (e) { err('RO disconnect', e); }\n      }\n      if (typeof ResizeObserver === 'function') {\n        const ro = new ResizeObserver(() => { try { chart.resize(); } catch (e) { err('resize', e); } });\n        ro.observe(el);\n        if (cb) cb[STATE_RO] = ro;\n      }\n    };\n\n    /* ---------- view orchestration ---------- */\n    const syncToggle = (dimKey) => {\n      document.querySelectorAll('.sc-stockval .scv-tog').forEach((btn) => {\n        const active = btn.getAttribute('data-dim') === dimKey;\n        btn.classList.toggle('is-active', active);\n        btn.setAttribute('aria-pressed', active ? 'true' : 'false');\n      });\n    };\n\n    const drawFor = (rows, dimKey) => {\n      const dim = DIMS[dimKey] ? dimKey : DEFAULT_DIM;\n      syncToggle(dim);\n      const sub = document.getElementById(SUB_ID);\n      if (sub) {\n        const total = rows.reduce((s, r) => s + (Number(r[COL.value]) || 0), 0);\n        sub.textContent = DIMS[dim].sub + ' · ' + fmtFull(total) + ' total';\n      }\n      renderChart(rows, dim);\n    };\n\n    const wireToggle = (rows) => {\n      document.querySelectorAll('.sc-stockval .scv-tog').forEach((btn) => {\n        btn.onclick = () => {\n          const dim = btn.getAttribute('data-dim');\n          if (!DIMS[dim]) return;\n          if (cb) cb[STATE_DIM] = dim;\n          drawFor(rows, dim);\n        };\n      });\n    };\n\n    const wireFilterReload = () => {\n      if (!cb) return;\n      if (!(window.zPortal && zPortal.dataSource && typeof zPortal.dataSource.on === 'function')) return;\n      const gen = (cb[STATE_GEN] || 0) + 1;\n      cb[STATE_GEN] = gen;\n      const prev = cb[STATE_HND];\n      if (prev && typeof zPortal.dataSource.off === 'function') {\n        DS_IDS.forEach((id) => { try { zPortal.dataSource.off('load', id, prev); } catch (e) { err('off', e); } });\n      }\n      const handler = () => {\n        if (cb[STATE_GEN] !== gen) return;\n        const fresh = getQueryData(QUERY_INDEX.inventory);\n        const dim = DIMS[cb[STATE_DIM]] ? cb[STATE_DIM] : DEFAULT_DIM;\n        wireToggle(fresh);\n        drawFor(fresh, dim);\n      };\n      cb[STATE_HND] = handler;\n      DS_IDS.forEach((id) => { try { zPortal.dataSource.on('load', id, handler); } catch (e) { err('on', e); } });\n    };\n\n    /* ---------- init ---------- */\n    const init = () => {\n      try {\n        const rows = getQueryData(QUERY_INDEX.inventory);\n        log('rows', rows.length);\n        const dim = (cb && DIMS[cb[STATE_DIM]]) ? cb[STATE_DIM] : DEFAULT_DIM;\n        wireToggle(rows);\n        wireFilterReload();\n        ensureECharts()\n          .then(() => { drawFor(rows, dim); })\n          .catch((e) => { err('ECharts load failed', e); })\n          .finally(() => { fireLoaded(); });\n      } catch (e) {\n        err('init failed', e);\n        fireLoaded();\n      }\n    };\n\n    init();\n  })();\n  </script>\n</div>"
  },
