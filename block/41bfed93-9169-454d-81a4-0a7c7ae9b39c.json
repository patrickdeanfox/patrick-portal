  "css": [
    ".wrapper.wrate-dept {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: var(--color-gray-100, #1B1B22);\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,0.07));\n  --divider: rgba(255,255,255,0.06);\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n}\n.wrapper.wrate-dept .chart-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  box-sizing: border-box;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 6px 18px rgba(0,0,0,0.5);\n  transition: border-color 0.16s ease, box-shadow 0.16s ease;\n}\n.wrapper.wrate-dept .chart-card:hover {\n  border-color: color-mix(in srgb, var(--accent) 22%, var(--line));\n  box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 10px 26px rgba(0,0,0,0.55);\n}\n.wrapper.wrate-dept .head {\n  margin: 0 0 12px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid var(--divider);\n}\n.wrapper.wrate-dept .eyebrow {\n  display: flex;\n  align-items: center;\n  gap: 7px;\n  margin: 0 0 6px;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: 0.13em;\n  text-transform: uppercase;\n  color: var(--color-gray-700, #C2C2CC);\n}\n.wrapper.wrate-dept .eyebrow::before {\n  content: \"\";\n  width: 7px;\n  height: 7px;\n  flex: 0 0 auto;\n  border-radius: 50%;\n  background: var(--accent);\n}\n.wrapper.wrate-dept .chart-card h3 {\n  margin: 0;\n  font: 800 15px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -0.01em;\n  color: var(--ink);\n}\n.wrapper.wrate-dept .sub {\n  margin: 4px 0 0;\n  font: 500 12px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--muted);\n}\n.wrapper.wrate-dept .canvas {\n  flex: 1;\n  width: 100%;\n  min-height: 280px;\n}\n.wrapper.wrate-dept .empty {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  min-height: 280px;\n  padding: 16px;\n  border: 1px dashed var(--line);\n  border-radius: 12px;\n  color: var(--muted);\n  font: 600 12px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  text-align: center;\n}\n.wrapper.wrate-dept :focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 2px;\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper.wrate-dept .chart-card { transition: none; }\n}\n/* ---------- Responsive: container-query reflow (block sizes to its own grid cell, not the viewport) ---------- */\n.wrapper.wrate-dept { box-sizing: border-box; min-width: 0; max-width: 100%; }\n.wrapper.wrate-dept .head { min-width: 0; }\n.wrapper.wrate-dept .eyebrow { flex-wrap: wrap; min-width: 0; overflow-wrap: anywhere; }\n.wrapper.wrate-dept .chart-card h3,\n.wrapper.wrate-dept .sub { overflow-wrap: break-word; min-width: 0; }\n@container (max-width: 720px) {\n  .wrapper.wrate-dept .chart-card { padding: 14px 16px; }\n  .wrapper.wrate-dept .canvas { min-height: 240px; }\n}\n@container (max-width: 480px) {\n  .wrapper.wrate-dept .chart-card { padding: 12px 14px; }\n  .wrapper.wrate-dept .head { margin-bottom: 10px; padding-bottom: 10px; }\n  .wrapper.wrate-dept .chart-card h3 { font-size: 14px; line-height: 1.2; }\n  .wrapper.wrate-dept .canvas,\n  .wrapper.wrate-dept .empty { min-height: 220px; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper wrate-dept\">\n  <div class=\"chart-card\">\n    <div class=\"head\">\n      <div class=\"eyebrow\">CRM · Win Analytics</div>\n      <h3>Win Rate by Department</h3>\n      <div class=\"sub\">Closed-won share of decided opportunities, with pipeline value as context</div>\n    </div>\n    <div class=\"canvas\" id=\"wrate-dept-canvas\" role=\"img\" aria-label=\"Bar chart of win rate by owner department, with a pipeline-amount line for context\"></div>\n  </div>\n  <script>\n  (function () {\n    'use strict';\n\n    // ---------- Top-level config ----------\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) console.log('[CRM Win Rate by Dept]', ...args); };\n    const logError = (...args) => { if (DEBUG) console.error('[CRM Win Rate by Dept]', ...args); };\n\n    const QUERY_INDEX = { winRateByDept: 0 };\n    const COL = {\n      department: 'owner_department',\n      opportunities: 'opportunities',\n      won: 'won',\n      lost: 'lost',\n      winRate: 'win_rate',\n      pipeline: 'pipeline_amount',\n      weighted: 'weighted_amount'\n    };\n\n    const CANVAS_ID = 'wrate-dept-canvas';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n    // Datasources backing the bound query (filter-driven redraw).\n    const DS_IDS = ['6c5b40d2-9365-42c6-b770-711a30cf689f', '4e3711b1-abf9-48cc-9136-68e8a3f8f813'];\n\n    const COLORS = {\n      winRate: '#FFD21E',\n      pipeline: '#FF3D8B',\n      ink: '#F4F4F7',\n      label: '#C2C2CC',\n      axisLine: 'rgba(255,255,255,0.18)',\n      splitLine: 'rgba(255,255,255,0.06)',\n      tooltipBg: '#1B1B22',\n      tooltipBorder: 'rgba(255,255,255,0.10)'\n    };\n\n    // ---------- Pure data helpers ----------\n    const getQueryData = (index) => {\n      const q = currentBlock.queryResults[index];\n      if (!q || !q.data) return [];\n      return q.mappedData || q.data.map((d) => Object.fromEntries(q.columns.map((c, k) => [c, d[k]])));\n    };\n\n    const toNumber = (value) => {\n      const n = parseFloat(value);\n      return Number.isFinite(n) ? n : 0;\n    };\n\n    const formatPct = (pct) => pct.toFixed(1) + '%';\n\n    const formatMoney = (value) => value.toLocaleString('en-US', {\n      style: 'currency', currency: 'USD', maximumFractionDigits: 0\n    });\n\n    const formatMoneyCompact = (value) => value.toLocaleString('en-US', {\n      style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1\n    });\n\n    const buildRows = () => {\n      const records = getQueryData(QUERY_INDEX.winRateByDept);\n      const rows = records\n        .filter((r) => r[COL.department] != null)\n        .map((r) => ({\n          department: String(r[COL.department]),\n          winRatePct: toNumber(r[COL.winRate]) * 100,\n          pipeline: toNumber(r[COL.pipeline]),\n          opportunities: toNumber(r[COL.opportunities]),\n          won: toNumber(r[COL.won]),\n          lost: toNumber(r[COL.lost])\n        }))\n        .sort((a, b) => b.winRatePct - a.winRatePct);\n      log('rows', rows.length, rows);\n      return rows;\n    };\n\n    // ---------- Chart option (pure) ----------\n    const buildOption = (rows) => {\n      const departments = rows.map((r) => r.department);\n      const winRateSeries = rows.map((r) => Number(r.winRatePct.toFixed(2)));\n      const pipelineSeries = rows.map((r) => r.pipeline);\n\n      return {\n        backgroundColor: 'transparent',\n        grid: { left: 8, right: 14, top: 48, bottom: 8, containLabel: true },\n        legend: {\n          top: 8, right: 8,\n          textStyle: { color: COLORS.label, fontSize: 11 },\n          itemWidth: 12, itemHeight: 8, icon: 'roundRect'\n        },\n        tooltip: {\n          trigger: 'axis',\n          backgroundColor: COLORS.tooltipBg,\n          borderColor: COLORS.tooltipBorder,\n          borderWidth: 1,\n          textStyle: { color: COLORS.ink, fontSize: 12 },\n          formatter: (params) => {\n            if (!params || !params.length) return '';\n            const dept = params[0].axisValueLabel || params[0].name;\n            const row = rows.find((r) => r.department === dept) || {};\n            const out = ['<strong>' + dept + '</strong>'];\n            out.push('Win rate: ' + formatPct(row.winRatePct || 0));\n            out.push('Pipeline: ' + formatMoney(row.pipeline || 0));\n            out.push('Won / Lost: ' + (row.won || 0) + ' / ' + (row.lost || 0));\n            out.push('Opportunities: ' + (row.opportunities || 0).toLocaleString());\n            return out.join('<br/>');\n          }\n        },\n        xAxis: {\n          type: 'category',\n          data: departments,\n          axisTick: { show: false },\n          axisLine: { lineStyle: { color: COLORS.axisLine } },\n          axisLabel: { color: COLORS.label, fontSize: 11 }\n        },\n        yAxis: [\n          {\n            type: 'value',\n            name: 'Win rate',\n            nameTextStyle: { color: COLORS.label, fontSize: 10, align: 'left' },\n            min: 0,\n            axisLine: { show: false },\n            axisTick: { show: false },\n            splitLine: { lineStyle: { color: COLORS.splitLine } },\n            axisLabel: { color: COLORS.label, fontSize: 10, formatter: (v) => v + '%' }\n          },\n          {\n            type: 'value',\n            name: 'Pipeline',\n            nameTextStyle: { color: COLORS.label, fontSize: 10, align: 'right' },\n            min: 0,\n            axisLine: { show: false },\n            axisTick: { show: false },\n            splitLine: { show: false },\n            axisLabel: { color: COLORS.label, fontSize: 10, formatter: (v) => formatMoneyCompact(v) }\n          }\n        ],\n        series: [\n          {\n            name: 'Win rate',\n            type: 'bar',\n            yAxisIndex: 0,\n            data: winRateSeries,\n            barWidth: '46%',\n            itemStyle: { color: COLORS.winRate, borderRadius: [4, 4, 0, 0] },\n            label: {\n              show: true, position: 'top', color: COLORS.ink, fontSize: 11, fontWeight: 700,\n              formatter: (p) => formatPct(p.value)\n            },\n            z: 2\n          },\n          {\n            name: 'Pipeline amount',\n            type: 'line',\n            yAxisIndex: 1,\n            data: pipelineSeries,\n            smooth: true,\n            symbol: 'circle',\n            symbolSize: 7,\n            lineStyle: { color: COLORS.pipeline, width: 2 },\n            itemStyle: { color: COLORS.pipeline },\n            z: 3\n          }\n        ]\n      };\n    };\n\n    // ---------- Render (side effects) ----------\n    const showEmpty = (el) => {\n      el.innerHTML = '<div class=\"empty\">No win-rate data available.</div>';\n    };\n\n    const render = () => {\n      const el = document.getElementById(CANVAS_ID);\n      if (!el || !window.echarts) return;\n\n      const prior = window.echarts.getInstanceByDom(el);\n      if (prior) prior.dispose();\n\n      const rows = buildRows();\n      if (!rows.length) { showEmpty(el); return; }\n      el.innerHTML = '';\n\n      const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n      chart.setOption(buildOption(rows));\n\n      if (window.__wrateDeptRO) window.__wrateDeptRO.disconnect();\n      window.__wrateDeptRO = new ResizeObserver(() => {\n        const inst = window.echarts.getInstanceByDom(el);\n        if (inst) inst.resize();\n      });\n      window.__wrateDeptRO.observe(el);\n      log('rendered', rows.length, 'departments');\n    };\n\n    const subscribeFilters = () => {\n      if (!(window.zPortal && zPortal.dataSource && typeof zPortal.dataSource.on === 'function')) return;\n      if (window.__wrateDeptOnLoad) {\n        DS_IDS.forEach((id) => { try { zPortal.dataSource.off('load', id, window.__wrateDeptOnLoad); } catch (e) { logError('off failed', e); } });\n      }\n      const handler = () => { try { render(); } catch (e) { logError('redraw on load failed', e); } };\n      window.__wrateDeptOnLoad = handler;\n      DS_IDS.forEach((id) => { try { zPortal.dataSource.on('load', id, handler); } catch (e) { logError('on failed', e); } });\n    };\n\n    // ---------- Bottom-level init() ----------\n    const init = () => {\n      let onLoaded = null;\n      try { onLoaded = currentBlock.getOnLoadedCallback(); } catch (e) { logError('no loaded callback', e); }\n      let done = false;\n      const finishLoaded = () => { if (done) return; done = true; if (typeof onLoaded === 'function') { try { onLoaded(); } catch (e) { logError('loaded cb failed', e); } } };\n\n      if (window.echarts) {\n        try { render(); subscribeFilters(); } catch (e) { logError('render failed', e); } finally { finishLoaded(); }\n        return;\n      }\n\n      zPortal.resources.load(ECHARTS_URL)\n        .then(() => { render(); subscribeFilters(); })\n        .catch((e) => { logError('echarts load failed', e); })\n        .finally(() => { finishLoaded(); });\n    };\n\n    init();\n  })();\n  </script>\n</div>"
  },
