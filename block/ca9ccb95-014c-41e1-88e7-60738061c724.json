    "html": [
      "<div class=\"hc-tbl-wrap\">\n  <div class=\"hc-tbl-head\"><h3>Clinical Detail</h3><div class=\"hc-tbl-meta\"><span class=\"hc-tbl-count\" id=\"hc-tbl-count\"></span><input class=\"hc-tbl-search\" id=\"hc-tbl-search\" type=\"text\" placeholder=\"Search…\"></div></div>\n  <div class=\"hc-tbl-scroll\"><table class=\"hc-tbl\"><thead><tr id=\"hc-thead-row\"></tr></thead><tbody id=\"hc-tbody\"></tbody></table></div>\n</div>\n<script>(function(){\n  var CONFIG={dsId:\"dd2191e6-9dc3-4ff3-8b63-6f2e33c07c2a\",cols:[{k:'department',l:'Department'},{k:'physician',l:'Physician'},{k:'procedure_type',l:'Procedure'},{k:'patient_count',l:'Patients',n:true},{k:'avg_los_days',l:'Avg LOS',n:true,dec:1},{k:'readmissions',l:'Readmits',n:true},{k:'revenue',l:'Revenue',n:true,money:true}]};\n  var D=String.fromCharCode(36);\n  var state={sortK:'revenue',dir:-1,q:''};\n  function g(id){return document.getElementById(id);}\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function esc(s){return String(s).replace(/[&<>]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;'}[c];});}\n  function fmt(c,v){if(v==null||v==='')return '';if(c.money)return D+Number(v).toLocaleString();if(c.dec!=null)return Number(v).toFixed(c.dec);if(c.n)return Number(v).toLocaleString();return esc(v);}\n  function data(){var d=rows().slice();if(state.q){var s=state.q.toLowerCase();d=d.filter(function(r){return CONFIG.cols.some(function(c){return String(r[c.k]==null?'':r[c.k]).toLowerCase().indexOf(s)>=0;});});}var col=CONFIG.cols.filter(function(c){return c.k===state.sortK;})[0];d.sort(function(a,b){if(col&&col.n)return (num(a[state.sortK])-num(b[state.sortK]))*state.dir;return String(a[state.sortK]==null?'':a[state.sortK]).localeCompare(String(b[state.sortK]==null?'':b[state.sortK]))*state.dir;});return d;}\n  function renderHead(){var tr=g('hc-thead-row');if(!tr)return;tr.innerHTML='';CONFIG.cols.forEach(function(c){var th=document.createElement('th');if(c.n)th.className='num';th.textContent=c.l;if(state.sortK===c.k){var a=document.createElement('span');a.className='arr';a.textContent=state.dir<0?'▼':'▲';th.appendChild(a);}th.addEventListener('click',function(){if(state.sortK===c.k)state.dir*=-1;else{state.sortK=c.k;state.dir=c.n?-1:1;}renderHead();renderBody();});tr.appendChild(th);});}\n  function renderBody(){var tb=g('hc-tbody');if(!tb)return;var d=data();var html='';d.forEach(function(r){html+='<tr>';CONFIG.cols.forEach(function(c){html+='<td class=\"'+(c.n?'num':'')+'\">'+fmt(c,r[c.k])+'</td>';});html+='</tr>';});tb.innerHTML=html;var cnt=g('hc-tbl-count');if(cnt)cnt.textContent=d.length+' rows';}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{renderHead();renderBody();var s=g('hc-tbl-search');if(s)s.addEventListener('input',function(){state.q=s.value;renderBody();});}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',CONFIG.dsId,renderBody);}catch(e){}}\n  init();\n})();</script>"
