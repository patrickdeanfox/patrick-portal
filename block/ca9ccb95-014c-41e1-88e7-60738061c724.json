    ".hc-tbl-wrap{background:#fff;border:1px solid rgba(0,0,0,.07);border-radius:12px;box-shadow:0 1px 3px rgba(16,24,40,.06);height:100%;box-sizing:border-box;display:flex;flex-direction:column;padding:14px 16px 10px;font-family:var(--font-stack-primary,system-ui,-apple-system,sans-serif);}\n.hc-tbl-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:8px;flex-wrap:wrap;}\n.hc-tbl-head h3{margin:0;font-size:14px;font-weight:800;color:var(--color-text,#1f2937);}\n.hc-tbl-head .hc-tbl-meta{display:flex;align-items:center;gap:10px;}\n.hc-tbl-count{font-size:11px;color:#9ca3af;font-weight:600;}\n.hc-tbl-search{padding:7px 10px;border:1px solid rgba(0,0,0,.15);border-radius:8px;font-size:12px;min-width:170px;font-family:inherit;}\n.hc-tbl-search:focus{outline:none;border-color:var(--color-primary,#009fe4);box-shadow:0 0 0 3px rgba(0,159,228,.15);}\n.hc-tbl-scroll{flex:1 1 auto;overflow:auto;border-radius:8px;}\ntable.hc-tbl{width:100%;border-collapse:collapse;font-size:12.5px;}\n.hc-tbl thead th{position:sticky;top:0;background:#f8fafc;color:#475569;text-align:left;font-weight:700;font-size:11px;letter-spacing:.03em;text-transform:uppercase;padding:9px 10px;border-bottom:1px solid rgba(0,0,0,.08);cursor:pointer;white-space:nowrap;user-select:none;}\n.hc-tbl thead th.num{text-align:right;}\n.hc-tbl thead th .arr{color:var(--color-primary,#009fe4);font-size:9px;margin-left:4px;}\n.hc-tbl tbody td{padding:8px 10px;border-bottom:1px solid rgba(0,0,0,.05);color:var(--color-text,#334155);}\n.hc-tbl tbody td.num{text-align:right;font-variant-numeric:tabular-nums;}\n.hc-tbl tbody tr:hover{background:#f1f5f9;}"
