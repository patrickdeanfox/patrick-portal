{
  "name": "CRM · Sales Bookings (Showcase)",
  "type": "html",
  "css": [
    ".crm-showcase {",
    "  --cs-gap: 14px;",
    "  --cs-radius: 12px;",
    "  --cs-border: 1px solid rgba(127, 127, 127, 0.18);",
    "  --cs-card-bg: var(--block-bg-color, var(--header-bg-color, #ffffff));",
    "  --cs-accent: var(--color-primary, #119DA4);",
    "  box-sizing: border-box;",
    "  width: 100%;",
    "  height: 100%;",
    "  padding: 16px;",
    "  overflow: auto;",
    "  font-family: var(--font-stack-primary, \"Roboto\", \"Segoe UI\", system-ui, sans-serif);",
    "  color: var(--color-text, #2a2f3a);",
    "  background: var(--block-bg-color, transparent);",
    "}",
    ".crm-showcase *, .crm-showcase *::before, .crm-showcase *::after { box-sizing: border-box; }",
    "",
    ".crm-showcase .cs-head {",
    "  display: flex; align-items: flex-start; justify-content: space-between;",
    "  gap: var(--cs-gap); margin-bottom: 14px; flex-wrap: wrap;",
    "}",
    ".crm-showcase .cs-title { font-size: 20px; font-weight: 700; letter-spacing: 0.2px; }",
    ".crm-showcase .cs-sub { font-size: 12px; opacity: 0.65; margin-top: 2px; }",
    ".crm-showcase .cs-actions { display: flex; gap: 8px; }",
    "",
    ".crm-showcase .cs-btn {",
    "  appearance: none; cursor: pointer; font: inherit; font-size: 13px; font-weight: 600;",
    "  padding: 8px 14px; border-radius: 999px; border: none;",
    "  color: #fff; background: var(--cs-accent);",
    "  transition: filter 0.15s ease, transform 0.05s ease;",
    "}",
    ".crm-showcase .cs-btn:hover { filter: brightness(1.07); }",
    ".crm-showcase .cs-btn:active { transform: translateY(1px); }",
    ".crm-showcase .cs-btn:focus-visible { outline: 2px solid var(--cs-accent); outline-offset: 2px; }",
    ".crm-showcase .cs-btn-ghost {",
    "  color: var(--color-text, #2a2f3a); background: transparent; border: var(--cs-border);",
    "}",
    ".crm-showcase .cs-btn-ghost:hover { background: rgba(127, 127, 127, 0.1); filter: none; }",
    "",
    "/* Filters */",
    ".crm-showcase .cs-filters {",
    "  display: flex; flex-wrap: wrap; gap: 10px 18px; align-items: center;",
    "  padding: 12px 14px; margin-bottom: 14px;",
    "  border: var(--cs-border); border-radius: var(--cs-radius); background: var(--cs-card-bg);",
    "}",
    ".crm-showcase .cs-fgroup { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }",
    ".crm-showcase .cs-flabel { font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px; opacity: 0.6; margin-right: 2px; }",
    ".crm-showcase .cs-measure { margin-left: auto; }",
    "",
    ".crm-showcase .cs-chip {",
    "  appearance: none; cursor: pointer; font: inherit; font-size: 12px; font-weight: 500;",
    "  padding: 5px 11px; border-radius: 999px; border: var(--cs-border);",
    "  background: transparent; color: var(--color-text, #2a2f3a);",
    "  transition: background 0.12s ease, border-color 0.12s ease, color 0.12s ease;",
    "}",
    ".crm-showcase .cs-chip:hover { background: rgba(127, 127, 127, 0.1); }",
    ".crm-showcase .cs-chip:focus-visible { outline: 2px solid var(--cs-accent); outline-offset: 2px; }",
    ".crm-showcase .cs-chip.is-active {",
    "  background: var(--cs-accent); border-color: var(--cs-accent); color: #fff;",
    "}",
    "",
    "/* KPI cards */",
    ".crm-showcase .cs-kpis {",
    "  display: grid; grid-template-columns: repeat(5, 1fr); gap: var(--cs-gap); margin-bottom: var(--cs-gap);",
    "}",
    ".crm-showcase .cs-kpi {",
    "  border: var(--cs-border); border-radius: var(--cs-radius); background: var(--cs-card-bg);",
    "  padding: 12px 14px; min-width: 0;",
    "}",
    ".crm-showcase .cs-kpi-val { font-size: 20px; font-weight: 700; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }",
    ".crm-showcase .cs-kpi-label { font-size: 11px; opacity: 0.62; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.4px; }",
    ".crm-showcase .cs-kpi-sub { font-size: 12px; opacity: 0.8; margin-top: 2px; }",
    "",
    "/* Chart grid */",
    ".crm-showcase .cs-grid {",
    "  display: grid; grid-template-columns: 1.5fr 1fr; grid-auto-rows: minmax(0, auto); gap: var(--cs-gap);",
    "}",
    ".crm-showcase .cs-card {",
    "  border: var(--cs-border); border-radius: var(--cs-radius); background: var(--cs-card-bg);",
    "  padding: 12px 14px; min-width: 0;",
    "}",
    ".crm-showcase .cs-card-main { grid-row: span 2; }",
    ".crm-showcase .cs-card-head {",
    "  display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; margin-bottom: 4px;",
    "}",
    ".crm-showcase .cs-card-title { font-size: 14px; font-weight: 700; }",
    ".crm-showcase .cs-card-tools { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }",
    ".crm-showcase .cs-field { font-size: 12px; opacity: 0.85; display: inline-flex; align-items: center; gap: 6px; }",
    ".crm-showcase .cs-select {",
    "  font: inherit; font-size: 12px; padding: 4px 8px; border-radius: 8px;",
    "  border: var(--cs-border); background: var(--cs-card-bg); color: var(--color-text, #2a2f3a);",
    "}",
    ".crm-showcase .cs-toggle { font-size: 12px; display: inline-flex; align-items: center; cursor: pointer; user-select: none; }",
    ".crm-showcase .cs-toggle input { accent-color: var(--cs-accent); cursor: pointer; }",
    "",
    ".crm-showcase .cs-breadcrumb { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; margin: 2px 0 4px; min-height: 18px; }",
    ".crm-showcase .cs-crumb {",
    "  appearance: none; border: none; background: transparent; cursor: pointer; font: inherit;",
    "  font-size: 12px; padding: 2px 6px; border-radius: 6px; color: var(--cs-accent); font-weight: 600;",
    "}",
    ".crm-showcase .cs-crumb:hover { background: rgba(127, 127, 127, 0.12); }",
    ".crm-showcase .cs-crumb.is-current { color: var(--color-text, #2a2f3a); cursor: default; font-weight: 700; }",
    ".crm-showcase .cs-crumb-sep { opacity: 0.45; font-size: 12px; }",
    "",
    ".crm-showcase .cs-chart { width: 100%; height: 360px; }",
    ".crm-showcase .cs-chart-sm { height: 232px; }",
    ".crm-showcase .cs-hint { font-size: 11px; opacity: 0.55; margin-top: 4px; }",
    "",
    ".crm-showcase .cs-empty {",
    "  margin-top: 14px; padding: 18px; text-align: center; font-size: 13px; opacity: 0.7;",
    "  border: 1px dashed rgba(127, 127, 127, 0.4); border-radius: var(--cs-radius);",
    "}",
    "",
    "/* Responsive */",
    "@media (max-width: 1080px) {",
    "  .crm-showcase .cs-kpis { grid-template-columns: repeat(3, 1fr); }",
    "}",
    "@media (max-width: 820px) {",
    "  .crm-showcase .cs-grid { grid-template-columns: 1fr; }",
    "  .crm-showcase .cs-card-main { grid-row: auto; }",
    "  .crm-showcase .cs-measure { margin-left: 0; }",
    "}",
    "@media (max-width: 560px) {",
    "  .crm-showcase .cs-kpis { grid-template-columns: repeat(2, 1fr); }",
    "}"
  ],
  "json_data": {
    "isolated": false,
    "html": [
      "<div class=\"wrapper crm-showcase\" id=\"crm-showcase\">",
      "  <div class=\"cs-head\">",
      "    <div>",
      "      <div class=\"cs-title\">CRM Sales Bookings</div>",
      "      <div class=\"cs-sub\">Industry showcase &middot; interactive bookings analytics</div>",
      "    </div>",
      "    <div class=\"cs-actions\">",
      "      <button type=\"button\" class=\"cs-btn\" data-act=\"export-csv\">&#8681;&nbsp;Export CSV</button>",
      "      <button type=\"button\" class=\"cs-btn cs-btn-ghost\" data-act=\"reset\">Reset</button>",
      "    </div>",
      "  </div>",
      "",
      "  <div class=\"cs-filters\" id=\"cs-filters\"></div>",
      "",
      "  <div class=\"cs-kpis\" id=\"cs-kpis\"></div>",
      "",
      "  <div class=\"cs-grid\">",
      "    <section class=\"cs-card cs-card-main\">",
      "      <header class=\"cs-card-head\">",
      "        <div class=\"cs-card-title\" id=\"cs-main-title\">Bookings by Sales Rep</div>",
      "        <div class=\"cs-card-tools\">",
      "          <label class=\"cs-field\">Group by",
      "            <select id=\"cs-dim\" class=\"cs-select\"></select>",
      "          </label>",
      "          <label class=\"cs-toggle\"><input type=\"checkbox\" id=\"cs-avg\">&nbsp;Average</label>",
      "          <label class=\"cs-toggle\"><input type=\"checkbox\" id=\"cs-trend\">&nbsp;Trend line</label>",
      "        </div>",
      "      </header>",
      "      <div class=\"cs-breadcrumb\" id=\"cs-breadcrumb\"></div>",
      "      <div class=\"cs-chart\" id=\"cs-chart-main\"></div>",
      "      <div class=\"cs-hint\" id=\"cs-drill-hint\"></div>",
      "    </section>",
      "",
      "    <section class=\"cs-card\">",
      "      <header class=\"cs-card-head\"><div class=\"cs-card-title\">Product Line share</div></header>",
      "      <div class=\"cs-chart cs-chart-sm\" id=\"cs-chart-donut\"></div>",
      "    </section>",
      "",
      "    <section class=\"cs-card\">",
      "      <header class=\"cs-card-head\"><div class=\"cs-card-title\">Deal Stage &times; Product Line</div></header>",
      "      <div class=\"cs-chart cs-chart-sm\" id=\"cs-chart-stage\"></div>",
      "    </section>",
      "  </div>",
      "",
      "  <div class=\"cs-empty\" id=\"cs-empty\" hidden>No rows match the current filters.</div>",
      "</div>",
      "",
      "<script>",
      "(function () {",
      "  \"use strict\";",
      "",
      "  // ───────────────────────── Top-level config ─────────────────────────",
      "  var CONFIG = {",
      "    verboseLogging: false,",
      "    echartsUrl: \"https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js\",",
      "    queryIndex: 0,",
      "    rootId: \"crm-showcase\"",
      "  };",
      "",
      "  // Dimensions (drill order starts from the selected group-by dim, then the rest).",
      "  var DIMENSIONS = [",
      "    { key: \"sales_rep\", label: \"Sales Rep\" },",
      "    { key: \"product_line\", label: \"Product Line\" },",
      "    { key: \"deal_stage\", label: \"Deal Stage\" }",
      "  ];",
      "  var MEASURES = [",
      "    { key: \"bookings_amount\", label: \"Bookings\" },",
      "    { key: \"pipeline_value\", label: \"Pipeline\" }",
      "  ];",
      "  var WON_STAGE = \"Closed Won\";",
      "",
      "  // Real rows sampled from the bound datasource; fallback when no query is bound.",
      "  var FALLBACK_ROWS = [",
      "    { sales_rep: \"Alice Johnson\", product_line: \"Enterprise\", deal_stage: \"Closed Won\", bookings_amount: 42000, pipeline_value: 42000 },",
      "    { sales_rep: \"Alice Johnson\", product_line: \"SMB\", deal_stage: \"Closed Won\", bookings_amount: 18500, pipeline_value: 18500 },",
      "    { sales_rep: \"Alice Johnson\", product_line: \"Mid-Market\", deal_stage: \"Proposal\", bookings_amount: 22000, pipeline_value: 22000 },",
      "    { sales_rep: \"Bob Martinez\", product_line: \"Enterprise\", deal_stage: \"Closed Won\", bookings_amount: 67000, pipeline_value: 67000 },",
      "    { sales_rep: \"Bob Martinez\", product_line: \"Enterprise\", deal_stage: \"Negotiation\", bookings_amount: 55000, pipeline_value: 55000 },",
      "    { sales_rep: \"Bob Martinez\", product_line: \"SMB\", deal_stage: \"Closed Won\", bookings_amount: 9800, pipeline_value: 9800 },",
      "    { sales_rep: \"Carol Lee\", product_line: \"Mid-Market\", deal_stage: \"Closed Won\", bookings_amount: 31000, pipeline_value: 31000 },",
      "    { sales_rep: \"Carol Lee\", product_line: \"SMB\", deal_stage: \"Proposal\", bookings_amount: 14000, pipeline_value: 14000 },",
      "    { sales_rep: \"Carol Lee\", product_line: \"Enterprise\", deal_stage: \"Closed Won\", bookings_amount: 48000, pipeline_value: 48000 },",
      "    { sales_rep: \"David Kim\", product_line: \"SMB\", deal_stage: \"Closed Won\", bookings_amount: 11200, pipeline_value: 11200 },",
      "    { sales_rep: \"David Kim\", product_line: \"Mid-Market\", deal_stage: \"Negotiation\", bookings_amount: 27000, pipeline_value: 27000 },",
      "    { sales_rep: \"Eve Patel\", product_line: \"Enterprise\", deal_stage: \"Closed Won\", bookings_amount: 91000, pipeline_value: 91000 },",
      "    { sales_rep: \"Eve Patel\", product_line: \"Mid-Market\", deal_stage: \"Closed Won\", bookings_amount: 34000, pipeline_value: 34000 },",
      "    { sales_rep: \"Eve Patel\", product_line: \"SMB\", deal_stage: \"Proposal\", bookings_amount: 8500, pipeline_value: 8500 },",
      "    { sales_rep: \"Frank Wu\", product_line: \"Enterprise\", deal_stage: \"Negotiation\", bookings_amount: 72000, pipeline_value: 72000 },",
      "    { sales_rep: \"Frank Wu\", product_line: \"Mid-Market\", deal_stage: \"Closed Won\", bookings_amount: 29000, pipeline_value: 29000 },",
      "    { sales_rep: \"Frank Wu\", product_line: \"SMB\", deal_stage: \"Closed Won\", bookings_amount: 15000, pipeline_value: 15000 }",
      "  ];",
      "",
      "  // DEBUG-gated logger.",
      "  var log = function () { if (CONFIG.verboseLogging) console.log.apply(console, [\"[CRM Showcase]\"].concat([].slice.call(arguments))); };",
      "",
      "  // Loaded callback, obtained early (this block does async library loading).",
      "  var loadedCallback = currentBlock.getOnLoadedCallback();",
      "  var animatedCallback = currentBlock.getOnAnimatedCallback ? currentBlock.getOnAnimatedCallback() : function () {};",
      "",
      "  // ───────────────────────── Mutable UI state ─────────────────────────",
      "  var state = {",
      "    filters: { sales_rep: {}, product_line: {}, deal_stage: {} }, // value -> true (active)",
      "    measure: \"bookings_amount\",",
      "    groupDim: \"sales_rep\",",
      "    drill: [],          // [{ dim, value }]",
      "    showAvg: false,",
      "    showTrend: false",
      "  };",
      "",
      "  var allRows = [];",
      "  var charts = { main: null, donut: null, stage: null };",
      "  var rootEl = null;",
      "",
      "  // ───────────────────────── Pure helpers ─────────────────────────",
      "  var toObject = function (names, row) {",
      "    var obj = {};",
      "    for (var i = 0; i < names.length; i++) { obj[names[i]] = row[i]; }",
      "    return obj;",
      "  };",
      "",
      "  // v1.18 queryResults reader (tolerant of row-array and column-keyed shapes).",
      "  var getQueryData = function (index) {",
      "    var r = currentBlock && currentBlock.queryResults && currentBlock.queryResults[index];",
      "    if (!r || !r.data) { return []; }",
      "    var names = (r.columns || []).map(function (c) { return (c && typeof c === \"object\") ? c.name : c; });",
      "    if (!names.length) { return []; }",
      "    var data = r.data;",
      "    if (Array.isArray(data)) {",
      "      return data.map(function (row) { return Array.isArray(row) ? toObject(names, row) : row; });",
      "    }",
      "    var len = data[names[0]] ? data[names[0]].length : 0;",
      "    var out = [];",
      "    for (var i = 0; i < len; i++) {",
      "      var o = {};",
      "      names.forEach(function (n) { o[n] = data[n] ? data[n][i] : undefined; });",
      "      out.push(o);",
      "    }",
      "    return out;",
      "  };",
      "",
      "  var normalizeRows = function (rows) {",
      "    return rows",
      "      .filter(function (r) { return r && r.sales_rep != null && r.product_line != null && r.deal_stage != null; })",
      "      .map(function (r) {",
      "        return {",
      "          sales_rep: String(r.sales_rep),",
      "          product_line: String(r.product_line),",
      "          deal_stage: String(r.deal_stage),",
      "          bookings_amount: Number(r.bookings_amount) || 0,",
      "          pipeline_value: Number(r.pipeline_value) || 0",
      "        };",
      "      });",
      "  };",
      "",
      "  var distinct = function (rows, key) {",
      "    var seen = {}; var out = [];",
      "    rows.forEach(function (r) { if (!seen[r[key]]) { seen[r[key]] = true; out.push(r[key]); } });",
      "    return out.sort();",
      "  };",
      "",
      "  var sumMeasure = function (rows, measureKey) {",
      "    var t = 0; rows.forEach(function (r) { t += Number(r[measureKey]) || 0; }); return t;",
      "  };",
      "",
      "  var aggregateBy = function (rows, dimKey, measureKey) {",
      "    var map = {};",
      "    rows.forEach(function (r) { var k = r[dimKey]; map[k] = (map[k] || 0) + (Number(r[measureKey]) || 0); });",
      "    return Object.keys(map)",
      "      .map(function (k) { return { name: k, value: map[k] }; })",
      "      .sort(function (a, b) { return b.value - a.value; });",
      "  };",
      "",
      "  var measureLabel = function () {",
      "    var m = MEASURES.filter(function (x) { return x.key === state.measure; })[0];",
      "    return m ? m.label : \"Value\";",
      "  };",
      "  var dimLabel = function (key) {",
      "    var d = DIMENSIONS.filter(function (x) { return x.key === key; })[0];",
      "    return d ? d.label : key;",
      "  };",
      "",
      "  var fmtMoney = function (n) {",
      "    return Number(n || 0).toLocaleString(\"en-US\", { style: \"currency\", currency: \"USD\", maximumFractionDigits: 0 });",
      "  };",
      "  var fmtPct = function (n) {",
      "    return (Number(n || 0) * 100).toLocaleString(\"en-US\", { maximumFractionDigits: 1 }) + \"%\";",
      "  };",
      "",
      "  var activeValues = function (key) { return Object.keys(state.filters[key]); };",
      "",
      "  var applyFilters = function (rows) {",
      "    return rows.filter(function (r) {",
      "      return DIMENSIONS.every(function (d) {",
      "        var act = activeValues(d.key);",
      "        return act.length === 0 || state.filters[d.key][r[d.key]];",
      "      });",
      "    });",
      "  };",
      "  var applyDrill = function (rows) {",
      "    return rows.filter(function (r) {",
      "      return state.drill.every(function (step) { return r[step.dim] === step.value; });",
      "    });",
      "  };",
      "",
      "  var dimSequence = function () {",
      "    var rest = DIMENSIONS.map(function (d) { return d.key; }).filter(function (k) { return k !== state.groupDim; });",
      "    return [state.groupDim].concat(rest);",
      "  };",
      "  var currentDim = function () {",
      "    var seq = dimSequence();",
      "    return seq[Math.min(state.drill.length, seq.length - 1)];",
      "  };",
      "  var canDrillDeeper = function () {",
      "    return state.drill.length < dimSequence().length - 1;",
      "  };",
      "",
      "  // Least-squares linear fit over (index, value); returns fitted y values.",
      "  var linearTrend = function (values) {",
      "    var n = values.length;",
      "    if (n < 2) { return null; }",
      "    var sx = 0, sy = 0, sxy = 0, sxx = 0;",
      "    for (var i = 0; i < n; i++) { sx += i; sy += values[i]; sxy += i * values[i]; sxx += i * i; }",
      "    var denom = n * sxx - sx * sx;",
      "    if (denom === 0) { return null; }",
      "    var slope = (n * sxy - sx * sy) / denom;",
      "    var intercept = (sy - slope * sx) / n;",
      "    return values.map(function (_, i) { return slope * i + intercept; });",
      "  };",
      "",
      "  // ───────────────────────── Theme / palette ─────────────────────────",
      "  var themeVar = function (name, fallback) {",
      "    var v = rootEl ? getComputedStyle(rootEl).getPropertyValue(name) : \"\";",
      "    return (v && v.trim()) || fallback;",
      "  };",
      "  var COLORS = {};",
      "  var PALETTE = [];",
      "  var readTheme = function () {",
      "    COLORS.primary = themeVar(\"--color-primary\", \"#119DA4\");",
      "    COLORS.text = themeVar(\"--color-text\", \"#2a2f3a\");",
      "    COLORS.success = themeVar(\"--color-success\", \"#93C54B\");",
      "    COLORS.danger = themeVar(\"--color-danger\", \"#d9534f\");",
      "    COLORS.grid = \"rgba(127,127,127,0.16)\";",
      "    COLORS.muted = \"rgba(127,127,127,0.65)\";",
      "    COLORS.avg = \"#F2A900\";",
      "    COLORS.trend = COLORS.danger;",
      "    PALETTE = [COLORS.primary, \"#6C5CE7\", \"#FF7F50\", \"#2ECC71\", \"#F4C20D\", \"#E84393\", \"#00B8D9\", \"#8E9AAF\"];",
      "  };",
      "  var colorFor = function (value, domain) {",
      "    var idx = domain.indexOf(value);",
      "    return PALETTE[(idx < 0 ? 0 : idx) % PALETTE.length];",
      "  };",
      "",
      "  // ───────────────────────── ECharts loading ─────────────────────────",
      "  var loadScriptOnce = function (src) {",
      "    return new Promise(function (resolve, reject) {",
      "      var existing = document.querySelector('script[data-lib=\"' + src + '\"]');",
      "      if (existing) {",
      "        if (existing.dataset.loaded === \"1\") { resolve(); return; }",
      "        existing.addEventListener(\"load\", function () { resolve(); });",
      "        existing.addEventListener(\"error\", function () { reject(new Error(\"load failed \" + src)); });",
      "        return;",
      "      }",
      "      var s = document.createElement(\"script\");",
      "      s.src = src; s.dataset.lib = src;",
      "      s.addEventListener(\"load\", function () { s.dataset.loaded = \"1\"; resolve(); });",
      "      s.addEventListener(\"error\", function () { reject(new Error(\"load failed \" + src)); });",
      "      document.head.appendChild(s);",
      "    });",
      "  };",
      "  var ensureEcharts = function () {",
      "    if (window.echarts) { return Promise.resolve(); }",
      "    if (window.zPortal && zPortal.resources && zPortal.resources.load) {",
      "      return Promise.resolve(zPortal.resources.load(CONFIG.echartsUrl)).then(function () {",
      "        if (window.echarts) { return; }",
      "        return loadScriptOnce(CONFIG.echartsUrl);",
      "      }).catch(function () { return loadScriptOnce(CONFIG.echartsUrl); });",
      "    }",
      "    return loadScriptOnce(CONFIG.echartsUrl);",
      "  };",
      "",
      "  // ───────────────────────── DOM building ─────────────────────────",
      "  var el = function (id) { return rootEl.querySelector(\"#\" + id); };",
      "",
      "  var buildFilters = function () {",
      "    var host = el(\"cs-filters\");",
      "    host.innerHTML = \"\";",
      "",
      "    DIMENSIONS.forEach(function (d) {",
      "      var group = document.createElement(\"div\");",
      "      group.className = \"cs-fgroup\";",
      "      var label = document.createElement(\"span\");",
      "      label.className = \"cs-flabel\";",
      "      label.textContent = d.label;",
      "      group.appendChild(label);",
      "",
      "      distinct(allRows, d.key).forEach(function (val) {",
      "        var chip = document.createElement(\"button\");",
      "        chip.type = \"button\";",
      "        chip.className = \"cs-chip\";",
      "        chip.textContent = val;",
      "        chip.setAttribute(\"aria-pressed\", \"false\");",
      "        chip.addEventListener(\"click\", function () { toggleFilter(d.key, val); });",
      "        chip.dataset.dim = d.key;",
      "        chip.dataset.val = val;",
      "        group.appendChild(chip);",
      "      });",
      "      host.appendChild(group);",
      "    });",
      "",
      "    var mgroup = document.createElement(\"div\");",
      "    mgroup.className = \"cs-fgroup cs-measure\";",
      "    var mlabel = document.createElement(\"span\");",
      "    mlabel.className = \"cs-flabel\";",
      "    mlabel.textContent = \"Measure\";",
      "    mgroup.appendChild(mlabel);",
      "    MEASURES.forEach(function (m) {",
      "      var b = document.createElement(\"button\");",
      "      b.type = \"button\";",
      "      b.className = \"cs-chip cs-chip-measure\";",
      "      b.textContent = m.label;",
      "      b.dataset.measure = m.key;",
      "      b.addEventListener(\"click\", function () {",
      "        state.measure = m.key;",
      "        syncMeasureChips();",
      "        renderAll();",
      "      });",
      "      mgroup.appendChild(b);",
      "    });",
      "    host.appendChild(mgroup);",
      "",
      "    syncFilterChips();",
      "    syncMeasureChips();",
      "  };",
      "",
      "  var syncFilterChips = function () {",
      "    var chips = rootEl.querySelectorAll(\".cs-chip[data-dim]\");",
      "    [].forEach.call(chips, function (chip) {",
      "      var on = !!state.filters[chip.dataset.dim][chip.dataset.val];",
      "      chip.classList.toggle(\"is-active\", on);",
      "      chip.setAttribute(\"aria-pressed\", on ? \"true\" : \"false\");",
      "    });",
      "  };",
      "  var syncMeasureChips = function () {",
      "    var chips = rootEl.querySelectorAll(\".cs-chip-measure\");",
      "    [].forEach.call(chips, function (chip) {",
      "      chip.classList.toggle(\"is-active\", chip.dataset.measure === state.measure);",
      "    });",
      "  };",
      "",
      "  var buildDimSelect = function () {",
      "    var sel = el(\"cs-dim\");",
      "    sel.innerHTML = \"\";",
      "    DIMENSIONS.forEach(function (d) {",
      "      var o = document.createElement(\"option\");",
      "      o.value = d.key; o.textContent = d.label;",
      "      if (d.key === state.groupDim) { o.selected = true; }",
      "      sel.appendChild(o);",
      "    });",
      "    sel.addEventListener(\"change\", function () {",
      "      state.groupDim = sel.value;",
      "      state.drill = [];",
      "      renderAll();",
      "    });",
      "  };",
      "",
      "  var renderKpis = function () {",
      "    var rows = applyFilters(allRows);",
      "    var total = sumMeasure(rows, state.measure);",
      "    var deals = rows.length;",
      "    var avg = deals ? total / deals : 0;",
      "    var won = sumMeasure(rows.filter(function (r) { return r.deal_stage === WON_STAGE; }), state.measure);",
      "    var winRate = total ? won / total : 0;",
      "    var byRep = aggregateBy(rows, \"sales_rep\", state.measure);",
      "    var top = byRep[0];",
      "",
      "    var cards = [",
      "      { label: measureLabel() + \" (total)\", value: fmtMoney(total) },",
      "      { label: \"Deals\", value: deals.toLocaleString(\"en-US\") },",
      "      { label: \"Avg deal size\", value: fmtMoney(avg) },",
      "      { label: \"Win rate\", value: fmtPct(winRate) },",
      "      { label: \"Top rep\", value: top ? top.name : \"—\", sub: top ? fmtMoney(top.value) : \"\" }",
      "    ];",
      "    var host = el(\"cs-kpis\");",
      "    host.innerHTML = \"\";",
      "    cards.forEach(function (c) {",
      "      var card = document.createElement(\"div\");",
      "      card.className = \"cs-kpi\";",
      "      var v = document.createElement(\"div\"); v.className = \"cs-kpi-val\"; v.textContent = c.value;",
      "      var l = document.createElement(\"div\"); l.className = \"cs-kpi-label\"; l.textContent = c.label;",
      "      card.appendChild(v); card.appendChild(l);",
      "      if (c.sub) { var s = document.createElement(\"div\"); s.className = \"cs-kpi-sub\"; s.textContent = c.sub; card.appendChild(s); }",
      "      host.appendChild(card);",
      "    });",
      "  };",
      "",
      "  var renderBreadcrumb = function () {",
      "    var host = el(\"cs-breadcrumb\");",
      "    host.innerHTML = \"\";",
      "    var crumbs = [{ label: \"All\", level: 0 }].concat(state.drill.map(function (s, i) {",
      "      return { label: dimLabel(s.dim) + \": \" + s.value, level: i + 1 };",
      "    }));",
      "    crumbs.forEach(function (c, i) {",
      "      if (i > 0) {",
      "        var sep = document.createElement(\"span\"); sep.className = \"cs-crumb-sep\"; sep.textContent = \"›\";",
      "        host.appendChild(sep);",
      "      }",
      "      var b = document.createElement(\"button\");",
      "      b.type = \"button\";",
      "      b.className = \"cs-crumb\" + (i === crumbs.length - 1 ? \" is-current\" : \"\");",
      "      b.textContent = c.label;",
      "      b.addEventListener(\"click\", function () { state.drill = state.drill.slice(0, c.level); renderAll(); });",
      "      host.appendChild(b);",
      "    });",
      "  };",
      "",
      "  var baseChartGrid = function () {",
      "    return { left: 8, right: 18, top: 24, bottom: 8, containLabel: true };",
      "  };",
      "  var toolbox = function (name) {",
      "    return {",
      "      right: 6, top: -2, itemSize: 13,",
      "      feature: {",
      "        saveAsImage: { title: \"PNG\", name: name, pixelRatio: 2, backgroundColor: themeVar(\"--body-bg-color\", \"#ffffff\") },",
      "        dataView: { title: \"Data\", readOnly: true, lang: [\"Data view\", \"Close\", \"Refresh\"] },",
      "        restore: { title: \"Reset zoom\" }",
      "      },",
      "      iconStyle: { borderColor: COLORS.muted }",
      "    };",
      "  };",
      "",
      "  var renderMain = function () {",
      "    var dimKey = currentDim();",
      "    var rows = applyDrill(applyFilters(allRows));",
      "    var agg = aggregateBy(rows, dimKey, state.measure);",
      "    var cats = agg.map(function (a) { return a.name; });",
      "    var vals = agg.map(function (a) { return a.value; });",
      "",
      "    el(\"cs-main-title\").textContent = measureLabel() + \" by \" + dimLabel(dimKey);",
      "    el(\"cs-drill-hint\").textContent = canDrillDeeper()",
      "      ? \"Tip: click a bar to drill into \" + dimLabel(dimSequence()[state.drill.length + 1]) + \".\"",
      "      : \"Deepest level — use the breadcrumb to step back up.\";",
      "",
      "    var series = [{",
      "      type: \"bar\", name: measureLabel(), data: vals,",
      "      barMaxWidth: 46,",
      "      itemStyle: { color: COLORS.primary, borderRadius: [4, 4, 0, 0] },",
      "      emphasis: { focus: \"self\" },",
      "      markLine: state.showAvg ? {",
      "        silent: true, symbol: \"none\",",
      "        lineStyle: { type: \"dashed\", color: COLORS.avg, width: 2 },",
      "        data: [{ type: \"average\", name: \"Avg\" }],",
      "        label: { formatter: function (p) { return \"Avg \" + fmtMoney(p.value); }, color: COLORS.avg, position: \"insideEndTop\" }",
      "      } : null",
      "    }];",
      "",
      "    if (state.showTrend) {",
      "      var trend = linearTrend(vals);",
      "      if (trend) {",
      "        series.push({",
      "          type: \"line\", name: \"Trend\", data: trend, symbol: \"none\", smooth: false,",
      "          lineStyle: { color: COLORS.trend, width: 2 }, z: 6, tooltip: { show: false }",
      "        });",
      "      }",
      "    }",
      "",
      "    charts.main.setOption({",
      "      color: PALETTE,",
      "      textStyle: { color: COLORS.text },",
      "      tooltip: {",
      "        trigger: \"axis\", axisPointer: { type: \"shadow\" },",
      "        valueFormatter: function (v) { return fmtMoney(v); }",
      "      },",
      "      legend: { show: state.showTrend, bottom: 0, textStyle: { color: COLORS.text }, data: [\"Trend\"] },",
      "      toolbox: toolbox(\"crm-bookings-by-\" + dimKey),",
      "      grid: { left: 8, right: 18, top: 24, bottom: state.showTrend ? 28 : 8, containLabel: true },",
      "      xAxis: {",
      "        type: \"category\", data: cats,",
      "        axisLabel: { color: COLORS.text, interval: 0, hideOverlap: true, rotate: cats.length > 5 ? 22 : 0 },",
      "        axisLine: { lineStyle: { color: COLORS.grid } }, axisTick: { show: false }",
      "      },",
      "      yAxis: {",
      "        type: \"value\",",
      "        axisLabel: { color: COLORS.muted, formatter: function (v) { return v >= 1000 ? (v / 1000) + \"k\" : v; } },",
      "        splitLine: { lineStyle: { color: COLORS.grid } }",
      "      },",
      "      series: series",
      "    }, true);",
      "  };",
      "",
      "  var renderDonut = function () {",
      "    var rows = applyFilters(allRows);",
      "    var agg = aggregateBy(rows, \"product_line\", state.measure);",
      "    var domain = distinct(allRows, \"product_line\");",
      "    charts.donut.setOption({",
      "      textStyle: { color: COLORS.text },",
      "      tooltip: { trigger: \"item\", valueFormatter: function (v) { return fmtMoney(v); } },",
      "      legend: { bottom: 0, textStyle: { color: COLORS.text } },",
      "      toolbox: toolbox(\"crm-product-line-share\"),",
      "      series: [{",
      "        type: \"pie\", radius: [\"46%\", \"72%\"], center: [\"50%\", \"44%\"], avoidLabelOverlap: true,",
      "        itemStyle: { borderColor: themeVar(\"--body-bg-color\", \"#fff\"), borderWidth: 2 },",
      "        label: { color: COLORS.text, formatter: function (p) { return p.name + \"\\n\" + p.percent + \"%\"; } },",
      "        data: agg.map(function (a) { return { name: a.name, value: a.value, itemStyle: { color: colorFor(a.name, domain) } }; })",
      "      }]",
      "    }, true);",
      "  };",
      "",
      "  var renderStage = function () {",
      "    var rows = applyFilters(allRows);",
      "    var stages = distinct(allRows, \"deal_stage\");",
      "    var plines = distinct(allRows, \"product_line\");",
      "    var series = plines.map(function (pl) {",
      "      return {",
      "        name: pl, type: \"bar\", stack: \"total\", barMaxWidth: 48,",
      "        itemStyle: { color: colorFor(pl, plines) },",
      "        emphasis: { focus: \"series\" },",
      "        data: stages.map(function (st) {",
      "          return sumMeasure(rows.filter(function (r) { return r.deal_stage === st && r.product_line === pl; }), state.measure);",
      "        })",
      "      };",
      "    });",
      "    charts.stage.setOption({",
      "      textStyle: { color: COLORS.text },",
      "      tooltip: { trigger: \"axis\", axisPointer: { type: \"shadow\" }, valueFormatter: function (v) { return fmtMoney(v); } },",
      "      legend: { bottom: 0, textStyle: { color: COLORS.text } },",
      "      toolbox: toolbox(\"crm-deal-stage\"),",
      "      grid: { left: 8, right: 16, top: 16, bottom: 28, containLabel: true },",
      "      xAxis: {",
      "        type: \"category\", data: stages,",
      "        axisLabel: { color: COLORS.text }, axisLine: { lineStyle: { color: COLORS.grid } }, axisTick: { show: false }",
      "      },",
      "      yAxis: {",
      "        type: \"value\",",
      "        axisLabel: { color: COLORS.muted, formatter: function (v) { return v >= 1000 ? (v / 1000) + \"k\" : v; } },",
      "        splitLine: { lineStyle: { color: COLORS.grid } }",
      "      },",
      "      series: series",
      "    }, true);",
      "  };",
      "",
      "  // ───────────────────────── Interactions ─────────────────────────",
      "  var toggleFilter = function (dimKey, value) {",
      "    if (state.filters[dimKey][value]) { delete state.filters[dimKey][value]; }",
      "    else { state.filters[dimKey][value] = true; }",
      "    // Drill steps that contradict the active filter no longer make sense — prune them.",
      "    state.drill = state.drill.filter(function (s) {",
      "      var act = activeValues(s.dim);",
      "      return act.length === 0 || state.filters[s.dim][s.value];",
      "    });",
      "    renderAll();",
      "  };",
      "",
      "  var onMainBarClick = function (params) {",
      "    if (params.componentType !== \"series\" || params.seriesType !== \"bar\") { return; }",
      "    if (!canDrillDeeper()) { return; }",
      "    state.drill.push({ dim: currentDim(), value: params.name });",
      "    renderAll();",
      "  };",
      "",
      "  var resetAll = function () {",
      "    DIMENSIONS.forEach(function (d) { state.filters[d.key] = {}; });",
      "    state.measure = \"bookings_amount\";",
      "    state.groupDim = \"sales_rep\";",
      "    state.drill = [];",
      "    state.showAvg = false;",
      "    state.showTrend = false;",
      "    el(\"cs-avg\").checked = false;",
      "    el(\"cs-trend\").checked = false;",
      "    var sel = el(\"cs-dim\"); if (sel) { sel.value = state.groupDim; }",
      "    syncMeasureChips();",
      "    renderAll();",
      "  };",
      "",
      "  var rowsToCsv = function (rows) {",
      "    var cols = [\"sales_rep\", \"product_line\", \"deal_stage\", \"bookings_amount\", \"pipeline_value\"];",
      "    var esc = function (v) {",
      "      var s = String(v == null ? \"\" : v);",
      "      return /[\",\\n]/.test(s) ? '\"' + s.replace(/\"/g, '\"\"') + '\"' : s;",
      "    };",
      "    var lines = [cols.join(\",\")];",
      "    rows.forEach(function (r) { lines.push(cols.map(function (c) { return esc(r[c]); }).join(\",\")); });",
      "    return lines.join(\"\\n\");",
      "  };",
      "  var exportCsv = function () {",
      "    var rows = applyDrill(applyFilters(allRows));",
      "    var blob = new Blob([rowsToCsv(rows)], { type: \"text/csv;charset=utf-8;\" });",
      "    var url = URL.createObjectURL(blob);",
      "    var a = document.createElement(\"a\");",
      "    a.href = url; a.download = \"crm-sales-bookings.csv\";",
      "    document.body.appendChild(a); a.click();",
      "    document.body.removeChild(a);",
      "    setTimeout(function () { URL.revokeObjectURL(url); }, 1000);",
      "  };",
      "",
      "  // ───────────────────────── Orchestration ─────────────────────────",
      "  var renderAll = function () {",
      "    var filtered = applyFilters(allRows);",
      "    el(\"cs-empty\").hidden = filtered.length > 0;",
      "    syncFilterChips();",
      "    renderBreadcrumb();",
      "    renderKpis();",
      "    renderMain();",
      "    renderDonut();",
      "    renderStage();",
      "  };",
      "",
      "  var resizeAll = function () {",
      "    Object.keys(charts).forEach(function (k) { if (charts[k]) { charts[k].resize(); } });",
      "  };",
      "",
      "  var disposeExisting = function () {",
      "    [\"cs-chart-main\", \"cs-chart-donut\", \"cs-chart-stage\"].forEach(function (id) {",
      "      var node = rootEl.querySelector(\"#\" + id);",
      "      if (node && window.echarts) {",
      "        var inst = echarts.getInstanceByDom(node);",
      "        if (inst) { inst.dispose(); }",
      "      }",
      "    });",
      "    if (window.__crmShowcaseCleanup) { try { window.__crmShowcaseCleanup(); } catch (e) { log(\"cleanup failed\", e); } }",
      "  };",
      "",
      "  var wireStaticControls = function () {",
      "    el(\"cs-avg\").addEventListener(\"change\", function (e) { state.showAvg = e.target.checked; renderMain(); });",
      "    el(\"cs-trend\").addEventListener(\"change\", function (e) { state.showTrend = e.target.checked; renderMain(); });",
      "    rootEl.querySelector('[data-act=\"export-csv\"]').addEventListener(\"click\", exportCsv);",
      "    rootEl.querySelector('[data-act=\"reset\"]').addEventListener(\"click\", resetAll);",
      "  };",
      "",
      "  var init = function () {",
      "    rootEl = document.getElementById(CONFIG.rootId);",
      "    if (!rootEl) { loadedCallback(); return; }",
      "    readTheme();",
      "",
      "    var live = normalizeRows(getQueryData(CONFIG.queryIndex));",
      "    allRows = live.length ? live : normalizeRows(FALLBACK_ROWS);",
      "    log(\"rows\", allRows.length, live.length ? \"(live)\" : \"(fallback)\");",
      "",
      "    buildFilters();",
      "    buildDimSelect();",
      "    wireStaticControls();",
      "",
      "    ensureEcharts().then(function () {",
      "      disposeExisting();",
      "      charts.main = echarts.init(el(\"cs-chart-main\"));",
      "      charts.donut = echarts.init(el(\"cs-chart-donut\"));",
      "      charts.stage = echarts.init(el(\"cs-chart-stage\"));",
      "",
      "      charts.main.on(\"click\", onMainBarClick);",
      "      charts.donut.on(\"click\", function (p) { toggleFilter(\"product_line\", p.name); });",
      "      charts.stage.on(\"click\", function (p) { if (p.name) { toggleFilter(\"deal_stage\", p.name); } });",
      "",
      "      var onResize = function () { resizeAll(); };",
      "      window.addEventListener(\"resize\", onResize);",
      "      window.__crmShowcaseCleanup = function () {",
      "        window.removeEventListener(\"resize\", onResize);",
      "        Object.keys(charts).forEach(function (k) { if (charts[k]) { charts[k].dispose(); } });",
      "      };",
      "",
      "      renderAll();",
      "      animatedCallback();",
      "    }).catch(function (err) {",
      "      log(\"ECharts failed to load\", err);",
      "      el(\"cs-empty\").hidden = false;",
      "      el(\"cs-empty\").textContent = \"Charts could not be loaded.\";",
      "    }).then(function () {",
      "      loadedCallback();",
      "    });",
      "  };",
      "",
      "  init();",
      "})();",
      "</script>"
    ]
  },
  "ui_queries": [
    {
      "enabled": true,
      "page_size": 1000,
      "filter_strategy": {
        "type": "blacklist",
        "value": []
      },
      "query_id": "5ffb2cdb-bfbf-41d3-8fc9-758a17cbbbdd"
    }
