{
  "name": "EXEC · Chart Revenue & Margin Trend",
  "type": "html",
  "css": [
    ".wrapper-exec-revmargin {\n  --rm-surface: var(--block-bg-color, #15151A);\n  --rm-surface-raised: #1B1B22;\n  --rm-ink: var(--color-text, #F4F4F7);\n  --rm-muted: var(--color-gray-500, #8A8A96);\n  --rm-line: var(--color-gray-200, rgba(255,255,255,0.07));\n  --rm-accent: var(--color-primary, #FFD21E);\n  --rm-accent-2: var(--color-secondary, #FF3D8B);\n  --rm-font: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  container-type: inline-size;\n  box-sizing: border-box;\n  width: 100%;\n  max-width: 100%;\n  height: 100%;\n  color: var(--rm-ink);\n  font-family: var(--rm-font);\n  font-variant-numeric: tabular-nums;\n}\n.wrapper-exec-revmargin .card-rm {\n  box-sizing: border-box;\n  display: flex;\n  flex-direction: column;\n  width: 100%;\n  max-width: 100%;\n  height: 100%;\n  min-height: 360px;\n  min-width: 0;\n  background: var(--rm-surface);\n  border: 1px solid var(--rm-line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 6px 18px rgba(0,0,0,0.5);\n  transition: border-color .16s ease, box-shadow .16s ease, background-color .16s ease;\n}\n.wrapper-exec-revmargin .card-rm:hover,\n.wrapper-exec-revmargin .card-rm:focus-within {\n  background: var(--rm-surface-raised);\n  border-color: color-mix(in srgb, var(--rm-accent) 35%, var(--rm-line));\n  box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 8px 24px rgba(0,0,0,0.55), 0 0 26px -12px color-mix(in srgb, var(--rm-accent) 60%, transparent);\n}\n.wrapper-exec-revmargin .card-rm:focus-visible {\n  outline: 2px solid var(--rm-accent);\n  outline-offset: 2px;\n}\n.wrapper-exec-revmargin .head-rm {\n  box-sizing: border-box;\n  display: flex;\n  flex-direction: column;\n  gap: 3px;\n  margin-bottom: 12px;\n  min-width: 0;\n}\n.wrapper-exec-revmargin .eyebrow-rm {\n  display: inline-flex;\n  align-items: center;\n  font: 700 11px/1.2 var(--rm-font);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--rm-muted);\n}\n.wrapper-exec-revmargin .eyebrow-rm::before {\n  content: \"\";\n  flex: none;\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  margin-right: 8px;\n  background: var(--rm-accent);\n}\n.wrapper-exec-revmargin .title-rm {\n  margin: 0;\n  font: 800 16px/1.25 var(--rm-font);\n  letter-spacing: -0.01em;\n  color: var(--rm-ink);\n  overflow-wrap: break-word;\n  word-break: break-word;\n}\n.wrapper-exec-revmargin .sub-rm {\n  font: 500 11px/1.35 var(--rm-font);\n  color: var(--rm-muted);\n  overflow-wrap: break-word;\n}\n.wrapper-exec-revmargin .canvas-rm {\n  box-sizing: border-box;\n  flex: 1 1 auto;\n  width: 100%;\n  max-width: 100%;\n  min-width: 0;\n  min-height: 300px;\n}\n@container (max-width: 720px) {\n  .wrapper-exec-revmargin .card-rm { min-height: 320px; padding: 16px; }\n  .wrapper-exec-revmargin .canvas-rm { min-height: 260px; }\n}\n@container (max-width: 560px) {\n  .wrapper-exec-revmargin .card-rm { min-height: 300px; padding: 14px; }\n  .wrapper-exec-revmargin .title-rm { font-size: 15px; }\n  .wrapper-exec-revmargin .canvas-rm { min-height: 240px; }\n}\n@container (max-width: 420px) {\n  .wrapper-exec-revmargin .card-rm { min-height: 280px; padding: 12px; }\n  .wrapper-exec-revmargin .head-rm { margin-bottom: 10px; }\n  .wrapper-exec-revmargin .title-rm { font-size: 14px; }\n  .wrapper-exec-revmargin .canvas-rm { min-height: 220px; }\n}\n@supports not (container-type: inline-size) {\n  @media (max-width: 560px) {\n    .wrapper-exec-revmargin .card-rm { min-height: 300px; padding: 14px; }\n    .wrapper-exec-revmargin .title-rm { font-size: 15px; }\n    .wrapper-exec-revmargin .canvas-rm { min-height: 240px; }\n  }\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper-exec-revmargin .card-rm { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper wrapper-exec-revmargin\">\n  <div class=\"card-rm\">\n    <div class=\"head-rm\">\n      <span class=\"eyebrow-rm\">Executive Overview</span>\n      <h3 class=\"title-rm\">Revenue &amp; Margin Trend</h3>\n      <span class=\"sub-rm\">Monthly net revenue &amp; gross margin (USD)</span>\n    </div>\n    <div id=\"chart-rm\" class=\"canvas-rm\" role=\"img\" aria-label=\"Area and line chart of monthly net revenue and gross margin\"></div>\n  </div>\n  <script>\n  (function () {\n    'use strict';\n\n    /* ---------- top-level config ---------- */\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) console.log('[EXEC Revenue and Margin Trend]', ...args); };\n    const warn = (...args) => { if (DEBUG) console.warn('[EXEC Revenue and Margin Trend]', ...args); };\n\n    const QUERY_INDEX = { trend: 0 };\n    const COL = { month: 'order_month', revenue: 'net_revenue', margin: 'gross_margin' };\n\n    const CHART_EL_ID = 'chart-rm';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n    const FALLBACK_ACCENT = '#FFD21E';\n    const FALLBACK_ACCENT_2 = '#FF3D8B';\n    const COLOR_AXIS_LABEL = '#C2C2CC';\n    const COLOR_AXIS_LINE = 'rgba(255,255,255,0.18)';\n    const COLOR_SPLIT_LINE = 'rgba(255,255,255,0.06)';\n    const COLOR_TOOLTIP_BG = '#1B1B22';\n    const COLOR_TOOLTIP_BORDER = 'rgba(255,255,255,0.12)';\n    const COLOR_INK = '#F4F4F7';\n\n    const usd = (value) => Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n    const usdCompact = (value) => Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n    /* ---------- pure helpers ---------- */\n    function getQueryData(index) {\n      const result = currentBlock.queryResults[index];\n      if (!result || !result.data) return [];\n      return result.data.map((row) => Object.fromEntries(result.columns.map((col, k) => [col, row[k]])));\n    }\n\n    function readThemeColor(varName, fallback) {\n      try {\n        const root = document.querySelector('.wrapper-exec-revmargin');\n        if (!root) return fallback;\n        const value = getComputedStyle(root).getPropertyValue(varName);\n        return (value && value.trim()) ? value.trim() : fallback;\n      } catch (err) {\n        return fallback;\n      }\n    }\n\n    function formatMonthLabel(value) {\n      const date = new Date(value);\n      if (isNaN(date.getTime())) return String(value);\n      return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });\n    }\n\n    function buildOption(rows) {\n      const accent = readThemeColor('--color-primary', FALLBACK_ACCENT);\n      const accent2 = readThemeColor('--color-secondary', FALLBACK_ACCENT_2);\n      const months = rows.map((r) => formatMonthLabel(r[COL.month]));\n      const revenue = rows.map((r) => Number(r[COL.revenue] || 0));\n      const margin = rows.map((r) => Number(r[COL.margin] || 0));\n\n      const tooltipFormatter = (params) => {\n        if (!params || !params.length) return '';\n        const head = params[0].axisValueLabel || params[0].name;\n        const body = params.map((p) => {\n          const label = '<span style=\"color:' + COLOR_AXIS_LABEL + '\">' + p.marker + p.seriesName + '</span>';\n          const amount = '<span style=\"font-weight:700;color:' + COLOR_INK + '\">' + usd(p.value) + '</span>';\n          return '<div style=\"display:flex;justify-content:space-between;gap:24px;line-height:1.7;\">' + label + amount + '</div>';\n        }).join('');\n        return '<div style=\"font-weight:700;margin-bottom:4px;color:' + COLOR_INK + '\">' + head + '</div>' + body;\n      };\n\n      return {\n        backgroundColor: 'transparent',\n        color: [accent, accent2],\n        grid: { left: 8, right: 16, top: 48, bottom: 8, containLabel: true },\n        legend: {\n          data: ['Net Revenue', 'Gross Margin'],\n          top: 8,\n          right: 6,\n          icon: 'roundRect',\n          itemWidth: 12,\n          itemHeight: 8,\n          itemGap: 18,\n          textStyle: { color: COLOR_AXIS_LABEL, fontSize: 11 }\n        },\n        tooltip: {\n          trigger: 'axis',\n          backgroundColor: COLOR_TOOLTIP_BG,\n          borderColor: COLOR_TOOLTIP_BORDER,\n          borderWidth: 1,\n          padding: [8, 12],\n          textStyle: { color: COLOR_INK, fontSize: 12 },\n          axisPointer: { type: 'line', lineStyle: { color: 'rgba(255,255,255,0.18)', width: 1 } },\n          formatter: tooltipFormatter\n        },\n        xAxis: {\n          type: 'category',\n          data: months,\n          boundaryGap: false,\n          axisTick: { show: false },\n          axisLine: { lineStyle: { color: COLOR_AXIS_LINE } },\n          axisLabel: { color: COLOR_AXIS_LABEL, fontSize: 11, hideOverlap: true }\n        },\n        yAxis: {\n          type: 'value',\n          axisLine: { show: false },\n          axisTick: { show: false },\n          splitLine: { lineStyle: { color: COLOR_SPLIT_LINE } },\n          axisLabel: { color: COLOR_AXIS_LABEL, fontSize: 11, formatter: (v) => usdCompact(v) }\n        },\n        series: [\n          {\n            name: 'Net Revenue',\n            type: 'line',\n            smooth: true,\n            showSymbol: false,\n            symbolSize: 7,\n            z: 2,\n            lineStyle: { width: 2.5, color: accent },\n            itemStyle: { color: accent },\n            emphasis: { focus: 'series' },\n            areaStyle: {\n              opacity: 1,\n              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n                { offset: 0, color: 'rgba(255,210,30,0.40)' },\n                { offset: 0.55, color: 'rgba(255,210,30,0.14)' },\n                { offset: 1, color: 'rgba(255,210,30,0.02)' }\n              ])\n            },\n            data: revenue\n          },\n          {\n            name: 'Gross Margin',\n            type: 'line',\n            smooth: true,\n            showSymbol: false,\n            symbolSize: 7,\n            z: 3,\n            lineStyle: { width: 2.5, color: accent2 },\n            itemStyle: { color: accent2 },\n            emphasis: { focus: 'series' },\n            data: margin\n          }\n        ]\n      };\n    }\n\n    /* ---------- side-effecting render ---------- */\n    function renderChart() {\n      const el = document.getElementById(CHART_EL_ID);\n      if (!el || !window.echarts) { warn('render skipped: element or echarts missing'); return; }\n      const rows = getQueryData(QUERY_INDEX.trend);\n      log('rendering rows:', rows.length);\n\n      const prior = echarts.getInstanceByDom(el);\n      if (prior) prior.dispose();\n      if (currentBlock._rmResizeObs) {\n        try { currentBlock._rmResizeObs.disconnect(); } catch (err) { warn('resize disconnect failed', err); }\n        currentBlock._rmResizeObs = null;\n      }\n\n      const chart = echarts.init(el, null, { renderer: 'canvas' });\n      chart.setOption(buildOption(rows));\n\n      if (typeof ResizeObserver === 'function') {\n        const observer = new ResizeObserver(() => { try { chart.resize(); } catch (err) { warn('resize failed', err); } });\n        observer.observe(el);\n        currentBlock._rmResizeObs = observer;\n      }\n    }\n\n    function subscribeToReloads() {\n      try {\n        if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') return;\n        const sources = (typeof zPortal.dataSource.get === 'function') ? zPortal.dataSource.get() : null;\n        const ids = Array.isArray(sources) ? sources.map((s) => s && (s.id || s.datasource_id)).filter(Boolean) : [];\n        if (!ids.length) return;\n        if (currentBlock._rmLoadHandler) {\n          ids.forEach((id) => { try { zPortal.dataSource.off('load', id, currentBlock._rmLoadHandler); } catch (err) { warn('off failed', err); } });\n        }\n        const handler = () => renderChart();\n        ids.forEach((id) => { try { zPortal.dataSource.on('load', id, handler); } catch (err) { warn('subscribe failed', err); } });\n        currentBlock._rmLoadHandler = handler;\n      } catch (err) {\n        warn('subscribeToReloads failed', err);\n      }\n    }\n\n    function loadECharts() {\n      if (window.echarts) return Promise.resolve();\n      if (window.zPortal && zPortal.resources && typeof zPortal.resources.load === 'function') {\n        return zPortal.resources.load(ECHARTS_URL);\n      }\n      return Promise.reject(new Error('zPortal.resources.load unavailable'));\n    }\n\n    /* ---------- orchestrator ---------- */\n    function init() {\n      let onLoaded = null;\n      try {\n        onLoaded = (currentBlock && typeof currentBlock.getOnLoadedCallback === 'function') ? currentBlock.getOnLoadedCallback() : null;\n      } catch (err) {\n        onLoaded = null;\n      }\n\n      loadECharts()\n        .then(() => {\n          renderChart();\n          subscribeToReloads();\n        })\n        .catch((err) => { warn('init failed', err); })\n        .finally(() => {\n          try { if (typeof onLoaded === 'function') onLoaded(); } catch (err) { warn('onLoaded failed', err); }\n        });\n    }\n\n    init();\n  })();\n  </script>\n</div>"
  },
