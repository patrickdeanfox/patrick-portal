{
  "name": "SC · Chart PO Spend Over Time",
  "type": "html",
  "css": [
    ".wrapper.sc-po-spend {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,.07));\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  --font: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  container-type: inline-size;\n  height: 100%;\n  box-sizing: border-box;\n  color: var(--ink);\n  font-family: var(--font);\n  font-variant-numeric: tabular-nums;\n}\n.wrapper.sc-po-spend .chart-card {\n  box-sizing: border-box;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-height: 260px;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .15s ease, box-shadow .15s ease;\n}\n.wrapper.sc-po-spend .chart-card:hover {\n  border-color: color-mix(in srgb, var(--accent) 30%, var(--line));\n}\n.wrapper.sc-po-spend .chart-card:focus-within {\n  outline: 2px solid var(--accent);\n  outline-offset: 2px;\n}\n.wrapper.sc-po-spend .cc-head {\n  display: flex;\n  align-items: flex-end;\n  justify-content: space-between;\n  gap: 12px;\n  flex-wrap: wrap;\n  margin-bottom: 14px;\n}\n.wrapper.sc-po-spend .cc-title {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  min-width: 0;\n}\n.wrapper.sc-po-spend .eyebrow {\n  font: 700 11px/1 var(--font);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--accent);\n}\n.wrapper.sc-po-spend .cc-head h3 {\n  margin: 0;\n  font: 800 14px/1.2 var(--font);\n  letter-spacing: -.01em;\n  color: var(--ink);\n}\n.wrapper.sc-po-spend .cc-head .sub {\n  font: 500 11px/1.3 var(--font);\n  color: var(--muted);\n}\n.wrapper.sc-po-spend .canvas {\n  flex: 1 1 auto;\n  width: 100%;\n  min-height: 220px;\n}\n.wrapper.sc-po-spend .empty {\n  flex: 1 1 auto;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  min-height: 220px;\n  margin: 0;\n  padding: 0 16px;\n  color: var(--muted);\n  font: 600 13px/1.5 var(--font);\n}\n.wrapper.sc-po-spend .empty[hidden] {\n  display: none;\n}\n@container (max-width: 420px) {\n  .wrapper.sc-po-spend .chart-card { padding: 14px; }\n  .wrapper.sc-po-spend .cc-head { margin-bottom: 10px; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper.sc-po-spend .chart-card { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper sc-po-spend\">\n  <section class=\"chart-card\" aria-label=\"Purchase order spend over time\">\n    <header class=\"cc-head\">\n      <div class=\"cc-title\">\n        <span class=\"eyebrow\">Procurement</span>\n        <h3>PO Spend Over Time</h3>\n      </div>\n      <span class=\"sub\">Monthly purchase-order line spend (USD)</span>\n    </header>\n    <div class=\"canvas\" id=\"sc-po-spend-canvas\" role=\"img\" aria-label=\"Line chart of total purchase order line spend by month\"></div>\n    <p class=\"empty\" id=\"sc-po-spend-empty\" hidden>No purchase-order data available for the current filters.</p>\n  </section>\n  <script>\n  (function () {\n      'use strict';\n\n      // ----- Top-level config -------------------------------------------------\n      const DEBUG = false;\n      const TAG = '[SC · PO Spend Over Time]';\n      const log = function () { if (DEBUG) { console.log.apply(console, [TAG].concat(Array.prototype.slice.call(arguments))); } };\n      const logError = function () { if (DEBUG) { console.error.apply(console, [TAG].concat(Array.prototype.slice.call(arguments))); } };\n\n      const QUERY_INDEX = { SPEND: 0 };\n      const COL = { ORDER_DATE: 'order_date', LINE_SPEND: 'line_spend' };\n      const CANVAS_ID = 'sc-po-spend-canvas';\n      const EMPTY_ID = 'sc-po-spend-empty';\n      const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n      const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n\n      // ----- Pure helpers -----------------------------------------------------\n      const getQueryData = function (index) {\n          const q = currentBlock && currentBlock.queryResults && currentBlock.queryResults[index];\n          if (!q || q.data === undefined) { return []; }\n          return q.mappedData || q.data.map(function (row) {\n              return Object.fromEntries(q.columns.map(function (col, i) { return [col, row[i]]; }));\n          });\n      };\n\n      const monthLabel = function (key) {\n          const monthIndex = parseInt(key.slice(5, 7), 10) - 1;\n          const abbr = MONTHS[monthIndex] || key.slice(5, 7);\n          return abbr + \" '\" + key.slice(2, 4);\n      };\n\n      const formatCurrencyFull = function (value) {\n          return Number(value).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n      };\n\n      const formatCurrencyCompact = function (value) {\n          return Number(value).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n      };\n\n      const hexToRgba = function (hex, alpha) {\n          const match = /^#?([0-9a-f]{6})$/i.exec(String(hex).trim());\n          if (!match) { return 'rgba(255,210,30,' + alpha + ')'; }\n          const int = parseInt(match[1], 16);\n          return 'rgba(' + ((int >> 16) & 255) + ',' + ((int >> 8) & 255) + ',' + (int & 255) + ',' + alpha + ')';\n      };\n\n      const resolveCssVar = function (el, name, fallback) {\n          const value = getComputedStyle(el).getPropertyValue(name).trim();\n          return value || fallback;\n      };\n\n      // Aggregate SUM(line_spend) by month(order_date), sorted ascending.\n      const buildMonthlySpend = function (rows) {\n          const totals = new Map();\n          for (const row of rows) {\n              const rawDate = row[COL.ORDER_DATE];\n              if (rawDate === null || rawDate === undefined) { continue; }\n              const monthKey = String(rawDate).slice(0, 7);\n              if (monthKey.length !== 7) { continue; }\n              const spend = parseFloat(row[COL.LINE_SPEND]);\n              if (!isFinite(spend)) { continue; }\n              totals.set(monthKey, (totals.get(monthKey) || 0) + spend);\n          }\n          return Array.from(totals.entries())\n              .sort(function (a, b) { return a[0] < b[0] ? -1 : (a[0] > b[0] ? 1 : 0); })\n              .map(function (entry) { return { key: entry[0], label: monthLabel(entry[0]), value: entry[1] }; });\n      };\n\n      const buildOption = function (wrapperEl, points) {\n          const accent = resolveCssVar(wrapperEl, '--color-primary', '#FFD21E');\n          const ink = resolveCssVar(wrapperEl, '--color-text', '#F4F4F7');\n          return {\n              backgroundColor: 'transparent',\n              grid: { top: 16, right: 22, bottom: 26, left: 8, containLabel: true },\n              tooltip: {\n                  trigger: 'axis',\n                  backgroundColor: '#1B1B22',\n                  borderColor: 'rgba(255,255,255,0.12)',\n                  borderWidth: 1,\n                  padding: [8, 12],\n                  textStyle: { color: ink, fontSize: 12 },\n                  formatter: function (params) {\n                      const point = params[0];\n                      return point.axisValueLabel + '<br/>' + formatCurrencyFull(point.value);\n                  }\n              },\n              xAxis: {\n                  type: 'category',\n                  data: points.map(function (p) { return p.label; }),\n                  boundaryGap: false,\n                  axisLine: { lineStyle: { color: 'rgba(255,255,255,0.18)' } },\n                  axisTick: { show: false },\n                  axisLabel: { color: '#C2C2CC', fontSize: 11, hideOverlap: true }\n              },\n              yAxis: {\n                  type: 'value',\n                  axisLine: { show: false },\n                  axisTick: { show: false },\n                  splitLine: { lineStyle: { color: 'rgba(255,255,255,0.06)' } },\n                  axisLabel: { color: '#C2C2CC', fontSize: 11, formatter: function (value) { return formatCurrencyCompact(value); } }\n              },\n              series: [{\n                  name: 'PO Spend',\n                  type: 'line',\n                  smooth: false,\n                  showSymbol: false,\n                  symbol: 'circle',\n                  symbolSize: 6,\n                  sampling: 'lttb',\n                  data: points.map(function (p) { return p.value; }),\n                  lineStyle: { color: accent, width: 2.5 },\n                  itemStyle: { color: accent },\n                  emphasis: { focus: 'series', itemStyle: { color: accent } },\n                  areaStyle: {\n                      color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n                          { offset: 0, color: hexToRgba(accent, 0.28) },\n                          { offset: 1, color: hexToRgba(accent, 0.01) }\n                      ])\n                  }\n              }]\n          };\n      };\n\n      // ----- IO / side-effecting helpers --------------------------------------\n      const loadECharts = function () {\n          if (window.echarts) { return Promise.resolve(); }\n          return zPortal.resources.load(ECHARTS_URL);\n      };\n\n      const toggleEmpty = function (isEmpty) {\n          const canvasEl = document.getElementById(CANVAS_ID);\n          const emptyEl = document.getElementById(EMPTY_ID);\n          if (emptyEl) { emptyEl.hidden = !isEmpty; }\n          if (canvasEl) { canvasEl.style.display = isEmpty ? 'none' : ''; }\n      };\n\n      const renderChart = function (el, points) {\n          const wrapperEl = el.closest('.wrapper') || el;\n          const chart = echarts.init(el);\n          chart.setOption(buildOption(wrapperEl, points), true);\n          if (typeof ResizeObserver !== 'undefined') {\n              const observer = new ResizeObserver(function () { chart.resize(); });\n              observer.observe(el);\n              el._spendResizeObserver = observer;\n          }\n      };\n\n      const disposePrior = function (el) {\n          if (el._spendResizeObserver) {\n              el._spendResizeObserver.disconnect();\n              el._spendResizeObserver = null;\n          }\n          if (window.echarts) {\n              const prior = echarts.getInstanceByDom(el);\n              if (prior) { prior.dispose(); }\n          }\n      };\n\n      // ----- Orchestration ----------------------------------------------------\n      const init = function () {\n          const onLoaded = (currentBlock && currentBlock.getOnLoadedCallback && currentBlock.getOnLoadedCallback()) || function () {};\n          let finished = false;\n          const finish = function () { if (finished) { return; } finished = true; try { onLoaded(); } catch (cbErr) { logError('onLoaded failed', cbErr); } };\n\n          const el = document.getElementById(CANVAS_ID);\n          if (!el) { logError('canvas element missing'); finish(); return; }\n\n          disposePrior(el);\n\n          let points;\n          try {\n              const rows = getQueryData(QUERY_INDEX.SPEND);\n              log('rows', rows.length);\n              points = buildMonthlySpend(rows);\n              log('months', points.length);\n          } catch (err) {\n              logError('aggregation failed', err);\n              points = [];\n          }\n\n          if (!points.length) {\n              toggleEmpty(true);\n              finish();\n              return;\n          }\n          toggleEmpty(false);\n\n          loadECharts().then(function () {\n              try {\n                  renderChart(el, points);\n              } catch (err) {\n                  logError('render failed', err);\n              } finally {\n                  finish();\n              }\n          }).catch(function (err) {\n              logError('echarts load failed', err);\n              finish();\n          });\n      };\n\n      init();\n  })();\n  </script>\n</div>"
  },
