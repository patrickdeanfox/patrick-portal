{
  "name": "RT · Chart LTV vs Revenue",
  "type": "html",
  "css": [
    ".wrapper {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,0.07));\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n}\n\n.wrapper .ltvrev-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-height: 320px;\n  min-width: 0;\n  max-width: 100%;\n  box-sizing: border-box;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 6px 18px rgba(0,0,0,0.5);\n  transition: border-color 0.16s ease, box-shadow 0.16s ease;\n}\n\n.wrapper .ltvrev-card:hover {\n  border-color: color-mix(in srgb, var(--accent) 26%, var(--line));\n}\n\n.wrapper .ltvrev-head {\n  margin-bottom: 12px;\n  min-width: 0;\n}\n\n.wrapper .ltvrev-head h3 {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin: 0;\n  min-width: 0;\n  font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -0.01em;\n  color: var(--ink);\n  overflow-wrap: break-word;\n}\n\n.wrapper .ltvrev-head h3::before {\n  content: \"\";\n  flex: none;\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--accent);\n}\n\n.wrapper .ltvrev-head .sub {\n  margin: 4px 0 0 15px;\n  font: 500 11px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--muted);\n  overflow-wrap: break-word;\n}\n\n.wrapper .ltvrev-canvas {\n  flex: 1 1 auto;\n  width: 100%;\n  min-width: 0;\n  min-height: 240px;\n}\n\n.wrapper .ltvrev-empty {\n  margin: auto;\n  text-align: center;\n  color: var(--muted);\n  font: 600 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n}\n\n.wrapper .ltvrev-empty[hidden] {\n  display: none;\n}\n\n/* Block sizes to its own grid cell, not the viewport: collapse on container width. */\n@container (max-width: 720px) {\n  .wrapper .ltvrev-card {\n    padding: 15px 16px;\n  }\n  .wrapper .ltvrev-canvas {\n    min-height: 220px;\n  }\n}\n\n@container (max-width: 480px) {\n  .wrapper .ltvrev-card {\n    padding: 14px;\n    min-height: 300px;\n  }\n  .wrapper .ltvrev-head {\n    margin-bottom: 10px;\n  }\n  .wrapper .ltvrev-canvas {\n    min-height: 220px;\n  }\n}\n\n@container (max-width: 360px) {\n  .wrapper .ltvrev-head h3 {\n    font-size: 13px;\n  }\n  .wrapper .ltvrev-canvas {\n    min-height: 200px;\n  }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .wrapper .ltvrev-card {\n    transition: none;\n  }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper\">\n  <div class=\"ltvrev-card\">\n    <div class=\"ltvrev-head\">\n      <h3>Lifetime Value vs Net Revenue</h3>\n      <p class=\"sub\">Each point is a customer &middot; size = orders &middot; color = segment</p>\n    </div>\n    <div class=\"ltvrev-canvas\" id=\"rt-ltvrev-chart\" role=\"img\" aria-label=\"Scatter plot of customer lifetime value versus net revenue, sized by number of orders and colored by customer segment\"></div>\n    <p class=\"ltvrev-empty\" id=\"rt-ltvrev-empty\" hidden>No customer data to display.</p>\n  </div>\n</div>\n<script>\n(function () {\n    'use strict';\n\n    // ---------- top-level config ----------\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) console.log('[RT LTV vs Revenue]', ...args); };\n    const logError = (...args) => { if (DEBUG) console.error('[RT LTV vs Revenue]', ...args); };\n\n    const QUERY_INDEX = { customer360: 0 };\n    const COL = {\n        ltv: 'lifetime_value',\n        revenue: 'net_revenue',\n        orders: 'orders',\n        segment: 'customer_segment'\n    };\n\n    const CHART_EL_ID = 'rt-ltvrev-chart';\n    const EMPTY_EL_ID = 'rt-ltvrev-empty';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n    const PALETTE = ['#FFD21E', '#FF3D8B', '#34B9F3', '#36D399', '#A78BFA', '#FF9F45', '#2DD4BF'];\n    const SEGMENT_COLORS = {\n        Consumer: '#FFD21E',\n        SMB: '#FF3D8B',\n        Enterprise: '#34B9F3',\n        Government: '#36D399'\n    };\n    const SEGMENT_ORDER = ['Consumer', 'SMB', 'Enterprise', 'Government'];\n\n    const SYMBOL_MIN = 8;\n    const SYMBOL_MAX = 34;\n    const SYMBOL_PER_ORDER = 3;\n\n    let chartInstance = null;\n    let resizeObserver = null;\n\n    // ---------- pure helpers ----------\n    const toNumber = (value) => {\n        const n = Number(value);\n        return Number.isFinite(n) ? n : 0;\n    };\n\n    const formatMoney = (value) => toNumber(value).toLocaleString('en-US', {\n        style: 'currency', currency: 'USD', maximumFractionDigits: 0\n    });\n\n    const formatMoneyCompact = (value) => toNumber(value).toLocaleString('en-US', {\n        style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1\n    });\n\n    function getQueryData(index) {\n        const q = currentBlock.queryResults[index];\n        if (!q || !q.data) {\n            return [];\n        }\n        return q.mappedData || q.data.map((row) => Object.fromEntries(q.columns.map((col, i) => [col, row[i]])));\n    }\n\n    function buildSeries(rows) {\n        const bySegment = new Map();\n        rows.forEach((row) => {\n            const ltv = Number(row[COL.ltv]);\n            const revenue = Number(row[COL.revenue]);\n            if (!Number.isFinite(ltv) || !Number.isFinite(revenue)) {\n                return;\n            }\n            const segment = row[COL.segment] == null ? 'Unknown' : String(row[COL.segment]);\n            const orders = toNumber(row[COL.orders]);\n            if (!bySegment.has(segment)) {\n                bySegment.set(segment, []);\n            }\n            bySegment.get(segment).push([ltv, revenue, orders, segment]);\n        });\n\n        const segments = Array.from(bySegment.keys()).sort((a, b) => {\n            const ia = SEGMENT_ORDER.indexOf(a);\n            const ib = SEGMENT_ORDER.indexOf(b);\n            if (ia !== -1 && ib !== -1) return ia - ib;\n            if (ia !== -1) return -1;\n            if (ib !== -1) return 1;\n            return a.localeCompare(b);\n        });\n\n        return segments.map((segment, idx) => ({\n            name: segment,\n            type: 'scatter',\n            data: bySegment.get(segment),\n            itemStyle: {\n                color: SEGMENT_COLORS[segment] || PALETTE[idx % PALETTE.length],\n                opacity: 0.78,\n                borderColor: 'rgba(11,11,13,0.45)',\n                borderWidth: 0.5\n            },\n            emphasis: { focus: 'series', itemStyle: { opacity: 1 } },\n            symbolSize: (point) => {\n                const orders = Array.isArray(point) ? toNumber(point[2]) : 0;\n                return Math.max(SYMBOL_MIN, Math.min(SYMBOL_MAX, SYMBOL_MIN + orders * SYMBOL_PER_ORDER));\n            }\n        }));\n    }\n\n    function buildOption(series) {\n        return {\n            backgroundColor: 'transparent',\n            textStyle: { fontFamily: \"'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif\" },\n            color: PALETTE,\n            grid: { left: 8, right: 18, top: 28, bottom: 36, containLabel: true },\n            legend: {\n                top: 0,\n                right: 0,\n                icon: 'circle',\n                itemWidth: 9,\n                itemHeight: 9,\n                textStyle: { color: '#C2C2CC', fontSize: 11 }\n            },\n            tooltip: {\n                trigger: 'item',\n                backgroundColor: '#1B1B22',\n                borderColor: 'rgba(255,255,255,0.10)',\n                borderWidth: 1,\n                padding: [8, 10],\n                textStyle: { color: '#F4F4F7', fontSize: 12 },\n                formatter: (params) => {\n                    const point = params.data || [];\n                    return [\n                        '<strong>' + params.seriesName + '</strong>',\n                        'Lifetime value: ' + formatMoney(point[0]),\n                        'Net revenue: ' + formatMoney(point[1]),\n                        'Orders: ' + toNumber(point[2]).toLocaleString('en-US')\n                    ].join('<br/>');\n                }\n            },\n            xAxis: {\n                type: 'value',\n                name: 'Lifetime value',\n                nameLocation: 'middle',\n                nameGap: 30,\n                nameTextStyle: { color: '#8A8A96', fontSize: 11 },\n                axisLine: { lineStyle: { color: 'rgba(255,255,255,0.18)' } },\n                axisTick: { show: false },\n                axisLabel: { color: '#C2C2CC', fontSize: 10, formatter: (v) => formatMoneyCompact(v) },\n                splitLine: { lineStyle: { color: 'rgba(255,255,255,0.06)' } }\n            },\n            yAxis: {\n                type: 'value',\n                name: 'Net revenue',\n                nameLocation: 'middle',\n                nameGap: 46,\n                nameTextStyle: { color: '#8A8A96', fontSize: 11 },\n                axisLine: { lineStyle: { color: 'rgba(255,255,255,0.18)' } },\n                axisTick: { show: false },\n                axisLabel: { color: '#C2C2CC', fontSize: 10, formatter: (v) => formatMoneyCompact(v) },\n                splitLine: { lineStyle: { color: 'rgba(255,255,255,0.06)' } }\n            },\n            series: series\n        };\n    }\n\n    // ---------- render (disposes prior render first) ----------\n    function renderChart(rows) {\n        const el = document.getElementById(CHART_EL_ID);\n        const emptyEl = document.getElementById(EMPTY_EL_ID);\n        if (!el) {\n            logError('chart container not found');\n            return;\n        }\n\n        const prior = window.echarts.getInstanceByDom(el);\n        if (prior) {\n            prior.dispose();\n        }\n\n        const series = buildSeries(rows);\n        const hasPoints = series.some((s) => s.data.length > 0);\n        if (emptyEl) {\n            emptyEl.hidden = hasPoints;\n        }\n        el.style.display = hasPoints ? '' : 'none';\n        if (!hasPoints) {\n            chartInstance = null;\n            log('no plottable points');\n            return;\n        }\n\n        chartInstance = window.echarts.init(el, null, { renderer: 'canvas' });\n        chartInstance.setOption(buildOption(series));\n        log('rendered series', series.length);\n    }\n\n    function observeResize() {\n        const el = document.getElementById(CHART_EL_ID);\n        if (!el || typeof ResizeObserver === 'undefined') {\n            return;\n        }\n        if (resizeObserver) {\n            resizeObserver.disconnect();\n        }\n        resizeObserver = new ResizeObserver(() => {\n            if (chartInstance) {\n                chartInstance.resize();\n            }\n        });\n        resizeObserver.observe(el);\n    }\n\n    // ---------- single orchestrator ----------\n    async function init() {\n        const onLoaded = (currentBlock && typeof currentBlock.getOnLoadedCallback === 'function')\n            ? currentBlock.getOnLoadedCallback()\n            : null;\n        try {\n            const rows = getQueryData(QUERY_INDEX.customer360);\n            log('rows', rows.length);\n            if (!window.echarts) {\n                await zPortal.resources.load(ECHARTS_URL);\n            }\n            if (!window.echarts) {\n                logError('ECharts failed to load');\n                return;\n            }\n            renderChart(rows);\n            observeResize();\n        } catch (error) {\n            logError('init failed', error);\n        } finally {\n            if (typeof onLoaded === 'function') {\n                onLoaded();\n            }\n        }\n    }\n\n    init();\n})();\n</script>"
  },
