    "html": [
      "<div class=\"ind-kpis\">\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Bookings (Won)</span></div><div class=\"ind-kpi-val\" id=\"k-book\">—</div><div class=\"ind-spark\" id=\"sp-book\"></div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Pipeline</span></div><div class=\"ind-kpi-val\" id=\"k-pipe\">—</div><div class=\"ind-spark\" id=\"sp-pipe\"></div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Coverage</span></div><div class=\"ind-kpi-val\" id=\"k-cov\">—</div><div class=\"ind-kpi-sub\">pipeline / bookings</div></div>\n  <div class=\"ind-kpi ind-kpi-won\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Won Deals</span></div><div class=\"ind-won\"><div><div class=\"ind-kpi-val\" id=\"k-won\">—</div><div class=\"ind-kpi-sub\" id=\"k-won-sub\">closed won</div></div><div class=\"ind-donut\" id=\"dn-won\"></div></div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Reps</span></div><div class=\"ind-kpi-val\" id=\"k-reps\">—</div><div class=\"ind-kpi-sub\">in view</div></div>\n  <div class=\"ind-kpi\"><div class=\"ind-kpi-top\"><span class=\"ind-kpi-dot\"></span><span class=\"ind-kpi-label\">Product Lines</span></div><div class=\"ind-kpi-val\" id=\"k-lines\">—</div><div class=\"ind-kpi-sub\">in view</div></div>\n</div>\n<script>(function(){\n  var DS_ID=\"8d2e89b5-0db4-4ee0-8e7d-3f32a03a446a\";\n  var D=String.fromCharCode(36);\n  function rows(){var cb=(typeof currentBlock!=='undefined')?currentBlock:null;var r=cb&&cb.queryResults&&cb.queryResults[0];if(!r)return[];if(Array.isArray(r.mappedData))return r.mappedData;var cols=(r.columns||[]).map(function(c){return typeof c==='string'?c:(c&&c.name);});return(r.data||[]).map(function(rw){var o={};cols.forEach(function(c,i){o[c]=rw[i];});return o;});}\n  function num(v){var n=parseFloat(v);return isNaN(n)?0:n;}\n  function fmtInt(n){return Math.round(n).toLocaleString();}\n  function fmtMoney(n){if(n>=1e6)return D+(n/1e6).toFixed(2)+'M';if(n>=1e3)return D+Math.round(n/1e3)+'K';return D+fmtInt(n);}\n  function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}\n  function html(id,v){var e=document.getElementById(id);if(e)e.innerHTML=v;}\n  function tv(name,fb){try{var v=getComputedStyle(document.documentElement).getPropertyValue(name);return v&&v.trim()?v.trim():fb;}catch(e){return fb;}}\n  function sparkBars(vals,color){if(!vals.length)return '';var w=100,h=26,n=vals.length,gap=n>1?2:0;var bw=(w-gap*(n-1))/n;var max=Math.max.apply(null,vals)||1;var s='<svg viewBox=\"0 0 '+w+' '+h+'\" preserveAspectRatio=\"none\" width=\"100%\" height=\"26\" role=\"img\">';for(var i=0;i<n;i++){var bh=Math.max(2,(vals[i]/max)*(h-2));var x=(i*(bw+gap));var y=(h-bh);s+='<rect x=\"'+x.toFixed(2)+'\" y=\"'+y.toFixed(2)+'\" width=\"'+bw.toFixed(2)+'\" height=\"'+bh.toFixed(2)+'\" rx=\"1\" fill=\"'+color+'\"></rect>';}s+='</svg>';return s;}\n  function donut(pct,color,track){var size=44,sw=7,r=(size-sw)/2,cx=size/2,cy=size/2,c=2*Math.PI*r,off=c*(1-Math.max(0,Math.min(100,pct))/100);var s='<svg viewBox=\"0 0 '+size+' '+size+'\" width=\"'+size+'\" height=\"'+size+'\">';s+='<circle cx=\"'+cx+'\" cy=\"'+cy+'\" r=\"'+r+'\" fill=\"none\" stroke=\"'+track+'\" stroke-width=\"'+sw+'\"></circle>';s+='<circle cx=\"'+cx+'\" cy=\"'+cy+'\" r=\"'+r+'\" fill=\"none\" stroke=\"'+color+'\" stroke-width=\"'+sw+'\" stroke-linecap=\"round\" stroke-dasharray=\"'+c.toFixed(2)+'\" stroke-dashoffset=\"'+off.toFixed(2)+'\" transform=\"rotate(-90 '+cx+' '+cy+')\"></circle>';s+='<text x=\"'+cx+'\" y=\"'+cy+'\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"11.5\" font-weight=\"800\" fill=\"#1f2937\">'+Math.round(pct)+'%</text>';s+='</svg>';return s;}\n  function render(){var d=rows();var book=0,pipe=0,won=0,reps={},lines={},byRep={},byStage={};d.forEach(function(r){book+=num(r.bookings_amount);pipe+=num(r.pipeline_value);if(r.deal_stage==='Closed Won')won+=1;if(r.sales_rep){reps[r.sales_rep]=1;byRep[r.sales_rep]=(byRep[r.sales_rep]||0)+num(r.bookings_amount);}if(r.product_line)lines[r.product_line]=1;var st=r.deal_stage||'—';byStage[st]=(byStage[st]||0)+num(r.pipeline_value);});set('k-book',fmtMoney(book));set('k-pipe',fmtMoney(pipe));set('k-cov',(book?(pipe/book):0).toFixed(2)+'x');set('k-won',fmtInt(won));set('k-reps',Object.keys(reps).length);set('k-lines',Object.keys(lines).length);var repVals=Object.keys(byRep).sort().map(function(k){return byRep[k];});var order=['Closed Won','Negotiation','Proposal'];var stageVals=order.filter(function(s){return byStage[s]!=null;}).map(function(s){return byStage[s];});if(!stageVals.length)stageVals=Object.keys(byStage).map(function(k){return byStage[k];});html('sp-book',sparkBars(repVals,tv('--color-primary','#009fe4')));html('sp-pipe',sparkBars(stageVals,'#7c5cff'));var total=d.length,pct=total?(won/total*100):0;html('dn-won',donut(pct,tv('--color-primary','#009fe4'),'rgba(0,0,0,.10)'));set('k-won-sub','of '+fmtInt(total)+' deals');}\n  function init(){var loaded=(typeof currentBlock!=='undefined'&&currentBlock&&currentBlock.getOnLoadedCallback)?currentBlock.getOnLoadedCallback():function(){};try{render();}finally{loaded();}try{if(typeof zPortal!=='undefined'&&zPortal.dataSource&&zPortal.dataSource.on)zPortal.dataSource.on('load',DS_ID,render);}catch(e){}}\n  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();\n})();</script>"
