{
  "name": "EXEC · Chart Revenue by Category",
  "type": "html",
  "css": [
    ".wrapper-exec-revcat {\n  --surface: var(--block-bg-color, #15151A);\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --line: var(--color-gray-200, rgba(255,255,255,0.07));\n  --accent: var(--color-primary, #FFD21E);\n  box-sizing: border-box;\n  width: 100%;\n  max-width: 100%;\n  height: 100%;\n  container-type: inline-size;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n}\n\n.wrapper-exec-revcat .chart-card-revcat {\n  box-sizing: border-box;\n  display: flex;\n  flex-direction: column;\n  width: 100%;\n  max-width: 100%;\n  height: 100%;\n  min-width: 0;\n  min-height: 260px;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 6px 18px rgba(0,0,0,0.5);\n  transition: border-color .16s ease, background-color .16s ease;\n}\n\n.wrapper-exec-revcat .chart-card-revcat:hover {\n  border-color: color-mix(in srgb, var(--accent) 30%, var(--line));\n}\n\n.wrapper-exec-revcat .head-revcat {\n  margin: 0 0 12px;\n  min-width: 0;\n}\n\n.wrapper-exec-revcat .eyebrow-revcat {\n  display: inline-flex;\n  align-items: center;\n  gap: 7px;\n  max-width: 100%;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--color-gray-700, #C2C2CC);\n}\n\n.wrapper-exec-revcat .eyebrow-revcat::before {\n  content: \"\";\n  flex: 0 0 auto;\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: var(--accent);\n  box-shadow: 0 0 10px -2px color-mix(in srgb, var(--accent) 70%, transparent);\n}\n\n.wrapper-exec-revcat .head-revcat h3 {\n  margin: 7px 0 0;\n  font: 800 15px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--ink);\n  overflow-wrap: break-word;\n}\n\n.wrapper-exec-revcat .sub-revcat {\n  margin: 3px 0 0;\n  font: 500 11.5px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--muted);\n  overflow-wrap: break-word;\n}\n\n.wrapper-exec-revcat .canvas-revcat {\n  flex: 1 1 auto;\n  width: 100%;\n  max-width: 100%;\n  min-width: 0;\n  min-height: 220px;\n}\n\n/* Chart-pair stack point: when the page collapses the side-by-side pair to a\n   single column (<=720px) this card runs full width; hold the canvas floor so\n   the chart never collapses to zero height. */\n@container (max-width: 720px) {\n  .wrapper-exec-revcat .chart-card-revcat { min-height: 252px; }\n  .wrapper-exec-revcat .canvas-revcat { min-height: 220px; }\n}\n\n/* Narrow grid cell (tablet, dense multi-column): trim chrome, keep chart usable. */\n@container (max-width: 640px) {\n  .wrapper-exec-revcat .chart-card-revcat { padding: 14px 15px; }\n}\n\n/* Very narrow cell (phone / dense grid): tighten padding, hold type + canvas. */\n@container (max-width: 420px) {\n  .wrapper-exec-revcat .chart-card-revcat { padding: 13px; }\n  .wrapper-exec-revcat .head-revcat { margin-bottom: 10px; }\n  .wrapper-exec-revcat .head-revcat h3 { font-size: 14px; }\n  .wrapper-exec-revcat .canvas-revcat { min-height: 220px; }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .wrapper-exec-revcat .chart-card-revcat { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper wrapper-exec-revcat\">\n  <div class=\"chart-card-revcat\">\n    <div class=\"head-revcat\">\n      <span class=\"eyebrow-revcat\">Executive &middot; Revenue</span>\n      <h3>Revenue by Category</h3>\n      <p class=\"sub-revcat\">Net revenue by product category &middot; click a bar to filter the page</p>\n    </div>\n    <div class=\"canvas-revcat\" id=\"echart-exec-revcat\" role=\"img\" aria-label=\"Horizontal bar chart of net revenue by product category\"></div>\n  </div>\n  <script>\n  (function () {\n    'use strict';\n\n    // ---- Top-level config --------------------------------------------\n    const DEBUG = false;\n    const NS = '[EXEC Revenue by Category]';\n    const log = (...a) => { if (DEBUG) console.log(NS, ...a); };\n    const warn = (...a) => { if (DEBUG) console.warn(NS, ...a); };\n    const fail = (...a) => { console.error(NS, ...a); };\n\n    const QUERY_INDEX = { salesByCategory: 0 };\n    const COL_CATEGORY = 'product_category';\n    const COL_NET_REVENUE = 'net_revenue';\n    const FILTER_COLUMN = 'product_category';\n\n    const CHART_EL_ID = 'echart-exec-revcat';\n    const WRAPPER_SELECTOR = '.wrapper-exec-revcat';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n    const AXIS_LINE = 'rgba(255,255,255,0.18)';\n    const SPLIT_LINE = 'rgba(255,255,255,0.06)';\n    const AXIS_LABEL = '#C2C2CC';\n    const BAR_WIDTH = '56%';\n\n    // ---- Loaded callback (async block) -------------------------------\n    let onLoaded = null;\n    try { onLoaded = currentBlock.getOnLoadedCallback(); } catch (e) { warn('no loaded callback', e); }\n    let loadedCalled = false;\n    const signalLoaded = () => {\n      if (loadedCalled) return;\n      loadedCalled = true;\n      try { if (typeof onLoaded === 'function') onLoaded(); } catch (e) { warn('loaded cb error', e); }\n    };\n\n    // ---- Pure helpers ------------------------------------------------\n    function getQueryData(index) {\n      const r = currentBlock.queryResults && currentBlock.queryResults[index];\n      if (!r || !r.data) return [];\n      if (r.mappedData) return r.mappedData;\n      return r.data.map(d => Object.fromEntries(r.columns.map((c, k) => [c, d[k]])));\n    }\n\n    function resolveToken(el, name, fallback) {\n      try {\n        const v = getComputedStyle(el).getPropertyValue(name);\n        return (v && v.trim()) ? v.trim() : fallback;\n      } catch (e) { return fallback; }\n    }\n\n    const usd0 = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n    const usdCompact = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n\n    function buildSeries() {\n      const rows = getQueryData(QUERY_INDEX.salesByCategory);\n      log('rows', rows.length);\n      return rows\n        .map(r => ({ category: r[COL_CATEGORY], value: Number(r[COL_NET_REVENUE]) }))\n        .filter(d => d.category != null && Number.isFinite(d.value))\n        .sort((a, b) => b.value - a.value);\n    }\n\n    function buildOption(series, accent, ink) {\n      const categories = series.map(d => d.category);\n      const values = series.map(d => d.value);\n      return {\n        backgroundColor: 'transparent',\n        grid: { left: 8, right: 98, top: 12, bottom: 8, containLabel: true },\n        tooltip: {\n          trigger: 'item',\n          backgroundColor: '#1B1B22',\n          borderColor: 'rgba(255,255,255,0.10)',\n          borderWidth: 1,\n          textStyle: { color: ink, fontSize: 12 },\n          formatter: p => p.name + ': ' + usd0.format(p.value)\n        },\n        xAxis: {\n          type: 'value',\n          axisLine: { show: false },\n          axisTick: { show: false },\n          splitLine: { lineStyle: { color: SPLIT_LINE } },\n          axisLabel: { color: AXIS_LABEL, fontSize: 11, formatter: v => usdCompact.format(v) }\n        },\n        yAxis: {\n          type: 'category',\n          inverse: true,\n          data: categories,\n          axisLine: { lineStyle: { color: AXIS_LINE } },\n          axisTick: { show: false },\n          axisLabel: { color: AXIS_LABEL, fontSize: 12, fontWeight: 600 }\n        },\n        series: [{\n          name: 'Net revenue',\n          type: 'bar',\n          data: values,\n          barWidth: BAR_WIDTH,\n          itemStyle: { color: accent, borderRadius: [0, 6, 6, 0] },\n          emphasis: { itemStyle: { shadowBlur: 14, shadowColor: 'rgba(255,210,30,0.45)' } },\n          cursor: 'pointer',\n          label: {\n            show: true,\n            position: 'right',\n            color: ink,\n            fontWeight: 700,\n            fontSize: 12,\n            formatter: p => usd0.format(p.value)\n          }\n        }]\n      };\n    }\n\n    // ---- Render (idempotent: disposes prior instance) ----------------\n    let chart = null;\n    function render() {\n      if (!window.echarts) { warn('echarts missing at render'); return; }\n      const el = document.getElementById(CHART_EL_ID);\n      if (!el) { warn('chart element missing'); return; }\n      const wrapper = document.querySelector(WRAPPER_SELECTOR) || el;\n      const accent = resolveToken(wrapper, '--color-primary', '#FFD21E');\n      const ink = resolveToken(wrapper, '--color-text', '#F4F4F7');\n\n      const prior = window.echarts.getInstanceByDom(el);\n      if (prior) prior.dispose();\n\n      chart = window.echarts.init(el, null, { renderer: 'canvas' });\n      chart.setOption(buildOption(buildSeries(), accent, ink));\n\n      chart.off('click');\n      chart.on('click', params => {\n        if (params && params.componentType === 'series' && params.name != null) {\n          try {\n            log('filter', params.name);\n            zPortal.dataSource.setFilters(FILTER_COLUMN, [params.name]);\n          } catch (e) { fail('setFilters failed', e); }\n        }\n      });\n    }\n\n    // ---- Resize + reload wiring --------------------------------------\n    function wireResize() {\n      try {\n        if (window.__execRevCatRO) { window.__execRevCatRO.disconnect(); }\n        const el = document.getElementById(CHART_EL_ID);\n        if (!el || typeof ResizeObserver === 'undefined') return;\n        const ro = new ResizeObserver(() => { if (chart) chart.resize(); });\n        ro.observe(el);\n        window.__execRevCatRO = ro;\n      } catch (e) { warn('resize wiring failed', e); }\n    }\n\n    function wireReload() {\n      try {\n        if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') return;\n        const dsList = (typeof datasources !== 'undefined' && Array.isArray(datasources)) ? datasources : [];\n        const ids = dsList.map(d => d && d.id).filter(Boolean);\n        const prev = window.__execRevCatReload;\n        if (prev && Array.isArray(prev.ids) && typeof prev.handler === 'function' && typeof zPortal.dataSource.off === 'function') {\n          prev.ids.forEach(id => { try { zPortal.dataSource.off('load', id, prev.handler); } catch (e) {} });\n        }\n        const handler = () => { try { render(); } catch (e) { fail('reload render failed', e); } };\n        ids.forEach(id => { try { zPortal.dataSource.on('load', id, handler); } catch (e) {} });\n        window.__execRevCatReload = { ids: ids, handler: handler };\n      } catch (e) { warn('reload wiring failed', e); }\n    }\n\n    // ---- Orchestrator ------------------------------------------------\n    function init() {\n      const start = () => {\n        try {\n          render();\n          wireResize();\n          wireReload();\n        } catch (e) {\n          fail('render failed', e);\n        } finally {\n          signalLoaded();\n        }\n      };\n      if (window.echarts) {\n        start();\n      } else {\n        zPortal.resources.load(ECHARTS_URL)\n          .then(start)\n          .catch(e => { fail('echarts load failed', e); signalLoaded(); });\n      }\n    }\n\n    init();\n  })();\n  </script>\n</div>"
  },
