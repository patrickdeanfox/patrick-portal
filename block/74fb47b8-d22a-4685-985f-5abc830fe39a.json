{
  "name": "RT · Chart Customers by Segment",
  "type": "html",
  "css": [
    ".wrapper-rt-cust-seg {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --eyebrow-ink: var(--color-gray-700, #C2C2CC);\n  --line: var(--color-gray-200, rgba(255,255,255,.07));\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  height: 100%;\n  width: 100%;\n  max-width: 100%;\n  min-width: 0;\n  box-sizing: border-box;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n}\n.wrapper-rt-cust-seg .seg-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-width: 0;\n  max-width: 100%;\n  box-sizing: border-box;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease, box-shadow .16s ease, background-color .16s ease;\n}\n.wrapper-rt-cust-seg .seg-card:hover,\n.wrapper-rt-cust-seg .seg-card:focus-within {\n  background: var(--surface-raised);\n  border-color: color-mix(in srgb, var(--accent) 35%, var(--line));\n  box-shadow: 0 1px 0 rgba(255,255,255,.04) inset, 0 10px 26px rgba(0,0,0,.55), 0 0 24px -10px color-mix(in srgb, var(--accent) 55%, transparent);\n}\n.wrapper-rt-cust-seg .seg-card:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 2px;\n}\n.wrapper-rt-cust-seg .seg-head {\n  margin-bottom: 10px;\n  min-width: 0;\n}\n.wrapper-rt-cust-seg .seg-eyebrow {\n  display: inline-flex;\n  align-items: center;\n  margin: 0 0 5px;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--eyebrow-ink);\n}\n.wrapper-rt-cust-seg .seg-eyebrow::before {\n  content: \"\";\n  display: inline-block;\n  width: 7px;\n  height: 7px;\n  margin-right: 8px;\n  border-radius: 50%;\n  background: var(--accent);\n}\n.wrapper-rt-cust-seg .seg-title {\n  margin: 0;\n  font: 800 14px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--ink);\n  overflow-wrap: break-word;\n}\n.wrapper-rt-cust-seg .seg-sub {\n  margin-top: 3px;\n  font: 600 11px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--muted);\n  overflow-wrap: break-word;\n}\n.wrapper-rt-cust-seg .seg-canvas {\n  flex: 1 1 auto;\n  min-height: 240px;\n  width: 100%;\n  min-width: 0;\n  max-width: 100%;\n}\n@container (max-width: 720px) {\n  .wrapper-rt-cust-seg .seg-canvas { min-height: 220px; }\n}\n@container (max-width: 360px) {\n  .wrapper-rt-cust-seg .seg-card { padding: 13px; }\n  .wrapper-rt-cust-seg .seg-head { margin-bottom: 8px; }\n  .wrapper-rt-cust-seg .seg-canvas { min-height: 220px; }\n}\n@media (prefers-reduced-motion: reduce) {\n  .wrapper-rt-cust-seg .seg-card { transition: none; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": [
      "<div class=\"wrapper wrapper-rt-cust-seg\">\n  <div class=\"seg-card\" role=\"figure\" aria-label=\"Customer count by segment\">\n    <div class=\"seg-head\">\n      <span class=\"seg-eyebrow\">Segmentation</span>\n      <h3 class=\"seg-title\">Customers by Segment</h3>\n      <div class=\"seg-sub\">Customer count — click a slice to filter</div>\n    </div>\n    <div id=\"rt-seg-chart\" class=\"seg-canvas\" aria-live=\"polite\"></div>\n  </div>\n  <script>\n  (function () {\n    'use strict';\n\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) console.log('[RT Customers by Segment]', ...args); };\n    const warn = (...args) => { if (DEBUG) console.warn('[RT Customers by Segment]', ...args); };\n\n    const QUERY_INDEX = { CUSTOMERS: 0 };\n    const COL_SEGMENT = 'customer_segment';\n    const COL_REVENUE = 'net_revenue';\n    const FILTER_COL = 'customer_segment';\n    const CUSTOMER_DS_ID = '8e9b7e82-7b1a-4b42-ba11-4b613909c864';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const WRAPPER_SEL = '.wrapper-rt-cust-seg';\n    const CHART_ID = 'rt-seg-chart';\n    const PALETTE = ['#FFD21E', '#FF3D8B', '#34B9F3', '#36D399', '#A78BFA', '#FF9F45', '#2DD4BF'];\n    const INK = '#F4F4F7';\n    const MUTED = '#8A8A96';\n    const AXIS_LABEL = '#C2C2CC';\n    const SURFACE = '#15151A';\n    const SURFACE_RAISED = '#1B1B22';\n\n    const wrapperEl = document.querySelector(WRAPPER_SEL);\n    const chartEl = wrapperEl ? wrapperEl.querySelector('#' + CHART_ID) : null;\n\n    const onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback)\n      ? currentBlock.getOnLoadedCallback()\n      : null;\n    let loadedFired = false;\n    const fireLoaded = () => {\n      if (loadedFired) return;\n      loadedFired = true;\n      try { if (typeof onLoaded === 'function') onLoaded(); } catch (e) { warn('onLoaded failed', e); }\n    };\n\n    let chartInstance = null;\n    let resizeObserver = null;\n\n    const getQueryData = (index) => {\n      const q = currentBlock.queryResults[index];\n      if (!q || !q.data) return [];\n      return q.mappedData || q.data.map(d => Object.fromEntries(q.columns.map((c, k) => [c, d[k]])));\n    };\n\n    const aggregateBySegment = (rows) => {\n      const bySeg = new Map();\n      rows.forEach(r => {\n        const seg = r[COL_SEGMENT];\n        if (seg === null || seg === undefined || seg === '') return;\n        const rev = Number(r[COL_REVENUE]);\n        const entry = bySeg.get(seg) || { name: String(seg), count: 0, revenue: 0 };\n        entry.count += 1;\n        entry.revenue += Number.isFinite(rev) ? rev : 0;\n        bySeg.set(seg, entry);\n      });\n      return Array.from(bySeg.values()).sort((a, b) => b.count - a.count);\n    };\n\n    const buildOption = (segments) => {\n      if (!segments.length) {\n        return {\n          backgroundColor: 'transparent',\n          title: { text: 'No customer data', left: 'center', top: 'middle', textStyle: { color: MUTED, fontSize: 13, fontWeight: 600 } }\n        };\n      }\n      const totalCustomers = segments.reduce((sum, s) => sum + s.count, 0);\n      return {\n        color: PALETTE,\n        backgroundColor: 'transparent',\n        title: {\n          text: totalCustomers.toLocaleString(),\n          subtext: 'CUSTOMERS',\n          left: 'center',\n          top: '39%',\n          textAlign: 'center',\n          textStyle: { color: INK, fontSize: 26, fontWeight: 800 },\n          subtextStyle: { color: MUTED, fontSize: 10, fontWeight: 700 }\n        },\n        tooltip: {\n          trigger: 'item',\n          backgroundColor: SURFACE_RAISED,\n          borderColor: 'rgba(255,255,255,.12)',\n          borderWidth: 1,\n          textStyle: { color: INK, fontSize: 12 },\n          formatter: (p) => {\n            const d = p.data || {};\n            const count = (d.count || 0).toLocaleString();\n            const pct = totalCustomers ? (d.count / totalCustomers * 100).toFixed(1) : '0.0';\n            const money = (d.revenue || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n            return '<strong>' + p.name + '</strong><br/>Customers: ' + count + ' (' + pct + '%)<br/>Net revenue: ' + money;\n          }\n        },\n        legend: {\n          bottom: 0,\n          icon: 'circle',\n          itemWidth: 9,\n          itemHeight: 9,\n          textStyle: { color: AXIS_LABEL, fontSize: 11 }\n        },\n        series: [{\n          name: 'Customers by segment',\n          type: 'pie',\n          radius: ['54%', '78%'],\n          center: ['50%', '46%'],\n          avoidLabelOverlap: true,\n          itemStyle: { borderColor: SURFACE, borderWidth: 2, borderRadius: 4 },\n          label: { color: INK, fontSize: 11, formatter: '{b}: {d}%' },\n          labelLine: { length: 10, length2: 8, lineStyle: { color: 'rgba(255,255,255,.25)' } },\n          emphasis: { scale: true, scaleSize: 6 },\n          data: segments.map(s => ({ name: s.name, value: s.count, count: s.count, revenue: s.revenue }))\n        }]\n      };\n    };\n\n    const disposeChart = () => {\n      if (chartInstance) {\n        try { chartInstance.dispose(); } catch (e) { warn('dispose failed', e); }\n        chartInstance = null;\n      }\n      if (chartEl && window.echarts) {\n        const lingering = window.echarts.getInstanceByDom(chartEl);\n        if (lingering) { try { lingering.dispose(); } catch (e) { warn('dispose lingering failed', e); } }\n      }\n    };\n\n    const handleSliceClick = (params) => {\n      if (!params || params.name == null) return;\n      try {\n        zPortal.dataSource.setFilters(FILTER_COL, [params.name]);\n        log('filter set', FILTER_COL, params.name);\n      } catch (e) {\n        warn('setFilters failed', e);\n      }\n    };\n\n    const render = () => {\n      if (!chartEl || !window.echarts) return;\n      const rows = getQueryData(QUERY_INDEX.CUSTOMERS);\n      log('rows', rows.length);\n      const segments = aggregateBySegment(rows);\n      disposeChart();\n      chartInstance = window.echarts.init(chartEl, null, { renderer: 'canvas' });\n      chartInstance.setOption(buildOption(segments), true);\n      chartInstance.off('click');\n      chartInstance.on('click', handleSliceClick);\n    };\n\n    const setupResize = () => {\n      if (resizeObserver || !chartEl || typeof ResizeObserver === 'undefined') return;\n      resizeObserver = new ResizeObserver(() => { if (chartInstance) chartInstance.resize(); });\n      resizeObserver.observe(chartEl);\n    };\n\n    const subscribeToReload = () => {\n      if (typeof zPortal === 'undefined' || !zPortal.dataSource || !zPortal.dataSource.on) return;\n      try {\n        if (chartEl && chartEl.__segReloadHandler && zPortal.dataSource.off) {\n          zPortal.dataSource.off('load', CUSTOMER_DS_ID, chartEl.__segReloadHandler);\n        }\n        const handler = () => { if (window.echarts) render(); };\n        if (chartEl) chartEl.__segReloadHandler = handler;\n        zPortal.dataSource.on('load', CUSTOMER_DS_ID, handler);\n      } catch (e) {\n        warn('subscribe failed', e);\n      }\n    };\n\n    const loadEChartsLib = () => {\n      if (window.echarts) return Promise.resolve();\n      const savedDefine = window.define;\n      window.define = undefined;\n      return Promise.resolve(zPortal.resources.load(ECHARTS_URL))\n        .finally(() => { window.define = savedDefine; });\n    };\n\n    const init = () => {\n      if (!chartEl) { warn('chart element not found'); fireLoaded(); return; }\n      loadEChartsLib()\n        .then(() => { render(); setupResize(); subscribeToReload(); })\n        .catch((e) => { warn('echarts load/render failed', e); })\n        .finally(fireLoaded);\n    };\n\n    init();\n  })();\n  </script>\n</div>"
    ]
  },
