  "css": [
    ".wrapper-exec-mktspend {\n    --ms-surface: var(--block-bg-color, #15151A);\n    --ms-surface-raised: #1B1B22;\n    --ms-ink: var(--color-text, #F4F4F7);\n    --ms-muted: var(--color-gray-500, #8A8A96);\n    --ms-line: var(--color-gray-200, rgba(255,255,255,.07));\n    --ms-accent: var(--color-primary, #FFD21E);\n    --ms-accent-2: var(--color-secondary, #FF3D8B);\n    box-sizing: border-box;\n    width: 100%;\n    min-width: 0;\n    max-width: 100%;\n    height: 100%;\n    container-type: inline-size;\n    color: var(--ms-ink);\n    font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n    font-variant-numeric: tabular-nums;\n}\n\n.wrapper-exec-mktspend .ms-card {\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    min-width: 0;\n    height: 100%;\n    min-height: 300px;\n    background: var(--ms-surface);\n    border: 1px solid var(--ms-line);\n    border-radius: 14px;\n    padding: 16px 18px;\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n    transition: border-color .18s ease, box-shadow .18s ease, background-color .18s ease;\n}\n\n.wrapper-exec-mktspend .ms-card:hover {\n    border-color: color-mix(in srgb, var(--ms-accent) 30%, var(--ms-line));\n}\n\n.wrapper-exec-mktspend .ms-card:focus-within {\n    border-color: color-mix(in srgb, var(--ms-accent) 45%, var(--ms-line));\n    box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5), 0 0 0 1px color-mix(in srgb, var(--ms-accent) 40%, transparent);\n}\n\n.wrapper-exec-mktspend .ms-head {\n    box-sizing: border-box;\n    flex: 0 0 auto;\n    min-width: 0;\n    padding-bottom: 12px;\n    margin-bottom: 14px;\n    border-bottom: 1px solid var(--ms-line);\n}\n\n.wrapper-exec-mktspend .ms-title {\n    margin: 0;\n    font-size: 14px;\n    font-weight: 800;\n    line-height: 1.25;\n    letter-spacing: -.01em;\n    color: var(--ms-ink);\n    overflow-wrap: break-word;\n}\n\n.wrapper-exec-mktspend .ms-sub {\n    margin: 3px 0 0;\n    font-size: 11px;\n    font-weight: 500;\n    line-height: 1.35;\n    color: var(--ms-muted);\n    overflow-wrap: break-word;\n}\n\n.wrapper-exec-mktspend .ms-canvas {\n    flex: 1 1 auto;\n    width: 100%;\n    min-width: 0;\n    min-height: 220px;\n}\n\n.wrapper-exec-mktspend .ms-empty {\n    flex: 1 1 auto;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 220px;\n    padding: 0 12px;\n    text-align: center;\n    font-size: 13px;\n    font-weight: 500;\n    color: var(--ms-muted);\n}\n\n.wrapper-exec-mktspend .ms-empty[hidden] {\n    display: none;\n}\n\n.wrapper-exec-mktspend :focus-visible {\n    outline: 2px solid var(--ms-accent);\n    outline-offset: 2px;\n    border-radius: 6px;\n}\n\n@container (max-width: 480px) {\n    .wrapper-exec-mktspend .ms-card { padding: 14px; }\n    .wrapper-exec-mktspend .ms-head { padding-bottom: 10px; margin-bottom: 12px; }\n}\n\n@container (max-width: 340px) {\n    .wrapper-exec-mktspend .ms-card { padding: 12px; }\n    .wrapper-exec-mktspend .ms-head { padding-bottom: 9px; margin-bottom: 10px; }\n}\n\n@media (prefers-reduced-motion: reduce) {\n    .wrapper-exec-mktspend .ms-card { transition: none; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": "<div class=\"wrapper wrapper-exec-mktspend\">\n    <div class=\"ms-card\" aria-live=\"polite\">\n        <div class=\"ms-head\">\n            <h3 class=\"ms-title\">Marketing Spend &amp; Conversions by Channel Group</h3>\n            <p class=\"ms-sub\">Total spend (USD) and conversions, aggregated across channels</p>\n        </div>\n        <div id=\"ms-chart-exec-mktspend\" class=\"ms-canvas\" role=\"img\" aria-label=\"Grouped bar chart of total marketing spend and conversions by channel group\"></div>\n        <div class=\"ms-empty\" hidden>No marketing channel data available.</div>\n    </div>\n    <script>\n    (function () {\n        'use strict';\n\n        // ----- Top-level config -----\n        const DEBUG = false;\n        const log = function () { if (DEBUG) { console.log.apply(console, ['[EXEC Marketing Spend by Channel Group]'].concat([].slice.call(arguments))); } };\n        log.warn = function () { if (DEBUG) { console.warn.apply(console, ['[EXEC Marketing Spend by Channel Group]'].concat([].slice.call(arguments))); } };\n        log.error = function () { if (DEBUG) { console.error.apply(console, ['[EXEC Marketing Spend by Channel Group]'].concat([].slice.call(arguments))); } };\n\n        const QUERY_INDEX = { MARKETING: 0 };\n        const COL_GROUP = 'channel_group';\n        const COL_SPEND = 'spend';\n        const COL_CONVERSIONS = 'conversions';\n\n        const WRAPPER_SELECTOR = '.wrapper-exec-mktspend';\n        const CHART_EL_ID = 'ms-chart-exec-mktspend';\n        const EMPTY_SELECTOR = '.ms-empty';\n        const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n\n        // Datasources backing the bound query (for filter-reload subscription).\n        const DATASOURCE_IDS = ['9deb8485-31f6-4399-b00a-046b66b76bfc', '292d59b8-f424-4250-b442-e21795ee7ee0'];\n\n        // Preferred left-to-right ordering of the four channel groups.\n        const GROUP_ORDER = ['Acquisition', 'Retention', 'Awareness', 'Direct'];\n\n        const wrapperEl = document.querySelector(WRAPPER_SELECTOR);\n        let resizeObserver = null;\n\n        // ----- Pure helpers -----\n        function readToken(el, name, fallback) {\n            try {\n                const value = getComputedStyle(el).getPropertyValue(name).trim();\n                return value || fallback;\n            } catch (err) {\n                return fallback;\n            }\n        }\n\n        function readTheme(el) {\n            return {\n                accent: readToken(el, '--color-primary', '#FFD21E'),\n                accent2: readToken(el, '--color-secondary', '#FF3D8B'),\n                ink: readToken(el, '--color-text', '#F4F4F7'),\n                muted: readToken(el, '--color-gray-500', '#8A8A96'),\n                line: readToken(el, '--color-gray-200', 'rgba(255,255,255,.07)'),\n                font: readToken(el, '--font-stack-primary', \"'Inter', system-ui, sans-serif\"),\n                axisLine: 'rgba(255,255,255,.18)',\n                splitLine: 'rgba(255,255,255,.06)',\n                label: '#C2C2CC',\n                tooltipBg: '#1B1B22'\n            };\n        }\n\n        function formatCurrency(value) {\n            return Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n        }\n\n        function formatCurrencyCompact(value) {\n            return Number(value || 0).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n        }\n\n        function formatCount(value) {\n            return Number(value || 0).toLocaleString('en-US');\n        }\n\n        function getQueryData(index) {\n            const q = (typeof currentBlock !== 'undefined' && currentBlock.queryResults) ? currentBlock.queryResults[index] : null;\n            if (!q || !q.data) {\n                return [];\n            }\n            return q.mappedData || q.data.map(function (row) {\n                return Object.fromEntries(q.columns.map(function (col, i) { return [col, row[i]]; }));\n            });\n        }\n\n        function aggregateByGroup(rows) {\n            const totals = new Map();\n            rows.forEach(function (row) {\n                const group = row[COL_GROUP];\n                if (group === null || group === undefined || group === '') {\n                    return;\n                }\n                if (!totals.has(group)) {\n                    totals.set(group, { group: group, spend: 0, conversions: 0 });\n                }\n                const bucket = totals.get(group);\n                bucket.spend += Number(row[COL_SPEND]) || 0;\n                bucket.conversions += Number(row[COL_CONVERSIONS]) || 0;\n            });\n            const ordered = [];\n            GROUP_ORDER.forEach(function (name) {\n                if (totals.has(name)) {\n                    ordered.push(totals.get(name));\n                    totals.delete(name);\n                }\n            });\n            totals.forEach(function (bucket) { ordered.push(bucket); });\n            return ordered;\n        }\n\n        function buildOption(buckets, theme) {\n            const categories = buckets.map(function (b) { return b.group; });\n            const spendValues = buckets.map(function (b) { return Math.round(b.spend); });\n            const conversionValues = buckets.map(function (b) { return Math.round(b.conversions); });\n            return {\n                backgroundColor: 'transparent',\n                textStyle: { fontFamily: theme.font },\n                color: [theme.accent, theme.accent2],\n                grid: { left: 8, right: 8, top: 52, bottom: 8, containLabel: true },\n                legend: {\n                    top: 10,\n                    right: 8,\n                    itemWidth: 11,\n                    itemHeight: 11,\n                    itemGap: 16,\n                    icon: 'roundRect',\n                    textStyle: { color: theme.label, fontSize: 11 },\n                    data: ['Spend', 'Conversions']\n                },\n                tooltip: {\n                    trigger: 'axis',\n                    axisPointer: { type: 'shadow', shadowStyle: { color: 'rgba(255,255,255,.05)' } },\n                    backgroundColor: theme.tooltipBg,\n                    borderColor: theme.line,\n                    borderWidth: 1,\n                    textStyle: { color: theme.ink, fontSize: 12 },\n                    formatter: function (params) {\n                        if (!params || !params.length) { return ''; }\n                        let html = '<div style=\"font-weight:700;margin-bottom:4px;\">' + params[0].axisValue + '</div>';\n                        params.forEach(function (p) {\n                            const value = p.seriesName === 'Spend' ? formatCurrency(p.value) : formatCount(p.value);\n                            html += '<div style=\"display:flex;align-items:center;gap:8px;\">' + p.marker + '<span>' + p.seriesName + '</span><span style=\"margin-left:auto;font-weight:700;\">' + value + '</span></div>';\n                        });\n                        return html;\n                    }\n                },\n                xAxis: {\n                    type: 'category',\n                    data: categories,\n                    axisLine: { lineStyle: { color: theme.axisLine } },\n                    axisTick: { show: false },\n                    axisLabel: { color: theme.label, fontSize: 11, fontWeight: 600 }\n                },\n                yAxis: [\n                    {\n                        type: 'value',\n                        name: 'Spend',\n                        nameTextStyle: { color: theme.muted, fontSize: 10, align: 'left' },\n                        axisLine: { show: false },\n                        axisTick: { show: false },\n                        splitLine: { lineStyle: { color: theme.splitLine } },\n                        axisLabel: { color: theme.label, fontSize: 10, formatter: function (v) { return formatCurrencyCompact(v); } }\n                    },\n                    {\n                        type: 'value',\n                        name: 'Conversions',\n                        nameTextStyle: { color: theme.muted, fontSize: 10, align: 'right' },\n                        axisLine: { show: false },\n                        axisTick: { show: false },\n                        splitLine: { show: false },\n                        axisLabel: { color: theme.label, fontSize: 10, formatter: function (v) { return formatCount(v); } }\n                    }\n                ],\n                series: [\n                    {\n                        name: 'Spend',\n                        type: 'bar',\n                        yAxisIndex: 0,\n                        data: spendValues,\n                        barMaxWidth: 34,\n                        itemStyle: { color: theme.accent, borderRadius: [4, 4, 0, 0] },\n                        label: { show: true, position: 'top', color: theme.ink, fontSize: 10, fontWeight: 700, formatter: function (p) { return formatCurrencyCompact(p.value); } }\n                    },\n                    {\n                        name: 'Conversions',\n                        type: 'bar',\n                        yAxisIndex: 1,\n                        data: conversionValues,\n                        barMaxWidth: 34,\n                        itemStyle: { color: theme.accent2, borderRadius: [4, 4, 0, 0] },\n                        label: { show: true, position: 'top', color: theme.ink, fontSize: 10, fontWeight: 700, formatter: function (p) { return formatCount(p.value); } }\n                    }\n                ]\n            };\n        }\n\n        // ----- Side-effecting render -----\n        function renderChart() {\n            const el = wrapperEl ? wrapperEl.querySelector('#' + CHART_EL_ID) : document.getElementById(CHART_EL_ID);\n            const emptyEl = wrapperEl ? wrapperEl.querySelector(EMPTY_SELECTOR) : null;\n            if (!el || !window.echarts) {\n                return;\n            }\n\n            const prior = window.echarts.getInstanceByDom(el);\n            if (prior) {\n                prior.dispose();\n            }\n\n            const rows = getQueryData(QUERY_INDEX.MARKETING);\n            const buckets = aggregateByGroup(rows);\n            log('rows', rows.length, 'groups', buckets.length);\n\n            if (emptyEl) {\n                emptyEl.hidden = buckets.length > 0;\n            }\n            if (!buckets.length) {\n                log.warn('no channel groups after aggregation');\n                return;\n            }\n\n            const theme = readTheme(el);\n            const chart = window.echarts.init(el, null, { renderer: 'canvas' });\n            chart.setOption(buildOption(buckets, theme));\n\n            if (resizeObserver) {\n                resizeObserver.disconnect();\n            }\n            if (typeof ResizeObserver !== 'undefined') {\n                resizeObserver = new ResizeObserver(function () { chart.resize(); });\n                resizeObserver.observe(el);\n            }\n        }\n\n        function handleReload() {\n            log('datasource reload — redrawing');\n            renderChart();\n        }\n\n        function subscribeToReloads() {\n            if (!window.zPortal || !zPortal.dataSource || typeof zPortal.dataSource.on !== 'function') {\n                return;\n            }\n            const prior = (typeof currentBlock !== 'undefined') ? currentBlock.__execMktSpendReload : null;\n            DATASOURCE_IDS.forEach(function (dsId) {\n                try {\n                    if (prior && typeof zPortal.dataSource.off === 'function') {\n                        zPortal.dataSource.off('load', dsId, prior);\n                    }\n                    zPortal.dataSource.on('load', dsId, handleReload);\n                } catch (err) {\n                    log.error('reload subscription failed for', dsId, err);\n                }\n            });\n            if (typeof currentBlock !== 'undefined') {\n                currentBlock.__execMktSpendReload = handleReload;\n            }\n        }\n\n        // ----- Orchestrator -----\n        function init() {\n            const onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : null;\n            let finished = false;\n            const finish = function () {\n                if (finished) { return; }\n                finished = true;\n                if (typeof onLoaded === 'function') { onLoaded(); }\n            };\n\n            const startRender = function () {\n                try {\n                    renderChart();\n                    subscribeToReloads();\n                } catch (err) {\n                    log.error('render failed', err);\n                } finally {\n                    finish();\n                }\n            };\n\n            try {\n                if (window.echarts) {\n                    startRender();\n                } else {\n                    zPortal.resources.load(ECHARTS_URL).then(startRender).catch(function (err) {\n                        log.error('echarts load failed', err);\n                        finish();\n                    });\n                }\n            } catch (err) {\n                log.error('init failed', err);\n                finish();\n            }\n        }\n\n        init();\n    })();\n    </script>\n</div>"
  },
