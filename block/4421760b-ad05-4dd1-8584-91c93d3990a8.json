{
  "name": "CRM · Chart Pipeline vs Weighted",
  "type": "html",
  "css": [
    ".wrapper .cpw-root {\n  /* block-local token base — extends the existing family, never drops it */\n  --cpw-surface: var(--block-bg-color, #15151A);\n  --cpw-surface-raised: #1B1B22;\n  --cpw-ink: var(--color-text, #F4F4F7);\n  --cpw-muted: var(--color-gray-500, #8A8A96);\n  --cpw-line: var(--color-gray-200, rgba(255,255,255,0.07));\n  --cpw-accent: var(--color-primary, #FFD21E);\n  --cpw-accent-2: var(--color-secondary, #FF3D8B);\n  container-type: inline-size;\n  box-sizing: border-box;\n  max-width: 100%;\n  min-width: 0;\n  color: var(--cpw-ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  height: 100%;\n}\n\n.wrapper .cpw-card {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-width: 0;\n  box-sizing: border-box;\n  background: var(--cpw-surface);\n  border: 1px solid var(--cpw-line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 6px 18px rgba(0,0,0,0.5);\n  transition: border-color 0.18s ease, box-shadow 0.18s ease;\n}\n\n/* Calm at rest; a restrained yellow accent appears only on hover / keyboard focus. */\n.wrapper .cpw-card:hover,\n.wrapper .cpw-card:focus-within {\n  border-color: color-mix(in srgb, var(--cpw-accent) 32%, var(--cpw-line));\n  box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset,\n              0 8px 22px rgba(0,0,0,0.55),\n              0 0 24px -10px color-mix(in srgb, var(--cpw-accent) 55%, transparent);\n}\n\n.wrapper .cpw-head {\n  margin: 0 0 12px;\n  padding-bottom: 12px;\n  min-width: 0;\n  border-bottom: 1px solid var(--cpw-line);\n}\n\n.wrapper .cpw-title {\n  margin: 0;\n  font: 800 14px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -0.01em;\n  color: var(--cpw-ink);\n  overflow-wrap: anywhere;\n}\n\n.wrapper .cpw-sub {\n  margin: 4px 0 0;\n  font: 500 11px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--cpw-muted);\n  overflow-wrap: anywhere;\n}\n\n.wrapper .cpw-body {\n  position: relative;\n  flex: 1 1 auto;\n  min-width: 0;\n  min-height: 240px;\n}\n\n.wrapper .cpw-canvas {\n  width: 100%;\n  height: 100%;\n  min-height: 240px;\n  font-variant-numeric: tabular-nums;\n}\n\n.wrapper .cpw-empty {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin: 0;\n  font: 600 13px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--cpw-muted);\n}\n\n.wrapper .cpw-empty[hidden] {\n  display: none;\n}\n\n/* Width-based collapse on the block's OWN inline-size (it sizes to its grid cell,\n   not the viewport). The chart-pair stacks at the page-grid level (two sibling\n   blocks); within this block the chart simply holds a min-height floor so ECharts\n   always has a real box to draw into and never collapses to zero height. */\n@container (max-width: 720px) {\n  .wrapper .cpw-card { padding: 15px 16px; }\n  .wrapper .cpw-body, .wrapper .cpw-canvas { min-height: 220px; }\n}\n\n@container (max-width: 520px) {\n  .wrapper .cpw-card { padding: 12px 14px; }\n  .wrapper .cpw-head { margin-bottom: 10px; padding-bottom: 10px; }\n  .wrapper .cpw-body, .wrapper .cpw-canvas { min-height: 220px; }\n}\n\n@container (max-width: 360px) {\n  .wrapper .cpw-card { padding: 11px 12px; }\n  .wrapper .cpw-title { font-size: 13px; }\n  .wrapper .cpw-sub { font-size: 10.5px; }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .wrapper .cpw-card { transition: none; }\n}"
  ],
  "json_data": {
    "html": "<div class=\"wrapper\">\n  <div class=\"cpw-root\">\n    <div class=\"cpw-card\">\n      <div class=\"cpw-head\">\n        <h3 class=\"cpw-title\">Pipeline vs Weighted by Stage</h3>\n        <p class=\"cpw-sub\">Total opportunity value vs probability-weighted, in funnel order</p>\n      </div>\n      <div class=\"cpw-body\" aria-live=\"polite\">\n        <div id=\"cpw-chart\" class=\"cpw-canvas\" role=\"img\" aria-label=\"Grouped bar chart comparing total pipeline amount and weighted amount for each sales stage\"></div>\n        <p id=\"cpw-empty\" class=\"cpw-empty\" hidden>No pipeline data available.</p>\n      </div>\n    </div>\n  </div>\n  <script>\n  (function () {\n    'use strict';\n\n    // ---- top-level config ----\n    const DEBUG = false;\n    const log = (...args) => { if (DEBUG) console.log('[CRM Chart Pipeline vs Weighted]', ...args); };\n    const warn = (...args) => { if (DEBUG) console.warn('[CRM Chart Pipeline vs Weighted]', ...args); };\n    const fail = (...args) => { if (DEBUG) console.error('[CRM Chart Pipeline vs Weighted]', ...args); };\n\n    const QUERY_INDEX = { PIPELINE_BY_STAGE: 0 };\n    const COL = { STAGE: 'stage', PIPELINE: 'pipeline_amount', WEIGHTED: 'weighted_amount' };\n    const STAGE_ORDER = ['Prospecting', 'Qualification', 'Proposal', 'Negotiation', 'Closed Won', 'Closed Lost'];\n\n    const CHART_EL_ID = 'cpw-chart';\n    const EMPTY_EL_ID = 'cpw-empty';\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const STATE_KEY = '__cpwPipelineWeightedState';\n\n    const AXIS_LINE = 'rgba(255,255,255,0.18)';\n    const SPLIT_LINE = 'rgba(255,255,255,0.06)';\n    const AXIS_LABEL = '#C2C2CC';\n    const INK = '#F4F4F7';\n    const TOOLTIP_BG = '#1B1B22';\n    const TOOLTIP_BORDER = 'rgba(255,255,255,0.10)';\n\n    const THIS_SCRIPT = document.currentScript;\n\n    // ---- pure helpers ----\n    function cssVar(el, name, fallback) {\n        try {\n            const value = el ? getComputedStyle(el).getPropertyValue(name).trim() : '';\n            return value || fallback;\n        } catch (e) {\n            return fallback;\n        }\n    }\n\n    function getQueryData(index) {\n        const result = (typeof currentBlock !== 'undefined' && currentBlock.queryResults) ? currentBlock.queryResults[index] : null;\n        if (!result || !result.data) return [];\n        if (result.mappedData) return result.mappedData;\n        return result.data.map((row) => Object.fromEntries(result.columns.map((col, i) => [col, row[i]])));\n    }\n\n    function fmtFull(value) {\n        return Number(value).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });\n    }\n\n    function fmtCompact(value) {\n        return Number(value).toLocaleString('en-US', { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 });\n    }\n\n    function shapeRows(rows) {\n        const byStage = new Map();\n        rows.forEach((row) => {\n            const stage = row[COL.STAGE];\n            if (stage === null || stage === undefined) return;\n            byStage.set(String(stage), {\n                pipeline: Number(row[COL.PIPELINE]) || 0,\n                weighted: Number(row[COL.WEIGHTED]) || 0\n            });\n        });\n        const ordered = [];\n        STAGE_ORDER.forEach((stage) => {\n            if (byStage.has(stage)) {\n                ordered.push({ stage, value: byStage.get(stage) });\n                byStage.delete(stage);\n            }\n        });\n        byStage.forEach((value, stage) => ordered.push({ stage, value }));\n        return ordered;\n    }\n\n    function buildOption(ordered, colorPipeline, colorWeighted) {\n        const categories = ordered.map((entry) => entry.stage);\n        const pipeline = ordered.map((entry) => entry.value.pipeline);\n        const weighted = ordered.map((entry) => entry.value.weighted);\n        return {\n            backgroundColor: 'transparent',\n            grid: { left: 6, right: 16, top: 46, bottom: 6, containLabel: true },\n            legend: {\n                data: ['Pipeline', 'Weighted'],\n                top: 8,\n                right: 8,\n                icon: 'roundRect',\n                itemWidth: 12,\n                itemHeight: 8,\n                itemGap: 18,\n                textStyle: { color: AXIS_LABEL, fontSize: 11 }\n            },\n            tooltip: {\n                trigger: 'axis',\n                axisPointer: { type: 'shadow' },\n                backgroundColor: TOOLTIP_BG,\n                borderColor: TOOLTIP_BORDER,\n                borderWidth: 1,\n                textStyle: { color: INK, fontSize: 12 },\n                formatter: (params) => {\n                    if (!params || !params.length) return '';\n                    let html = '<div style=\"font-weight:700;margin-bottom:4px;\">' + params[0].axisValue + '</div>';\n                    params.forEach((p) => {\n                        html += '<div style=\"display:flex;justify-content:space-between;gap:18px;\">'\n                            + '<span>' + p.marker + p.seriesName + '</span>'\n                            + '<span style=\"font-variant-numeric:tabular-nums;font-weight:700;\">' + fmtFull(p.value) + '</span>'\n                            + '</div>';\n                    });\n                    return html;\n                }\n            },\n            xAxis: {\n                type: 'category',\n                data: categories,\n                axisLine: { lineStyle: { color: AXIS_LINE } },\n                axisTick: { show: false },\n                axisLabel: { color: AXIS_LABEL, fontSize: 11, interval: 0, hideOverlap: true }\n            },\n            yAxis: {\n                type: 'value',\n                axisLine: { show: false },\n                axisTick: { show: false },\n                splitLine: { lineStyle: { color: SPLIT_LINE } },\n                axisLabel: { color: AXIS_LABEL, fontSize: 11, formatter: (value) => fmtCompact(value) }\n            },\n            series: [\n                {\n                    name: 'Pipeline',\n                    type: 'bar',\n                    data: pipeline,\n                    barMaxWidth: 30,\n                    itemStyle: { color: colorPipeline, borderRadius: [4, 4, 0, 0] },\n                    emphasis: { focus: 'series' },\n                    label: { show: true, position: 'top', color: INK, fontSize: 10, formatter: (p) => fmtCompact(p.value) },\n                    labelLayout: { hideOverlap: true }\n                },\n                {\n                    name: 'Weighted',\n                    type: 'bar',\n                    data: weighted,\n                    barMaxWidth: 30,\n                    itemStyle: { color: colorWeighted, borderRadius: [4, 4, 0, 0] },\n                    emphasis: { focus: 'series' },\n                    label: { show: true, position: 'top', color: INK, fontSize: 10, formatter: (p) => fmtCompact(p.value) },\n                    labelLayout: { hideOverlap: true }\n                }\n            ]\n        };\n    }\n\n    // ---- state + cleanup ----\n    function getState() {\n        if (!window[STATE_KEY]) window[STATE_KEY] = { observer: null, handlers: [] };\n        return window[STATE_KEY];\n    }\n\n    function collectDatasourceIds() {\n        try {\n            if (typeof datasources !== 'undefined' && Array.isArray(datasources)) {\n                return datasources.map((d) => d && (d.id || d.datasource_id)).filter(Boolean);\n            }\n        } catch (e) {\n            warn('could not read datasources global', e);\n        }\n        return [];\n    }\n\n    function cleanup() {\n        const state = getState();\n        if (state.observer) {\n            try { state.observer.disconnect(); } catch (e) { warn('observer disconnect failed', e); }\n            state.observer = null;\n        }\n        if (state.handlers && state.handlers.length && typeof zPortal !== 'undefined' && zPortal.dataSource && zPortal.dataSource.off) {\n            state.handlers.forEach((h) => {\n                try { zPortal.dataSource.off('load', h.dsId, h.fn); } catch (e) { warn('off failed', e); }\n            });\n        }\n        state.handlers = [];\n    }\n\n    // ---- side-effecting render ----\n    function renderChart(chartEl, ordered) {\n        const prior = window.echarts.getInstanceByDom(chartEl);\n        if (prior) prior.dispose();\n        const chart = window.echarts.init(chartEl, null, { renderer: 'canvas' });\n        const colorPipeline = cssVar(chartEl, '--color-primary', '#FFD21E');\n        const colorWeighted = cssVar(chartEl, '--color-secondary', '#FF3D8B');\n        chart.setOption(buildOption(ordered, colorPipeline, colorWeighted));\n        return chart;\n    }\n\n    function setupResize(chartEl, chart) {\n        if (!chartEl || !chart || typeof ResizeObserver === 'undefined') return;\n        const state = getState();\n        const observer = new ResizeObserver(() => { try { chart.resize(); } catch (e) { warn('resize failed', e); } });\n        observer.observe(chartEl);\n        state.observer = observer;\n    }\n\n    function subscribeReload(redraw) {\n        if (typeof zPortal === 'undefined' || !zPortal.dataSource || !zPortal.dataSource.on) return;\n        const state = getState();\n        collectDatasourceIds().forEach((dsId) => {\n            const fn = () => { try { redraw(); } catch (e) { fail('reload redraw failed', e); } };\n            try {\n                zPortal.dataSource.on('load', dsId, fn);\n                state.handlers.push({ dsId, fn });\n            } catch (e) {\n                warn('subscribe failed for', dsId, e);\n            }\n        });\n    }\n\n    function init() {\n        const onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback) ? currentBlock.getOnLoadedCallback() : null;\n        let loadedFired = false;\n        const fireLoaded = () => {\n            if (loadedFired) return;\n            loadedFired = true;\n            if (typeof onLoaded === 'function') {\n                try { onLoaded(); } catch (e) { fail('onLoaded callback threw', e); }\n            }\n        };\n\n        const root = THIS_SCRIPT ? THIS_SCRIPT.closest('.wrapper') : document.querySelector('.wrapper');\n        const chartEl = root ? root.querySelector('#' + CHART_EL_ID) : document.getElementById(CHART_EL_ID);\n        const emptyEl = root ? root.querySelector('#' + EMPTY_EL_ID) : document.getElementById(EMPTY_EL_ID);\n\n        cleanup();\n\n        const draw = () => {\n            try {\n                const rows = getQueryData(QUERY_INDEX.PIPELINE_BY_STAGE);\n                log('row count', rows.length);\n                const ordered = shapeRows(rows);\n                log('shaped stages', ordered.map((o) => o.stage));\n                if (!ordered.length) {\n                    if (emptyEl) emptyEl.hidden = false;\n                    if (chartEl) chartEl.style.display = 'none';\n                    return;\n                }\n                if (emptyEl) emptyEl.hidden = true;\n                if (chartEl) {\n                    chartEl.style.display = '';\n                    const chart = renderChart(chartEl, ordered);\n                    setupResize(chartEl, chart);\n                }\n            } catch (e) {\n                fail('draw failed', e);\n            }\n        };\n\n        if (!chartEl) {\n            fail('chart element missing');\n            fireLoaded();\n            return;\n        }\n\n        const ready = window.echarts ? Promise.resolve() : zPortal.resources.load(ECHARTS_URL);\n        ready\n            .then(() => { draw(); subscribeReload(draw); })\n            .catch((e) => { fail('echarts load failed', e); })\n            .finally(() => { fireLoaded(); });\n    }\n\n    init();\n  })();\n  </script>\n</div>"
  },
