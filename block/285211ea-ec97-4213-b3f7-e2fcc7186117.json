  "css": [
    ".crm-rh-wrap {\n  --surface: var(--block-bg-color, #15151A);\n  --surface-raised: #1B1B22;\n  --ink: var(--color-text, #F4F4F7);\n  --muted: var(--color-gray-500, #8A8A96);\n  --soft: var(--color-gray-700, #C2C2CC);\n  --line: var(--color-gray-200, rgba(255,255,255,.07));\n  --accent: var(--color-primary, #FFD21E);\n  --accent-2: var(--color-secondary, #FF3D8B);\n  box-sizing: border-box;\n  width: 100%;\n  max-width: 100%;\n  height: 100%;\n  min-height: 260px;\n  container-type: inline-size;\n  color: var(--ink);\n  font-family: var(--font-stack-primary, 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif);\n  font-variant-numeric: tabular-nums;\n}\n.crm-rh-wrap .chart-card {\n  box-sizing: border-box;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-height: 260px;\n  background: var(--surface);\n  border: 1px solid var(--line);\n  border-radius: 14px;\n  padding: 16px 18px;\n  box-shadow: 0 1px 0 rgba(255,255,255,.03) inset, 0 6px 18px rgba(0,0,0,.5);\n  transition: border-color .16s ease;\n}\n.crm-rh-wrap .chart-card:hover {\n  border-color: color-mix(in srgb, var(--accent) 30%, var(--line));\n}\n.crm-rh-wrap .card-head {\n  margin: 0 0 10px;\n  display: flex;\n  flex-direction: column;\n  gap: 3px;\n  min-width: 0;\n}\n.crm-rh-wrap .eyebrow {\n  margin: 0;\n  display: inline-flex;\n  align-items: center;\n  font: 700 11px/1.2 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: .13em;\n  text-transform: uppercase;\n  color: var(--soft);\n}\n.crm-rh-wrap .eyebrow::before {\n  content: \"\";\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  margin-right: 8px;\n  flex: none;\n  background: var(--accent);\n}\n.crm-rh-wrap .card-head h3 {\n  margin: 0;\n  font: 800 15px/1.25 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  letter-spacing: -.01em;\n  color: var(--ink);\n  overflow-wrap: anywhere;\n}\n.crm-rh-wrap .card-head .sub {\n  margin: 0;\n  font: 500 11px/1.35 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n  color: var(--muted);\n  overflow-wrap: anywhere;\n}\n.crm-rh-wrap .canvas {\n  box-sizing: border-box;\n  flex: 1 1 auto;\n  width: 100%;\n  min-width: 0;\n  min-height: 220px;\n}\n.crm-rh-wrap .empty {\n  flex: 1 1 auto;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  padding: 12px;\n  color: var(--muted);\n  font: 600 12px/1.4 var(--font-stack-primary, 'Inter', system-ui, sans-serif);\n}\n.crm-rh-wrap .empty[hidden] { display: none; }\n\n@container (max-width: 720px) {\n  .crm-rh-wrap .chart-card { padding: 15px 16px; }\n}\n@container (max-width: 560px) {\n  .crm-rh-wrap .chart-card { padding: 14px 15px; }\n  .crm-rh-wrap .card-head h3 { font-size: 14px; }\n  .crm-rh-wrap .card-head .sub { font-size: 10.5px; }\n}\n@container (max-width: 420px) {\n  .crm-rh-wrap .chart-card { padding: 13px 14px; }\n  .crm-rh-wrap .card-head h3 { font-size: 14px; }\n  .crm-rh-wrap .eyebrow { letter-spacing: .1em; }\n}\n@container (max-width: 320px) {\n  .crm-rh-wrap .chart-card { padding: 12px; }\n  .crm-rh-wrap .card-head { margin-bottom: 8px; }\n}\n\n@supports not (container-type: inline-size) {\n  @media (max-width: 560px) {\n    .crm-rh-wrap .chart-card { padding: 14px 15px; }\n    .crm-rh-wrap .card-head h3 { font-size: 14px; }\n  }\n  @media (max-width: 420px) {\n    .crm-rh-wrap .chart-card { padding: 13px 14px; }\n  }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .crm-rh-wrap .chart-card { transition: none; }\n}"
  ],
  "json_data": {
    "isolated": false,
    "html": "<div class=\"wrapper crm-rh-wrap\">\n  <section class=\"chart-card\" aria-label=\"Average resolution hours by priority\">\n    <header class=\"card-head\">\n      <p class=\"eyebrow\">Support SLA</p>\n      <h3>Resolution Hours by Priority</h3>\n      <p class=\"sub\">Ticket-weighted average resolution time &middot; SLA view</p>\n    </header>\n    <div id=\"crm-rh-canvas\" class=\"canvas\" role=\"img\" aria-label=\"Bar chart of average ticket resolution hours by priority\"></div>\n    <p id=\"crm-rh-empty\" class=\"empty\" hidden>No resolution data available.</p>\n  </section>\n  <script>\n  (function () {\n    'use strict';\n\n    /* ---- top-level config ---- */\n    const DEBUG = false;\n    const log = (...a) => { if (DEBUG) console.log('[CRM Resolution Hours by Priority]', ...a); };\n    const warn = (...a) => { if (DEBUG) console.warn('[CRM Resolution Hours by Priority]', ...a); };\n\n    const QUERY_INDEX = { sla: 0 };\n    const COL = { priority: 'priority', tickets: 'tickets', hours: 'avg_resolution_hours' };\n    const PRIORITY_ORDER = ['Low', 'Medium', 'High', 'Urgent'];\n    const DANGER_HOURS = 37.2;\n    const ECHARTS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/echarts/5.5.0/echarts.min.js';\n    const ROOT_SEL = '.crm-rh-wrap';\n    const CANVAS_ID = 'crm-rh-canvas';\n    const EMPTY_ID = 'crm-rh-empty';\n\n    const onLoaded = (typeof currentBlock !== 'undefined' && currentBlock.getOnLoadedCallback)\n      ? currentBlock.getOnLoadedCallback()\n      : null;\n    let loadedCalled = false;\n    const fireLoaded = () => {\n      if (loadedCalled || !onLoaded) { return; }\n      loadedCalled = true;\n      try { onLoaded(); } catch (e) { warn('onLoaded failed', e); }\n    };\n\n    /* ---- pure helpers ---- */\n    function getQueryData(index) {\n      const q = (typeof currentBlock !== 'undefined' && currentBlock.queryResults)\n        ? currentBlock.queryResults[index]\n        : null;\n      if (!q || !q.data) { return []; }\n      if (q.mappedData) { return q.mappedData; }\n      return q.data.map((d) => Object.fromEntries(q.columns.map((col, k) => [col, d[k]])));\n    }\n\n    function aggregateByPriority(rows) {\n      const acc = {};\n      rows.forEach((r) => {\n        const priority = r[COL.priority];\n        const hours = Number(r[COL.hours]);\n        const tickets = Number(r[COL.tickets]);\n        if (priority == null || !Number.isFinite(hours) || !Number.isFinite(tickets) || tickets <= 0) { return; }\n        if (!acc[priority]) { acc[priority] = { weighted: 0, tickets: 0 }; }\n        acc[priority].weighted += hours * tickets;\n        acc[priority].tickets += tickets;\n      });\n      const ordered = PRIORITY_ORDER.filter((p) => acc[p]);\n      Object.keys(acc).forEach((p) => { if (!ordered.includes(p)) { ordered.push(p); } });\n      return ordered.map((p) => ({\n        priority: p,\n        hours: acc[p].weighted / acc[p].tickets,\n        tickets: acc[p].tickets\n      }));\n    }\n\n    function readColors(rootEl) {\n      const cssVar = (name, fallback) => {\n        const v = getComputedStyle(rootEl).getPropertyValue(name).trim();\n        return v || fallback;\n      };\n      return {\n        ink: cssVar('--color-text', '#F4F4F7'),\n        muted: cssVar('--color-gray-500', '#8A8A96'),\n        label: '#C2C2CC',\n        axis: 'rgba(255,255,255,.18)',\n        split: 'rgba(255,255,255,.06)',\n        line: cssVar('--color-gray-200', 'rgba(255,255,255,.07)'),\n        warn: cssVar('--color-warning', '#F6C453'),\n        danger: cssVar('--color-danger', '#FF5A6E')\n      };\n    }\n\n    function buildOption(series, c) {\n      const categories = series.map((s) => s.priority);\n      const bars = series.map((s) => ({\n        value: Number(s.hours.toFixed(2)),\n        tickets: s.tickets,\n        itemStyle: { color: s.hours >= DANGER_HOURS ? c.danger : c.warn, borderRadius: [4, 4, 0, 0] }\n      }));\n      return {\n        backgroundColor: 'transparent',\n        animationDuration: 420,\n        grid: { left: 6, right: 14, top: 30, bottom: 6, containLabel: true },\n        tooltip: {\n          trigger: 'item',\n          backgroundColor: '#1B1B22',\n          borderColor: c.line,\n          borderWidth: 1,\n          padding: 10,\n          textStyle: { color: c.ink, fontSize: 12 },\n          formatter: (p) => {\n            const tickets = Number(p.data.tickets || 0).toLocaleString();\n            return '<b>' + p.name + '</b><br/>Avg resolution: <b>' + p.value.toFixed(1) + ' h</b><br/>Tickets: ' + tickets;\n          }\n        },\n        xAxis: {\n          type: 'category',\n          data: categories,\n          axisLine: { lineStyle: { color: c.axis } },\n          axisTick: { show: false },\n          axisLabel: { color: c.label, fontSize: 11, fontWeight: 600 }\n        },\n        yAxis: {\n          type: 'value',\n          min: 0,\n          name: 'Avg hours',\n          nameTextStyle: { color: c.muted, fontSize: 10, align: 'left', padding: [0, 0, 4, 0] },\n          axisLine: { show: false },\n          axisTick: { show: false },\n          splitLine: { lineStyle: { color: c.split } },\n          axisLabel: { color: c.label, fontSize: 10, formatter: '{value}h' }\n        },\n        series: [{\n          type: 'bar',\n          name: 'Avg resolution hours',\n          data: bars,\n          barMaxWidth: 56,\n          label: {\n            show: true,\n            position: 'top',\n            color: c.ink,\n            fontSize: 11,\n            fontWeight: 700,\n            formatter: (p) => p.value.toFixed(1) + 'h'\n          },\n          markLine: {\n            symbol: 'none',\n            silent: true,\n            lineStyle: { color: c.danger, type: 'dashed', width: 1, opacity: 0.75 },\n            label: { color: c.muted, fontSize: 10, position: 'insideEndTop', formatter: 'SLA flag ' + DANGER_HOURS + 'h' },\n            data: [{ yAxis: DANGER_HOURS }]\n          }\n        }]\n      };\n    }\n\n    /* ---- side-effecting render ---- */\n    function renderChart(el, rootEl, series) {\n      const echarts = window.echarts;\n      const prior = echarts.getInstanceByDom(el);\n      if (prior) { prior.dispose(); }\n      const chart = echarts.init(el, null, { renderer: 'canvas' });\n      chart.setOption(buildOption(series, readColors(rootEl)));\n      if (el._crmRhRo) { el._crmRhRo.disconnect(); }\n      const ro = new ResizeObserver(() => { chart.resize(); });\n      ro.observe(el);\n      el._crmRhRo = ro;\n    }\n\n    function showEmpty(show, el, emptyEl) {\n      if (emptyEl) {\n        if (show) { emptyEl.removeAttribute('hidden'); }\n        else { emptyEl.setAttribute('hidden', ''); }\n      }\n      if (el) { el.style.display = show ? 'none' : ''; }\n    }\n\n    /* ---- single orchestrator ---- */\n    function init() {\n      try {\n        const rootEl = document.querySelector(ROOT_SEL);\n        const el = document.getElementById(CANVAS_ID);\n        const emptyEl = document.getElementById(EMPTY_ID);\n        if (!rootEl || !el) { warn('mount nodes missing'); fireLoaded(); return; }\n\n        const rows = getQueryData(QUERY_INDEX.sla);\n        log('rows', rows.length);\n        const series = aggregateByPriority(rows);\n        log('series', series);\n\n        if (!series.length) {\n          showEmpty(true, el, emptyEl);\n          fireLoaded();\n          return;\n        }\n        showEmpty(false, el, emptyEl);\n\n        const start = () => {\n          try { renderChart(el, rootEl, series); }\n          catch (e) { warn('render failed', e); }\n          finally { fireLoaded(); }\n        };\n\n        if (window.echarts) {\n          start();\n        } else {\n          zPortal.resources.load(ECHARTS_URL).then(start).catch((e) => { warn('echarts load failed', e); fireLoaded(); });\n        }\n      } catch (e) {\n        warn('init failed', e);\n        fireLoaded();\n      }\n    }\n\n    init();\n  })();\n  </script>\n</div>"
  },
