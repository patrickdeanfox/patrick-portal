{
  "name": "DW · Mkt Ad Spend",
  "sql": "SELECT\n    gs                                                                          AS ad_spend_id,\n    1 + (('x'||substr(md5('ADCMP'||gs::text),1,8))::bit(32)::bigint % 100)      AS campaign_id,\n    1 + (('x'||substr(md5('ADCHAN'||gs::text),1,8))::bit(32)::bigint % 12)      AS channel_id,\n    (CURRENT_DATE - (('x'||substr(md5('ADDATE'||gs::text),1,8))::bit(32)::bigint % 365)::int) AS spend_date,\n    round((( ('x'||substr(md5('ADSPEND'||gs::text),1,8))::bit(32)::bigint % 500000)/100.0 + 10)::numeric, 2) AS spend,\n    (('x'||substr(md5('ADIMP'||gs::text),1,8))::bit(32)::bigint % 100000) + 100  AS impressions,\n    (('x'||substr(md5('ADCLICK'||gs::text),1,8))::bit(32)::bigint % 5000)        AS clicks,\n    (('x'||substr(md5('ADCONV'||gs::text),1,8))::bit(32)::bigint % 200)          AS conversions\nFROM generate_series(1, 4000) AS gs",
  "json_data": null,
