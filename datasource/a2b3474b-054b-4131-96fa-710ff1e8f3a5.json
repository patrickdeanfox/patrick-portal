{
  "name": "SYS · Logins by Month",
  "sql": "SELECT * \nFROM (\n    SELECT \n        jsonb_extract_path_text(value::jsonb, 'username') AS username,\n        EXTRACT(MONTH FROM date_created) AS login_month,\n        COUNT(*) AS login_count\n    FROM events\n    WHERE type = 'USER_LOGIN'\n      AND jsonb_extract_path_text(value::jsonb, 'success') = 'true'\n    GROUP BY username, login_month\n    ORDER BY login_month, username\n) AS anon_1 \n\n",
