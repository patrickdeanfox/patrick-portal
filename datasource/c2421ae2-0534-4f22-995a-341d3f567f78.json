{
  "name": "SC · Inventory — Sample",
  "sql": "SELECT\n    'PRD-' || lpad(gs::text, 3, '0') AS product_id,\n    (ARRAY['Widget','Gadget','Gizmo','Thingamajig','Doohickey'])[gs] AS product_name,\n    floor(random() * 500 + 50)::int AS stock_on_hand,\n    floor(random() * 100 + 10)::int AS reorder_level,\n    (ARRAY['Warehouse A','Warehouse B','Warehouse C'])[floor(random() * 3 + 1)::int] AS warehouse,\n    round((random() * 200 + 5)::numeric, 2) AS unit_cost,\n    (ARRAY['Active','Discontinued','Backordered'])[floor(random() * 3 + 1)::int] AS status,\n    CURRENT_DATE - (floor(random() * 90)::int) AS last_restock_date\nFROM generate_series(1, 5) AS gs",
