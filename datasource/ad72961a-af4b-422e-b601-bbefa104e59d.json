{
  "name": "SYS · Events",
  "sql": "SELECT\n    e.id,\n    e.type,\n    e.date_created,\n    e.value::jsonb->>'username'             AS value__username,\n    e.value::jsonb->>'user_id'              AS value__user_id,\n    e.value::jsonb->>'page_id'              AS value__page_id,\n    e.value::jsonb->>'page_url'             AS value__page_url,\n    e.value::jsonb->>'email'                AS value__email,\n    e.value::jsonb->>'error_text'           AS value__error_text,\n    (e.value::jsonb->>'success')::BOOLEAN   AS value__success\nFROM events e\nWHERE\n    e.type = 'PAGE_VIEW'\nORDER BY e.date_created desc",
