{
  "name": "RT · Orders (Joined)",
  "sql": "select\n    o.order_id,\n    o.order_line,\n    o.order_date,\n    o.customer_id,\n    o.product_id,\n    o.quantity,\n    b.price,\n    b.category1,\n    b.category2,\n    bs.bikeshop_id,\n    bs.bikeshop_name,\n    bs.bikeshop_city,\n    bs.bikeshop_state\nfrom orders o\ninner join bikeshops bs\n    on o.customer_id = bs.bikeshop_id\ninner join bikes b\n    on o.product_id = b.bike_id",
