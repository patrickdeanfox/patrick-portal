{
  "name": "RT · Sales — Sample",
  "sql": "SELECT\n        gs AS sale_id,\n        'PRD-' || lpad((floor(random() * 5 + 1)::int)::text, 3, '0') AS product_id,\n        (ARRAY['Electronics','Clothing','Food','Books','Sports'])[floor(random() * 5 + 1)::int] AS category,\n        round((random() * 500 + 10)::numeric, 2) AS price,\n        floor(random() * 100 + 1)::int AS quantity_sold,\n        (ARRAY['Alice','Bob','Charlie','Diana','Eve'])[floor(random() * 5 + 1)::int] AS salesperson,\n        (ARRAY['New York','Chicago','LA','Houston','Miami'])[floor(random() * 5 + 1)::int] AS city,\n        CURRENT_DATE - (floor(random() * 365)::int) AS sale_date\n    FROM generate_series(1, 10) AS gs",
